test "math still works":
    assert_eq(1 + 1, 2)
    assert_ne(2 + 2, 5)

test "bool checks work too":
    assert(10 > 3)
    assert_ne(7, 8)

test "try unwrap works in tests":
    n := parse_int("42")!
    assert_eq(n, 42)

test "parse_int keeps zero and minus one distinct":
    assert_eq(parse_int("0")!, 0)
    assert_eq(parse_int("-1")!, -1)
