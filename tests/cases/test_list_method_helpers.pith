fn main():
    nums := [5, 3, 8, 1, 9, 2]

    mid := nums.slice(1, 4)
    print(mid.len().to_string())
    print(mid[0].to_string() + "," + mid[1].to_string() + "," + mid[2].to_string())

    sorted := nums.sort()
    print(sorted[0].to_string() + "," + sorted[1].to_string() + "," + sorted[2].to_string())
    print(nums[0].to_string() + "," + nums[1].to_string() + "," + nums[2].to_string())

    words := ["banana", "apple", "cherry"]
    sorted_words := words.sort()
    print(sorted_words.join(","))
    print(words.join(","))
