# CSV parsing via stdlib import
from std.csv import parse, encode_row

fn main():
    data := "name,age,city" + chr(10) + "alice,30,nyc" + chr(10) + "bob,25,sf"
    rows := parse(data)
    print("rows: 3")
    print("header: " + rows[0].join("|"))
    print("row 1: " + rows[1].join("|"))
    print("row 2: " + rows[2].join("|"))

    mut quoted: List[String] := ["hello, world", "plain"]
    print("encoded: " + encode_row(quoted))
    print("stdlib csv work")
