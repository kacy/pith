pub fn kill_process(process: Process) -> Bool:
    return process_kill(process.handle)

pub fn close_process(process: Process):
    process_close(process.handle)

pub fn string_buffer_string(buf: StringBuffer) -> String:
    if string_buffer_data.contains_key(buf.handle):
        return string_buffer_data[buf.handle]
    return ""

pub fn string_buffer_clear(buf: StringBuffer):
    string_buffer_data.insert(buf.handle, "")

pub fn string_reader_read(reader: StringReader, max_bytes: Int) -> String!:
    return string_reader_read_internal(reader, max_bytes)

pub fn string_buffer_write(buf: StringBuffer, data: String) -> Int!:
    return string_buffer_write_internal(buf, data)

pub fn read_all(reader: StringReader) -> String!:
    return read_all_string(reader)

pub fn read_all_chunked(reader: StringReader, chunk_size: Int) -> String!:
    return read_all_string_chunked(reader, chunk_size)

pub fn write_all(writer: StringBuffer, data: String) -> Int!:
    return write_all_string(writer, data)

pub fn copy(reader: StringReader, writer: StringBuffer) -> Int!:
    return copy_string(reader, writer)

pub fn copy_chunked(reader: StringReader, writer: StringBuffer, chunk_size: Int) -> Int!:
    return copy_string_chunked(reader, writer, chunk_size)

pub fn connect(host: String, port: Int) -> TcpStream!:
    return tcp_stream_connect(host, port)

