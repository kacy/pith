# std.hash — cryptographic and non-cryptographic hashing
#
# the raw hashing surface is bytes-first.
# string helpers stay around as explicit utf-8 wrappers so text hashing
# still reads clearly at call sites.
#
#   import std.bytes as bytes
#   import std.hash as hash
#   digest := hash.sha256(bytes.from_string_utf8("hello world"))
#   bucket := hash.fnv1a_string("key") % 64

import std.bytes as bytes
import std.bits as bits

fn mask32(value: Int) -> Int:
    return bits.mask32(value)

fn rotate_right(value: Int, amount: Int) -> Int:
    return bits.rotr32(value, amount)

mut sha256_round_constants: List[Int] := []
mut constants_initialized: Bool := false

fn sha_init():
    if constants_initialized:
        return
    constants_initialized = true
    sha256_round_constants.push(1116352408)
    sha256_round_constants.push(1899447441)
