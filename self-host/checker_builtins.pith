    fix_builtin_binding("tcp_wait_readable", [tid_int, tid_int], tid_int)
    fix_builtin_binding("tcp_wait_writable", [tid_int, tid_int], tid_int)
    fix_builtin_binding("tcp_set_timeout", [tid_int, tid_int], tid_void)
    fix_builtin_binding("process_spawn", [tid_string], int_result)
    fix_builtin_binding("process_spawn_argv", [tid_string, list_string, tid_string, list_string, list_string], int_result)
    fix_builtin_binding("process_output_argv", [tid_string, list_string, tid_string, list_string, list_string], int_result)
    fix_builtin_binding("process_write", [tid_int, tid_string], int_result)
    fix_builtin_binding("process_read", [tid_int, tid_int], str_result)
    fix_builtin_binding("process_read_err", [tid_int, tid_int], str_result)
    fix_builtin_binding("process_write_bytes", [tid_int, tid_bytes], int_result)
    fix_builtin_binding("process_read_bytes", [tid_int, tid_int], bytes_result)
    fix_builtin_binding("process_read_err_bytes", [tid_int, tid_int], bytes_result)
    fix_builtin_binding("process_wait", [tid_int], tid_int)
    fix_builtin_binding("process_kill", [tid_int], tid_bool)
    fix_builtin_binding("process_close", [tid_int], tid_void)
    fix_builtin_binding("process_output_status", [tid_int], tid_int)
    fix_builtin_binding("process_output_stdout", [tid_int], tid_string)
    fix_builtin_binding("process_output_stderr", [tid_int], tid_string)
    fix_builtin_binding("process_output_close", [tid_int], tid_void)

fn create_function_type(params: List[Int], ret: Int) -> Int:
    return add_type_info(ti_function(params, ret))

fn define_builtin_function(name: String, fn_tid: Int):
    define_binding(builtin_scope, name, fn_tid, false)

fn fix_builtin_binding(name: String, params: List[Int], ret: Int):
    define_builtin_function(name, add_type_info(ti_function(params, ret)))

fn register_sync_primitive_type(name: String, param_tids: List[Int]):
    mut fields: List[String] := []
    mut ftypes: List[Int] := []
    mut fpub: List[Bool] := []
    mut fmut: List[Bool] := []
    tid := add_type_info(ti_struct(name, fields, ftypes, fpub, fmut))
    register_type_name(name, tid)
    mut ctor_params: List[Int] := []
    mut j := 0
    while j < param_tids.len():
        ctor_params.push(param_tids[j])
        j = j + 1
    ctor_tid := add_type_info(ti_function(ctor_params, tid))
    define_binding(builtin_scope, name, ctor_tid, false)
