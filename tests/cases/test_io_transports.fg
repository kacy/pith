import std.io as io

fn main() -> Int!:
    stream := io.from_fd(7)
    print(stream.fd.to_string())

    buffered := stream.buffered_reader()
    print(buffered.handle.to_string())
    print("[" + buffered.read(0)! + "]")

    placeholder := io.from_fd(-1)
    placeholder.set_timeout(10)
    print("ok")
    return 0
