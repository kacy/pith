struct Node:
    kind: String
    children: List[Int]

fn main():
    mut kids: List[Int] := []
    kids.push(10)
    kids.push(20)
    kids.push(30)
    print("kids len before struct: " + to_string(kids.len()))

    node := Node("test", kids)
    print("node.kind: " + node.kind)
    print("node.children.len: " + to_string(node.children.len()))
    for c in node.children:
        print("child: " + to_string(c))
