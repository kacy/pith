from std.io import spawn_process, process_stdout, process_stderr, close_process, wait_process
from std.io import buffered_process_stdout_chunked, buffered_process_stderr_chunked
from std.io import buffered_process_stdout_read, buffered_process_stdout_read_line
from std.io import buffered_process_stderr_read_line

fn main() -> Int!:
    stdout_proc := spawn_process("printf 'alpha\nbeta\r\ngamma'")!
    stdout_reader := buffered_process_stdout_chunked(process_stdout(stdout_proc), 2)
    print(buffered_process_stdout_read(stdout_reader, 3)!)
    print(buffered_process_stdout_read_line(stdout_reader)!)
    print(buffered_process_stdout_read_line(stdout_reader)!)
    print("[" + buffered_process_stdout_read_line(stdout_reader)! + "]")
    print(wait_process(stdout_proc).to_string())
    close_process(stdout_proc)

    stderr_proc := spawn_process("printf 'warn\nfatal' >&2")!
    stderr_reader := buffered_process_stderr_chunked(process_stderr(stderr_proc), 1)
    print(buffered_process_stderr_read_line(stderr_reader)!)
    print(buffered_process_stderr_read_line(stderr_reader)!)
    print("[" + buffered_process_stderr_read_line(stderr_reader)! + "]")
    print(wait_process(stderr_proc).to_string())
    close_process(stderr_proc)
    return 0
