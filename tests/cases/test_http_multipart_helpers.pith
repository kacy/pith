import std.bytes as bytes
import std.io as io
import std.net.http as http

fn main() -> String!:
    file_buf := bytes.buffer()
    file_buf.write_string_utf8("FG")!
    file_buf.write_byte(255)!
    file_buf.write_byte(0)!

    mut parts: List[http.MultipartPart] := []
    parts.push(http.multipart_field("note", "hello multipart"))
    parts.push(http.multipart_file("blob", "blob.bin", "application/octet-stream", file_buf.bytes()))

    req_bytes := http.post_request("example.test", 80, "/upload").multipart_body_with_boundary(parts, "pith-boundary-test")!.to_bytes()!
    req := http.read_request_buffered_bytes(io.bytes_reader(req_bytes).buffered_chunked(7))!
    blob := req.multipart_part("blob")!

    print("multipart-is:" + req.is_multipart()!.to_string())
    print("multipart-boundary:" + req.multipart_boundary()!)
    print("multipart-note:" + req.multipart_text("note")!)
    print("multipart-body-default:" + req.body_text_or("binary"))
    print("multipart-file-type:" + blob.header("Content-Type"))
    print("multipart-file-byte2:" + blob.body_bytes()[2].to_string())
    print("multipart-file-text-or:" + blob.text_or("binary"))
    return ""
