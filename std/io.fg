fn string_reader_read_internal(reader: StringReader, max_bytes: Int) -> String!:
    if max_bytes <= 0:
        return ""
    if not string_reader_data.contains_key(reader.handle):
        return ""

    data := string_reader_data[reader.handle]
    mut offset := 0
    if string_reader_offsets.contains_key(reader.handle):
        offset = string_reader_offsets[reader.handle]
    if offset >= data.len():
        return ""

    mut end := offset + max_bytes
    if end > data.len():
        end = data.len()
    chunk := data.substring(offset, end)
    string_reader_offsets.insert(reader.handle, end)
    return chunk

fn string_buffer_write_internal(buf: StringBuffer, data: String) -> Int!:
    if data.len() == 0:
        return 0
    string_buffer_append_chunk(buf, data)
    string_buffer_maybe_compact(buf)
    return data.len()

fn bytes_after_write(data: Bytes, wrote: Int) -> Bytes:
    if wrote >= data.len():
        return bytes.empty()
    return data.slice(wrote, data.len())

fn bytes_cursor_read_internal(reader: BytesCursor, max_bytes: Int) -> Bytes!:
    if max_bytes <= 0:
        return bytes.empty()
    if not bytes_reader_data.contains_key(reader.handle):
        return bytes.empty()

    data := bytes_reader_data[reader.handle]
    mut offset := 0
    if bytes_reader_offsets.contains_key(reader.handle):
        offset = bytes_reader_offsets[reader.handle]
    if offset >= data.len():
        return bytes.empty()

    mut end := offset + max_bytes
    if end > data.len():
        end = data.len()
    chunk := data.slice(offset, end)
    bytes_reader_offsets.insert(reader.handle, end)
    return chunk

fn write_all_byte_buffer(writer: ByteBuffer, data: Bytes) -> Int!:
    mut total := 0
    mut remaining := data
    while remaining.len() > 0:
        wrote := writer.write_bytes(remaining)!
        if wrote <= 0:
            fail "write returned 0"
        total = total + wrote
        remaining = bytes_after_write(remaining, wrote)
    return total

fn copy_bytes_cursor(reader: BytesCursor, writer: ByteBuffer) -> Int!:
    return copy_bytes_cursor_chunked(reader, writer, DEFAULT_CHUNK_SIZE)

fn copy_bytes_cursor_chunked(reader: BytesCursor, writer: ByteBuffer, chunk_size: Int) -> Int!:
    size := normalized_chunk_size(chunk_size)
    mut total := 0
    mut chunk := reader.read_bytes(size)!
    while not chunk.is_empty():
        total = total + writer.write_bytes(chunk)!
        chunk = reader.read_bytes(size)!
    return total

fn read_all_bytes_cursor(reader: BytesCursor) -> Bytes!:
    return read_all_bytes_cursor_chunked(reader, DEFAULT_CHUNK_SIZE)

fn read_all_bytes_cursor_chunked(reader: BytesCursor, chunk_size: Int) -> Bytes!:
    size := normalized_chunk_size(chunk_size)
    buf := bytes.buffer_with_capacity(size)
    mut chunk := reader.read_bytes(size)!
    while not chunk.is_empty():
        buf.write(chunk)!
        chunk = reader.read_bytes(size)!
    return buf.bytes()

