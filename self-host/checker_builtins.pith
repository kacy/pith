    define_builtin_function("byte_buffer_write", create_function_type([TID_INT, tid_bytes], int_result))
    define_builtin_function("byte_buffer_write_string_utf8", create_function_type([TID_INT, TID_STRING], int_result))
    define_builtin_function("byte_buffer_write_byte", create_function_type([TID_INT, TID_INT], int_result))
