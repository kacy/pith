    fix_builtin_binding("min", [tid_int, tid_int], tid_int)
    fix_builtin_binding("max", [tid_int, tid_int], tid_int)
    fix_builtin_binding("random_int", [tid_int, tid_int], tid_int)
    fix_builtin_binding("bit_and", [tid_int, tid_int], tid_int)
    fix_builtin_binding("bit_or", [tid_int, tid_int], tid_int)
    fix_builtin_binding("bit_xor", [tid_int, tid_int], tid_int)
    fix_builtin_binding("bit_shl", [tid_int, tid_int], tid_int)
