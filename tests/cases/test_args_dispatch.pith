fn main():
    a := args()
    print(a.len().to_string())
    if a.len() >= 2:
        mut cmd := ""
        for arg, i in a:
            if i == 1:
                cmd = arg
        print(cmd)
        if cmd == "hello":
            print("matched hello")
        elif cmd == "world":
            print("matched world")
        else:
            print("no match")
