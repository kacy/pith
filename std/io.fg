fn buffered_process_stdout_read_line(reader: BufferedProcessStdout) -> String!:
    return buffered_process_stdout_read_line_internal(reader)

fn buffered_process_stderr_read(reader: BufferedProcessStderr, max_bytes: Int) -> String!:
