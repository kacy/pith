fn main():
    mut m: Map[String, Int] := {}
    m.insert("a", 10)
    m.insert("b", 20)
    if m.contains_key("a"):
        print("has a")
    if m.contains_key("b"):
        print("has b")
    if m.contains_key("c"):
        print("has c")
    print(m["a"].to_string())
    print(m["b"].to_string())
