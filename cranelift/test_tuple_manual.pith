fn main():
    # Allocate a tuple-like struct manually
    let ptr := allocate(16)  # 2 * 8 bytes
    store(ptr, 0, 42)        # Store at offset 0
    store(ptr, 8, 100)       # Store at offset 8
    
    # Now access using field access syntax
    let first := load(ptr, 0)
    let second := load(ptr, 8)
    print_int(first)
    print_int(second)