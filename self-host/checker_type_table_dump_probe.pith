from checker import initialize_checker
from types import get_type_info

fn main():
    initialize_checker("dump")
    mut tid := 21
    while tid <= 40:
        info := get_type_info(tid)
        print(tid.to_string())
        print(info.kind)
        print(info.param_types.len().to_string())
        print(info.return_type.to_string())
        tid = tid + 1
