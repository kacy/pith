import std.archive.tar as tar
import std.bytes as bytes
import std.fs as fs
import std.os.path as path

fn push_zeroes(values: List[Int], count: Int):
    mut i := 0
    while i < count:
        values.push(0)
        i = i + 1

fn push_string(values: List[Int], text: String, width: Int):
    mut i := 0
    while i < text.len():
        values.push(ord(text[i]))
        i = i + 1
    push_zeroes(values, width - text.len())

fn octal(value: Int) -> String:
    if value == 0:
        return "0"
    mut n := value
    mut out := ""
    while n > 0:
        out = chr(48 + (n % 8)) + out
        n = n / 8
    return out

fn push_octal(values: List[Int], value: Int, width: Int):
    digits := octal(value)
    push_zeroes(values, width - digits.len() - 1)
    for ch in digits:
        values.push(ord(ch))
    values.push(0)

fn push_checksum(values: List[Int], value: Int):
    digits := octal(value)
    push_zeroes(values, 6 - digits.len())
    for ch in digits:
        values.push(ord(ch))
    values.push(0)
    values.push(32)

fn values_checksum(values: List[Int]) -> Int:
    mut sum := 0
    for value in values:
        sum = sum + value
    return sum

fn values_bytes(values: List[Int]) -> Bytes!:
    out := bytes.buffer_with_capacity(values.len())
    for value in values:
        out.write_byte(value)!
    return out.bytes()

fn unsafe_archive() -> Bytes!:
    mut header: List[Int] := []
    push_string(header, "../evil.txt", 100)
    push_octal(header, 420, 8)
    push_octal(header, 0, 8)
    push_octal(header, 0, 8)
    push_octal(header, 0, 12)
    push_octal(header, 0, 12)
    push_zeroes(header, 8)
    header.push(ord("0"))
    push_string(header, "", 100)
    push_string(header, "ustar", 6)
    push_string(header, "00", 2)
    push_string(header, "", 32)
    push_string(header, "", 32)
    push_octal(header, 0, 8)
    push_octal(header, 0, 8)
    push_string(header, "", 155)
    push_zeroes(header, 12)
    checksum := values_checksum(header)

    mut final_header: List[Int] := []
    push_string(final_header, "../evil.txt", 100)
    push_octal(final_header, 420, 8)
    push_octal(final_header, 0, 8)
    push_octal(final_header, 0, 8)
    push_octal(final_header, 0, 12)
    push_octal(final_header, 0, 12)
    push_checksum(final_header, checksum)
    final_header.push(ord("0"))
    push_string(final_header, "", 100)
    push_string(final_header, "ustar", 6)
    push_string(final_header, "00", 2)
    push_string(final_header, "", 32)
    push_string(final_header, "", 32)
    push_octal(final_header, 0, 8)
    push_octal(final_header, 0, 8)
    push_string(final_header, "", 155)
    push_zeroes(final_header, 12)

    out := bytes.buffer()
    out.write(values_bytes(final_header)!)!
    mut i := 0
    while i < 1024:
        out.write_byte(0)!
        i = i + 1
    return out.bytes()

fn main() -> Int!:
    root := fs.make_temp_dir("forge_tar_")!
    bundle := path.join(root, "bundle")
    fs.make_dirs(bundle)
    fs.write(path.join(bundle, "hello.txt"), "hello tar")!

    archive := tar.create([bundle])!
    entries := tar.list(archive)!
    print("entries:" + entries.len().to_string())
    print("entry0:" + entries[0].name + ":" + entries[0].is_dir.to_string())
    print("entry1:" + entries[1].name + ":" + entries[1].size.to_string())

    out_dir := path.join(root, "out")
    tar.extract(archive, out_dir)!
    print("roundtrip:" + fs.read(path.join(path.join(out_dir, "bundle"), "hello.txt"))!)

    archive_path := path.join(root, "bundle.tar")
    tar.create_file([bundle], archive_path)!
    out_dir2 := path.join(root, "out2")
    tar.extract_file(archive_path, out_dir2)!
    print("file-api:" + fs.read(path.join(path.join(out_dir2, "bundle"), "hello.txt"))!)

    unsafe := tar.extract(unsafe_archive()!, path.join(root, "unsafe"))
    print("unsafe:" + unsafe.is_err.to_string())
    print("cleanup:" + fs.remove_tree(root).to_string())
    return 0
