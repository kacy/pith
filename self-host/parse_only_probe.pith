from lexer import lex_all
from parser import parse
from ast import reset_arena
from ir_emitter import emit_ir

fn main() -> String!:
    src := read_file(args()[1])!
    token_list := lex_all(src)
    reset_arena()
    parsed_root := parse(token_list)
    if parsed_root >= 0:
        print("done")
    return ""
