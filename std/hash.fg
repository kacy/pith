# std.hash — cryptographic and non-cryptographic hashing
#
# Provides SHA-256 (FIPS 180-4), SHA-1 (RFC 3174), and FNV-1a hash functions.
# SHA-256 returns a 64-character lowercase hex string.
# SHA-1 returns a 40-character lowercase hex string.
# FNV-1a returns a 32-bit integer suitable for hash tables.
#
#   from std.hash import sha256, fnv1a
#   digest := sha256("hello world")
#   bucket := fnv1a("key") % 64

# ===============================================================
# SHA-256 Implementation (FIPS 180-4)
# ===============================================================

# 32-bit mask for SHA-256 word operations
fn m(x: Int) -> Int:
    return bit_and(x, 4294967295)

# 32-bit right rotation for SHA-256
fn rotr(x: Int, n: Int) -> Int:
    return m(bit_or(bit_shr(x, n), bit_shl(x, 32 - n)))

# SHA-256 round constants (first 32 bits of fractional cube roots of first 64 primes)
mut g_k: List[Int] := []
mut g_k_ready: Bool := false

# Lazy initialization of SHA-256 constants
fn sha_init():
    if g_k_ready:
        return
    g_k_ready = true
    g_k.push(1116352408)
    g_k.push(1899447441)
    g_k.push(3049323471)
    g_k.push(3921009573)
    g_k.push(961987163)
    g_k.push(1508970993)
    g_k.push(2453635748)
