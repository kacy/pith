from std.io import string_reader, buffered_string_reader_chunked
from std.io import buffered_string_reader_read_line, buffered_string_reader_read
from std.net.http import parse_request, get_header, body

fn main() -> Int!:
    crlf := chr(13) + chr(10)
    mut request := "POST /submit HTTP/1.1" + crlf
    request = request + "Host: example.com" + crlf
    request = request + "Content-Length: 11" + crlf
    request = request + "X-Test: chunked" + crlf
    request = request + crlf
    request = request + "hello world"

    reader := buffered_string_reader_chunked(string_reader(request), 3)
    request_line := buffered_string_reader_read_line(reader)!
    mut raw := request_line + crlf
    mut line := buffered_string_reader_read_line(reader)!
    while line.len() > 0:
        raw = raw + line + crlf
        line = buffered_string_reader_read_line(reader)!
    raw = raw + crlf

    head_req := parse_request(raw)
    length_text := get_header(head_req, "Content-Length")
    if length_text != "":
        raw = raw + buffered_string_reader_read(reader, parse_int(length_text)!)!

    print(body(parse_request(raw)))
    return 0
