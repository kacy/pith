from std.csv import save, parse_file, parse_with_headers_file
from std.fs import exists, remove

fn main() -> String!:
    csv_path := "/tmp/forge_io_csv.csv"

    mut rows: List[List[String]] := []
    rows.push(["name", "age"])
    rows.push(["alice", "30"])
    rows.push(["bob", "25"])

    print(save(csv_path, rows)!.to_string())

    parsed := parse_file(csv_path)!
    print(parsed.len().to_string())
    print(parsed[1].join("|"))

    with_headers := parse_with_headers_file(csv_path)!
    print(with_headers.len().to_string())
    print(with_headers[0]["name"] + "|" + with_headers[0]["age"])
    print(exists(csv_path).to_string())

    remove(csv_path)
    return ""
