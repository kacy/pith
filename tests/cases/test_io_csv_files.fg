import std.csv as csv
import std.fs as fs

fn main() -> String!:
    csv_path := "/tmp/forge_io_csv.csv"

    mut rows: List[List[String]] := []
    rows.push(["name", "age"])
    rows.push(["alice", "30"])
    rows.push(["bob", "25"])

    print(csv.save_chunked(csv_path, rows, 3)!.to_string())

    parsed := csv.parse_file_chunked(csv_path, 2)!
    print(parsed.len().to_string())
    print(parsed[1].join("|"))

    with_headers := csv.parse_with_headers_file_chunked(csv_path, 2)!
    print(with_headers.len().to_string())
    print(with_headers[0]["name"] + "|" + with_headers[0]["age"])
    print(fs.exists(csv_path).to_string())

    fs.remove(csv_path)
    return ""
