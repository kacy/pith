fn ok_value() -> Int!:
    return 1

fn main():
    mut count := 0
    while true:
        client := ok_value()
        if client.is_ok:
            handled := ok_value()
            print("handled=" + handled.to_string())
            count = count + 1
            if count == 3:
                break
            if handled.is_err:
                print("handle err")
    print("done")
