import std.bytes as bytes
import std.io as io
import std.net.http as http
import std.net.websocket as websocket

fn main() -> Int!:
    mut headers: Map[String, String] := {}
    request_bytes := websocket.client_request("example.com", "/accept", headers)!
    req := http.read_request_buffered_bytes(io.bytes_reader(request_bytes).buffered_chunked(5))!

    inbound := websocket.client_text_frame_bytes("hi", bytes.from_string_utf8("abcd"))!
    outbound := bytes.buffer()
    ws := websocket.accept_buffered(req, io.bytes_reader(inbound).buffered_chunked(3), outbound.buffered_chunked(4))!

    response := websocket.upgrade_response(req)!
    print(outbound.bytes().slice(0, response.len()).to_string_utf8()!.contains("101 Switching Protocols").to_string())

    print(ws.recv_text()!)
    ws.send_text("echo:hi")!

    frame := websocket.parse_frame(outbound.bytes().slice(response.len(), outbound.bytes().len()))!
    print(frame.is_text().to_string())
    print(frame.payload_text()!)
    print(ws.is_closed().to_string())
    return 0
