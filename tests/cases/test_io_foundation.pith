import std.io as io

fn main() -> Int!:
    reader := io.string_reader("pith io")
    print(reader.read_all()!)

    chunked_reader := io.string_reader("abcdef")
    print(chunked_reader.read_all_chunked(2)!)

    direct_reader := io.string_reader("xyz")
    print(direct_reader.read(2)!)
    print(direct_reader.read(2)!)

    buf := io.string_buffer()
    print(buf.is_empty().to_string())
    print(buf.write("hi")!.to_string())
    print(buf.len().to_string())
    print(buf.string())
    print(buf.string())

    buf2 := io.string_buffer()
    print(buf2.write_all("hello")!.to_string())
    print(buf2.string())
    print(buf2.write_line("!")!.to_string())
    print(buf2.newline()!.to_string())
    print(buf2.string())
    print(buf2.len().to_string())
    buf2.clear()
    print(buf2.is_empty().to_string())
    print("[" + buf2.string() + "]")

    src := io.string_reader("copy me")
    dst := io.string_buffer()
    print(io.copy(src, dst)!.to_string())
    print(dst.string())

    src2 := io.string_reader("chunked")
    dst2 := io.string_buffer()
    print(io.copy_chunked(src2, dst2, 3)!.to_string())
    print(dst2.string())

    src3 := io.string_reader("done")
    print(src3.read_all()!)
    print(buf.string())
    return 0
