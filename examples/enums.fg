# enum declarations with variant data

enum Direction:
    North
    South
    East
    West

enum Shape:
    Circle(Float)
    Rectangle(Float, Float)
    Point

enum Result:
    Ok(Int)
    Err(String)

# enums are registered as types. match expressions and
# variant construction aren't checked yet, but the type
# declarations are validated at compile time.

fn main():
    print("enums declared")
