    return process_read(reader.handle, max_bytes)

pub fn process_stderr_read(reader: ProcessStderr, max_bytes: Int) -> String!:
    return process_read_err(reader.handle, max_bytes)

fn normalized_chunk_size(chunk_size: Int) -> Int:
    if chunk_size <= 0:
        return DEFAULT_CHUNK_SIZE
    return chunk_size

fn allocate_string_reader_handle(data: String) -> Int:
    handle := next_string_reader_handle
    next_string_reader_handle = next_string_reader_handle + 1
    string_reader_data.insert(handle, data)
    string_reader_offsets.insert(handle, 0)
    return handle

fn allocate_string_buffer_handle() -> Int:
    handle := next_string_buffer_handle
    next_string_buffer_handle = next_string_buffer_handle + 1
    string_buffer_data.insert(handle, "")
    return handle

fn allocate_buffered_string_reader_handle(source_handle: Int, chunk_size: Int) -> Int:
    handle := next_buffered_string_reader_handle
    next_buffered_string_reader_handle = next_buffered_string_reader_handle + 1
    buffered_string_reader_sources.insert(handle, source_handle)
    buffered_string_reader_chunk_sizes.insert(handle, normalized_chunk_size(chunk_size))
    buffered_string_reader_cache.insert(handle, "")
    return handle

fn allocate_buffered_string_writer_handle(target_handle: Int, chunk_size: Int) -> Int:
    handle := next_buffered_string_writer_handle
    next_buffered_string_writer_handle = next_buffered_string_writer_handle + 1
    buffered_string_writer_targets.insert(handle, target_handle)
    buffered_string_writer_chunk_sizes.insert(handle, normalized_chunk_size(chunk_size))
    buffered_string_writer_cache.insert(handle, "")
    return handle

fn allocate_buffered_tcp_stream_handle(fd: Int, chunk_size: Int) -> Int:
    handle := next_buffered_tcp_stream_handle
    next_buffered_tcp_stream_handle = next_buffered_tcp_stream_handle + 1
    buffered_tcp_stream_fds.insert(handle, fd)
    buffered_tcp_stream_chunk_sizes.insert(handle, normalized_chunk_size(chunk_size))
    buffered_tcp_stream_cache.insert(handle, "")
    return handle

fn allocate_buffered_tcp_writer_handle(fd: Int, chunk_size: Int) -> Int:
    handle := next_buffered_tcp_writer_handle
    next_buffered_tcp_writer_handle = next_buffered_tcp_writer_handle + 1
    buffered_tcp_writer_fds.insert(handle, fd)
    buffered_tcp_writer_chunk_sizes.insert(handle, normalized_chunk_size(chunk_size))
    buffered_tcp_writer_cache.insert(handle, "")
    return handle

fn allocate_buffered_file_reader_handle(file_handle: Int, chunk_size: Int) -> Int:
    handle := next_buffered_file_reader_handle
    next_buffered_file_reader_handle = next_buffered_file_reader_handle + 1
    buffered_file_reader_handles.insert(handle, file_handle)
    buffered_file_reader_chunk_sizes.insert(handle, normalized_chunk_size(chunk_size))
    buffered_file_reader_cache.insert(handle, "")
    return handle

fn allocate_buffered_file_writer_handle(file_handle: Int, chunk_size: Int) -> Int:
    handle := next_buffered_file_writer_handle
    next_buffered_file_writer_handle = next_buffered_file_writer_handle + 1
    buffered_file_writer_handles.insert(handle, file_handle)
    buffered_file_writer_chunk_sizes.insert(handle, normalized_chunk_size(chunk_size))
    buffered_file_writer_cache.insert(handle, "")
    return handle

fn allocate_buffered_process_stdout_handle(process_handle: Int, chunk_size: Int) -> Int:
