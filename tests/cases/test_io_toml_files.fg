import std.toml as toml
import std.fs as fs

fn main() -> String!:
    toml_path := "/tmp/forge_io_toml.toml"
    newline := chr(10)

    mut doc := "# sample" + newline
    doc = doc + "title = " + chr(34) + "forge" + chr(34) + newline
    doc = doc + "enabled = true" + newline
    doc = doc + newline
    doc = doc + "[server]" + newline
    doc = doc + "host = " + chr(34) + "localhost" + chr(34) + newline
    doc = doc + "ports = [8080, 8081]" + newline

    print(fs.write(toml_path, doc)!.to_string())

    root := toml.parse_file(toml_path)
    print(toml.type_of(root))
    print(toml.get_string(root, "title"))
    print(toml.get_bool(root, "enabled").to_string())

    root_chunked := toml.parse_file_chunked(toml_path, 3)
    server := toml.get_table(root_chunked, "server")
    ports := toml.get_array(server, "ports")
    print(toml.get_string(server, "host"))
    print(toml.array_len(ports).to_string())
    print(toml.keys(root_chunked).len().to_string())
    print(fs.exists(toml_path).to_string())

    fs.remove(toml_path)
    return ""
