fn buffered_tcp_stream_read_internal(reader: BufferedTcpStream, max_bytes: Int) -> String!:
    if max_bytes <= 0:
        return ""
    if not buffered_tcp_stream_fds.contains_key(reader.handle):
        return ""

    mut result := ""
    while result.len() < max_bytes:
        mut cached := buffered_tcp_stream_cache_get(reader.handle)
        if cached.len() == 0:
            filled := buffered_tcp_stream_fill(reader.handle)!
            if filled <= 0:
                return result
            cached = buffered_tcp_stream_cache_get(reader.handle)
        mut take := max_bytes - result.len()
        if take > cached.len():
            take = cached.len()
        result = result + cached.substring(0, take)
        buffered_tcp_stream_consume(reader.handle, take)
    return result

fn buffered_tcp_stream_read_line_internal(reader: BufferedTcpStream) -> String!:
    if not buffered_tcp_stream_fds.contains_key(reader.handle):
        return ""

    mut result := ""
    while true:
        mut cached := buffered_tcp_stream_cache_get(reader.handle)
        if cached.len() == 0:
            filled := buffered_tcp_stream_fill(reader.handle)!
            if filled <= 0:
                return result
            cached = buffered_tcp_stream_cache_get(reader.handle)
        newline := find_newline(cached)
        if newline >= 0:
            result = result + cached.substring(0, newline)
            buffered_tcp_stream_consume(reader.handle, newline + 1)
            return trim_trailing_cr(result)
        result = result + cached
        buffered_tcp_stream_cache.insert(reader.handle, "")

