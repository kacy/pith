# Test multiple sequential while loops

fn test_sequential_whiles():
    mut i := 0
    
    # First while
    while i < 5:
        if i == 2:
            break
        i = i + 1
    
    # Assignment between whiles
    i = 10
    
    # Second while  
    while i < 15:
        if i == 12:
            break
        i = i + 1

fn main():
    test_sequential_whiles()
