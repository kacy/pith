# test std.test — the testing framework itself
from std.testing import assert_eq, assert_ne, check_true, check_not
from std.testing import assert_true, assert_false, assert_contains, done

fn main():
    assert_eq(1 + 1, 2)
    assert_eq(10 * 3, 30)
    assert_ne(1, 2)
    assert_eq("hello", "hello")
    assert_true("forge".starts_with("for"))
    assert_false("forge".contains("zig"))
    assert_contains("hello forge", "forge")
    check_true(10 > 5, "greater than")
    check_not(3 > 7, "not greater")
    assert_eq("hello".len(), 5)
    assert_eq("HELLO".to_lower(), "hello")
    done()
