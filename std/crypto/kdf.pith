# std.crypto.kdf - key derivation helpers

import std.bits as bits
import std.bytes as bytes
import std.encoding as encoding
import std.crypto.hmac as hmac

fn zero_bytes(count: Int) -> Bytes:
    out := bytes.buffer_with_capacity(count)
    mut i := 0
    while i < count:
        out.write_byte(0)
        i = i + 1
    return out.bytes()

fn int32_be(value: Int) -> Bytes:
    out := bytes.buffer_with_capacity(4)
    out.write_byte(bits.band(bits.shr(value, 24), 255))
    out.write_byte(bits.band(bits.shr(value, 16), 255))
    out.write_byte(bits.band(bits.shr(value, 8), 255))
    out.write_byte(bits.band(value, 255))
    return out.bytes()

fn bytes_to_list(data: Bytes) -> List[Int]:
    mut out: List[Int] := []
    mut i := 0
    while i < data.len():
        out.push(data[i])
        i = i + 1
    return out

fn list_to_bytes(data: List[Int], limit: Int) -> Bytes:
    out := bytes.buffer_with_capacity(limit)
    mut i := 0
    while i < data.len() and i < limit:
        out.write_byte(data[i])
        i = i + 1
    return out.bytes()

fn xor_digest(left: List[Int], right: Bytes) -> List[Int]:
    mut out: List[Int] := []
    mut i := 0
    while i < left.len():
        out.push(bits.xor(left[i], right[i]))
        i = i + 1
    return out

# hkdf extract with hmac-sha256.
pub fn hkdf_extract_sha256(salt: Bytes, secret: Bytes) -> Bytes:
    mut actual_salt := salt
    if actual_salt.len() == 0:
        actual_salt = zero_bytes(32)
    return hmac.sha256(actual_salt, secret)

# hkdf expand with hmac-sha256.
pub fn hkdf_expand_sha256(prk: Bytes, info: Bytes, length: Int) -> Bytes!:
    if length < 0:
        fail "hkdf length out of range"
    if length > 8160:
        fail "hkdf length out of range"
    mut okm := bytes.buffer_with_capacity(length)
    mut previous := bytes.empty()
    mut counter := 1
    while okm.bytes().len() < length:
        input := previous.concat(info).concat(int32_be(counter).slice(3, 4))
        previous = hmac.sha256(prk, input)
        need := length - okm.bytes().len()
        mut take := previous.len()
        if take > need:
            take = need
        okm.write(previous.slice(0, take))!
        counter = counter + 1
    return okm.bytes()

# hkdf extract with hmac-sha512.
pub fn hkdf_extract_sha512(salt: Bytes, secret: Bytes) -> Bytes:
    mut actual_salt := salt
    if actual_salt.len() == 0:
        actual_salt = zero_bytes(64)
    return hmac.sha512(actual_salt, secret)

# hkdf expand with hmac-sha512.
pub fn hkdf_expand_sha512(prk: Bytes, info: Bytes, length: Int) -> Bytes!:
    if length < 0:
        fail "hkdf length out of range"
    if length > 16320:
        fail "hkdf length out of range"
    mut okm := bytes.buffer_with_capacity(length)
    mut previous := bytes.empty()
    mut counter := 1
    while okm.bytes().len() < length:
        input := previous.concat(info).concat(int32_be(counter).slice(3, 4))
        previous = hmac.sha512(prk, input)
        need := length - okm.bytes().len()
        mut take := previous.len()
        if take > need:
            take = need
        okm.write(previous.slice(0, take))!
        counter = counter + 1
    return okm.bytes()

# derive bytes with HKDF-SHA256.
pub fn hkdf_sha256(secret: Bytes, salt: Bytes, info: Bytes, length: Int) -> Bytes!:
    return hkdf_expand_sha256(hkdf_extract_sha256(salt, secret), info, length)

# derive bytes with HKDF-SHA512.
pub fn hkdf_sha512(secret: Bytes, salt: Bytes, info: Bytes, length: Int) -> Bytes!:
    return hkdf_expand_sha512(hkdf_extract_sha512(salt, secret), info, length)

# derive bytes with PBKDF2-HMAC-SHA256.
pub fn pbkdf2_sha256(password: Bytes, salt: Bytes, iterations: Int, length: Int) -> Bytes!:
    if iterations <= 0:
        fail "pbkdf2 iterations must be positive"
    if length < 0:
        fail "pbkdf2 length out of range"
    out := bytes.buffer_with_capacity(length)
    mut block_index := 1
    while out.bytes().len() < length:
        mut u := hmac.sha256(password, salt.concat(int32_be(block_index)))
        mut mixed := bytes_to_list(u)
        mut round := 2
        while round <= iterations:
            u = hmac.sha256(password, u)
            mixed = xor_digest(mixed, u)
            round = round + 1
        need := length - out.bytes().len()
        block := list_to_bytes(mixed, need)
        out.write(block)!
        block_index = block_index + 1
    return out.bytes()

# derive bytes with PBKDF2-HMAC-SHA512.
pub fn pbkdf2_sha512(password: Bytes, salt: Bytes, iterations: Int, length: Int) -> Bytes!:
    if iterations <= 0:
        fail "pbkdf2 iterations must be positive"
    if length < 0:
        fail "pbkdf2 length out of range"
    out := bytes.buffer_with_capacity(length)
    mut block_index := 1
    while out.bytes().len() < length:
        mut u := hmac.sha512(password, salt.concat(int32_be(block_index)))
        mut mixed := bytes_to_list(u)
        mut round := 2
        while round <= iterations:
            u = hmac.sha512(password, u)
            mixed = xor_digest(mixed, u)
            round = round + 1
        need := length - out.bytes().len()
        block := list_to_bytes(mixed, need)
        out.write(block)!
        block_index = block_index + 1
    return out.bytes()

test "hkdf sha256 matches rfc 5869 vector":
    ikm := encoding.from_hex("0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b")!
    salt := encoding.from_hex("000102030405060708090a0b0c")!
    info := encoding.from_hex("f0f1f2f3f4f5f6f7f8f9")!
    okm := hkdf_sha256(ikm, salt, info, 42)!

    assert_eq(encoding.to_hex(okm), "3cb25f25faacd57a90434f64d0362f2a2d2d0a90cf1a5a4c5db02d56ecc4c5bf34007208d5b887185865")

test "hkdf extract and expand match rfc 5869 vector":
    ikm := encoding.from_hex("0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b")!
    salt := encoding.from_hex("000102030405060708090a0b0c")!
    info := encoding.from_hex("f0f1f2f3f4f5f6f7f8f9")!
    prk := hkdf_extract_sha256(salt, ikm)
    okm := hkdf_expand_sha256(prk, info, 42)!

    assert_eq(encoding.to_hex(prk), "077709362c2e32df0ddc3f0dc47bba6390b6c73bb50f9c3122ec844ad7c2b3e5")
    assert_eq(encoding.to_hex(okm), "3cb25f25faacd57a90434f64d0362f2a2d2d0a90cf1a5a4c5db02d56ecc4c5bf34007208d5b887185865")

test "hkdf sha512 matches known vector":
    ikm := encoding.from_hex("0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b")!
    salt := encoding.from_hex("000102030405060708090a0b0c")!
    info := encoding.from_hex("f0f1f2f3f4f5f6f7f8f9")!
    okm := hkdf_sha512(ikm, salt, info, 42)!

    assert_eq(encoding.to_hex(okm), "832390086cda71fb47625bb5ceb168e4c8e26a1a16ed34d9fc7fe92c1481579338da362cb8d9f925d7cb")

test "pbkdf2 sha256 matches common vectors":
    password := bytes.from_string_utf8("password")
    salt := bytes.from_string_utf8("salt")

    assert_eq(encoding.to_hex(pbkdf2_sha256(password, salt, 1, 32)!), "120fb6cffcf8b32c43e7225256c4f837a86548c92ccc35480805987cb70be17b")
    assert_eq(encoding.to_hex(pbkdf2_sha256(password, salt, 2, 32)!), "ae4d0c95af6b46d32d0adff928f06dd02a303f8ef3c251dfd6e2d85a95474c43")

test "pbkdf2 sha512 matches common vectors":
    password := bytes.from_string_utf8("password")
    salt := bytes.from_string_utf8("salt")

    assert_eq(encoding.to_hex(pbkdf2_sha512(password, salt, 1, 64)!), "867f70cf1ade02cff3752599a3a53dc4af34c7a669815ae5d513554e1c8cf252c02d470a285a0501bad999bfe943c08f050235d7d68b1da55e63f73b60a57fce")
    assert_eq(encoding.to_hex(pbkdf2_sha512(password, salt, 2, 64)!), "e1d9c16aa681708a45f5c7c4e215ceb66e011a2e9f0040713f18aefdb866d53cf76cab2868a39b9f7840edce4fef5a82be67335c77a6068e04112754f27ccf4e")

test "kdf rejects invalid parameters":
    assert(hkdf_sha256(bytes.empty(), bytes.empty(), bytes.empty(), -1).is_err)
    assert(hkdf_sha512(bytes.empty(), bytes.empty(), bytes.empty(), -1).is_err)
    assert(pbkdf2_sha256(bytes.empty(), bytes.empty(), 0, 32).is_err)
    assert(pbkdf2_sha512(bytes.empty(), bytes.empty(), 0, 32).is_err)
    assert(pbkdf2_sha256(bytes.empty(), bytes.empty(), 1, -1).is_err)
    assert(pbkdf2_sha512(bytes.empty(), bytes.empty(), 1, -1).is_err)
    assert_eq(hkdf_sha256(bytes.empty(), bytes.empty(), bytes.empty(), 0)!.len(), 0)
    assert_eq(hkdf_sha512(bytes.empty(), bytes.empty(), bytes.empty(), 0)!.len(), 0)
    assert_eq(pbkdf2_sha256(bytes.empty(), bytes.empty(), 1, 0)!.len(), 0)
    assert_eq(pbkdf2_sha512(bytes.empty(), bytes.empty(), 1, 0)!.len(), 0)
