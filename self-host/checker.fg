# create a function type from param list and return type
fn create_function_type(params: List[Int], ret: Int) -> Int:
    return add_type_info(ti_function(params, ret))

# register a builtin function name with a pre-computed function type
fn define_builtin_function(name: String, fn_tid: Int):
    define_binding(current_scope, name, fn_tid, false)

fn fix_builtin_binding(name: String, params: List[Int], ret: Int):
    define_builtin_function(name, add_type_info(ti_function(params, ret)))

# register an opaque sync primitive type with a constructor
fn register_sync_primitive_type(name: String, param_tids: List[Int]):
    mut fields: List[String] := []
    mut ftypes: List[Int] := []
    mut fpub: List[Bool] := []
    mut fmut: List[Bool] := []
    tid := add_type_info(ti_struct(name, fields, ftypes, fpub, fmut))
    register_type_name(name, tid)
    # constructor: create function type with param_tids -> tid
    mut ctor_params: List[Int] := []
    mut j := 0
    while j < param_tids.len():
        ctor_params.push(param_tids[j])
        j = j + 1
    ctor_tid := add_type_info(ti_function(ctor_params, tid))
    define_binding(current_scope, name, ctor_tid, false)

# ---------------------------------------------------------------
# intern collection types
# ---------------------------------------------------------------

fn build_collection_type_name(base: String, key_or_elem: Int, val: Int) -> String:
    if val < 0:
        return base + "[" + get_type_name(key_or_elem) + "]"
    return base + "[" + get_type_name(key_or_elem) + "," + get_type_name(val) + "]"

fn intern_list_type(elem: Int) -> Int:
    name := build_collection_type_name("List", elem, -1)
    existing := lookup_type_id(name)
    if existing == -1:
        add_type_info(ti_list(elem))
        tid := get_type_count() - 1
        register_type_name(name, tid)
        return tid
    return existing

fn intern_set_type(elem: Int) -> Int:
    name := build_collection_type_name("Set", elem, -1)
    existing := lookup_type_id(name)
    if existing == -1:
        add_type_info(ti_set(elem))
        tid := get_type_count() - 1
        register_type_name(name, tid)
        return tid
    return existing

fn intern_map_type(key_type: Int, val_type: Int) -> Int:
    name := build_collection_type_name("Map", key_type, val_type)
    existing := lookup_type_id(name)
    if existing == -1:
        add_type_info(ti_map(key_type, val_type))
        tid := get_type_count() - 1
        register_type_name(name, tid)
        return tid
    return existing

fn intern_task_type(inner: Int) -> Int:
    name := build_collection_type_name("Task", inner, -1)
    existing := lookup_type_id(name)
    if existing == -1:
        add_type_info(ti_task(inner))
        tid := get_type_count() - 1
        register_type_name(name, tid)
        return tid
    return existing

fn intern_channel_type(inner: Int) -> Int:
    name := build_collection_type_name("Channel", inner, -1)
    existing := lookup_type_id(name)
    if existing == -1:
        add_type_info(ti_channel(inner))
        tid := get_type_count() - 1
        register_type_name(name, tid)
        return tid
    return existing

pub fn debug_intern_list_string() -> Int:
    return intern_list_type(lookup_type_id("String"))

pub fn debug_add_list_type_direct() -> Int:
    add_type_info(ti_list(lookup_type_id("String")))
    return get_type_count()

# build an instantiation name like "Pair[Int,String]"
fn build_instantiated_type_name(base: String, type_args: List[Int]) -> String:
    mut result := base + "["
    for i in type_args:
        if result.len() > base.len() + 1:
            result = result + ","
        result = result + get_type_name(i)
    result = result + "]"
    return result

# ---------------------------------------------------------------
# type resolution — resolve AST type expression nodes to TypeIds
# ---------------------------------------------------------------

mut type_resolve_depth := 0

pub fn c_resolve_type(node_idx: Int) -> Int:
    return resolve_type_with_substitution(node_idx, false, "")

# resolve a type expression node, with optional generic substitution
# subst_active: if true, subst_params/subst_args provide substitution
fn resolve_type_implementation(node_idx: Int) -> Int:
    if node_idx < 0:
        return TID_ERR
    type_resolve_depth = type_resolve_depth + 1
    if type_resolve_depth > 128:
        type_resolve_depth = type_resolve_depth - 1
        report_error("E233", "type nesting too deep")
        return TID_ERR
    node := get_node(node_idx)
    mut result := TID_ERR
    if node.kind == "type":
        result = resolve_named_type(node.value)
    elif node.kind == "generic_type":
        result = resolve_generic_type_from_node(node)
    elif node.kind == "optional_type":
        inner := resolve_type_implementation(node.children[0])
        if is_error_type(inner):
            result = TID_ERR
        else:
            result = add_type_info(ti_optional(inner))
    elif node.kind == "result_type":
        ok := resolve_type_implementation(node.children[0])
        mut err_tid := TID_STRING
        if node.children.len() > 1:
            err_tid = resolve_type_implementation(node.children[1])
        result = add_type_info(ti_result(ok, err_tid))
    elif node.kind == "tuple_type":
        mut elems: List[Int] := []
        for child in node.children:
            elems.push(resolve_type_implementation(child))
        result = add_type_info(ti_tuple(elems))
    elif node.kind == "fn_type":
        mut params: List[Int] := []
        mut ret := TID_VOID
        for child in node.children:
            cn := get_node(child)
            if cn.kind == "param":
                params.push(resolve_type_implementation(cn.children[0]))
            elif cn.kind == "returns":
                ret = resolve_type_implementation(cn.children[0])
        result = add_type_info(ti_function(params, ret))
    type_resolve_depth = type_resolve_depth - 1
    return result

fn resolve_imported_type_name(name: String) -> String:
    parts := split_qualified_name(name)
    alias := parts.0
    member := parts.1
    if member == "":
        return name
    if module_aliases.contains_key(alias):
        module_path := module_aliases[alias]
        target := module_import_target_name(module_path, member)
        if lookup_type_id(target) >= 0:
            return target
        if lookup_type_id(member) >= 0:
            return member
    return name

fn resolve_named_type(name: String) -> Int:
    resolved_name := resolve_imported_type_name(name)
    tid := lookup_type_id(resolved_name)
    if tid < 0:
        report_error("E202", "unknown type: " + name)
        return TID_ERR
    return tid

fn resolve_generic_type_from_node(node: Node) -> Int:
    base := resolve_imported_type_name(node.value)
    mut type_args: List[Int] := []
    for child in node.children:
        type_args.push(resolve_type_implementation(child))
    return resolve_generic_type(base, type_args)

fn resolve_generic_type(base: String, type_args: List[Int]) -> Int:
    # builtin generic types
    if strings_equal(base, "List"):
        if type_args.len() != 1:
            report_error("E221", "List expects 1 type argument, got " + type_args.len().to_string())
            return TID_ERR
        return intern_list_type(type_args[0])
    if strings_equal(base, "Set"):
        if type_args.len() != 1:
            report_error("E221", "Set expects 1 type argument, got " + type_args.len().to_string())
            return TID_ERR
        return intern_set_type(type_args[0])
    if strings_equal(base, "Map"):
        if type_args.len() != 2:
            report_error("E221", "Map expects 2 type arguments, got " + type_args.len().to_string())
            return TID_ERR
        return intern_map_type(type_args[0], type_args[1])
    if strings_equal(base, "Task"):
        if type_args.len() != 1:
            report_error("E221", "Task expects 1 type argument, got " + type_args.len().to_string())
            return TID_ERR
        return intern_task_type(type_args[0])
    if strings_equal(base, "Channel"):
        if type_args.len() != 1:
            report_error("E221", "Channel expects 1 type argument, got " + type_args.len().to_string())
            return TID_ERR
        return intern_channel_type(type_args[0])
    # user-defined generic types
    if has_generic_declaration(base):
        decl_idx := get_generic_declaration_index(base)
        return instantiate_generic_type(decl_idx, type_args)
    report_error("E202", "unknown generic type: " + base)
    return TID_ERR

# resolve with substitution map (for generic instantiation)
fn resolve_type_with_substitution(node_idx: Int, subst_active: Bool, subst_key: String) -> Int:
    # no substitution — use the normal path
    return resolve_type_implementation(node_idx)

# resolve with a substitution map for generic params
fn resolve_type_with_substitution_map(node_idx: Int, subst_params: List[String], subst_args: List[Int]) -> Int:
    if node_idx < 0:
        return TID_ERR
    node := get_node(node_idx)
    if node.kind == "type":
        # check if this type name is a generic param that should be substituted
        mut i := 0
        for p in subst_params:
            if strings_equal(p, node.value):
                if i < subst_args.len():
                    return subst_args[i]
                return TID_ERR
            i = i + 1
        return resolve_named_type(node.value)
    if node.kind == "generic_type":
        mut type_args: List[Int] := []
        for child in node.children:
            type_args.push(resolve_type_with_substitution_map(child, subst_params, subst_args))
        return resolve_generic_type(node.value, type_args)
    if node.kind == "optional_type":
        inner := resolve_type_with_substitution_map(node.children[0], subst_params, subst_args)
        if is_error_type(inner):
            return TID_ERR
        return add_type_info(ti_optional(inner))
    if node.kind == "result_type":
        ok := resolve_type_with_substitution_map(node.children[0], subst_params, subst_args)
        mut err_tid := TID_STRING
        if node.children.len() > 1:
            err_tid = resolve_type_with_substitution_map(node.children[1], subst_params, subst_args)
        return add_type_info(ti_result(ok, err_tid))
    if node.kind == "tuple_type":
        mut elems: List[Int] := []
        for child in node.children:
            elems.push(resolve_type_with_substitution_map(child, subst_params, subst_args))
        return add_type_info(ti_tuple(elems))
    if node.kind == "fn_type":
        mut params: List[Int] := []
        mut ret := TID_VOID
        for child in node.children:
            cn := get_node(child)
            if cn.kind == "param":
                params.push(resolve_type_with_substitution_map(cn.children[0], subst_params, subst_args))
            elif cn.kind == "returns":
                ret = resolve_type_with_substitution_map(cn.children[0], subst_params, subst_args)
        return add_type_info(ti_function(params, ret))
    return TID_ERR

# ---------------------------------------------------------------
# pass 1 — declaration registration
# ---------------------------------------------------------------

pub fn c_register_all(root_idx: Int):
    root := get_node(root_idx)
    for child in root.children:
        register_top_level_declarations(child)

fn register_top_level_declarations(node_idx: Int):
    node := get_node(node_idx)
    if node.kind == "pub":
        register_declaration(node.children[0], true)
    elif node.kind == "from_import":
        # imports not handled in single-file mode
        return
    elif node.kind == "import":
        return
    else:
        register_declaration(node_idx, false)

fn register_declaration(node_idx: Int, is_pub: Bool):
    node := get_node(node_idx)
    if node.kind == "fn_decl":
        register_function_declaration(node_idx, node)
    elif node.kind == "struct_decl":
        register_struct_declaration(node_idx, node)
    elif node.kind == "enum_decl":
        register_enum_declaration(node_idx, node)
    elif node.kind == "interface_decl":
        register_interface_declaration(node_idx, node)
    elif node.kind == "impl_decl":
        register_implementation_declaration(node_idx, node)
    elif node.kind == "type_alias":
        register_type_alias_declaration(node)
    elif node.kind == "binding":
        # handled in pass 2
        return
    elif node.kind == "test_decl":
        # no names to register
        return

# ---------------------------------------------------------------
# pass 1 — function declarations
# ---------------------------------------------------------------

fn register_function_declaration(node_idx: Int, node: Node):
    name := node.value
    if declaration_has_generic_params(node):
        register_generic_declaration(name, node_idx)
        return
    # resolve function signature
    fn_tid := resolve_function_signature(node)
    if fn_tid >= 0:
        define_binding(current_scope, name, fn_tid, false)
        if current_checker_module_path.len() > 0:
            define_binding(current_scope, module_generic_target_name(current_checker_module_path, name), fn_tid, false)

fn resolve_function_signature(node: Node) -> Int:
    mut params: List[Int] := []
    mut ret := TID_VOID
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "param":
            if cn.children.len() > 0:
                ptid := resolve_type_implementation(cn.children[0])
                params.push(ptid)
            else:
                report_error("E230", "parameter requires a type annotation")
                params.push(TID_ERR)
        elif cn.kind == "returns":
            ret = resolve_type_implementation(cn.children[0])
    return add_type_info(ti_function(params, ret))

# ---------------------------------------------------------------
# pass 1 — struct declarations
# ---------------------------------------------------------------

fn register_struct_declaration(node_idx: Int, node: Node):
    name := node.value
    if declaration_has_generic_params(node):
        register_generic_declaration(name, node_idx)
        define_binding(current_scope, name, TID_ERR, false)
        return
    base_name := name
    # non-generic: resolve field types immediately
    mut field_names: List[String] := []
    mut field_types: List[Int] := []
    mut field_pub: List[Bool] := []
    mut field_mut: List[Bool] := []
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "field":
            fname := extract_field_name(cn.value)
            is_pub := cn.value.contains(" pub")
            is_mut := cn.value.contains(" mut")
            field_names.push(fname)
            if cn.children.len() > 0:
                ftid := resolve_type_implementation(cn.children[0])
                field_types.push(ftid)
            else:
                field_types.push(TID_ERR)
            field_pub.push(is_pub)
            field_mut.push(is_mut)
    tid := add_type_info(ti_struct(base_name, field_names, field_types, field_pub, field_mut))
    register_type_name(base_name, tid)
    define_binding(current_scope, base_name, tid, false)

# ---------------------------------------------------------------
# pass 1 — enum declarations
# ---------------------------------------------------------------

fn register_enum_declaration(node_idx: Int, node: Node):
    name := node.value
    if declaration_has_generic_params(node):
        register_generic_declaration(name, node_idx)
        define_binding(current_scope, name, TID_ERR, false)
        return
    base_name := name
    # non-generic: resolve variant types immediately
    mut variant_names: List[String] := []
    mut variant_types: List[List[Int]] := []
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "variant":
            variant_names.push(cn.value)
            mut vtypes: List[Int] := []
            for vc in cn.children:
                vtypes.push(resolve_type_implementation(vc))
            variant_types.push(vtypes)
    tid := add_type_info(ti_enum(base_name, variant_names, variant_types))
    register_type_name(base_name, tid)
    define_binding(current_scope, base_name, tid, false)

# ---------------------------------------------------------------
# pass 1 — interface declarations
# ---------------------------------------------------------------

fn register_interface_declaration(node_idx: Int, node: Node):
    base_name := node.value
    mut name := base_name
    mut generic_names: List[String] := []
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "generic_param":
            generic_names.push(cn.value)
    if generic_names.len() > 0:
        name = build_interface_type_name(name, generic_names)
    # register as a zero-field struct in type table (so it's resolvable)
    mut empty_s: List[String] := []
    mut empty_i: List[Int] := []
    mut empty_b: List[Bool] := []
    tid := add_type_info(ti_struct(name, empty_s, empty_i, empty_b, empty_b))
    register_type_name(name, tid)
    if generic_names.len() > 0:
        register_type_name(base_name, tid)
        register_interface_declaration_name(base_name)
    register_interface_declaration_name(name)

# ---------------------------------------------------------------
# pass 1 — impl declarations
# ---------------------------------------------------------------

fn register_implementation_declaration(node_idx: Int, node: Node):
    # children[0] is the target type (or interface type if "impl X for Y:")
    # optional for_type node follows
    # then method fn_decls
    first_type_node := get_node(node.children[0])
    mut concrete_name := ""
    mut interface_name := ""
    mut method_start := 1

    # check if there's a for_type node
    if node.children.len() > 1:
        second_node := get_node(node.children[1])
        if second_node.kind == "for_type":
            # impl Interface for Type:
            interface_name = get_type_node_name(first_type_node)
            for_inner := get_node(second_node.children[0])
            concrete_name = get_type_node_name(for_inner)
            method_start = 2
            # record in impl set
            key := concrete_name + chr(9) + interface_name
            implementation_set.insert(key, 1)
        else:
            concrete_name = get_type_node_name(first_type_node)
    else:
        concrete_name = get_type_node_name(first_type_node)

    if concrete_name == "":
        return

    # register each method (skip first method_start children)
    mut skip := method_start
    for child in node.children:
        if skip > 0:
            skip = skip - 1
            continue
        mut cn := get_node(child)
        mut method_node_idx := child
        mut method_is_pub := false
        if cn.kind == "pub":
            method_is_pub = true
            method_node_idx = cn.children[0]
            cn = get_node(method_node_idx)
        if cn.kind == "fn_decl":
            register_method_declaration(concrete_name, method_node_idx, cn, method_is_pub)

fn register_method_declaration(type_name: String, node_idx: Int, node: Node, is_pub: Bool):
    mut method_name := node.value
    fn_tid := resolve_function_signature(node)
    key := type_name + "." + method_name
    method_type_map.insert(key, fn_tid)
    method_visibility_map.insert(key, is_pub)
    register_method_signature(key, node_idx, is_pub)

fn check_type_implements_interface(type_name: String, iface_name: String) -> Bool:
    key := type_name + chr(9) + iface_name
    return implementation_set.contains_key(key)

fn has_interface_declaration(name: String) -> Bool:
    for iface_name in interface_declaration_names:
        if strings_equal(iface_name, name):
            return true
    base := extract_base_type_name(name)
    if base != name:
        for iface_name in interface_declaration_names:
            if strings_equal(iface_name, base):
                return true
    return false

fn build_interface_type_name(base: String, args: List[String]) -> String:
    mut result := base + "["
    mut first := true
    for arg in args:
        if first == false:
            result = result + ","
        first = false
        result = result + arg
    return result + "]"

# ---------------------------------------------------------------
# pass 1 — type alias
# ---------------------------------------------------------------

fn register_type_alias_declaration(node: Node):
    name := node.value
    if node.children.len() > 0:
        target := resolve_type_implementation(node.children[0])
        register_type_name(name, target)

# ---------------------------------------------------------------
# helpers
# ---------------------------------------------------------------

fn extract_base_type_name(name: String) -> String:
    # "swap[T]" -> "swap", "Pair[A, B]" -> "Pair"
    mut i := 0
    while i < name.len():
        if ord(name[i]) == 91:
            return name.substring(0, i)
        i = i + 1
    return name

fn declaration_has_generic_params(node: Node) -> Bool:
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "generic_param":
            return true
    return false

fn collect_generic_parameter_names(node: Node) -> List[String]:
    mut params: List[String] := []
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "generic_param":
            params.push(trim_type_text(cn.value))
    return params

fn register_generic_declaration(name: String, node_idx: Int):
    key := module_generic_target_name(current_checker_module_path, name)
    if generic_declaration_map.contains_key(key) == false:
        generic_declaration_names.push(key)
    generic_declaration_map.insert(key, node_idx)
    if current_checker_module_path.len() > 0 and generic_declaration_map.contains_key(name) == false:
        generic_declaration_names.push(name)
        generic_declaration_map.insert(name, node_idx)

fn resolve_generic_declaration_key(name: String) -> String:
    if current_checker_module_path.len() > 0:
        current_key := module_generic_target_name(current_checker_module_path, name)
        if generic_declaration_map.contains_key(current_key):
            return current_key
    if generic_declaration_map.contains_key(name):
        return name
    for entry in generic_named_import_entries:
        parts := entry.split(chr(9))
        if parts.len() >= 3:
            if parts[0] == current_checker_module_path and parts[1] == name:
                imported_key := module_generic_target_name(parts[2], name)
                if generic_declaration_map.contains_key(imported_key):
                    return imported_key
    for entry in generic_wildcard_import_entries:
        parts := entry.split(chr(9))
        if parts.len() >= 2:
            if parts[0] == current_checker_module_path:
                imported_key := module_generic_target_name(parts[1], name)
                if generic_declaration_map.contains_key(imported_key):
                    return imported_key
    return ""

fn has_generic_declaration(name: String) -> Bool:
    return resolve_generic_declaration_key(name).len() > 0

fn get_generic_declaration_index(name: String) -> Int:
    key := resolve_generic_declaration_key(name)
    if key.len() > 0:
        return generic_declaration_map[key]
    return - 1

fn register_interface_declaration_name(name: String):
    for iface_name in interface_declaration_names:
        if strings_equal(iface_name, name):
            return
    interface_declaration_names.push(name)

fn register_method_signature(key: String, node_idx: Int, is_pub: Bool):
    method_decl_index_map.insert(key, node_idx)
    method_visibility_map.insert(key, is_pub)

fn has_method_declaration(key: String) -> Bool:
    return method_decl_index_map.contains_key(key)

fn get_method_declaration_index(key: String) -> Int:
    if method_decl_index_map.contains_key(key):
        return method_decl_index_map[key]
    return - 1

fn collect_function_param_types(node: Node) -> List[Int]:
    mut params: List[Int] := []
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "param":
            if cn.children.len() > 0:
                params.push(resolve_type_implementation(cn.children[0]))
            else:
                params.push(TID_ERR)
    return params

fn collect_function_return_type(node: Node) -> Int:
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "returns":
            return resolve_type_implementation(cn.children[0])
    return TID_VOID

fn extract_field_name(value: String) -> String:
    # "name pub mut" -> "name"
    mut i := 0
    while i < value.len():
        if ord(value[i]) == 32:
            return value.substring(0, i)
        i = i + 1
    return value

fn strings_equal(a: String, b: String) -> Bool:
    if a.len() != b.len():
        return false
    mut i := 0
    while i < a.len():
        if ord(a[i]) != ord(b[i]):
            return false
        i = i + 1
    return true

fn split_qualified_name(value: String) -> (String, String):
    mut i := 0
    while i < value.len():
        if ord(value[i]) == 46:
            return (value.substring(0, i), value.substring(i + 1, value.len()))
        i = i + 1
    return (value, "")

fn get_type_node_name(node: Node) -> String:
    # extract the type name from a type expression node
    if node.kind == "type":
        if node.value.contains("["):
            base := extract_base_type_name(node.value)
            inner := node.value.substring(base.len() + 1, node.value.len() - 1)
            parts := inner.split(",")
            mut args: List[String] := []
            for part in parts:
                args.push(part.trim())
            return build_interface_type_name(base, args)
        return node.value
    if node.kind == "generic_type":
        mut parts: List[String] := []
        for child in node.children:
            child_name := get_type_node_name(get_node(child))
            if child_name == "":
                return ""
            parts.push(child_name)
        return build_interface_type_name(node.value, parts)
    return ""

fn get_type_node_name_with_substitution(node: Node, subst_map: Map[String, Int]) -> String:
    if node.kind == "type":
        if node.value.contains("["):
            base := extract_base_type_name(node.value)
            inner := node.value.substring(base.len() + 1, node.value.len() - 1)
            raw_parts := inner.split(",")
            mut args: List[String] := []
            for raw in raw_parts:
                part := raw.trim()
                if subst_map.contains_key(part):
                    args.push(get_type_name(subst_map[part]))
                else:
                    args.push(part)
            return build_interface_type_name(base, args)
        if subst_map.contains_key(node.value):
            return get_type_name(subst_map[node.value])
        return node.value
    if node.kind == "generic_type":
        mut parts: List[String] := []
        for child in node.children:
            child_name := get_type_node_name_with_substitution(get_node(child), subst_map)
            if child_name == "":
                return ""
            parts.push(child_name)
        return build_interface_type_name(node.value, parts)
    return ""

# extract the binding name from a binding value like "x" or "x mut"
fn extract_binding_name(value: String) -> String:
    mut i := 0
    while i < value.len():
        if ord(value[i]) == 32:
            return value.substring(0, i)
        i = i + 1
    return value

fn binding_is_mutable(value: String) -> Bool:
    return value.contains(" mut")

# ---------------------------------------------------------------
# pass 2 — check declarations
# ---------------------------------------------------------------

pub fn c_check_all(root_idx: Int):
    root := get_node(root_idx)
    for child in root.children:
        check_top_level_declarations(child)

fn check_top_level_declarations(node_idx: Int):
    node := get_node(node_idx)
    if node.kind == "pub":
        check_declaration(node.children[0])
    elif node.kind == "from_import":
        return
    elif node.kind == "import":
        return
    else:
        check_declaration(node_idx)

fn check_declaration(node_idx: Int):
    node := get_node(node_idx)
    if node.kind == "fn_decl":
        check_function_declaration(node)
    elif node.kind == "binding":
        check_binding_statement(node_idx, current_scope)
    elif node.kind == "impl_decl":
        check_implementation_declaration(node)
    elif node.kind == "test_decl":
        check_test_declaration(node)

# ---------------------------------------------------------------
# pass 2 — function checking
# ---------------------------------------------------------------

fn check_function_declaration(node: Node):
    if declaration_has_generic_params(node):
        return
    name := node.value
    # skip main — it may not be registered if it's the entry point
    fn_tid := lookup_binding(current_scope, name)
    if fn_tid < 0:
        return
    fn_info := get_type_info(fn_tid)
    if fn_info.kind != "function":
        return
    # create function scope with return type
    fn_scope := create_function_scope(current_scope, fn_info.return_type)
    # define parameters
    mut param_idx := 0
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "param":
            pname := extract_binding_name(cn.value)
            if param_idx < fn_info.param_types.len():
                define_binding(fn_scope, pname, fn_info.param_types[param_idx], cn.value.contains("mut"))
            param_idx = param_idx + 1
        elif cn.kind == "body":
            check_function_body(child, fn_scope)

fn check_function_body(node_idx: Int, scope_id: Int):
    node := get_node(node_idx)
    if node.children.len() > 0:
        block := get_node(node.children[0])
        if block.kind == "block":
            check_block_statement(block, scope_id)

fn check_block_statement(node: Node, scope_id: Int):
    for child in node.children:
        check_statement(child, scope_id)

# ---------------------------------------------------------------
# pass 2 — impl checking
# ---------------------------------------------------------------

fn check_implementation_declaration(node: Node):
    first_type_node := get_node(node.children[0])
    mut concrete_name := ""
    mut method_start := 1

    if node.children.len() > 1:
        second_node := get_node(node.children[1])
        if second_node.kind == "for_type":
            for_inner := get_node(second_node.children[0])
            concrete_name = get_type_node_name(for_inner)
            method_start = 2
        else:
            concrete_name = get_type_node_name(first_type_node)
    else:
        concrete_name = get_type_node_name(first_type_node)

    if concrete_name == "":
        return

    concrete_tid := lookup_type_id(concrete_name)
    if concrete_tid < 0:
        return

    # check each method body (skip first method_start children)
    mut skip := method_start
    for child in node.children:
        if skip > 0:
            skip = skip - 1
            continue
        mut cn := get_node(child)
        if cn.kind == "pub":
            cn = get_node(cn.children[0])
        if cn.kind == "fn_decl":
            check_method_body(concrete_name, concrete_tid, cn)

fn check_method_body(type_name: String, type_tid: Int, node: Node):
    param_types := collect_function_param_types(node)
    ret_type := collect_function_return_type(node)
    method_scope := create_function_scope(current_scope, ret_type)
    # bind self
    define_binding(method_scope, "self", type_tid, false)

    # define parameters (skipping self — it's implicit)
    mut param_idx := 0
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "param":
            pname := extract_binding_name(cn.value)
            if param_idx < param_types.len():
                define_binding(method_scope, pname, param_types[param_idx], cn.value.contains("mut"))
            param_idx = param_idx + 1
        elif cn.kind == "body":
            check_function_body(child, method_scope)

# ---------------------------------------------------------------
# pass 2 — test checking
# ---------------------------------------------------------------

fn check_test_declaration(node: Node):
    test_scope := create_function_scope(current_scope, TID_VOID)
    checking_test_decl = true
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "body":
            check_function_body(child, test_scope)
    checking_test_decl = false

# ---------------------------------------------------------------
# statement checking
# ---------------------------------------------------------------

fn check_statement(node_idx: Int, scope_id: Int):
    node := get_node(node_idx)
    if node.kind == "binding":
        check_binding_statement(node_idx, scope_id)
    elif node.kind == "assignment":
        check_assignment(node, scope_id)
    elif node.kind == "return":
        check_return_statement(node, scope_id)
    elif node.kind == "fail":
        check_fail_statement(node, scope_id)
    elif node.kind == "if_stmt":
        check_if_statement(node, scope_id)
    elif node.kind == "while_stmt":
        check_while_statement(node, scope_id)
    elif node.kind == "for_stmt":
        check_for_statement(node, scope_id)
    elif node.kind == "break":
        if is_in_loop_scope(scope_id) == false:
            report_error("E215", "break outside of loop")
    elif node.kind == "continue":
        if is_in_loop_scope(scope_id) == false:
            report_error("E215", "continue outside of loop")
    elif node.kind == "match_expr":
        check_match_expression(node_idx, scope_id)
    else:
        # expression statement
        c_check_expr(node_idx, scope_id)

# ---------------------------------------------------------------
# binding statement
# ---------------------------------------------------------------

fn check_binding_statement(node_idx: Int, scope_id: Int):
    node := get_node(node_idx)
    name := extract_binding_name(node.value)
    is_mut := binding_is_mutable(node.value)
    # children: [type_expr?, value_expr]
    # if 2 children -> first is type annotation, second is value
    # if 1 child -> no annotation, child is value
    if node.children.len() == 2:
        # has type annotation
        annotated := resolve_type_implementation(node.children[0])
        val_type := c_check_expr(node.children[1], scope_id)
        if is_error_type(annotated) == false:
            if is_error_type(val_type) == false:
                if annotated != val_type:
                    if types_structurally_equal(annotated, val_type):
                        define_binding(scope_id, name, annotated, is_mut)
                        return
                    # special case: allow empty collections with annotations
                    val_node := get_node(node.children[1])
                    if val_node.kind != "list":
                        if val_node.kind != "map":
                            if val_node.kind != "set":
                                report_error("E200", "type mismatch: expected " + get_type_name(annotated) + ", got " + get_type_name(val_type))
        define_binding(scope_id, name, annotated, is_mut)
    elif node.children.len() == 1:
        val_type := c_check_expr(node.children[0], scope_id)
        define_binding(scope_id, name, val_type, is_mut)

# ---------------------------------------------------------------
# assignment statement
# ---------------------------------------------------------------

fn check_assignment(node: Node, scope_id: Int):
    # node.value is the operator: "=", "+=", "-=", "*=", "/="
    # children[0] is target, children[1] is value
    if node.children.len() < 2:
        return
    target_idx := node.children[0]
    value_idx := node.children[1]
    target_node := get_node(target_idx)
    # check target mutability
    if target_node.kind == "ident":
        if is_binding_mutable(scope_id, target_node.value) == false:
            report_error_with_fix("E216", "cannot assign to immutable variable '" + target_node.value + "'", "declare with 'mut': mut " + target_node.value)
            return
    target_type := c_check_expr(target_idx, scope_id)
    val_type := c_check_expr(value_idx, scope_id)
    if is_error_type(target_type):
        return
    if is_error_type(val_type):
        return
    op := node.value
    if op == "=":
        if target_type != val_type:
            if types_structurally_equal(target_type, val_type) == false:
                report_error("E200", "type mismatch: expected " + get_type_name(target_type) + ", got " + get_type_name(val_type))
    else:
        # compound assignment: +=, -=, *=, /=
        if is_numeric_type(target_type) == false:
            report_error("E217", "operator " + op + " requires numeric type, got " + get_type_name(target_type))
        elif target_type != val_type:
            report_error("E200", "type mismatch: expected " + get_type_name(target_type) + ", got " + get_type_name(val_type))

# ---------------------------------------------------------------
# return statement
# ---------------------------------------------------------------

fn check_return_statement(node: Node, scope_id: Int):
    expected := get_scope_return_type(scope_id)
    if expected < 0:
        report_error("E231", "return outside of function")
        return
    if node.children.len() == 0:
        # bare return
        if expected != TID_VOID:
            report_error("E200", "return type mismatch: expected " + get_type_name(expected) + ", got Void")
        return
    actual := c_check_expr(node.children[0], scope_id)
    if is_error_type(actual):
        return
    if actual == expected:
        return
    # allow returning inner type from result-returning function
    exp_info := get_type_info(expected)
    if exp_info.kind == "result":
        if actual == exp_info.inner:
            return
    # allow returning inner type from optional-returning function
    if exp_info.kind == "optional":
        if actual == exp_info.inner:
            return
    # check structural equality (tuples)
    if types_structurally_equal(actual, expected):
        return
    report_error_with_fix("E200", "return type mismatch: expected " + get_type_name(expected) + ", got " + get_type_name(actual), "change the return type to " + get_type_name(actual))

# ---------------------------------------------------------------
# fail statement
# ---------------------------------------------------------------

fn check_fail_statement(node: Node, scope_id: Int):
    ret_type := get_scope_return_type(scope_id)
    if ret_type < 0:
        report_error("E231", "fail outside of function")
        return
    ret_info := get_type_info(ret_type)
    if ret_info.kind != "result":
        report_error("E234", "fail requires function to return a result type")
        return
    if node.children.len() < 1:
        return
    err_type := c_check_expr(node.children[0], scope_id)
    if is_error_type(err_type):
        return
    if types_compatible(err_type, ret_info.value_type) == false:
        report_error("E219", "fail type mismatch: expected " + get_type_name(ret_info.value_type) + ", got " + get_type_name(err_type))

# ---------------------------------------------------------------
# if statement
# ---------------------------------------------------------------

fn check_if_statement(node: Node, scope_id: Int):
    # children: [condition, then, elif..., else?]
    if node.children.len() < 2:
        return
    tid_bool := lookup_type_id("Bool")
    # check condition
    cond_type := c_check_expr(node.children[0], scope_id)
    if is_error_type(cond_type) == false:
        if cond_type != tid_bool:
            report_error("E200", "condition must be Bool, got " + get_type_name(cond_type))
    # check then branch
    then_node := get_node(node.children[1])
    if then_node.kind == "then":
        then_scope := create_scope(scope_id)
        if then_node.children.len() > 0:
            block := get_node(then_node.children[0])
            if block.kind == "block":
                check_block_statement(block, then_scope)
    # check elif and else branches (skip first 2: condition + then)
    mut skip_if := 2
    for child in node.children:
        if skip_if > 0:
            skip_if = skip_if - 1
            continue
        cn := get_node(child)
        if cn.kind == "elif":
            elif_scope := create_scope(scope_id)
            if cn.children.len() > 0:
                econd := c_check_expr(cn.children[0], elif_scope)
                if is_error_type(econd) == false:
                    if econd != tid_bool:
                        report_error("E200", "condition must be Bool, got " + get_type_name(econd))
            if cn.children.len() > 1:
                ebody := get_node(cn.children[1])
                if ebody.kind == "block":
                    check_block_statement(ebody, elif_scope)
                elif ebody.kind == "then":
                    if ebody.children.len() > 0:
                        eblock := get_node(ebody.children[0])
                        if eblock.kind == "block":
                            check_block_statement(eblock, elif_scope)
        elif cn.kind == "else":
            else_scope := create_scope(scope_id)
            if cn.children.len() > 0:
                eblock := get_node(cn.children[0])
                if eblock.kind == "block":
                    check_block_statement(eblock, else_scope)

# ---------------------------------------------------------------
# while statement
# ---------------------------------------------------------------

fn check_while_statement(node: Node, scope_id: Int):
    if node.children.len() < 2:
        return
    tid_bool := lookup_type_id("Bool")
    cond_type := c_check_expr(node.children[0], scope_id)
    if is_error_type(cond_type) == false:
        if cond_type != tid_bool:
            report_error("E200", "condition must be Bool, got " + get_type_name(cond_type))
    loop_scope := create_loop_scope(scope_id)
    body_node := get_node(node.children[1])
    if body_node.kind == "body":
        check_function_body(node.children[1], loop_scope)
    elif body_node.kind == "block":
        check_block_statement(body_node, loop_scope)

# ---------------------------------------------------------------
# for statement
# ---------------------------------------------------------------

fn check_for_statement(node: Node, scope_id: Int):
    # node.value: "x" or "x, i" (binding names)
    # children[0]: iterable expression
    # children[1]: body
    if node.children.len() < 2:
        return
    iter_type := c_check_expr(node.children[0], scope_id)
    if is_error_type(iter_type):
        return
    # infer element type from collection
    tid_err := lookup_type_id("<error>")
    tid_int := lookup_type_id("Int")
    tid_string := lookup_type_id("String")
    mut elem_type := tid_err
    iter_info := get_type_info(iter_type)
    if iter_type == tid_string:
        elem_type = tid_string
    elif iter_info.kind == "list":
        elem_type = iter_info.inner
    elif iter_info.kind == "map":
        elem_type = iter_info.key_type
    elif iter_info.kind == "set":
        elem_type = iter_info.inner
    else:
        report_error("E217", "cannot iterate over " + get_type_name(iter_type))
        return
    # create loop scope
    loop_scope := create_loop_scope(scope_id)
    # bind the loop variable
    if node.children.len() >= 3:
        elem_name := get_node(node.children[2]).value
        define_binding(loop_scope, elem_name, elem_type, false)
        if node.children.len() >= 4:
            idx_name := get_node(node.children[3]).value
            define_binding(loop_scope, idx_name, tid_int, false)
    else:
        binding_names := node.value
        define_binding(loop_scope, binding_names.trim(), elem_type, false)
    # check body
    body_node := get_node(node.children[1])
    if body_node.kind == "body":
        check_function_body(node.children[1], loop_scope)
    elif body_node.kind == "block":
        check_block_statement(body_node, loop_scope)

# ---------------------------------------------------------------
# expression checking
# ---------------------------------------------------------------

pub fn c_check_expr(node_idx: Int, scope_id: Int) -> Int:
    result := check_expression_implementation(node_idx, scope_id)
    expression_type_cache.insert(node_idx, result)
    return result

# look up cached expression type (returns TID_ERR if not found)
pub fn c_get_expr_type(node_idx: Int) -> Int:
    if expression_type_cache.contains_key(node_idx):
        return expression_type_cache[node_idx]
    return TID_ERR

fn check_expression_implementation(node_idx: Int, scope_id: Int) -> Int:
    node := get_node(node_idx)
    tid_int := lookup_type_id("Int")
    tid_float := lookup_type_id("Float")
    tid_string := lookup_type_id("String")
    tid_bool := lookup_type_id("Bool")
    tid_err := lookup_type_id("<error>")
    if node.kind == "int_lit":
        return tid_int
    if node.kind == "float_lit":
        return tid_float
    if node.kind == "string_lit":
        return tid_string
    if node.kind == "bool_lit":
        return tid_bool
    if node.kind == "none_lit":
        return tid_err
    if node.kind == "ident":
        return check_identifier(node_idx, node.value, scope_id)
    if node.kind == "self":
        return check_identifier(node_idx, "self", scope_id)
    if node.kind == "binary":
        return check_binary_expression(node, scope_id)
    if node.kind == "unary":
        return check_unary_expression(node, scope_id)
    if node.kind == "grouped":
        if node.children.len() > 0:
            return c_check_expr(node.children[0], scope_id)
        return TID_ERR
    if node.kind == "string_interp":
        # check all interpolated expressions
        for child in node.children:
            cn := get_node(child)
            if cn.kind != "lit":
                expr_tid := c_check_expr(child, scope_id)
                if is_error_type(expr_tid) == false:
                    if type_supports_stringify(expr_tid) == false:
                        report_error("E219", "string interpolation requires a stringifiable value, got " + get_type_name(expr_tid))
        return tid_string
    if node.kind == "if_expr":
        return check_if_expression(node, scope_id)
    if node.kind == "call":
        return check_function_call(node, scope_id)
    if node.kind == "method_call":
        return check_method_call(node, scope_id)
    if node.kind == "field_access":
        return check_field_access_expression(node, scope_id)
    if node.kind == "index":
        return check_index_expression(node, scope_id)
    if node.kind == "unwrap":
        return check_unwrap_expression(node, scope_id)
    if node.kind == "try":
        return check_try_expression(node, scope_id)
    if node.kind == "catch_expr":
        return check_catch_expression(node, scope_id)
    if node.kind == "select_expr":
        return check_select_expression(node, scope_id)
    if node.kind == "match_expr":
        return check_match_expression(node_idx, scope_id)
    if node.kind == "lambda":
        return check_lambda_expression(node, scope_id)
    if node.kind == "list":
        return check_list_expression(node, scope_id)
    if node.kind == "map":
        return check_map_expression(node, scope_id)
    if node.kind == "set":
        return check_set_expression(node, scope_id)
    if node.kind == "tuple":
        return check_tuple_expression(node, scope_id)
    if node.kind == "struct_init":
        return check_struct_initialization(node, scope_id)
    if node.kind == "spawn":
        return check_spawn_expression(node, scope_id)
    if node.kind == "await":
        return check_await_expression(node, scope_id)
    return TID_ERR

fn type_supports_stringify(tid: Int) -> Bool:
    if tid < 0:
        return false
    info := get_type_info(tid)
    if info.kind == "primitive":
        return info.name == "String" or info.name == "Int" or info.name == "UInt" or info.name == "Int8" or info.name == "Int16" or info.name == "Int32" or info.name == "Int64" or info.name == "UInt8" or info.name == "UInt16" or info.name == "UInt32" or info.name == "UInt64" or info.name == "Float" or info.name == "Bool"
    if info.kind == "result":
        return type_supports_stringify(info.inner) and type_supports_stringify(info.value_type)
    return false

# ---------------------------------------------------------------
# identifier lookup
# ---------------------------------------------------------------

fn check_identifier(node_idx: Int, name: String, scope_id: Int) -> Int:
    tid := lookup_binding(scope_id, name)
    if tid >= 0:
        return tid
    # check if it's a generic decl name — suppress false "undefined" errors
    if has_generic_declaration(name):
        return TID_ERR
    report_error_at(node_idx, "E201", "undefined variable: " + name)
    return TID_ERR

# ---------------------------------------------------------------
# binary expression checking
# ---------------------------------------------------------------

fn check_binary_expression(node: Node, scope_id: Int) -> Int:
    if node.children.len() < 2:
        return TID_ERR
    op := node.value
    tid_bool := lookup_type_id("Bool")
    tid_string := lookup_type_id("String")
    # pipe operator: special handling
    if op == "pipe":
        return check_pipe_expression(node, scope_id)

    left := c_check_expr(node.children[0], scope_id)
    right := c_check_expr(node.children[1], scope_id)

    if is_error_type(left):
        return TID_ERR
    if is_error_type(right):
        return TID_ERR

    # string concatenation
    if op == "add":
        if left == tid_string:
            if right == tid_string:
                return tid_string

    # arithmetic operators: add, sub, mul, div, mod
    if op == "add":
        if is_numeric_type(left) == false:
            report_error("E217", "operator + requires numeric type, got " + get_type_name(left))
            return TID_ERR
        if left != right:
            report_error("E217", "operator + type mismatch: " + get_type_name(left) + " vs " + get_type_name(right))
            return TID_ERR
        return left
    if op == "sub":
        if is_numeric_type(left) == false:
            report_error("E217", "operator - requires numeric type, got " + get_type_name(left))
            return TID_ERR
        if left != right:
            report_error("E217", "operator - type mismatch: " + get_type_name(left) + " vs " + get_type_name(right))
            return TID_ERR
        return left
    if op == "mul":
        if is_numeric_type(left) == false:
            report_error("E217", "operator * requires numeric type, got " + get_type_name(left))
            return TID_ERR
        if left != right:
            report_error("E217", "operator * type mismatch: " + get_type_name(left) + " vs " + get_type_name(right))
            return TID_ERR
        return left
    if op == "div":
        if is_numeric_type(left) == false:
            report_error("E217", "operator / requires numeric type, got " + get_type_name(left))
            return TID_ERR
        if left != right:
            report_error("E217", "operator / type mismatch: " + get_type_name(left) + " vs " + get_type_name(right))
            return TID_ERR
        return left
    if op == "mod":
        if is_integer_type(left) == false:
            report_error("E217", "operator % requires integer type, got " + get_type_name(left))
            return TID_ERR
        if left != right:
            report_error("E217", "operator % type mismatch: " + get_type_name(left) + " vs " + get_type_name(right))
            return TID_ERR
        return left

    # comparison operators: eq, neq
    if op == "eq":
        if left != right:
            report_error("E217", "operator == type mismatch: " + get_type_name(left) + " vs " + get_type_name(right))
            return TID_ERR
        return tid_bool
    if op == "neq":
        if left != right:
            report_error("E217", "operator != type mismatch: " + get_type_name(left) + " vs " + get_type_name(right))
            return TID_ERR
        return tid_bool

    # ordering: lt, gt, lte, gte
    if op == "lt":
        if is_numeric_type(left) == false:
            if left != tid_string:
                report_error("E217", "operator < requires numeric or string type, got " + get_type_name(left))
                return TID_ERR
        if left != right:
            report_error("E217", "operator < type mismatch: " + get_type_name(left) + " vs " + get_type_name(right))
            return TID_ERR
        return tid_bool
    if op == "gt":
        if is_numeric_type(left) == false:
            if left != tid_string:
                report_error("E217", "operator > requires numeric or string type, got " + get_type_name(left))
                return TID_ERR
        if left != right:
            report_error("E217", "operator > type mismatch: " + get_type_name(left) + " vs " + get_type_name(right))
            return TID_ERR
        return tid_bool
    if op == "lte":
        if is_numeric_type(left) == false:
            if left != tid_string:
                report_error("E217", "operator <= requires numeric or string type, got " + get_type_name(left))
                return TID_ERR
        if left != right:
            report_error("E217", "operator <= type mismatch: " + get_type_name(left) + " vs " + get_type_name(right))
            return TID_ERR
        return tid_bool
    if op == "gte":
        if is_numeric_type(left) == false:
            if left != tid_string:
                report_error("E217", "operator >= requires numeric or string type, got " + get_type_name(left))
                return TID_ERR
        if left != right:
            report_error("E217", "operator >= type mismatch: " + get_type_name(left) + " vs " + get_type_name(right))
            return TID_ERR
        return tid_bool

    # logical: and, or
    if op == "and":
        if left != tid_bool:
            report_error("E217", "operator 'and' requires Bool, got " + get_type_name(left))
            return TID_ERR
        if right != tid_bool:
            report_error("E217", "operator 'and' requires Bool, got " + get_type_name(right))
            return TID_ERR
        return tid_bool
    if op == "or":
        if left != tid_bool:
            report_error("E217", "operator 'or' requires Bool, got " + get_type_name(left))
            return TID_ERR
        if right != tid_bool:
            report_error("E217", "operator 'or' requires Bool, got " + get_type_name(right))
            return TID_ERR
        return tid_bool

    return TID_ERR

# ---------------------------------------------------------------
# pipe expression: value | fn_name
# ---------------------------------------------------------------

fn check_pipe_expression(node: Node, scope_id: Int) -> Int:
    left := c_check_expr(node.children[0], scope_id)
    if is_error_type(left):
        return TID_ERR
    rhs_node := get_node(node.children[1])
    if rhs_node.kind != "ident":
        report_error("E208", "pipe operator requires a function name on the right")
        return TID_ERR
    fn_name := rhs_node.value
    fn_tid := lookup_binding(scope_id, fn_name)
    if fn_tid < 0:
        report_error("E201", "undefined function: " + fn_name)
        return TID_ERR
    fn_info := get_type_info(fn_tid)
    if fn_info.kind != "function":
        report_error("E208", "'" + fn_name + "' is not a function")
        return TID_ERR
    if fn_info.param_types.len() != 1:
        report_error("E207", "pipe target '" + fn_name + "' must take exactly 1 parameter")
        return TID_ERR
    if left != fn_info.param_types[0]:
        report_error("E200", "pipe type mismatch: function expects " + get_type_name(fn_info.param_types[0]) + ", got " + get_type_name(left))
        return TID_ERR
    return fn_info.return_type

# ---------------------------------------------------------------
# unary expression
# ---------------------------------------------------------------

fn check_unary_expression(node: Node, scope_id: Int) -> Int:
    tid_bool := lookup_type_id("Bool")
    if node.children.len() < 1:
        return TID_ERR
    operand := c_check_expr(node.children[0], scope_id)
    if is_error_type(operand):
        return TID_ERR
    op := node.value
    if op == "negate":
        if is_numeric_type(operand) == false:
            report_error("E217", "unary - requires numeric type, got " + get_type_name(operand))
            return TID_ERR
        return operand
    if op == "not":
        if operand != tid_bool:
            report_error("E217", "unary 'not' requires Bool, got " + get_type_name(operand))
            return TID_ERR
        return tid_bool
    return TID_ERR

# ---------------------------------------------------------------
# call expression
# ---------------------------------------------------------------

fn check_json_decode_callee(index_node: Node, member_name: String) -> Bool:
    if index_node.kind != "index" or index_node.children.len() < 2:
        return false
    base_node := get_node(index_node.children[0])
    if base_node.kind != "field_access" or base_node.value != member_name:
        return false
    if base_node.children.len() < 1:
        return false
    recv_node := get_node(base_node.children[0])
    if recv_node.kind != "ident":
        return false
    if module_aliases.contains_key(recv_node.value):
        if module_aliases[recv_node.value] == "std.json":
            return true
    return recv_node.value == "json" or recv_node.value == "json_mod"

fn resolve_json_decode_type_arg(type_arg_idx: Int) -> Int:
    type_arg := get_node(type_arg_idx)
    if type_arg.kind == "ident":
        return resolve_named_type(type_arg.value)
    if type_arg.kind == "field_access" and type_arg.children.len() > 0:
        recv := get_node(type_arg.children[0])
        if recv.kind == "ident":
            return resolve_named_type(recv.value + "." + type_arg.value)
    report_error("E202", "json.decode type argument must be a concrete struct type")
    return TID_ERR

fn json_decode_field_supported(field_tid: Int) -> Bool:
    return field_tid == lookup_type_id("String") or field_tid == lookup_type_id("Int") or field_tid == lookup_type_id("Bool")

fn check_json_decode_call(index_node: Node, arg_indices: List[Int], scope_id: Int, text_input: Bool) -> Int:
    if index_node.children.len() < 2:
        report_error("E222", "json.decode requires an explicit struct type")
        return TID_ERR
    if arg_indices.len() != 1:
        report_error("E207", "json.decode expects 1 argument, got " + arg_indices.len().to_string())
        return TID_ERR

    target_tid := resolve_json_decode_type_arg(index_node.children[1])
    if is_error_type(target_tid):
        return TID_ERR
    target_info := get_type_info(target_tid)
    if target_info.kind != "struct":
        report_error("E219", "json.decode target must be a struct, got " + get_type_name(target_tid))
        return TID_ERR

    arg_node := get_node(arg_indices[0])
    mut arg_expr_idx := arg_indices[0]
    if arg_node.kind == "arg" and arg_node.children.len() > 0:
        arg_expr_idx = arg_node.children[0]
    arg_tid := c_check_expr(arg_expr_idx, scope_id)
    mut expected_tid := lookup_type_id("Bytes")
    if text_input:
        expected_tid = lookup_type_id("String")
    if is_error_type(arg_tid) == false and arg_tid != expected_tid:
        report_error("E219", "json.decode argument type mismatch: expected " + get_type_name(expected_tid) + ", got " + get_type_name(arg_tid))
        return TID_ERR

    for field_name, i in target_info.fields:
        if i < target_info.field_pub.len() and not target_info.field_pub[i]:
            report_error("E219", "json.decode target field must be public: " + field_name)
            return TID_ERR
        if i < target_info.field_types.len():
            field_tid := target_info.field_types[i]
            if not json_decode_field_supported(field_tid):
                report_error("E219", "json.decode does not support field '" + field_name + "' of type " + get_type_name(field_tid))
                return TID_ERR
    err_tid := lookup_type_id("JsonDecodeError")
    if err_tid < 0:
        report_error("E202", "unknown type: JsonDecodeError")
        return TID_ERR
    return add_type_info(ti_result(target_tid, err_tid))

fn check_function_call(node: Node, scope_id: Int) -> Int:
    if node.children.len() < 1:
        return TID_ERR
    callee_idx := node.children[0]
    callee_node := get_node(callee_idx)

    # get argument nodes (children after callee)
    mut arg_indices: List[Int] := []
    mut skip_callee := 1
    for child in node.children:
        if skip_callee > 0:
            skip_callee = skip_callee - 1
            continue
        arg_indices.push(child)

    # Channel[T]() constructor — callee is an index expr like Channel[Int]
    if callee_node.kind == "index":
        if check_json_decode_callee(callee_node, "decode"):
            return check_json_decode_call(callee_node, arg_indices, scope_id, false)
        if check_json_decode_callee(callee_node, "decode_text"):
            return check_json_decode_call(callee_node, arg_indices, scope_id, true)
        if callee_node.children.len() >= 2:
            obj_node := get_node(callee_node.children[0])
            if obj_node.kind == "ident":
                if obj_node.value == "Channel":
                    return check_channel_constructor(callee_node, arg_indices, scope_id)
        return check_function_call_expression(callee_idx, arg_indices, scope_id)

    if callee_node.kind == "ident":
        name := callee_node.value
        # special case: assert_eq / assert_ne
        if checking_test_decl and name == "assert_eq":
            return check_assertion_equality(arg_indices, scope_id)
        if checking_test_decl and name == "assert_ne":
            return check_assertion_equality(arg_indices, scope_id)
        if name == "map":
            return check_list_map_builtin(arg_indices, scope_id)
        if name == "filter":
            return check_list_filter_builtin(arg_indices, scope_id)
        if name == "reduce":
            return check_list_reduce_builtin(arg_indices, scope_id)
        # check if it's a struct constructor
        struct_tid := lookup_type_id(name)
        if struct_tid >= 0:
            info := get_type_info(struct_tid)
            if info.kind == "struct":
                # opaque types (0 fields) with args use a constructor function
                # e.g. Semaphore(10) — registered via register_sync_primitive_type
                if info.fields.len() == 0:
                    if arg_indices.len() > 0:
                        return check_function_call_expression(callee_idx, arg_indices, scope_id)
                return check_struct_constructor(name, struct_tid, info, arg_indices, scope_id)
            if info.kind == "enum":
                # enum variant constructor (qualified as EnumName.Variant)
                # — this case shouldn't happen for plain ident calls
                return check_function_call_expression(callee_idx, arg_indices, scope_id)
        existing_fn := lookup_binding(scope_id, name)
        if existing_fn >= 0:
            existing_info := get_type_info(existing_fn)
            if existing_info.kind == "function":
                return check_function_call_expression(callee_idx, arg_indices, scope_id)
        # check if it's a generic declaration
        if has_generic_declaration(name):
            gdecl := get_node(get_generic_declaration_index(name))
            if gdecl.kind == "struct_decl":
                return check_generic_struct_constructor(name, arg_indices, scope_id)
            return check_generic_function_call(name, arg_indices, scope_id)
        # normal function call
        return check_function_call_expression(callee_idx, arg_indices, scope_id)

    # non-ident callee (e.g. lambda call)
    return check_function_call_expression(callee_idx, arg_indices, scope_id)

# check a Channel[T]() constructor call — resolves the type argument
# and returns the channel type id
fn check_channel_constructor(index_node: Node, arg_indices: List[Int], scope_id: Int) -> Int:
    # index_node.children[1] is the type argument (e.g. "Int" in Channel[Int])
    type_arg_node := get_node(index_node.children[1])
    if type_arg_node.kind != "ident":
        report_error("E210", "Channel type argument must be a type name")
        return TID_ERR
    inner_tid := resolve_named_type(type_arg_node.value)
    if is_error_type(inner_tid):
        return TID_ERR
    if arg_indices.len() > 1:
        report_error("E207", "Channel constructor takes 0 or 1 arguments, got " + arg_indices.len().to_string())
        return TID_ERR
    if arg_indices.len() == 1:
        expect_one_typed_argument("Channel", arg_indices, lookup_type_id("Int"), scope_id)
    mut type_args: List[Int] := []
    type_args.push(inner_tid)
    return resolve_generic_type("Channel", type_args)

fn check_function_call_expression(callee_idx: Int, arg_indices: List[Int], scope_id: Int) -> Int:
    callee_type := c_check_expr(callee_idx, scope_id)
    if is_error_type(callee_type):
        return TID_ERR
    return check_callable_type_with_args(callee_type, arg_indices, scope_id)

fn check_callable_type_with_args(callee_type: Int, arg_indices: List[Int], scope_id: Int) -> Int:
    fn_info := get_type_info(callee_type)
    if fn_info.kind != "function":
        report_error("E208", "expression is not callable")
        return TID_ERR
    # check arg count
    if arg_indices.len() != fn_info.param_types.len():
        report_error("E207", "expected " + fn_info.param_types.len().to_string() + " arguments, got " + arg_indices.len().to_string())
        return TID_ERR
    # check arg types
    mut idx := 0
    for ai in arg_indices:
        arg_node := get_node(ai)
        mut arg_expr_idx := ai
        if arg_node.kind == "arg":
            if arg_node.children.len() > 0:
                arg_expr_idx = arg_node.children[0]
        arg_type := c_check_expr(arg_expr_idx, scope_id)
        if is_error_type(arg_type) == false:
            if idx < fn_info.param_types.len():
                expected := fn_info.param_types[idx]
                if arg_type != expected:
                    if types_structurally_equal(arg_type, expected) == false:
                        report_error("E219", "argument type mismatch: expected " + get_type_name(expected) + ", got " + get_type_name(arg_type))
        idx = idx + 1
    return fn_info.return_type

fn check_struct_constructor(name: String, struct_tid: Int, info: TypeInfo, arg_indices: List[Int], scope_id: Int) -> Int:
    # check field count
    if arg_indices.len() != info.fields.len():
        report_error("E207", name + " expects " + info.fields.len().to_string() + " fields, got " + arg_indices.len().to_string())
        return TID_ERR
    # check field types
    mut idx := 0
    for ai in arg_indices:
        arg_node := get_node(ai)
        mut arg_expr_idx := ai
        if arg_node.kind == "arg":
            if arg_node.children.len() > 0:
                arg_expr_idx = arg_node.children[0]
        arg_type := c_check_expr(arg_expr_idx, scope_id)
        if is_error_type(arg_type) == false:
            if idx < info.field_types.len():
                expected := info.field_types[idx]
                if arg_type != expected:
                    report_error("E219", "field '" + info.fields[idx] + "' type mismatch: expected " + get_type_name(expected) + ", got " + get_type_name(arg_type))
        idx = idx + 1
    return struct_tid

fn check_generic_struct_constructor(name: String, arg_indices: List[Int], scope_id: Int) -> Int:
    decl_idx := get_generic_declaration_index(name)
    decl_node := get_node(decl_idx)
    generic_params := collect_generic_parameter_names(decl_node)
    # evaluate all argument types
    mut arg_types: List[Int] := []
    for ai in arg_indices:
        arg_node := get_node(ai)
        mut arg_expr := ai
        if arg_node.kind == "arg":
            if arg_node.children.len() > 0:
                arg_expr = arg_node.children[0]
        arg_types.push(c_check_expr(arg_expr, scope_id))
    # collect field type nodes from the struct declaration
    mut field_type_nodes: List[Int] := []
    for child in decl_node.children:
        cn := get_node(child)
        if cn.kind == "field":
            if cn.children.len() > 0:
                field_type_nodes.push(cn.children[0])
            else:
                field_type_nodes.push(-1)
    # check field count
    if arg_types.len() != field_type_nodes.len():
        report_error("E207", name + " expects " + field_type_nodes.len().to_string() + " fields, got " + arg_types.len().to_string())
        return TID_ERR
    # infer type args from argument types
    mut subst_map: Map[String, Int] := {}
    mut fidx := 0
    for ftn in field_type_nodes:
        if ftn >= 0:
            fnode := get_node(ftn)
            if fnode.kind == "type":
                for gp in generic_params:
                    if strings_equal(gp, fnode.value):
                        if fidx < arg_types.len():
                            if subst_map.contains_key(gp) == false:
                                subst_map.insert(gp, arg_types[fidx])
        fidx = fidx + 1
    # check interface bounds
    if check_type_parameter_bounds(decl_idx, subst_map) == false:
        return TID_ERR
    # build type_args list in order of generic_params
    mut type_args: List[Int] := []
    for gp in generic_params:
        if subst_map.contains_key(gp):
            type_args.push(subst_map[gp])
        else:
            type_args.push(TID_ERR)
    # instantiate the struct
    return instantiate_generic_struct_type(decl_node, type_args)

fn check_assertion_equality(arg_indices: List[Int], scope_id: Int) -> Int:
    if arg_indices.len() != 2:
        report_error("E207", "assert_eq expects 2 arguments, got " + arg_indices.len().to_string())
        return TID_VOID
    first_idx := arg_indices[0]
    second_idx := arg_indices[1]
    first_node := get_node(first_idx)
    second_node := get_node(second_idx)
    mut first_expr := first_idx
    mut second_expr := second_idx
    if first_node.kind == "arg":
        if first_node.children.len() > 0:
            first_expr = first_node.children[0]
    if second_node.kind == "arg":
        if second_node.children.len() > 0:
            second_expr = second_node.children[0]
    t1 := c_check_expr(first_expr, scope_id)
    t2 := c_check_expr(second_expr, scope_id)
    if is_error_type(t1) == false:
        if is_error_type(t2) == false:
            if t1 != t2:
                report_error("E219", "assert_eq arguments must be the same type: " + get_type_name(t1) + " vs " + get_type_name(t2))
    return TID_VOID

fn call_arg_expr_index(arg_idx: Int) -> Int:
    arg_node := get_node(arg_idx)
    if arg_node.kind == "arg":
        if arg_node.children.len() > 0:
            return arg_node.children[0]
    return arg_idx

fn check_list_map_builtin(arg_indices: List[Int], scope_id: Int) -> Int:
    if arg_indices.len() != 2:
        report_error("E207", "map expects 2 arguments, got " + arg_indices.len().to_string())
        return TID_ERR
    list_tid := c_check_expr(call_arg_expr_index(arg_indices[0]), scope_id)
    fn_tid := c_check_expr(call_arg_expr_index(arg_indices[1]), scope_id)
    if is_error_type(list_tid):
        return TID_ERR
    if is_error_type(fn_tid):
        return TID_ERR
    list_info := get_type_info(list_tid)
    if list_info.kind != "list":
        report_error("E219", "map expects a List as the first argument, got " + get_type_name(list_tid))
        return TID_ERR
    fn_info := get_type_info(fn_tid)
    if fn_info.kind != "function":
        report_error("E208", "map expects a function as the second argument")
        return TID_ERR
    if fn_info.param_types.len() != 1:
        report_error("E207", "map callback expects 1 parameter, got " + fn_info.param_types.len().to_string())
        return TID_ERR
    if types_structurally_equal(fn_info.param_types[0], list_info.inner) == false:
        report_error("E219", "map callback parameter mismatch: expected " + get_type_name(list_info.inner) + ", got " + get_type_name(fn_info.param_types[0]))
        return TID_ERR
    return intern_list_type(fn_info.return_type)

fn check_list_filter_builtin(arg_indices: List[Int], scope_id: Int) -> Int:
    if arg_indices.len() != 2:
        report_error("E207", "filter expects 2 arguments, got " + arg_indices.len().to_string())
        return TID_ERR
    list_tid := c_check_expr(call_arg_expr_index(arg_indices[0]), scope_id)
    fn_tid := c_check_expr(call_arg_expr_index(arg_indices[1]), scope_id)
    if is_error_type(list_tid):
        return TID_ERR
    if is_error_type(fn_tid):
        return TID_ERR
    list_info := get_type_info(list_tid)
    if list_info.kind != "list":
        report_error("E219", "filter expects a List as the first argument, got " + get_type_name(list_tid))
        return TID_ERR
    fn_info := get_type_info(fn_tid)
    if fn_info.kind != "function":
        report_error("E208", "filter expects a function as the second argument")
        return TID_ERR
    if fn_info.param_types.len() != 1:
        report_error("E207", "filter callback expects 1 parameter, got " + fn_info.param_types.len().to_string())
        return TID_ERR
    if types_structurally_equal(fn_info.param_types[0], list_info.inner) == false:
        report_error("E219", "filter callback parameter mismatch: expected " + get_type_name(list_info.inner) + ", got " + get_type_name(fn_info.param_types[0]))
        return TID_ERR
    if fn_info.return_type != lookup_type_id("Bool"):
        if is_integer_type(fn_info.return_type) == false:
            report_error("E219", "filter callback must return Bool or Int-like truthy value, got " + get_type_name(fn_info.return_type))
            return TID_ERR
    return list_tid

fn check_list_reduce_builtin(arg_indices: List[Int], scope_id: Int) -> Int:
    if arg_indices.len() != 3:
        report_error("E207", "reduce expects 3 arguments, got " + arg_indices.len().to_string())
        return TID_ERR
    list_tid := c_check_expr(call_arg_expr_index(arg_indices[0]), scope_id)
    init_tid := c_check_expr(call_arg_expr_index(arg_indices[1]), scope_id)
    fn_tid := c_check_expr(call_arg_expr_index(arg_indices[2]), scope_id)
    if is_error_type(list_tid):
        return TID_ERR
    if is_error_type(init_tid):
        return TID_ERR
    if is_error_type(fn_tid):
        return TID_ERR
    list_info := get_type_info(list_tid)
    if list_info.kind != "list":
        report_error("E219", "reduce expects a List as the first argument, got " + get_type_name(list_tid))
        return TID_ERR
    fn_info := get_type_info(fn_tid)
    if fn_info.kind != "function":
        report_error("E208", "reduce expects a function as the third argument")
        return TID_ERR
    if fn_info.param_types.len() != 2:
        report_error("E207", "reduce callback expects 2 parameters, got " + fn_info.param_types.len().to_string())
        return TID_ERR
    if types_structurally_equal(fn_info.param_types[0], init_tid) == false:
        report_error("E219", "reduce accumulator parameter mismatch: expected " + get_type_name(init_tid) + ", got " + get_type_name(fn_info.param_types[0]))
        return TID_ERR
    if types_structurally_equal(fn_info.param_types[1], list_info.inner) == false:
        report_error("E219", "reduce element parameter mismatch: expected " + get_type_name(list_info.inner) + ", got " + get_type_name(fn_info.param_types[1]))
        return TID_ERR
    if types_structurally_equal(fn_info.return_type, init_tid) == false:
        report_error("E219", "reduce callback return mismatch: expected " + get_type_name(init_tid) + ", got " + get_type_name(fn_info.return_type))
        return TID_ERR
    return init_tid

# ---------------------------------------------------------------
# interface bounds checking
# ---------------------------------------------------------------

fn check_type_parameter_bounds(decl_node_idx: Int, subst_map: Map[String, Int]) -> Bool:
    decl_node := get_node(decl_node_idx)
    mut ok := true
    for child in decl_node.children:
        cn := get_node(child)
        if cn.kind == "generic_param":
            param_name := cn.value
            if subst_map.contains_key(param_name):
                inferred_tid := subst_map[param_name]
                type_name := get_type_name(inferred_tid)
                # walk bound children (each is a type node for an interface)
                for bound_idx in cn.children:
                    bound_node := get_node(bound_idx)
                    iface_name := get_type_node_name_with_substitution(bound_node, subst_map)
                    if has_interface_declaration(iface_name) == false:
                        report_error("E226", "unknown interface '" + iface_name + "' in bound for '" + param_name + "'")
                        ok = false
                    else:
                        if check_type_implements_interface(type_name, iface_name) == false:
                            report_error("E226", "type '" + type_name + "' does not implement interface '" + iface_name + "'")
                            ok = false
    return ok

# ---------------------------------------------------------------
# generic function call
# ---------------------------------------------------------------

fn bind_inferred_generic_type(name: String, actual_tid: Int) -> Bool:
    if generic_inference_subst.contains_key(name):
        existing := generic_inference_subst[name]
        if types_structurally_equal(existing, actual_tid) == false:
            report_error("E219", "type parameter inference mismatch for " + name + ": " + get_type_name(existing) + " vs " + get_type_name(actual_tid))
            return false
        return true
    generic_inference_subst.insert(name, actual_tid)
    return true

fn trim_type_text(text: String) -> String:
    mut start := 0
    mut end := text.len()
    while start < end and text[start] == " ":
        start = start + 1
    while end > start and text[end - 1] == " ":
        end = end - 1
    return text.substring(start, end)

fn split_top_level_type_args(text: String) -> List[String]:
    mut parts: List[String] := []
    mut start := 0
    mut depth := 0
    mut i := 0
    while i < text.len():
        ch := text[i]
        if ch == "[":
            depth = depth + 1
        elif ch == "]":
            depth = depth - 1
        elif ch == "," and depth == 0:
            parts.push(trim_type_text(text.substring(start, i)))
            start = i + 1
        i = i + 1
    parts.push(trim_type_text(text.substring(start, text.len())))
    return parts

fn infer_generic_subst_from_type_text(type_name: String, actual_tid: Int, generic_params: List[String]) -> Bool:
    if actual_tid < 0:
        return true
    trimmed := trim_type_text(type_name)
    for gp in generic_params:
        normalized_gp := trim_type_text(gp)
        if strings_equal(normalized_gp, trimmed):
            return bind_inferred_generic_type(normalized_gp, actual_tid)

    actual_info := get_type_info(actual_tid)

    if trimmed.starts_with("List[") and trimmed.ends_with("]"):
        if actual_info.kind != "list":
            return true
        inner_text := trimmed.substring(5, trimmed.len() - 1)
        return infer_generic_subst_from_type_text(inner_text, actual_info.inner, generic_params)

    if trimmed.starts_with("Set[") and trimmed.ends_with("]"):
        if actual_info.kind != "set":
            return true
        inner_text := trimmed.substring(4, trimmed.len() - 1)
        return infer_generic_subst_from_type_text(inner_text, actual_info.inner, generic_params)

    if trimmed.starts_with("Task[") and trimmed.ends_with("]"):
        if actual_info.kind != "task":
            return true
        inner_text := trimmed.substring(5, trimmed.len() - 1)
        return infer_generic_subst_from_type_text(inner_text, actual_info.inner, generic_params)

    if trimmed.starts_with("Channel[") and trimmed.ends_with("]"):
        if actual_info.kind != "channel":
            return true
        inner_text := trimmed.substring(8, trimmed.len() - 1)
        return infer_generic_subst_from_type_text(inner_text, actual_info.inner, generic_params)

    if trimmed.starts_with("Map[") and trimmed.ends_with("]"):
        if actual_info.kind != "map":
            return true
        args := split_top_level_type_args(trimmed.substring(4, trimmed.len() - 1))
        if args.len() > 0:
            if infer_generic_subst_from_type_text(args[0], actual_info.key_type, generic_params) == false:
                return false
        if args.len() > 1:
            return infer_generic_subst_from_type_text(args[1], actual_info.value_type, generic_params)
        return true

    return true

fn infer_generic_subst_from_type_node(type_idx: Int, actual_tid: Int, generic_params: List[String]) -> Bool:
    if type_idx < 0 or actual_tid < 0:
        return true
    node := get_node(type_idx)
    if node.kind == "type":
        return infer_generic_subst_from_type_text(node.value, actual_tid, generic_params)

    actual_info := get_type_info(actual_tid)

    if node.kind == "generic_type":
        for gp in generic_params:
            normalized_gp := trim_type_text(gp)
            if strings_equal(normalized_gp, trim_type_text(node.value)):
                return bind_inferred_generic_type(normalized_gp, actual_tid)
        if node.value == "List":
            if actual_info.kind == "list" and node.children.len() > 0:
                return infer_generic_subst_from_type_node(node.children[0], actual_info.inner, generic_params)
            return true
        if node.value == "Set":
            if actual_info.kind == "set" and node.children.len() > 0:
                return infer_generic_subst_from_type_node(node.children[0], actual_info.inner, generic_params)
            return true
        if node.value == "Task":
            if actual_info.kind == "task" and node.children.len() > 0:
                return infer_generic_subst_from_type_node(node.children[0], actual_info.inner, generic_params)
            return true
        if node.value == "Channel":
            if actual_info.kind == "channel" and node.children.len() > 0:
                return infer_generic_subst_from_type_node(node.children[0], actual_info.inner, generic_params)
            return true
        if node.value == "Map":
            if actual_info.kind == "map" and node.children.len() > 1:
                if infer_generic_subst_from_type_node(node.children[0], actual_info.key_type, generic_params) == false:
                    return false
                return infer_generic_subst_from_type_node(node.children[1], actual_info.value_type, generic_params)
            return true
        return true

    if node.kind == "optional_type":
        if actual_info.kind == "optional" and node.children.len() > 0:
            return infer_generic_subst_from_type_node(node.children[0], actual_info.inner, generic_params)
        return true

    if node.kind == "result_type":
        if actual_info.kind == "result" and node.children.len() > 0:
            if infer_generic_subst_from_type_node(node.children[0], actual_info.inner, generic_params) == false:
                return false
            if node.children.len() > 1 and actual_info.value_type >= 0:
                return infer_generic_subst_from_type_node(node.children[1], actual_info.value_type, generic_params)
        return true

    if node.kind == "tuple_type":
        if actual_info.kind == "tuple":
            for child, i in node.children:
                if i < actual_info.elements.len():
                    if infer_generic_subst_from_type_node(child, actual_info.elements[i], generic_params) == false:
                        return false
        return true

    if node.kind == "fn_type":
        if actual_info.kind == "function":
            for child, i in node.children:
                cn := get_node(child)
                if cn.kind == "param":
                    if i < actual_info.param_types.len():
                        if infer_generic_subst_from_type_node(cn.children[0], actual_info.param_types[i], generic_params) == false:
                            return false
                    continue
                if cn.kind == "returns":
                    if cn.children.len() > 0:
                        return infer_generic_subst_from_type_node(cn.children[0], actual_info.return_type, generic_params)
        return true

    return true

fn check_generic_function_call(name: String, arg_indices: List[Int], scope_id: Int) -> Int:
    decl_idx := get_generic_declaration_index(name)
    decl_node := get_node(decl_idx)
    generic_params := collect_generic_parameter_names(decl_node)
    # evaluate all argument types
    mut arg_types: List[Int] := []
    for ai in arg_indices:
        arg_node := get_node(ai)
        mut arg_expr := ai
        if arg_node.kind == "arg":
            if arg_node.children.len() > 0:
                arg_expr = arg_node.children[0]
        arg_types.push(c_check_expr(arg_expr, scope_id))
    # collect param type nodes from the declaration
    mut param_type_nodes: List[Int] := []
    for child in decl_node.children:
        cn := get_node(child)
        if cn.kind == "param":
            if cn.children.len() > 0:
                param_type_nodes.push(cn.children[0])
            else:
                param_type_nodes.push(-1)
    # check arg count
    if arg_types.len() != param_type_nodes.len():
        report_error("E207", "expected " + param_type_nodes.len().to_string() + " arguments, got " + arg_types.len().to_string())
        return TID_ERR
    # infer type args from argument types using a map
    generic_inference_subst = {}
    mut pidx := 0
    for ptn in param_type_nodes:
        if ptn >= 0 and pidx < arg_types.len():
            if infer_generic_subst_from_type_node(ptn, arg_types[pidx], generic_params) == false:
                return TID_ERR
        pidx = pidx + 1
    # verify all generic params were inferred, build subst_args list
    mut subst_args: List[Int] := []
    mut all_inferred := true
    for gp in generic_params:
        normalized_gp := trim_type_text(gp)
        if generic_inference_subst.contains_key(normalized_gp):
            subst_args.push(generic_inference_subst[normalized_gp])
        else:
            all_inferred = false
            mut debug_args: List[String] := []
            for arg_tid in arg_types:
                debug_args.push(get_type_name(arg_tid))
            mut debug_params: List[String] := []
            for ptn in param_type_nodes:
                if ptn >= 0:
                    pnode := get_node(ptn)
                    debug_params.push(pnode.kind + ":" + pnode.value)
            report_error("E222", "cannot infer type parameter " + gp)
            # Return immediately to prevent cascading errors
            return TID_ERR
    # check interface bounds
    if check_type_parameter_bounds(decl_idx, generic_inference_subst) == false:
        return TID_ERR
    # resolve return type with substitution
    mut ret_type := TID_VOID
    for child in decl_node.children:
        cn := get_node(child)
        if cn.kind == "returns":
            ret_type = resolve_type_with_substitution_map(cn.children[0], generic_params, subst_args)
    # validate arg types against concrete param types
    mut vidx := 0
    for ptn in param_type_nodes:
        if ptn >= 0:
            if vidx < arg_types.len():
                concrete := resolve_type_with_substitution_map(ptn, generic_params, subst_args)
                if is_error_type(concrete) == false:
                    if is_error_type(arg_types[vidx]) == false:
                        if arg_types[vidx] != concrete:
                            if types_structurally_equal(arg_types[vidx], concrete) == false:
                                report_error("E219", "argument type mismatch: expected " + get_type_name(concrete) + ", got " + get_type_name(arg_types[vidx]))
        vidx = vidx + 1
    return ret_type

# ---------------------------------------------------------------
# method call
# ---------------------------------------------------------------

fn check_method_call(node: Node, scope_id: Int) -> Int:
    # node.value = method name
    # children[0] = receiver
    # children[1..] = arguments
    if node.children.len() < 1:
        return TID_ERR
    mut method_name := node.value
    if method_name.starts_with("."):
        method_name = method_name.substring(1, method_name.len())
    recv_node := get_node(node.children[0])

    mut arg_indices: List[Int] := []
    mut skip_recv := 1
    for child in node.children:
        if skip_recv > 0:
            skip_recv = skip_recv - 1
            continue
        arg_indices.push(child)

    if recv_node.kind == "ident":
        recv_name := recv_node.value
        if module_aliases.contains_key(recv_name):
            module_path := module_aliases[recv_name]
            qualified_name := module_import_target_name(module_path, method_name)
            module_name := module_generic_target_name(module_path, method_name)
            mut callee_type := lookup_binding(scope_id, module_name)
            if callee_type < 0:
                callee_type = lookup_binding(scope_id, qualified_name)
            if callee_type < 0:
                callee_type = lookup_binding(scope_id, method_name)
            if callee_type < 0:
                generic_name := module_generic_target_name(module_path, method_name)
                if has_generic_declaration(generic_name):
                    return check_generic_function_call(generic_name, arg_indices, scope_id)
                if has_generic_declaration(method_name):
                    return check_generic_function_call(method_name, arg_indices, scope_id)
            if callee_type < 0:
                report_error("E201", "undefined function: " + recv_name + "." + method_name)
                return TID_ERR
            return check_callable_type_with_args(callee_type, arg_indices, scope_id)

    receiver_type := c_check_expr(node.children[0], scope_id)
    if is_error_type(receiver_type):
        return TID_ERR
    mut recv_info := get_type_info(receiver_type)
    mut dispatch_type := receiver_type
    if recv_info.kind == "optional":
        dispatch_type = recv_info.inner
        recv_info = get_type_info(dispatch_type)
    elif recv_info.kind == "result":
        result_method := check_result_method_call(method_name, recv_info, arg_indices, scope_id)
        if is_error_type(result_method) == false:
            return result_method
        dispatch_type = recv_info.inner
        recv_info = get_type_info(dispatch_type)

    tid_string := lookup_type_id("String")
    tid_bytes := lookup_type_id("Bytes")
    tid_int := lookup_type_id("Int")
    tid_float := lookup_type_id("Float")
    tid_bool := lookup_type_id("Bool")

    # string methods
    if dispatch_type == tid_string:
        return check_string_method_call(method_name, arg_indices, scope_id)
    if dispatch_type == tid_bytes:
        return check_bytes_method_call(method_name, arg_indices, scope_id)
    # primitive methods
    if is_integer_type(dispatch_type):
        return check_int_method_call(method_name, arg_indices, scope_id)
    if dispatch_type == tid_float:
        return check_float_method_call(method_name, arg_indices, scope_id)
    if dispatch_type == tid_bool:
        return check_bool_method_call(method_name, arg_indices, scope_id)

    # collection methods
    if recv_info.kind == "list":
        result := check_list_method_call(method_name, recv_info, arg_indices, scope_id)
        if is_error_type(result) == false:
            return result
    if recv_info.kind == "map":
        result := check_map_method_call(method_name, recv_info, arg_indices, scope_id)
        if is_error_type(result) == false:
            return result
    if recv_info.kind == "set":
        result := check_set_method_call(method_name, recv_info, arg_indices, scope_id)
        if is_error_type(result) == false:
            return result

    # channel methods
    if recv_info.kind == "channel":
        ch_result := check_channel_method_call(method_name, recv_info, arg_indices, scope_id)
        if is_error_type(ch_result) == false:
            return ch_result

    if recv_info.kind == "task":
        task_result := check_task_method_call(method_name, recv_info, arg_indices, scope_id)
        if is_error_type(task_result) == false:
            return task_result

    # sync primitive methods
    if recv_info.kind == "struct":
        sync_result := check_sync_primitive_method_call(recv_info.name, method_name, arg_indices, scope_id)
        if is_error_type(sync_result) == false:
            return sync_result

    # user-defined methods
    type_name := get_type_name(dispatch_type)
    key := type_name + "." + method_name
    if has_method_declaration(key):
        method_node := get_node(get_method_declaration_index(key))
        param_types := collect_function_param_types(method_node)
        ret_type := collect_function_return_type(method_node)
        # check arg count
        if arg_indices.len() != param_types.len():
            report_error("E207", method_name + " expects " + param_types.len().to_string() + " arguments, got " + arg_indices.len().to_string())
            return TID_ERR
        # check arg types
        mut aidx := 0
        for ai in arg_indices:
            arg_node := get_node(ai)
            mut arg_expr := ai
            if arg_node.kind == "arg":
                if arg_node.children.len() > 0:
                    arg_expr = arg_node.children[0]
            atype := c_check_expr(arg_expr, scope_id)
            if is_error_type(atype) == false:
                if aidx < param_types.len():
                    if atype != param_types[aidx]:
                        if types_structurally_equal(atype, param_types[aidx]) == false:
                            report_error("E219", "argument type mismatch: expected " + get_type_name(param_types[aidx]) + ", got " + get_type_name(atype))
            aidx = aidx + 1
        return ret_type
    report_error("E209", get_type_name(receiver_type) + " has no method '" + method_name + "'")
    return TID_ERR

# ---------------------------------------------------------------
# string methods
# ---------------------------------------------------------------

fn check_string_method_call(method: String, args: List[Int], scope_id: Int) -> Int:
    tid_int := lookup_type_id("Int")
    tid_string := lookup_type_id("String")
    tid_bool := lookup_type_id("Bool")
    if method == "len":
        expect_no_arguments(method, args)
        return tid_int
    if method == "trim":
        expect_no_arguments(method, args)
        return tid_string
    if method == "to_upper":
        expect_no_arguments(method, args)
        return tid_string
    if method == "to_lower":
        expect_no_arguments(method, args)
        return tid_string
    if method == "is_empty":
        expect_no_arguments(method, args)
        return tid_bool
    if method == "contains":
        expect_one_string_argument(method, args, scope_id)
        return tid_bool
    if method == "starts_with":
        expect_one_string_argument(method, args, scope_id)
        return tid_bool
    if method == "ends_with":
        expect_one_string_argument(method, args, scope_id)
        return tid_bool
    if method == "index_of":
        expect_one_string_argument(method, args, scope_id)
        return tid_int
    if method == "last_index_of":
        expect_one_string_argument(method, args, scope_id)
        return tid_int
    if method == "split":
        expect_one_string_argument(method, args, scope_id)
        return intern_list_type(tid_string)
    if method == "substring":
        expect_two_int_arguments(method, args, scope_id)
        return tid_string
    if method == "replace":
        expect_two_string_arguments(method, args, scope_id)
        return tid_string
    if method == "repeat":
        expect_one_typed_argument(method, args, tid_int, scope_id)
        return tid_string
    if method == "pad_left":
        expect_int_string_arguments(method, args, scope_id)
        return tid_string
    if method == "pad_right":
        expect_int_string_arguments(method, args, scope_id)
        return tid_string
    if method == "chars":
        expect_no_arguments(method, args)
        return intern_list_type(tid_string)
    report_error("E209", "String has no method '" + method + "'")
    return TID_ERR

# ---------------------------------------------------------------
# bytes methods
# ---------------------------------------------------------------

fn check_bytes_method_call(method: String, args: List[Int], scope_id: Int) -> Int:
    tid_int := lookup_type_id("Int")
    tid_string := lookup_type_id("String")
    tid_bytes := lookup_type_id("Bytes")
    tid_bool := lookup_type_id("Bool")
    if method == "len":
        expect_no_arguments(method, args)
        return tid_int
    if method == "is_empty":
        expect_no_arguments(method, args)
        return tid_bool
    if method == "slice":
        expect_two_int_arguments(method, args, scope_id)
        return tid_bytes
    if method == "concat":
        expect_one_typed_argument(method, args, tid_bytes, scope_id)
        return tid_bytes
    if method == "to_string_utf8":
        expect_no_arguments(method, args)
        return add_type_info(ti_result(tid_string, TID_STRING))
    report_error("E209", "Bytes has no method '" + method + "'")
    return TID_ERR

fn check_result_method_call(method: String, info: TypeInfo, args: List[Int], scope_id: Int) -> Int:
    tid_string := lookup_type_id("String")
    if method == "to_string":
        expect_no_arguments(method, args)
        if type_supports_stringify(info.inner) == false or type_supports_stringify(info.value_type) == false:
            report_error("E219", "result.to_string requires stringifiable ok and err values")
            return TID_ERR
        return tid_string
    if method == "unwrap_or":
        if args.len() != 1:
            report_error("E207", "unwrap_or expects 1 argument, got " + args.len().to_string())
            return TID_ERR
        check_argument_type(args[0], info.inner, scope_id)
        return info.inner
    if method == "or_else":
        if args.len() != 1:
            report_error("E207", "or_else expects 1 argument, got " + args.len().to_string())
            return TID_ERR
        handler_type := c_check_expr(call_arg_expr_index(args[0]), scope_id)
        if is_error_type(handler_type):
            return TID_ERR
        handler_info := get_type_info(handler_type)
        if handler_info.kind != "function":
            report_error("E219", "or_else expects a function, got " + get_type_name(handler_type))
            return TID_ERR
        if handler_info.param_types.len() != 1:
            report_error("E219", "or_else handler must take exactly 1 argument")
            return TID_ERR
        if types_compatible(handler_info.param_types[0], info.value_type) == false:
            report_error("E219", "or_else handler must accept " + get_type_name(info.value_type) + ", got " + get_type_name(handler_info.param_types[0]))
            return TID_ERR
        ret_info := get_type_info(handler_info.return_type)
        if ret_info.kind != "result":
            report_error("E219", "or_else handler must return a result type")
            return TID_ERR
        if types_compatible(ret_info.inner, info.inner) == false:
            report_error("E219", "or_else handler must return " + get_type_name(info.inner) + " on success, got " + get_type_name(ret_info.inner))
            return TID_ERR
        return handler_info.return_type
    return TID_ERR

# ---------------------------------------------------------------
# primitive methods
# ---------------------------------------------------------------

fn check_int_method_call(method: String, args: List[Int], scope_id: Int) -> Int:
    tid_string := lookup_type_id("String")
    tid_float := lookup_type_id("Float")
    if method == "to_string":
        expect_no_arguments(method, args)
        return tid_string
    if method == "to_float":
        expect_no_arguments(method, args)
        return tid_float
    report_error("E209", "Int has no method '" + method + "'")
    return TID_ERR

fn check_float_method_call(method: String, args: List[Int], scope_id: Int) -> Int:
    tid_string := lookup_type_id("String")
    tid_int := lookup_type_id("Int")
    if method == "to_string":
        expect_no_arguments(method, args)
        return tid_string
    if method == "to_int":
        expect_no_arguments(method, args)
        return tid_int
    report_error("E209", "Float has no method '" + method + "'")
    return TID_ERR

fn check_bool_method_call(method: String, args: List[Int], scope_id: Int) -> Int:
    tid_string := lookup_type_id("String")
    if method == "to_string":
        expect_no_arguments(method, args)
        return tid_string
    report_error("E209", "Bool has no method '" + method + "'")
    return TID_ERR

# ---------------------------------------------------------------
# list methods
# ---------------------------------------------------------------

fn check_list_method_call(method: String, info: TypeInfo, args: List[Int], scope_id: Int) -> Int:
    elem := info.inner
    tid_int := lookup_type_id("Int")
    tid_string := lookup_type_id("String")
    tid_bool := lookup_type_id("Bool")
    tid_void := lookup_type_id("Void")
    if method == "push":
        expect_one_typed_argument(method, args, elem, scope_id)
        return tid_void
    if method == "len":
        expect_no_arguments(method, args)
        return tid_int
    if method == "is_empty":
        expect_no_arguments(method, args)
        return tid_bool
    if method == "clear":
        expect_no_arguments(method, args)
        return tid_void
    if method == "reverse":
        expect_no_arguments(method, args)
        return tid_void
    if method == "remove":
        expect_one_typed_argument(method, args, tid_int, scope_id)
        return tid_void
    if method == "contains":
        expect_one_typed_argument(method, args, elem, scope_id)
        return tid_bool
    if method == "join":
        expect_one_typed_argument(method, args, tid_string, scope_id)
        return tid_string
    if method == "index_of":
        expect_one_typed_argument(method, args, elem, scope_id)
        return tid_int
    if method == "slice":
        expect_two_int_arguments(method, args, scope_id)
        return intern_list_type(elem)
    if method == "sort":
        expect_no_arguments(method, args)
        return intern_list_type(elem)
    # not a built-in list method
    return - 1

# ---------------------------------------------------------------
# map methods
# ---------------------------------------------------------------

fn check_map_method_call(method: String, info: TypeInfo, args: List[Int], scope_id: Int) -> Int:
    key_t := info.key_type
    val_t := info.value_type
    tid_void := lookup_type_id("Void")
    tid_int := lookup_type_id("Int")
    tid_bool := lookup_type_id("Bool")
    if method == "insert":
        if args.len() != 2:
            report_error("E207", "insert expects 2 arguments, got " + args.len().to_string())
            return tid_void
        # check key type
        check_argument_type(args[0], key_t, scope_id)
        check_argument_type(args[1], val_t, scope_id)
        return tid_void
    if method == "len":
        expect_no_arguments(method, args)
        return tid_int
    if method == "is_empty":
        expect_no_arguments(method, args)
        return tid_bool
    if method == "clear":
        expect_no_arguments(method, args)
        return tid_void
    if method == "contains_key":
        expect_one_typed_argument(method, args, key_t, scope_id)
        return tid_bool
    if method == "get_default":
        if args.len() != 2:
            report_error("E207", "get_default expects 2 arguments, got " + args.len().to_string())
            return val_t
        check_argument_type(args[0], key_t, scope_id)
        check_argument_type(args[1], val_t, scope_id)
        return val_t
    if method == "remove":
        expect_one_typed_argument(method, args, key_t, scope_id)
        return tid_void
    if method == "keys":
        expect_no_arguments(method, args)
        return intern_list_type(key_t)
    if method == "values":
        expect_no_arguments(method, args)
        return intern_list_type(val_t)
    return - 1

# ---------------------------------------------------------------
# set methods
# ---------------------------------------------------------------

fn check_set_method_call(method: String, info: TypeInfo, args: List[Int], scope_id: Int) -> Int:
    elem := info.inner
    if method == "add":
        expect_one_typed_argument(method, args, elem, scope_id)
        return TID_VOID
    if method == "len":
        expect_no_arguments(method, args)
        return TID_INT
    if method == "is_empty":
        expect_no_arguments(method, args)
        return TID_BOOL
    if method == "clear":
        expect_no_arguments(method, args)
        return TID_VOID
    if method == "contains":
        expect_one_typed_argument(method, args, elem, scope_id)
        return TID_BOOL
    if method == "remove":
        expect_one_typed_argument(method, args, elem, scope_id)
        return TID_VOID
    return - 1

# ---------------------------------------------------------------
# method arg validators
# ---------------------------------------------------------------

fn check_sync_primitive_method_call(type_name: String, method: String, args: List[Int], scope_id: Int) -> Int:
    tid_void := lookup_type_id("Void")
    tid_int := lookup_type_id("Int")
    tid_err := lookup_type_id("<error>")
    if type_name == "Mutex":
        if method == "lock":
            expect_no_arguments("Mutex.lock", args)
            return tid_void
        if method == "unlock":
            expect_no_arguments("Mutex.unlock", args)
            return tid_void
    if type_name == "WaitGroup":
        if method == "add":
            expect_one_typed_argument("WaitGroup.add", args, tid_int, scope_id)
            return tid_void
        if method == "done":
            expect_no_arguments("WaitGroup.done", args)
            return tid_void
        if method == "wait":
            expect_no_arguments("WaitGroup.wait", args)
            return tid_void
    if type_name == "Semaphore":
        if method == "acquire":
            expect_no_arguments("Semaphore.acquire", args)
            return tid_void
        if method == "release":
            expect_no_arguments("Semaphore.release", args)
            return tid_void
    return tid_err

fn check_channel_method_call(method: String, info: TypeInfo, args: List[Int], scope_id: Int) -> Int:
    tid_int := lookup_type_id("Int")
    tid_bool := lookup_type_id("Bool")
    tid_err := lookup_type_id("<error>")
    inner := info.inner
    if method == "send":
        expect_one_typed_argument("Channel.send", args, inner, scope_id)
        return tid_bool
    if method == "recv":
        # recv() returns T? (optional of inner type)
        expect_no_arguments("Channel.recv", args)
        return add_type_info(ti_optional(inner))
    if method == "try_send":
        expect_one_typed_argument("Channel.try_send", args, inner, scope_id)
        return tid_bool
    if method == "try_recv":
        expect_no_arguments("Channel.try_recv", args)
        return add_type_info(ti_optional(inner))
    if method == "close":
        expect_no_arguments("Channel.close", args)
        return tid_bool
    if method == "is_closed":
        expect_no_arguments("Channel.is_closed", args)
        return tid_bool
    if method == "len":
        expect_no_arguments("Channel.len", args)
        return tid_int
    if method == "cap":
        expect_no_arguments("Channel.cap", args)
        return tid_int
    return tid_err

fn check_task_method_call(method: String, info: TypeInfo, args: List[Int], scope_id: Int) -> Int:
    tid_bool := lookup_type_id("Bool")
    tid_void := lookup_type_id("Void")
    tid_err := lookup_type_id("<error>")
    if method == "is_done":
        expect_no_arguments("Task.is_done", args)
        return tid_bool
    if method == "detach":
        expect_no_arguments("Task.detach", args)
        return tid_void
    return tid_err

fn expect_no_arguments(method: String, args: List[Int]):
    if args.len() != 0:
        report_error("E207", method + " takes no arguments, got " + args.len().to_string())

fn expect_one_string_argument(method: String, args: List[Int], scope_id: Int):
    tid_string := lookup_type_id("String")
    if args.len() != 1:
        report_error("E207", method + " expects 1 argument, got " + args.len().to_string())
        return
    check_argument_type(args[0], tid_string, scope_id)

fn expect_two_string_arguments(method: String, args: List[Int], scope_id: Int):
    tid_string := lookup_type_id("String")
    if args.len() != 2:
        report_error("E207", method + " expects 2 arguments, got " + args.len().to_string())
        return
    check_argument_type(args[0], tid_string, scope_id)
    check_argument_type(args[1], tid_string, scope_id)

fn expect_two_int_arguments(method: String, args: List[Int], scope_id: Int):
    tid_int := lookup_type_id("Int")
    if args.len() != 2:
        report_error("E207", method + " expects 2 arguments, got " + args.len().to_string())
        return
    check_argument_type(args[0], tid_int, scope_id)
    check_argument_type(args[1], tid_int, scope_id)

fn expect_int_string_arguments(method: String, args: List[Int], scope_id: Int):
    tid_int := lookup_type_id("Int")
    tid_string := lookup_type_id("String")
    if args.len() != 2:
        report_error("E207", method + " expects 2 arguments, got " + args.len().to_string())
        return
    check_argument_type(args[0], tid_int, scope_id)
    check_argument_type(args[1], tid_string, scope_id)

fn expect_one_typed_argument(method: String, args: List[Int], expected: Int, scope_id: Int):
    if args.len() != 1:
        report_error("E207", method + " expects 1 argument, got " + args.len().to_string())
        return
    check_argument_type(args[0], expected, scope_id)

fn check_argument_type(arg_idx: Int, expected: Int, scope_id: Int):
    arg_node := get_node(arg_idx)
    mut expr_idx := arg_idx
    if arg_node.kind == "arg":
        if arg_node.children.len() > 0:
            expr_idx = arg_node.children[0]
    actual := c_check_expr(expr_idx, scope_id)
    if is_error_type(actual) == false:
        if actual != expected:
            if types_structurally_equal(actual, expected) == false:
                report_error("E219", "argument type mismatch: expected " + get_type_name(expected) + ", got " + get_type_name(actual))

# ---------------------------------------------------------------
# field access
# ---------------------------------------------------------------

fn check_field_access_expression(node: Node, scope_id: Int) -> Int:
    if node.children.len() < 1:
        return TID_ERR
    field_name := node.value

    # check if this is module alias access (e.g., math.abs)
    obj_node_idx := node.children[0]
    obj_node := get_node(obj_node_idx)
    if obj_node.kind == "ident":
        obj_name := obj_node.value
        if module_aliases.contains_key(obj_name):
            module_path := module_aliases[obj_name]
            qualified_name := module_import_target_name(module_path, field_name)
            module_name := module_generic_target_name(module_path, field_name)
            mut func_tid := lookup_binding(scope_id, module_name)
            if func_tid >= 0:
                return func_tid
            func_tid = lookup_binding(scope_id, qualified_name)
            if func_tid >= 0:
                return func_tid
            func_tid = lookup_binding(scope_id, field_name)
            if func_tid >= 0:
                return func_tid
            report_error("E209", "module '" + obj_name + "' has no function '" + field_name + "'")
            return TID_ERR

    obj_type := c_check_expr(obj_node_idx, scope_id)
    if is_error_type(obj_type):
        return TID_ERR
    obj_info := get_type_info(obj_type)
    if obj_info.kind == "struct":
        mut fidx := 0
        while fidx < obj_info.fields.len():
            if strings_equal(obj_info.fields[fidx], field_name):
                if fidx < obj_info.field_types.len():
                    return obj_info.field_types[fidx]
                return TID_ERR
            fidx = fidx + 1
        report_error("E209", get_type_name(obj_type) + " has no field '" + field_name + "'")
        return TID_ERR
    if obj_info.kind == "tuple":
        # parse field name as integer index
        idx := parse_integer_string(field_name)
        if idx < 0:
            report_error("E209", "tuple field must be a numeric index")
            return TID_ERR
        if idx >= obj_info.elements.len():
            report_error("E209", "tuple index " + field_name + " out of bounds (tuple has " + obj_info.elements.len().to_string() + " elements)")
            return TID_ERR
        return obj_info.elements[idx]
    if obj_info.kind == "result":
        tid_bool := lookup_type_id("Bool")
        if strings_equal(field_name, "is_ok") or strings_equal(field_name, "is_err"):
            return tid_bool
        if strings_equal(field_name, "ok"):
            return obj_info.inner
        if strings_equal(field_name, "err"):
            return obj_info.value_type
        report_error("E209", "result has no field '" + field_name + "'")
        return TID_ERR
    # enum variant access (e.g. Shape.Circle) — for match patterns
    if obj_info.kind == "enum":
        # this is typically used in patterns, not field access
        # but allow it for enum variant references
        return obj_type
    report_error("E209", get_type_name(obj_type) + " has no field '" + field_name + "'")
    return TID_ERR

fn parse_integer_string(s: String) -> Int:
    # simple integer parser for tuple field indices
    if s.len() == 0:
        return - 1
    mut result := 0
    mut i := 0
    while i < s.len():
        ch := s[i]
        if ch == "0":
            result = result * 10
        elif ch == "1":
            result = result * 10 + 1
        elif ch == "2":
            result = result * 10 + 2
        elif ch == "3":
            result = result * 10 + 3
        elif ch == "4":
            result = result * 10 + 4
        elif ch == "5":
            result = result * 10 + 5
        elif ch == "6":
            result = result * 10 + 6
        elif ch == "7":
            result = result * 10 + 7
        elif ch == "8":
            result = result * 10 + 8
        elif ch == "9":
            result = result * 10 + 9
        else:
            return - 1
        i = i + 1
    return result

# ---------------------------------------------------------------
# index expression
# ---------------------------------------------------------------

fn check_index_expression(node: Node, scope_id: Int) -> Int:
    tid_string := lookup_type_id("String")
    tid_bytes := lookup_type_id("Bytes")
    tid_int := lookup_type_id("Int")
    if node.children.len() < 2:
        return TID_ERR
    mut obj_type := c_check_expr(node.children[0], scope_id)
    idx_type := c_check_expr(node.children[1], scope_id)
    if is_error_type(obj_type):
        return TID_ERR
    if is_error_type(idx_type):
        return TID_ERR
    mut obj_info := get_type_info(obj_type)
    if obj_info.kind == "optional":
        obj_type = obj_info.inner
        obj_info = get_type_info(obj_type)
    elif obj_info.kind == "result":
        obj_type = obj_info.inner
        obj_info = get_type_info(obj_type)
    # string indexing
    if obj_type == tid_string:
        if is_integer_type(idx_type) == false:
            report_error("E217", "string index must be integer, got " + get_type_name(idx_type))
            return TID_ERR
        return tid_string
    if obj_type == tid_bytes:
        if is_integer_type(idx_type) == false:
            report_error("E217", "bytes index must be integer, got " + get_type_name(idx_type))
            return TID_ERR
        return tid_int
    if obj_info.kind == "list":
        if is_integer_type(idx_type) == false:
            report_error("E217", "list index must be integer, got " + get_type_name(idx_type))
            return TID_ERR
        return obj_info.inner
    if obj_info.kind == "map":
        if idx_type != obj_info.key_type:
            report_error("E217", "map key type mismatch: expected " + get_type_name(obj_info.key_type) + ", got " + get_type_name(idx_type))
            return TID_ERR
        return obj_info.value_type
    report_error("E217", get_type_name(obj_type) + " does not support indexing")
    return TID_ERR

# ---------------------------------------------------------------
# unwrap expression (value?)
# ---------------------------------------------------------------

fn check_unwrap_expression(node: Node, scope_id: Int) -> Int:
    if node.children.len() < 1:
        return TID_ERR
    inner := c_check_expr(node.children[0], scope_id)
    if is_error_type(inner):
        return TID_ERR
    info := get_type_info(inner)
    if info.kind == "optional":
        return info.inner
    report_error_with_fix("E224", "unwrap requires an optional type, got " + get_type_name(inner), "use ? for unwrapping optional types")
    return TID_ERR

# ---------------------------------------------------------------
# try expression (value!)
# ---------------------------------------------------------------

fn check_try_expression(node: Node, scope_id: Int) -> Int:
    if node.children.len() < 1:
        return TID_ERR
    inner := c_check_expr(node.children[0], scope_id)
    if is_error_type(inner):
        return TID_ERR
    info := get_type_info(inner)
    if info.kind == "result":
        if checking_test_decl:
            return info.inner
        # verify enclosing function also returns a result
        ret := get_scope_return_type(scope_id)
        if ret < 0:
            report_error("E239", "try (!) can only be used in functions that return a result type")
            return TID_ERR
        ret_info := get_type_info(ret)
        if ret_info.kind != "result":
            report_error("E239", "try (!) can only be used in functions that return a result type")
            return TID_ERR
        if types_compatible(info.value_type, ret_info.value_type) == false:
            report_error("E239", "try (!) error type mismatch: cannot propagate " + get_type_name(info.value_type) + " from function returning " + get_type_name(ret))
            return TID_ERR
        return info.inner
    report_error_with_fix("E224", "try requires a result type, got " + get_type_name(inner), "use ! for unwrapping optional types")
    return TID_ERR

fn check_catch_expression(node: Node, scope_id: Int) -> Int:
    if node.children.len() < 2:
        return TID_ERR
    result_type := c_check_expr(node.children[0], scope_id)
    if is_error_type(result_type):
        return TID_ERR
    result_info := get_type_info(result_type)
    if result_info.kind != "result":
        report_error("E224", "catch requires a result type, got " + get_type_name(result_type))
        return TID_ERR
    fallback_type := c_check_expr(node.children[1], scope_id)
    if is_error_type(fallback_type):
        return TID_ERR
    if types_compatible(fallback_type, result_info.inner) == false:
        report_error("E219", "catch fallback type mismatch: expected " + get_type_name(result_info.inner) + ", got " + get_type_name(fallback_type))
        return TID_ERR
    return result_info.inner

fn check_select_expression(node: Node, scope_id: Int) -> Int:
    if node.children.len() == 0:
        report_error("E232", "select requires at least one arm")
        return TID_ERR
    mut result_type := TID_ERR
    mut saw_default := false
    mut saw_timeout := false
    for child in node.children:
        arm_node := get_node(child)
        arm_type := check_select_arm(arm_node, scope_id)
        if arm_node.kind == "select_default_arm":
            if saw_default:
                report_error("E232", "select can only have one default arm")
            saw_default = true
        elif arm_node.kind == "select_timeout_arm":
            if saw_timeout:
                report_error("E232", "select can only have one timeout arm")
            saw_timeout = true
        if is_error_type(result_type):
            result_type = arm_type
        elif is_error_type(arm_type) == false:
            if arm_type != result_type:
                if arm_type != TID_VOID and result_type != TID_VOID:
                    report_error("E225", "select arms have different types: " + get_type_name(result_type) + " vs " + get_type_name(arm_type))
    return result_type

fn check_select_arm(arm: Node, scope_id: Int) -> Int:
    if arm.kind == "select_recv_arm":
        return check_select_recv_arm(arm, scope_id)
    if arm.kind == "select_send_arm":
        return check_select_send_arm(arm, scope_id)
    if arm.kind == "select_timeout_arm":
        return check_select_timeout_arm(arm, scope_id)
    if arm.kind == "select_default_arm":
        return check_select_arm_body(arm, 0, scope_id)
    report_error("E232", "invalid select arm")
    return TID_ERR

fn check_select_recv_arm(arm: Node, scope_id: Int) -> Int:
    if arm.children.len() < 2:
        report_error("E232", "select recv arm requires a recv expression and body")
        return TID_ERR
    recv_node := get_node(arm.children[0])
    if recv_node.kind != "method_call" or recv_node.value != "recv":
        report_error("E232", "select recv arms must use name := channel.recv()")
        return TID_ERR
    recv_type := c_check_expr(arm.children[0], scope_id)
    if is_error_type(recv_type):
        return TID_ERR
    arm_scope := create_scope(scope_id)
    define_binding(arm_scope, arm.value, recv_type, false)
    return check_select_arm_body(arm, 1, arm_scope)

fn check_select_send_arm(arm: Node, scope_id: Int) -> Int:
    if arm.children.len() < 2:
        report_error("E232", "select send arm requires a send expression and body")
        return TID_ERR
    send_node := get_node(arm.children[0])
    if send_node.kind != "method_call" or send_node.value != "send":
        report_error("E232", "select send arms must use channel.send(value)")
        return TID_ERR
    send_type := c_check_expr(arm.children[0], scope_id)
    if is_error_type(send_type):
        return TID_ERR
    if send_type != TID_BOOL:
        report_error("E232", "select send arms must use a channel send expression")
        return TID_ERR
    return check_select_arm_body(arm, 1, scope_id)

fn check_select_timeout_arm(arm: Node, scope_id: Int) -> Int:
    if arm.children.len() < 2:
        report_error("E232", "select timeout arm requires a duration and body")
        return TID_ERR
    timeout_type := c_check_expr(arm.children[0], scope_id)
    if is_error_type(timeout_type) == false:
        if timeout_type != TID_INT:
            report_error("E219", "select timeout expects Int milliseconds, got " + get_type_name(timeout_type))
    return check_select_arm_body(arm, 1, scope_id)

fn check_select_arm_body(arm: Node, body_idx: Int, scope_id: Int) -> Int:
    if body_idx >= arm.children.len():
        return TID_VOID
    body_node := get_node(arm.children[body_idx])
    if body_node.kind == "body":
        if body_node.children.len() == 0:
            return TID_VOID
        return c_check_expr(body_node.children[0], scope_id)
    if body_node.kind == "block":
        check_block_statement(body_node, scope_id)
        return TID_VOID
    return c_check_expr(arm.children[body_idx], scope_id)

# ---------------------------------------------------------------
# if expression
# ---------------------------------------------------------------

fn check_if_expression(node: Node, scope_id: Int) -> Int:
    # children: [condition, then_expr, elif_branches..., else_expr]
    if node.children.len() < 2:
        return TID_ERR
    cond := c_check_expr(node.children[0], scope_id)
    if is_error_type(cond) == false:
        if cond != TID_BOOL:
            report_error("E200", "condition must be Bool, got " + get_type_name(cond))
    # check then branch
    then_type := c_check_expr(node.children[1], scope_id)
    mut result_type := then_type
    # check remaining branches (skip first 2: condition + then)
    mut skip_br := 2
    for child in node.children:
        if skip_br > 0:
            skip_br = skip_br - 1
            continue
        cn := get_node(child)
        if cn.kind == "elif_branch":
            if cn.children.len() >= 2:
                econd := c_check_expr(cn.children[0], scope_id)
                if is_error_type(econd) == false:
                    if econd != TID_BOOL:
                        report_error("E200", "condition must be Bool, got " + get_type_name(econd))
                etype := c_check_expr(cn.children[1], scope_id)
                if is_error_type(result_type):
                    result_type = etype
                elif is_error_type(etype) == false:
                    if etype != result_type:
                        report_error("E225", "if expression branches have different types: " + get_type_name(result_type) + " vs " + get_type_name(etype))
        else:
            # else branch
            etype := c_check_expr(child, scope_id)
            if is_error_type(result_type):
                result_type = etype
            elif is_error_type(etype) == false:
                if etype != result_type:
                    report_error("E225", "if expression branches have different types: " + get_type_name(result_type) + " vs " + get_type_name(etype))
    return result_type

# ---------------------------------------------------------------
# match expression
# ---------------------------------------------------------------

fn check_match_expression(node_idx: Int, scope_id: Int) -> Int:
    node := get_node(node_idx)
    # children[0] is the subject expression
    # children[1..] are arm nodes
    if node.children.len() < 2:
        return TID_ERR
    subject_type := c_check_expr(node.children[0], scope_id)
    if is_error_type(subject_type):
        return TID_ERR
    mut result_type := TID_ERR
    mut arm_values: List[String] := []
    mut skip_subj := 1
    for child in node.children:
        if skip_subj > 0:
            skip_subj = skip_subj - 1
            continue
        arm_node := get_node(child)
        if arm_node.kind == "arm":
            arm_type := check_match_arm(arm_node, subject_type, scope_id)
            # collect pattern values for exhaustiveness
            if arm_node.children.len() > 0:
                pat := get_node(arm_node.children[0])
                pv := collect_arm_pattern_bindings(pat)
                if pv.len() > 0:
                    arm_values.push(pv)
            if is_error_type(result_type):
                result_type = arm_type
            elif is_error_type(arm_type) == false:
                if arm_type != result_type:
                    if arm_type != TID_VOID:
                        if result_type != TID_VOID:
                            report_error("E225", "match arms have different types: " + get_type_name(result_type) + " vs " + get_type_name(arm_type))
    # exhaustiveness checking
    check_match_exhaustiveness(subject_type, arm_values, node_idx)
    return result_type

fn check_match_arm(arm: Node, subject_type: Int, scope_id: Int) -> Int:
    # children: [pattern, guard?, body]
    if arm.children.len() < 2:
        return TID_ERR
    arm_scope := create_scope(scope_id)
    # check pattern
    check_pattern_match(arm.children[0], subject_type, arm_scope)
    # find body (may have guard between pattern and body)
    mut body_idx := 1
    if arm.children.len() > 2:
        guard_node := get_node(arm.children[1])
        if guard_node.kind == "guard":
            if guard_node.children.len() > 0:
                guard_type := c_check_expr(guard_node.children[0], arm_scope)
                if is_error_type(guard_type) == false:
                    if guard_type != TID_BOOL:
                        report_error("E218", "match guard must be Bool, got " + get_type_name(guard_type))
            body_idx = 2
    if body_idx >= arm.children.len():
        return TID_VOID
    body_node := get_node(arm.children[body_idx])
    if body_node.kind == "body":
        check_function_body(arm.children[body_idx], arm_scope)
        return TID_VOID
    if body_node.kind == "block":
        check_block_statement(body_node, arm_scope)
        return TID_VOID
    # expression arm
    return c_check_expr(arm.children[body_idx], arm_scope)

# ---------------------------------------------------------------
# pattern checking
# ---------------------------------------------------------------

fn check_pattern_match(pat_idx: Int, expected_type: Int, scope_id: Int):
    pat := get_node(pat_idx)
    if pat.kind == "pat_wildcard":
        return
    if pat.kind == "pat_binding":
        define_binding(scope_id, pat.value, expected_type, false)
        return
    if pat.kind == "pat_int":
        if is_integer_type(expected_type) == false:
            report_error("E228", "integer pattern cannot match " + get_type_name(expected_type))
        return
    if pat.kind == "pat_float":
        if expected_type != TID_FLOAT:
            report_error("E228", "float pattern cannot match " + get_type_name(expected_type))
        return
    if pat.kind == "pat_string":
        if expected_type != TID_STRING:
            report_error("E228", "string pattern cannot match " + get_type_name(expected_type))
        return
    if pat.kind == "pat_bool":
        if expected_type != TID_BOOL:
            report_error("E228", "bool pattern cannot match " + get_type_name(expected_type))
        return
    if pat.kind == "pat_none":
        return
    if pat.kind == "pat_variant":
        check_variant_pattern_match(pat, expected_type, scope_id)
        return
    if pat.kind == "pat_tuple":
        check_tuple_pattern_match(pat, expected_type, scope_id)
        return

fn check_variant_pattern_match(pat: Node, expected_type: Int, scope_id: Int):
    # value: "EnumName.VariantName"
    # children: sub-patterns for variant fields
    parts := split_qualified_name(pat.value)
    if parts.1.len() == 0:
        return
    type_name := parts.0
    variant_name := parts.1
    enum_tid := lookup_type_id(type_name)
    if enum_tid < 0:
        report_error("E202", "unknown type: " + type_name)
        return
    if enum_tid != expected_type:
        report_error("E228", "variant pattern type " + type_name + " does not match expected type " + get_type_name(expected_type))
        return
    enum_info := get_type_info(enum_tid)
    if enum_info.kind != "enum":
        report_error("E228", type_name + " is not an enum")
        return
    # find the variant
    mut found := false
    mut vidx := 0
    for v in enum_info.variants:
        if strings_equal(v, variant_name):
            found = true
            # check sub-pattern count
            if vidx < enum_info.variant_types.len():
                variant_fields := enum_info.variant_types[vidx]
                if pat.children.len() != variant_fields.len():
                    report_error("E213", variant_name + " has " + variant_fields.len().to_string() + " fields, but pattern has " + pat.children.len().to_string())
                    return
                # check each sub-pattern
                mut fidx := 0
                for sub_pat in pat.children:
                    if fidx < variant_fields.len():
                        check_pattern_match(sub_pat, variant_fields[fidx], scope_id)
                    fidx = fidx + 1
        vidx = vidx + 1
    if found == false:
        report_error("E212", type_name + " has no variant '" + variant_name + "'")

fn check_tuple_pattern_match(pat: Node, expected_type: Int, scope_id: Int):
    info := get_type_info(expected_type)
    if info.kind != "tuple":
        report_error("E228", "tuple pattern cannot match " + get_type_name(expected_type))
        return
    if pat.children.len() != info.elements.len():
        report_error("E213", "tuple pattern has " + pat.children.len().to_string() + " elements, expected " + info.elements.len().to_string())
        return
    mut i := 0
    for sub_pat in pat.children:
        if i < info.elements.len():
            check_pattern_match(sub_pat, info.elements[i], scope_id)
        i = i + 1

# ---------------------------------------------------------------
# exhaustiveness checking
# ---------------------------------------------------------------

fn collect_arm_pattern_bindings(pat: Node) -> String:
    if pat.kind == "pat_wildcard":
        return "_"
    if pat.kind == "pat_binding":
        return "_"
    if pat.kind == "pat_bool":
        return pat.value
    if pat.kind == "pat_variant":
        # extract variant name from "EnumName.VariantName"
        parts := split_qualified_name(pat.value)
        if parts.1.len() > 0:
            return parts.1
        return parts.0
    if pat.kind == "pat_int":
        return pat.value
    if pat.kind == "pat_string":
        return pat.value
    return ""

fn check_match_exhaustiveness(subject_type: Int, arm_values: List[String], node_idx: Int):
    # if any wildcard or binding pattern, it's exhaustive
    for v in arm_values:
        if v == "_":
            return
    # check by type
    if subject_type == TID_BOOL:
        check_bool_exhaustiveness(arm_values)
        return
    subj_info := get_type_info(subject_type)
    if subj_info.kind == "enum":
        check_enum_exhaustiveness(subj_info, arm_values)
        return
    if subj_info.kind == "optional":
        # Optional needs both Some and None patterns (or wildcard)
        mut has_some := false
        mut has_none := false
        for v in arm_values:
            if v == "Some":
                has_some = true
            elif v == "_":
                has_some = true
            if v == "None":
                has_none = true
            elif v == "_":
                has_none = true
        if not has_some:
            report_error("E204", "non-exhaustive match on Optional: add 'Some' case or wildcard (_)")
        if not has_none:
            report_error("E204", "non-exhaustive match on Optional: add 'None' case or wildcard (_)")
        return
    # infinite domain (Int, String, Float) — need wildcard
    report_error("E204", "non-exhaustive match: add a wildcard (_) pattern")

fn check_bool_exhaustiveness(arm_values: List[String]):
    mut has_true := false
    mut has_false := false
    for v in arm_values:
        if v == "true":
            has_true = true
        if v == "false":
            has_false = true
    if has_true == false:
        report_error("E204", "non-exhaustive match: missing 'true' case")
    if has_false == false:
        report_error("E204", "non-exhaustive match: missing 'false' case")

fn check_enum_exhaustiveness(info: TypeInfo, arm_values: List[String]):
    mut missing: List[String] := []
    for variant in info.variants:
        mut found := false
        for v in arm_values:
            if strings_equal(v, variant):
                found = true
        if found == false:
            missing.push(variant)
    if missing.len() > 0:
        report_error("E204", "non-exhaustive match: missing variants: " + missing.join(", "))

# ---------------------------------------------------------------
# lambda expression
# ---------------------------------------------------------------

fn check_lambda_expression(node: Node, scope_id: Int) -> Int:
    # children: params..., body (last child is the expression body or body node)
    mut params: List[Int] := []
    lambda_scope := create_scope(scope_id)
    mut body_idx := -1
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "param":
            if cn.children.len() > 0:
                ptid := resolve_type_implementation(cn.children[0])
                params.push(ptid)
                pname := extract_binding_name(cn.value)
                define_binding(lambda_scope, pname, ptid, false)
            else:
                report_error("E230", "lambda parameter requires a type annotation")
                params.push(TID_ERR)
        else:
            body_idx = child
    # check body
    mut ret_type := TID_VOID
    if body_idx >= 0:
        body_node := get_node(body_idx)
        if body_node.kind == "body":
            # short-form lambda: body wraps a single expression
            if body_node.children.len() > 0:
                ret_type = c_check_expr(body_node.children[0], lambda_scope)
        elif body_node.kind == "block":
            check_block_statement(body_node, lambda_scope)
        else:
            ret_type = c_check_expr(body_idx, lambda_scope)
    return add_type_info(ti_function(params, ret_type))

# ---------------------------------------------------------------
# collection literal expressions
# ---------------------------------------------------------------

fn check_list_expression(node: Node, scope_id: Int) -> Int:
    tid_err := lookup_type_id("<error>")
    if node.children.len() == 0:
        # empty list — type comes from annotation context
        return tid_err
    # check all elements
    mut elem_type := tid_err
    for child in node.children:
        t := c_check_expr(child, scope_id)
        if is_error_type(elem_type):
            elem_type = t
        elif is_error_type(t) == false:
            if t != elem_type:
                report_error("E223", "list elements must be the same type: expected " + get_type_name(elem_type) + ", got " + get_type_name(t))
    if is_error_type(elem_type):
        return tid_err
    return intern_list_type(elem_type)

fn check_map_expression(node: Node, scope_id: Int) -> Int:
    tid_err := lookup_type_id("<error>")
    if node.children.len() == 0:
        return tid_err
    mut key_type := tid_err
    mut val_type := tid_err
    for child in node.children:
        entry := get_node(child)
        if entry.kind == "entry":
            if entry.children.len() >= 2:
                kt := c_check_expr(entry.children[0], scope_id)
                vt := c_check_expr(entry.children[1], scope_id)
                if is_error_type(key_type):
                    key_type = kt
                elif is_error_type(kt) == false:
                    if kt != key_type:
                        report_error("E223", "map keys must be the same type")
                if is_error_type(val_type):
                    val_type = vt
                elif is_error_type(vt) == false:
                    if vt != val_type:
                        report_error("E223", "map values must be the same type")
    if is_error_type(key_type):
        return tid_err
    if is_error_type(val_type):
        return tid_err
    return intern_map_type(key_type, val_type)

fn check_set_expression(node: Node, scope_id: Int) -> Int:
    # sets look like {a, b, c} — distinguish from map by no entries
    tid_err := lookup_type_id("<error>")
    if node.children.len() == 0:
        return tid_err
    mut elem_type := tid_err
    for child in node.children:
        t := c_check_expr(child, scope_id)
        if is_error_type(elem_type):
            elem_type = t
        elif is_error_type(t) == false:
            if t != elem_type:
                report_error("E223", "set elements must be the same type")
    if is_error_type(elem_type):
        return tid_err
    return intern_set_type(elem_type)

fn check_tuple_expression(node: Node, scope_id: Int) -> Int:
    mut elems: List[Int] := []
    for child in node.children:
        elems.push(c_check_expr(child, scope_id))
    return add_type_info(ti_tuple(elems))

fn check_struct_initialization(node: Node, scope_id: Int) -> Int:
    # node.value contains the struct type name
    struct_name := node.value
    struct_tid := lookup_type_id(struct_name)
    if struct_tid < 0:
        report_error("E202", "unknown type: " + struct_name)
        return TID_ERR

    # get struct info
    info := get_type_info(struct_tid)
    if info.kind != "struct":
        report_error("E202", struct_name + " is not a struct type")
        return TID_ERR

    # check field count
    if node.children.len() != info.fields.len():
        report_error("E207", struct_name + " expects " + info.fields.len().to_string() + " fields, got " + node.children.len().to_string())
        return TID_ERR

    # check each field type
    mut idx := 0
    for child in node.children:
        arg_node := get_node(child)
        arg_type := c_check_expr(child, scope_id)
        if is_error_type(arg_type) == false:
            if idx < info.field_types.len():
                expected := info.field_types[idx]
                if arg_type != expected:
                    report_error("E219", "field '" + info.fields[idx] + "' type mismatch: expected " + get_type_name(expected) + ", got " + get_type_name(arg_type))
        idx = idx + 1

    return struct_tid

# ---------------------------------------------------------------
# spawn/await
# ---------------------------------------------------------------

fn check_spawn_expression(node: Node, scope_id: Int) -> Int:
    if node.children.len() < 1:
        report_error("E232", "spawn requires a function call")
        return TID_ERR
    inner_node := get_node(node.children[0])
    if inner_node.kind != "call":
        report_error("E232", "spawn requires a function call")
        return TID_ERR
    inner := c_check_expr(node.children[0], scope_id)
    if is_error_type(inner):
        return TID_ERR
    return add_type_info(ti_task(inner))

fn check_await_expression(node: Node, scope_id: Int) -> Int:
    if node.children.len() < 1:
        report_error("E232", "await requires a Task expression")
        return TID_ERR
    inner := c_check_expr(node.children[0], scope_id)
    if is_error_type(inner):
        return TID_ERR
    info := get_type_info(inner)
    if info.kind == "task":
        return info.inner
    report_error("E232", "await requires a Task type, got " + get_type_name(inner))
    return TID_ERR

# ---------------------------------------------------------------
# generic instantiation
# ---------------------------------------------------------------

fn instantiate_generic_type(decl_idx: Int, type_args: List[Int]) -> Int:
    decl := get_node(decl_idx)
    if decl.kind == "struct_decl":
        return instantiate_generic_struct_type(decl, type_args)
    if decl.kind == "enum_decl":
        return instantiate_generic_enum_type(decl, type_args)
    return TID_ERR

fn instantiate_generic_struct_type(decl: Node, type_args: List[Int]) -> Int:
    name := decl.value
    base_name := name
    inst_name := build_instantiated_type_name(base_name, type_args)
    existing := lookup_type_id(inst_name)
    if existing != -1:
        return existing
    generic_params := collect_generic_parameter_names(decl)
    mut field_names: List[String] := []
    mut field_types: List[Int] := []
    mut field_pub: List[Bool] := []
    mut field_mut: List[Bool] := []
    for child in decl.children:
        cn := get_node(child)
        if cn.kind == "field":
            fname := extract_field_name(cn.value)
            is_pub := cn.value.contains(" pub")
            is_mut := cn.value.contains(" mut")
            field_names.push(fname)
            field_pub.push(is_pub)
            field_mut.push(is_mut)
            if cn.children.len() > 0:
                ftid := resolve_type_with_substitution_map(cn.children[0], generic_params, type_args)
                field_types.push(ftid)
            else:
                field_types.push(TID_ERR)
    tid := add_type_info(ti_struct(inst_name, field_names, field_types, field_pub, field_mut))
    register_type_name(inst_name, tid)
    return tid

fn instantiate_generic_enum_type(decl: Node, type_args: List[Int]) -> Int:
    name := decl.value
    base_name := name
    inst_name := build_instantiated_type_name(base_name, type_args)
    existing := lookup_type_id(inst_name)
    if existing != -1:
        return existing
    generic_params := collect_generic_parameter_names(decl)
    mut variant_names: List[String] := []
    mut variant_types: List[List[Int]] := []
    for child in decl.children:
        cn := get_node(child)
        if cn.kind == "variant":
            variant_names.push(cn.value)
            mut vtypes: List[Int] := []
            for vc in cn.children:
                vtypes.push(resolve_type_with_substitution_map(vc, generic_params, type_args))
            variant_types.push(vtypes)
    tid := add_type_info(ti_enum(inst_name, variant_names, variant_types))
    register_type_name(inst_name, tid)
    return tid

# ---------------------------------------------------------------
# structural equality
# ---------------------------------------------------------------

fn types_structurally_equal(a: Int, b: Int) -> Bool:
    if a == b:
        return true
    if a < 0:
        return false
    if b < 0:
        return false
    ai := get_type_info(a)
    bi := get_type_info(b)
    # function type structural equality
    if ai.kind == "function":
        if bi.kind == "function":
            if ai.param_types.len() != bi.param_types.len():
                return false
            for ap, i in ai.param_types:
                if i < bi.param_types.len():
                    if types_structurally_equal(ap, bi.param_types[i]) == false:
                        return false
            if types_structurally_equal(ai.return_type, bi.return_type) == false:
                return false
            return true
    # tuple structural equality
    if ai.kind == "tuple":
        if bi.kind == "tuple":
            if ai.elements.len() != bi.elements.len():
                return false
            for ae, i in ai.elements:
                if i < bi.elements.len():
                    if types_structurally_equal(ae, bi.elements[i]) == false:
                        return false
            return true
    # result structural equality
    if ai.kind == "result":
        if bi.kind == "result":
            if types_structurally_equal(ai.inner, bi.inner) == false:
                return false
            return types_structurally_equal(ai.value_type, bi.value_type)
    # optional structural equality
    if ai.kind == "optional":
        if bi.kind == "optional":
            return types_structurally_equal(ai.inner, bi.inner)
    # list structural equality
    if ai.kind == "list":
        if bi.kind == "list":
            return types_structurally_equal(ai.inner, bi.inner)
    # map structural equality
    if ai.kind == "map":
        if bi.kind == "map":
            if types_structurally_equal(ai.key_type, bi.key_type) == false:
                return false
            return types_structurally_equal(ai.value_type, bi.value_type)
    # set structural equality
    if ai.kind == "set":
        if bi.kind == "set":
            return types_structurally_equal(ai.inner, bi.inner)
    # task structural equality
    if ai.kind == "task":
        if bi.kind == "task":
            return types_structurally_equal(ai.inner, bi.inner)
    # channel structural equality
    if ai.kind == "channel":
        if bi.kind == "channel":
            return types_structurally_equal(ai.inner, bi.inner)
    # struct structural equality
    if ai.kind == "struct":
        if bi.kind == "struct":
            if ai.fields.len() != bi.fields.len():
                return false
            for field_name, i in ai.fields:
                if field_name != bi.fields[i]:
                    return false
                if types_structurally_equal(ai.field_types[i], bi.field_types[i]) == false:
                    return false
            return true
    # enum structural equality
    if ai.kind == "enum":
        if bi.kind == "enum":
            if ai.variants.len() != bi.variants.len():
                return false
            for variant_name, i in ai.variants:
                if variant_name != bi.variants[i]:
                    return false
                # compare variant field types
                if ai.variant_types[i].len() != bi.variant_types[i].len():
                    return false
                for field_type, j in ai.variant_types[i]:
                    if types_structurally_equal(field_type, bi.variant_types[i][j]) == false:
                        return false
            return true
    return false

fn types_compatible(actual: Int, expected: Int) -> Bool:
    if actual == expected:
        return true
    return types_structurally_equal(actual, expected)

# ---------------------------------------------------------------
# public API — run checker and return diagnostics as JSON
# ---------------------------------------------------------------

pub fn c_run(root_idx: Int, file_path: String) -> List[Diagnostic]:
    initialize_checker(file_path)
    process_import_aliases(root_idx)
    c_register_all(root_idx)
    c_check_all(root_idx)
    return checker_diagnostics

# run checker passes on a single module without re-initializing.
# call initialize_checker() once, then c_run_module() for each module in order.
pub fn c_run_module(root_idx: Int) -> List[Diagnostic]:
    process_import_aliases(root_idx)
    c_register_all(root_idx)
    c_check_all(root_idx)
    return checker_diagnostics

pub fn c_diagnostics_to_json(diags: List[Diagnostic]) -> String:
    return render_diagnostics_json(diags)
