import std.toml as toml
import std.fs as fs
import std.os.path as os_path

struct TomlDerivedFixture:
    pub name: String
    pub score: Int
    pub active: Bool

struct TomlServerFixture:
    pub host: String
    pub port: Int

struct TomlOptionalFixture:
    pub name: String
    pub tls: Bool?

struct TomlDefaultFixture:
    pub name: String
    pub tls: Bool = false

struct TomlNestedDefaultServer:
    pub host: String
    pub port: Int = 8080
    pub tls: Bool = false

struct TomlNestedDefaultApp:
    pub name: String
    pub server: TomlNestedDefaultServer = TomlNestedDefaultServer("localhost")

fn main() -> Int!:
    nl := chr(10)
    dq := chr(34)
    doc := "name = " + dq + "pith" + dq + nl + "score = 42" + nl + "active = true"
    nested_doc := "[server]" + nl + "host = " + dq + "localhost" + dq + nl + "port = 8080"

    root := toml.parse(doc)
    from_handle := toml.decode[TomlDerivedFixture](root)
    if from_handle.is_ok:
        print(from_handle.ok.name + ":" + from_handle.ok.score.to_string() + ":" + from_handle.ok.active.to_string())

    from_text := toml.decode_text[TomlDerivedFixture](doc)
    if from_text.is_ok:
        print(from_text.ok.name + "@" + from_text.ok.score.to_string())

    missing := toml.decode_text[TomlDerivedFixture]("name = " + dq + "pith" + dq)
    print(missing.is_err.to_string())
    if missing.is_err:
        print(missing.err.message.contains("score").to_string())

    invalid := toml.decode_text[TomlDerivedFixture]("name = ")
    print(invalid.is_err.to_string())
    if invalid.is_err:
        print(invalid.err.message.contains("invalid toml").to_string())

    optional_doc := "name = " + dq + "pith" + dq + nl + "tls = true"
    optional_missing_doc := "name = " + dq + "pith" + dq
    optional_present := toml.decode_text[TomlOptionalFixture](optional_doc)
    optional_missing := toml.decode_text[TomlOptionalFixture](optional_missing_doc)
    if optional_present.is_ok:
        print(optional_present.ok.name + ":" + optional_present.ok.tls?.to_string())
    if optional_missing.is_ok:
        print(optional_missing.ok.name + ":" + (optional_missing.ok.tls == none).to_string())

    defaulted := toml.decode_text[TomlDefaultFixture]("name = " + dq + "pith" + dq)
    if defaulted.is_ok:
        print(defaulted.ok.name + ":" + defaulted.ok.tls.to_string())

    nested_default_missing_doc := "name = " + dq + "pith" + dq
    nested_default_partial_doc := "name = " + dq + "pith" + dq + nl + "[server]" + nl + "host = " + dq + "edge" + dq
    nested_default_missing := toml.decode_text[TomlNestedDefaultApp](nested_default_missing_doc)
    nested_default_partial := toml.decode_text[TomlNestedDefaultApp](nested_default_partial_doc)
    if nested_default_missing.is_ok:
        print(nested_default_missing.ok.name + ":" + nested_default_missing.ok.server.host + ":" + nested_default_missing.ok.server.port.to_string() + ":" + nested_default_missing.ok.server.tls.to_string())
    if nested_default_partial.is_ok:
        print(nested_default_partial.ok.name + ":" + nested_default_partial.ok.server.host + ":" + nested_default_partial.ok.server.port.to_string() + ":" + nested_default_partial.ok.server.tls.to_string())

    nested_root := toml.parse(nested_doc)
    nested := toml.decode_path[TomlServerFixture](nested_root, "server")
    if nested.is_ok:
        print(nested.ok.host + "#" + nested.ok.port.to_string())

    nested_text := toml.decode_text_path[TomlServerFixture](nested_doc, "server")
    if nested_text.is_ok:
        print(nested_text.ok.host + "$" + nested_text.ok.port.to_string())

    root := fs.make_temp_dir("pith-toml-derived-")!
    file_path := os_path.join(root, "app.toml")
    assert(fs.write(file_path, nested_doc)!)
    nested_file := toml.decode_file_path[TomlServerFixture](file_path, "server")
    if nested_file.is_ok:
        print(nested_file.ok.host + "%" + nested_file.ok.port.to_string())
    assert(fs.remove_tree(root))

    nested_missing := toml.decode_text_path[TomlServerFixture](nested_doc, "database")
    print(nested_missing.is_err.to_string())
    if nested_missing.is_err:
        print(nested_missing.err.message.contains("missing table field").to_string())
    return 0
