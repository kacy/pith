impl StringReader:
    fn read(max_bytes: Int) -> String!:
        return string_reader_read(self, max_bytes)

    fn read_all() -> String!:
        return read_all(self)

    fn read_all_chunked(chunk_size: Int) -> String!:
        return read_all_chunked(self, chunk_size)

    fn buffered() -> BufferedStringReader:
        return buffered_string_reader(self)

    fn buffered_chunked(chunk_size: Int) -> BufferedStringReader:
        return buffered_string_reader_chunked(self, chunk_size)

impl Reader for StringReader:
    fn read(max_bytes: Int) -> String!:
        return string_reader_read(self, max_bytes)

impl StringBuffer:
    fn write(data: String) -> Int!:
        return string_buffer_write(self, data)

    fn write_all(data: String) -> Int!:
        return write_all(self, data)

    fn write_line(data: String) -> Int!:
        return string_buffer_write_line(self, data)

    fn newline() -> Int!:
        return string_buffer_write(self, chr(10))

    fn string() -> String:
        return string_buffer_string(self)

    fn len() -> Int:
        return string_buffer_len(self)

    fn is_empty() -> Bool:
        return string_buffer_len(self) == 0

    fn clear():
        string_buffer_clear(self)

    fn buffered() -> BufferedStringWriter:
        return buffered_string_writer(self)

    fn buffered_chunked(chunk_size: Int) -> BufferedStringWriter:
        return buffered_string_writer_chunked(self, chunk_size)

impl Writer for StringBuffer:
    fn write(data: String) -> Int!:
        return string_buffer_write(self, data)

impl BytesCursor:
    fn read_bytes(max_bytes: Int) -> Bytes!:
        return bytes_cursor_read(self, max_bytes)

    fn read_all_bytes() -> Bytes!:
        return read_all_bytes_cursor(self)

    fn read_all_bytes_chunked(chunk_size: Int) -> Bytes!:
