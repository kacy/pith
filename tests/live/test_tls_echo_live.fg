import std.net.http as http
import std.net.tls as tls

CERT_PATH := "tests/live/fixtures/localhost.crt"
KEY_PATH := "tests/live/fixtures/localhost.key"
CA_PATH := "tests/live/fixtures/localhost-ca.crt"

fn choose_port(start: Int) -> Int!:
    mut port := start
    while port < start + 200:
        probe := tcp_listen("127.0.0.1", port)
        if probe.is_ok:
            tcp_close(probe.ok)
            return port
        port = port + 1
    fail "no free tcp port"

fn alpn_server_config() -> tls.Config!:
    cfg := tls.server_config(CERT_PATH, KEY_PATH)!
    return cfg.with_alpn(["forge.echo", "http/1.1"]).enable_session_resumption()

fn alpn_client_config() -> tls.Config!:
    cfg := tls.client_config_with_ca_file(CA_PATH)!
    return cfg.with_alpn(["forge.echo", "http/1.1"]).enable_session_resumption()

fn run_server(port: Int) -> Int!:
    server_cfg := alpn_server_config()!
    listener := tls.listen("127.0.0.1", port, server_cfg)!

    echo_conn := listener.accept()!
    echo_state := echo_conn.state()
    assert(echo_state.version == 772)
    assert(echo_state.cipher_suite > 0)
    assert(echo_state.negotiated_protocol == "forge.echo")
    assert(not echo_state.did_resume)
    assert(not echo_state.peer_chain_present)
    assert(not echo_state.client_auth_requested)
    assert(not echo_state.client_auth_verified)
    assert(echo_conn.peer_common_name() == "")
    msg := echo_conn.read(64)!
    echo_conn.write_all("echo:" + msg)!
    echo_conn.close()

    resumed_conn := listener.accept()!
    resumed_state := resumed_conn.state()
    assert(resumed_state.did_resume)
    assert(resumed_state.negotiated_protocol == "forge.echo")
    resumed_msg := resumed_conn.read(64)!
    resumed_conn.write_all("echo:" + resumed_msg)!
    resumed_conn.close()

    http_conn := listener.accept()!
    req := http_conn.read(2048)!
    if req.contains("GET /secure HTTP/1.1"):
        http_conn.write_all("HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\nContent-Length: 12\r\nConnection: close\r\n\r\nhello secure")!
    else:
        http_conn.write_all("HTTP/1.1 400 Bad Request\r\nContent-Length: 3\r\nConnection: close\r\n\r\nbad")!
    http_conn.close()

    listener.close()
    server_cfg.close()
    return 0

fn run_mtls_server(port: Int) -> Int!:
    server_cfg := tls.server_config(CERT_PATH, KEY_PATH)!.with_alpn(["forge.mtls"]).require_client_ca_file(CA_PATH)!
    listener := tls.listen("127.0.0.1", port, server_cfg)!
    conn := listener.accept()!
    state := conn.state()
    assert(state.version == 772)
    assert(state.negotiated_protocol == "forge.mtls")
    assert(state.peer_chain_present)
    assert(state.client_auth_requested)
    assert(state.client_auth_verified)
    assert(conn.peer_common_name() == "localhost")
    assert(conn.peer_dns_names().contains("localhost"))
    msg := conn.read(64)!
    conn.write_all("mtls:" + msg)!
    conn.close()
    listener.close()
    server_cfg.close()
    return 0

fn run_optional_client_auth_server(port: Int) -> Int!:
    server_cfg := tls.server_config(CERT_PATH, KEY_PATH)!.with_alpn(["forge.optional"]).request_client_ca_file(CA_PATH)!
    listener := tls.listen("127.0.0.1", port, server_cfg)!
    conn := listener.accept()!
    state := conn.state()
    assert(state.version == 772)
    assert(state.negotiated_protocol == "forge.optional")
    assert(not state.peer_chain_present)
    assert(state.client_auth_requested)
    assert(not state.client_auth_verified)
    assert(conn.peer_common_name() == "")
    assert(conn.peer_dns_names().len() == 0)
    msg := conn.read(64)!
    conn.write_all("optional:" + msg)!
    conn.close()
    listener.close()
    server_cfg.close()
    return 0

fn main() -> Int!:
    port := choose_port(18942)!
    server_task := spawn run_server(port)
    sleep(200)

    client_cfg := alpn_client_config()!
    conn := tls.dial_with_config("127.0.0.1", port, "localhost", client_cfg)!
    state := conn.state()
    assert(state.version == 772)
    assert(state.cipher_suite > 0)
    assert(state.negotiated_protocol == "forge.echo")
    assert(not state.did_resume)
    assert(state.peer_chain_present)
    assert(not state.client_auth_requested)
    assert(not state.client_auth_verified)
    conn.write_all("forge")!
    assert(conn.read(64)! == "echo:forge")
    assert(conn.negotiated_protocol() == "forge.echo")
    assert(conn.peer_common_name() == "localhost")
    assert(conn.peer_dns_names().contains("localhost"))
    conn.close()

    resumed_conn := tls.dial_with_config("127.0.0.1", port, "localhost", client_cfg)!
    resumed_state := resumed_conn.state()
    assert(resumed_state.did_resume)
    assert(resumed_state.peer_chain_present)
    assert(resumed_state.negotiated_protocol == "forge.echo")
    resumed_conn.write_all("again")!
    assert(resumed_conn.read(64)! == "echo:again")
    assert(resumed_conn.did_resume())
    assert(resumed_conn.peer_common_name() == "localhost")
    resumed_conn.close()

    http_cfg := tls.client_config_with_ca_file(CA_PATH)!.with_alpn(["http/1.1"])
    res := http.https_request_port("GET", "127.0.0.1", port, "/secure").send_tls_with_config("localhost", http_cfg)!
    assert(res.status == 200)
    assert(res.body_text()! == "hello secure")
    http_cfg.close()
    client_cfg.close()

    await server_task

    mtls_port := choose_port(19142)!
    mtls_task := spawn run_mtls_server(mtls_port)
    sleep(200)

    mtls_cfg := tls.client_config_with_ca_file(CA_PATH)!.with_alpn(["forge.mtls"]).with_client_certificate(CERT_PATH, KEY_PATH)!
    mtls_conn := tls.dial_with_config("127.0.0.1", mtls_port, "localhost", mtls_cfg)!
    mtls_state := mtls_conn.state()
    assert(mtls_state.negotiated_protocol == "forge.mtls")
    assert(mtls_state.peer_chain_present)
    assert(not mtls_state.client_auth_requested)
    assert(not mtls_state.client_auth_verified)
    mtls_conn.write_all("client")!
    assert(mtls_conn.read(64)! == "mtls:client")
    assert(mtls_conn.negotiated_protocol() == "forge.mtls")
    assert(mtls_conn.peer_common_name() == "localhost")
    assert(mtls_conn.peer_dns_names().contains("localhost"))
    mtls_conn.close()
    mtls_cfg.close()

    await mtls_task

    optional_port := choose_port(19342)!
    optional_task := spawn run_optional_client_auth_server(optional_port)
    sleep(200)

    optional_cfg := tls.client_config_with_ca_file(CA_PATH)!.with_alpn(["forge.optional"])
    optional_conn := tls.dial_with_config("127.0.0.1", optional_port, "localhost", optional_cfg)!
    optional_state := optional_conn.state()
    assert(optional_state.negotiated_protocol == "forge.optional")
    assert(optional_state.peer_chain_present)
    assert(not optional_state.client_auth_requested)
    assert(not optional_state.client_auth_verified)
    optional_conn.write_all("guest")!
    assert(optional_conn.read(64)! == "optional:guest")
    assert(optional_conn.negotiated_protocol() == "forge.optional")
    assert(optional_conn.peer_common_name() == "localhost")
    optional_conn.close()
    optional_cfg.close()

    await optional_task
    return 0
