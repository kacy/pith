pub fn read_file_text(path: String) -> String!:
    return read_file_text_chunked(path, DEFAULT_CHUNK_SIZE)

pub fn read_file_text_chunked(path: String, chunk_size: Int) -> String!:
    stream := file_stream_open_read(path)!
    content := read_all_file_stream_chunked(stream, chunk_size)!
    stream.close()
    return content

pub fn write_file_text(path: String, data: String) -> Int!:
    return write_file_text_chunked(path, data, DEFAULT_CHUNK_SIZE)

pub fn write_file_text_chunked(path: String, data: String, chunk_size: Int) -> Int!:
    stream := file_stream_open_write(path)!
    writer := stream.buffered_writer_chunked(chunk_size)
    mut total := writer.write(data)!
    total = total + writer.flush()!
    stream.close()
    return total

pub fn append_file_text(path: String, data: String) -> Int!:
    return append_file_text_chunked(path, data, DEFAULT_CHUNK_SIZE)

pub fn append_file_text_chunked(path: String, data: String, chunk_size: Int) -> Int!:
    stream := file_stream_open_append(path)!
    writer := stream.buffered_writer_chunked(chunk_size)
    mut total := writer.write(data)!
    total = total + writer.flush()!
    stream.close()
    return total

fn write_all_process_stdin(writer: ProcessStdin, data: String) -> Int!:
    mut total := 0
    mut remaining := data
    while remaining.len() > 0:
        wrote := writer.write(remaining)!
        if wrote <= 0:
            fail "write returned 0"
        total = total + wrote
        remaining = remaining_after_write(remaining, wrote)
    return total

