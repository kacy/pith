{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Pith",
  "scopeName": "source.pith",
  "fileTypes": [
    "fg"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#types"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.pith",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.pith",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.pith"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.pith"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.pith",
              "match": "\\\\[nrt\\\"{0]"
            },
            {
              "name": "meta.interpolation.pith",
              "begin": "\\{",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.begin.pith"
                }
              },
              "end": "\\}",
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.end.pith"
                }
              },
              "patterns": [
                {
                  "include": "#keywords"
                },
                {
                  "include": "#numbers"
                },
                {
                  "include": "#types"
                },
                {
                  "include": "#operators"
                }
              ]
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.pith",
          "match": "\\b(if|elif|else|for|in|while|match|return|fail|break|continue|spawn|await)\\b"
        },
        {
          "name": "keyword.declaration.pith",
          "match": "\\b(fn|struct|enum|interface|impl|type|import|from|as|pub|mut|ref|weak)\\b"
        },
        {
          "name": "keyword.operator.word.pith",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.pith",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.none.pith",
          "match": "\\bnone\\b"
        },
        {
          "name": "variable.language.self.pith",
          "match": "\\bself\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.pith",
          "match": "\\b(Int|UInt|Float|Bool|String|Bytes|Void|Task|Channel|List|Map|Set|Option|Result|Error|Int8|Int16|Int32|Int64|UInt8|UInt16|UInt32|UInt64)\\b"
        },
        {
          "name": "entity.name.type.pith",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.pith",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d[\\d_]*)?\\b"
        },
        {
          "name": "constant.numeric.integer.hex.pith",
          "match": "\\b0x[0-9A-Fa-f][0-9A-Fa-f_]*\\b"
        },
        {
          "name": "constant.numeric.integer.binary.pith",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.integer.octal.pith",
          "match": "\\b0o[0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.integer.decimal.pith",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.pith",
          "match": "(:=|\\+=|-=|\\*=|/=|=)"
        },
        {
          "name": "keyword.operator.comparison.pith",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arrow.pith",
          "match": "(->|=>)"
        },
        {
          "name": "keyword.operator.arithmetic.pith",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.other.pith",
          "match": "(\\?|!|\\.|,|:|\\|)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.pith",
          "match": "(?<=\\bfn\\s)([a-zA-Z_][a-zA-Z0-9_]*)"
        },
        {
          "name": "variable.parameter.pith",
          "match": "(?<=\\()([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*:)|(?<=,\\s*)([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*:)"
        }
      ]
    }
  }
}
