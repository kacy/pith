# ir_emitter.fg — Forge-to-IR compiler (Stage 2)
#
# reads the parsed AST and emits a simple text IR that a thin Rust
# wrapper translates to Cranelift API calls.
#
# IR format:
#   string N "content"                  — string data
#   func NAME NPARAM RETTYPE            — function header (RETTYPE uses IR return-kind vocabulary)
#   param NAME                          — function parameter
#   endfunc                             — end of function
#   iconst REG VALUE                    — integer constant
#   strref REG STRIDX                   — reference to string data
#   call REG FNAME RETTYPE NARGS ARG... — function call
#   callv FNAME NARGS ARG...            — void call (no return)
#   add REG A B                         — integer add
#   sub REG A B                         — integer sub
#   mul REG A B                         — integer mul
#   div REG A B                         — integer div
#   mod REG A B                         — integer mod
#   eq REG A B                          — compare equal
#   neq REG A B                         — compare not equal
#   lt REG A B                          — compare less than
#   gt REG A B                          — compare greater than
#   lte REG A B                         — compare less or equal
#   gte REG A B                         — compare greater or equal
#   brif COND THEN_LABEL ELSE_LABEL     — conditional branch
#   label NAME                          — label
#   jmp LABEL                           — unconditional jump
#   ret REG                             — return value
#   load REG VARNAME                    — load variable
#   store VARNAME REG                   — store variable
#   concat REG A B                      — string concatenation

from ast import get_node, node_kind, node_value, node_child, node_child_count, Node
from checker import c_get_expr_type
from types import get_type_info

# --- type knowledge constants (single source of truth) ---
FLOAT_RETURNING_FUNCS := "pow,sqrt,floor,ceil,round,to_float,get_float,toml_get_float,json_get_float"
BOOL_RETURNING_FUNCS := "file_exists,dir_exists,get_bool,object_has,has,toml_get_bool,toml_has,json_get_bool,json_object_has"
INT_RETURNING_FUNCS := "abs,min,max,clamp,len,fnv1a,ord,exec,toml_get_int,toml_array_len,url_parse,url_port,json_parse,json_get_int,json_object_get,json_array_len"
STRING_RETURNING_FUNCS := "sha256,hex_encode,hex_decode,to_hex,b64_encode,chr,read_file,env,path_join,path_dir,path_base,path_ext,path_stem,scheme,host,query,fragment,decode,exec_output,type_of,get_string,toml_type_of,toml_get_string,url_scheme,url_host,url_path,url_query,url_fragment,url_to_string,url_encode,url_decode,json_type_of,json_get_string"
BYTES_RETURNING_FUNCS := "bytes_from_string_utf8,read_file_bytes,file_read_bytes,tcp_read_bytes,process_read_bytes,process_read_err_bytes,byte_buffer_bytes,b64_decode,from_hex,bytes_slice,bytes_concat"
LIST_RETURNING_FUNCS := "args,range,repeat_val,zeros,sort,sort_desc,reversed,take,drop,slice,unique,without,intersection,difference,flatten,chunks,json_object_keys"
LIST_STRING_RETURNING_FUNCS := "sort_strings,zip,enumerate,toml_keys"
BOOL_RETURNING_METHODS := "contains,starts_with,ends_with,is_empty,string_contains,string_is_empty,contains_key,map_contains_key,map_contains_ikey,map_is_empty,set_contains,set_contains_int,set_is_empty,list_contains,list_contains_string,list_is_empty"
VOID_METHODS := "sort,sort_strings,reverse,clear,push,remove,insert,add,list_remove,list_clear,list_reverse,map_insert_ikey,map_remove,map_remove_ikey,map_clear,set_add,set_add_int,set_remove,set_remove_int,set_clear"
STRING_RETURNING_METHODS := "trim,substring,to_upper,to_lower,reverse,replace,repeat,pad_left,pad_right,char_at,join,read_file,env,chr"

# --- state ---
mut ir_lines: List[String] := []
mut ir_next_reg := 0
mut ir_next_label := 0
mut ir_strings: List[String] := []
mut ir_var_regs: Map[String, Int] := {}
mut ir_var_types: Map[String, String] := {}  # variable name -> type hint or struct name
mut ir_map_value_types: Map[String, String] := {}  # map variable name -> value type
mut ir_global_int_names: List[String] := []
mut ir_global_string_names: List[String] := []
mut ir_global_list_string_names: List[String] := []
mut ir_global_list_names: List[String] := []
mut ir_global_map_names: List[String] := []
mut ir_global_map_int_names: List[String] := []
mut ir_global_map_value_types: Map[String, String] := {}
mut ir_global_set_names: List[String] := []
mut ir_global_set_int_names: List[String] := []
mut ir_global_bool_names: List[String] := []
mut ir_struct_names: Map[String, Int] := {}  # struct name -> field count
mut ir_struct_field_lookup: Map[String, String] := {}  # "Struct.field" -> field type
mut ir_struct_field_index_lookup: Map[String, String] := {}  # "Struct.field" -> field index string
mut ir_type_aliases: Map[String, String] := {}  # alias name -> target type
mut ir_last_was_ret := false  # tracks if the last emitted instruction was a return
mut ir_func_returns: Map[String, String] := {}  # function name -> return type hint
mut ir_lambda_count := 0
mut ir_for_count := 0
mut ir_break_stack: List[String] := []
mut ir_continue_stack: List[String] := []
mut ir_lambda_bodies: List[String] := []  # deferred lambda function IR
mut ir_module_count := 0  # increments per emit_ir call for unique naming
mut ir_impl_methods: Map[String, String] := {}
mut ir_import_renames: Map[String, String] := {}
mut ir_module_aliases: Map[String, String] := {}
mut ir_current_func_return_kind := ""
mut ir_preloaded_import_roots: List[Int] := []
mut ir_emit_tests := false

pub fn set_import_roots(roots: List[Int]):
    ir_preloaded_import_roots = roots

pub fn set_test_mode(enabled: Bool):
    ir_emit_tests = enabled

pub fn ir_reset():
    ir_lines = []
    ir_next_reg = 0
    ir_next_label = 0
    ir_strings = []
    ir_var_regs = {}
    ir_var_types = {}
    ir_map_value_types = {}
    ir_global_int_names = []
    ir_global_string_names = []
    ir_global_list_string_names = []
    ir_global_list_names = []
    ir_global_map_names = []
    ir_global_map_int_names = []
    ir_global_map_value_types = {}
    ir_global_set_names = []
    ir_global_set_int_names = []
    ir_global_bool_names = []
    ir_struct_field_lookup = {}
    ir_struct_field_index_lookup = {}
    ir_break_stack = []
    ir_continue_stack = []
    ir_impl_methods = {}
    ir_import_renames = {}
    ir_func_returns = {}
    ir_module_aliases = {}
    ir_current_func_return_kind = ""

fn ir_emit(line: String):
    ir_lines.push(line)

fn ir_reg() -> Int:
    r := ir_next_reg
    ir_next_reg = ir_next_reg + 1
    return r

fn ir_label() -> String:
    n := ir_next_label
    ir_next_label = ir_next_label + 1
    return "L" + n.to_string()

fn ir_strip_quotes(s: String) -> String:
    mut result := s
    if result.len() >= 2:
        if result.substring(0, 1) == chr(34):
            result = result.substring(1, result.len())
        if result.len() > 0 and result.substring(result.len() - 1, result.len()) == chr(34):
            result = result.substring(0, result.len() - 1)
    return result

fn ir_resolve_type_hint(type_name: String) -> String:
    mut resolved := type_name
    if ir_type_aliases.contains_key(resolved):
        resolved = ir_type_aliases[resolved]
    if resolved == "String":
        return "string"
    if resolved == "Bytes":
        return "bytes"
    if resolved == "Bool":
        return "bool"
    if resolved == "Int":
        return "int"
    if resolved == "Float":
        return "float"
    if resolved.contains("List[String]"):
        return "list_string"
    if resolved.contains("List[") or resolved == "List":
        return "list"
    if resolved.contains("Map[Int,") or resolved.contains("Map[Int, "):
        return "map_int"
    if resolved.contains("Map[") or resolved == "Map":
        return "map"
    if resolved.contains("Set[Int]") or resolved.contains("Set[UInt]") or resolved.contains("Set[Int8]") or resolved.contains("Set[Int16]") or resolved.contains("Set[Int32]") or resolved.contains("Set[Int64]") or resolved.contains("Set[UInt8]") or resolved.contains("Set[UInt16]") or resolved.contains("Set[UInt32]") or resolved.contains("Set[UInt64]"):
        return "set_int"
    if resolved.contains("Set[") or resolved == "Set":
        return "set"
    mut base := resolved
    if base.contains("["):
        base = base.substring(0, base.index_of("["))
    if ir_struct_names.contains_key(base):
        return base
    return resolved

fn ir_resolve_type_node(type_idx: Int) -> String:
    tn := get_node(type_idx)
    if tn.kind == "type":
        return ir_resolve_type_hint(tn.value)
    if tn.kind == "generic_type":
        if tn.value == "List":
            if tn.children.len() > 0:
                first := get_node(tn.children[0])
                if first.kind == "type" and first.value == "String":
                    return "list_string"
            return "list"
        if tn.value == "Map":
            if tn.children.len() > 0:
                first := get_node(tn.children[0])
                if first.kind == "type" and first.value == "Int":
                    return "map_int"
            return "map"
        if tn.value == "Set":
            return "set"
        return ir_resolve_type_hint(tn.value)
    if tn.kind == "result_type" and tn.children.len() > 0:
        inner_type := ir_resolve_type_node(tn.children[0])
        if inner_type == "int":
            return "result_int"
        if inner_type == "bool":
            return "result_bool"
        if inner_type == "bytes":
            return "bytes"
        return inner_type
    return ""

fn ir_resolve_map_value_type_node(type_idx: Int) -> String:
    tn := get_node(type_idx)
    if tn.kind == "generic_type" and tn.value == "Map" and tn.children.len() > 1:
        return ir_resolve_type_node(tn.children[1])
    return ""

fn ir_lookup_map_value_type(name: String) -> String:
    if ir_map_value_types.contains_key(name):
        return ir_map_value_types[name]
    return ""

fn ir_lookup_map_value_type_for_expr(idx: Int) -> String:
    node := get_node(idx)
    if node.kind == "ident":
        return ir_lookup_map_value_type(node.value)
    return ""

fn ir_expr_result_kind(idx: Int) -> String:
    checked_kind := ir_checked_result_kind(idx)
    if checked_kind.len() > 0:
        return checked_kind
    node := get_node(idx)
    if node.kind == "call" and node.children.len() > 0:
        fname := ir_resolve_static_callee_name(node.children[0])
        if fname.len() > 0 and ir_func_returns.contains_key(fname):
            ret_kind := ir_func_returns[fname]
            if ret_kind == "result_int" or ret_kind == "result_bool":
                return ret_kind
    if node.kind == "method_call":
        fname := ir_resolve_module_alias_method_call_name(idx)
        if fname.len() > 0 and ir_func_returns.contains_key(fname):
            ret_kind := ir_func_returns[fname]
            if ret_kind == "result_int" or ret_kind == "result_bool":
                return ret_kind
    return ""

fn ir_encode_result_value(value_reg: Int, result_kind: String) -> Int:
    if result_kind == "result_int" or result_kind == "result_bool":
        one := ir_reg()
        ir_emit("iconst " + one.to_string() + " 1")
        encoded := ir_reg()
        ir_emit("add " + encoded.to_string() + " " + value_reg.to_string() + " " + one.to_string())
        return encoded
    return value_reg

fn ir_decode_result_value(value_reg: Int, result_kind: String) -> Int:
    if result_kind == "result_int" or result_kind == "result_bool":
        one := ir_reg()
        ir_emit("iconst " + one.to_string() + " 1")
        decoded := ir_reg()
        ir_emit("sub " + decoded.to_string() + " " + value_reg.to_string() + " " + one.to_string())
        return decoded
    return value_reg

fn ir_find_free_vars(idx: Int, bound: List[String]) -> List[String]:
    mut free: List[String] := []
    mut stack: List[Int] := [idx]
    while stack.len() > 0:
        current := stack[stack.len() - 1]
        stack.remove(stack.len() - 1)
        kind := node_kind(current)
        if kind == "ident":
            name := node_value(current)
            mut is_bound := false
            mut i := 0
            while i < bound.len():
                if bound[i] == name:
                    is_bound = true
                i = i + 1
            mut already_free := false
            i = 0
            while i < free.len():
                if free[i] == name:
                    already_free = true
                i = i + 1
            if not is_bound and not already_free:
                free.push(name)
        mut i := 0
        child_count := node_child_count(current)
        while i < child_count:
            stack.push(node_child(current, i))
            i = i + 1
    return free
fn ir_str(s: String) -> String:
    cleaned := ir_strip_quotes(s)
    mut i := 0
    while i < ir_strings.len():
        if ir_strings[i] == cleaned:
            return "m" + ir_module_count.to_string() + "s" + i.to_string()
        i = i + 1
    idx := ir_strings.len()
    ir_strings.push(cleaned)
    return "m" + ir_module_count.to_string() + "s" + idx.to_string()

# --- collect strings (iterative to avoid deep recursion crashes) ---
fn ir_collect_strings(idx: Int):
    mut stack: List[Int] := [idx]
    while stack.len() > 0:
        current := stack[stack.len() - 1]
        stack.remove(stack.len() - 1)
        node := get_node(current)
        if node.kind == "string_lit" or node.kind == "string" or node.kind == "str_lit":
            ir_str(node.value)
        elif node.kind == "lit":
            ir_str(node.value)
        kids := node.children
        mut i := 0
        while i < node.children.len():
            stack.push(kids[i])
            i = i + 1

fn ir_retkind(type_name: String) -> String:
    if type_name.len() == 0:
        return "unknown"
    resolved := ir_resolve_type_hint(type_name)
    if resolved == "int":
        return "int"
    if resolved == "float":
        return "float"
    if resolved == "bool":
        return "bool"
    if resolved == "string":
        return "string"
    if resolved == "list":
        return "list"
    if resolved == "list_string":
        return "list_string"
    if resolved == "map":
        return "map"
    if resolved == "map_int":
        return "map_int"
    if resolved == "set_int":
        return "set_int"
    if resolved == "set":
        return "set"
    if resolved == "void":
        return "void"
    if ir_struct_names.contains_key(resolved):
        return "struct:" + resolved
    return resolved

fn ir_emit_func_header(name: String, param_count: Int, ret_type: String):
    ir_emit("func " + name + " " + param_count.to_string() + " " + ir_retkind(ret_type))

fn ir_emit_call_text(result_reg: Int, fname: String, ret_type: String, arg_count: Int, arg_text: String):
    mut call_line := "call " + result_reg.to_string() + " " + fname + " " + ir_retkind(ret_type) + " " + arg_count.to_string()
    if arg_text.len() > 0:
        call_line = call_line + arg_text
    ir_emit(call_line)

fn ir_emit_call0(result_reg: Int, fname: String, ret_type: String):
    ir_emit_call_text(result_reg, fname, ret_type, 0, "")

fn ir_emit_call1(result_reg: Int, fname: String, ret_type: String, arg0: Int):
    ir_emit_call_text(result_reg, fname, ret_type, 1, " " + arg0.to_string())

fn ir_module_default_alias(module_path: String) -> String:
    mut last_dot := 0 - 1
    mut i := 0
    while i < module_path.len():
        if module_path[i] == ".":
            last_dot = i
        i = i + 1
    if last_dot < 0:
        return module_path
    return module_path.substring(last_dot + 1, module_path.len())

fn ir_import_target_name(module_path: String, name: String) -> String:
    if module_path == "std.json":
        return "json_" + name
    if module_path == "std.toml":
        return "toml_" + name
    if module_path == "std.encoding":
        return "encoding_" + name
    if module_path == "std.hash":
        return "hash_" + name
    if module_path == "std.log":
        return "log_" + name
    if module_path == "std.os.path":
        if name == "base":
            return "forge_path_basename"
        return "path_" + name
    if module_path == "std.net.url":
        return "url_" + name
    if module_path == "std.fs":
        return "fs_" + name
    return name

fn ir_resolve_module_alias_call_name(idx: Int) -> String:
    node := get_node(idx)
    if node.kind != "field_access" or node.children.len() == 0:
        return ""
    recv := get_node(node.children[0])
    if recv.kind != "ident":
        return ""
    alias := recv.value
    if not ir_module_aliases.contains_key(alias):
        return ""
    return ir_import_target_name(ir_module_aliases[alias], node.value)

fn ir_resolve_module_alias_method_call_name(idx: Int) -> String:
    node := get_node(idx)
    if node.kind != "method_call" or node.children.len() == 0:
        return ""
    recv := get_node(node.children[0])
    if recv.kind != "ident":
        return ""
    alias := recv.value
    if not ir_module_aliases.contains_key(alias):
        return ""
    mut method_name := node.value
    if method_name.starts_with("."):
        method_name = method_name.substring(1, method_name.len())
    return ir_import_target_name(ir_module_aliases[alias], method_name)

fn ir_resolve_static_callee_name(idx: Int) -> String:
    node := get_node(idx)
    if node.kind == "ident":
        fname := node.value
        if ir_import_renames.contains_key(fname):
            return ir_import_renames[fname]
        return fname
    if node.kind == "field_access":
        return ir_resolve_module_alias_call_name(idx)
    return ""

fn ir_static_callee_uses_result_abi(idx: Int) -> Bool:
    node := get_node(idx)
    if node.kind == "ident":
        if ir_import_renames.contains_key(node.value):
            return true
    if node.kind == "field_access":
        if ir_resolve_module_alias_call_name(idx).len() > 0:
            return true
    fname := ir_resolve_static_callee_name(idx)
    if fname.len() > 0 and ir_func_returns.contains_key(fname):
        return true
    return false

fn ir_emit_call2(result_reg: Int, fname: String, ret_type: String, arg0: Int, arg1: Int):
    ir_emit_call_text(result_reg, fname, ret_type, 2, " " + arg0.to_string() + " " + arg1.to_string())

fn ir_emit_call3(result_reg: Int, fname: String, ret_type: String, arg0: Int, arg1: Int, arg2: Int):
    ir_emit_call_text(result_reg, fname, ret_type, 3, " " + arg0.to_string() + " " + arg1.to_string() + " " + arg2.to_string())

fn ir_copy_lines(lines: List[String]) -> List[String]:
    mut copy: List[String] := []
    mut i := 0
    while i < lines.len():
        copy.push(lines[i])
        i = i + 1
    return copy

fn ir_copy_var_regs(src: Map[String, Int]) -> Map[String, Int]:
    mut copy: Map[String, Int] := {}
    keys := src.keys()
    mut i := 0
    while i < keys.len():
        key := keys[i]
        copy.insert(key, src[key])
        i = i + 1
    return copy

fn ir_copy_var_types(src: Map[String, String]) -> Map[String, String]:
    mut copy: Map[String, String] := {}
    keys := src.keys()
    mut i := 0
    while i < keys.len():
        key := keys[i]
        copy.insert(key, src[key])
        i = i + 1
    return copy

fn ir_unpack_field_index(meta: String) -> Int:
    mut value := 0
    mut i := 0
    while i < meta.len():
        value = (value * 10) + (ord(meta.substring(i, i + 1)) - ord("0"))
        i = i + 1
    return value

fn ir_register_struct_layout(name: String, field_names: List[String], field_types: List[String]):
    if ir_struct_names.contains_key(name):
        return
    mut i := 0
    while i < field_names.len():
        ir_struct_field_lookup.insert(name + "." + field_names[i], field_types[i])
        ir_struct_field_index_lookup.insert(name + "." + field_names[i], i.to_string())
        i = i + 1
    ir_struct_names.insert(name, field_names.len())
    ir_emit("struct " + name + " " + field_names.join(" "))

fn ir_seed_global_types():
    for name in ir_global_int_names:
        ir_var_types.insert(name, "int")
    for name in ir_global_string_names:
        ir_var_types.insert(name, "string")
    for name in ir_global_list_string_names:
        ir_var_types.insert(name, "list_string")
    for name in ir_global_list_names:
        ir_var_types.insert(name, "list")
    for name in ir_global_map_int_names:
        ir_var_types.insert(name, "map_int")
    for name in ir_global_map_names:
        ir_var_types.insert(name, "map")
    for name in ir_global_set_int_names:
        ir_var_types.insert(name, "set_int")
    for name in ir_global_set_names:
        ir_var_types.insert(name, "set")
    for name in ir_global_bool_names:
        ir_var_types.insert(name, "bool")
    for name in ir_global_map_value_types.keys():
        ir_map_value_types.insert(name, ir_global_map_value_types[name])

fn ir_register_known_import_structs():
    ir_register_struct_layout("Node", ["kind", "value", "children", "line", "col"], ["string", "string", "list", "int", "int"])
    ir_register_struct_layout("Token", ["kind", "value", "current_line", "current_column"], ["string", "string", "int", "int"])
    ir_register_struct_layout("TypeInfo", ["kind", "name", "fields", "field_types", "field_pub", "field_mut", "param_types", "return_type", "inner", "key_type", "value_type", "elements", "variants", "variant_types"], ["string", "string", "list_string", "list", "list", "list", "list", "int", "int", "int", "int", "list", "list_string", "list"])
    ir_register_struct_layout("Diagnostic", ["severity", "code", "message", "file", "line", "col", "fix"], ["string", "string", "string", "string", "int", "int", "string"])

fn ir_type_from_tid(tid: Int) -> String:
    if tid < 0:
        return ""
    mut info := get_type_info(tid)
    if info.kind == "optional" or info.kind == "result":
        if info.inner < 0:
            return ""
        info = get_type_info(info.inner)
    if info.kind == "primitive":
        if info.name == "Int" or info.name == "UInt" or info.name == "Int8" or info.name == "Int16" or info.name == "Int32" or info.name == "Int64" or info.name == "UInt8" or info.name == "UInt16" or info.name == "UInt32" or info.name == "UInt64":
            return "int"
        if info.name == "Float":
            return "float"
        if info.name == "Bool":
            return "bool"
        if info.name == "String":
            return "string"
        if info.name == "Bytes":
            return "bytes"
        return ""
    if info.kind == "list":
        elem_info := get_type_info(info.inner)
        if elem_info.kind == "primitive" and elem_info.name == "String":
            return "list_string"
        return "list"
    if info.kind == "map":
        key_info := get_type_info(info.key_type)
        if key_info.kind == "primitive" and (key_info.name == "Int" or key_info.name == "UInt" or key_info.name == "Int8" or key_info.name == "Int16" or key_info.name == "Int32" or key_info.name == "Int64" or key_info.name == "UInt8" or key_info.name == "UInt16" or key_info.name == "UInt32" or key_info.name == "UInt64"):
            return "map_int"
        return "map"
    if info.kind == "set":
        elem_info := get_type_info(info.inner)
        if elem_info.kind == "primitive" and (elem_info.name == "Int" or elem_info.name == "UInt" or elem_info.name == "Int8" or elem_info.name == "Int16" or elem_info.name == "Int32" or elem_info.name == "Int64" or elem_info.name == "UInt8" or elem_info.name == "UInt16" or elem_info.name == "UInt32" or elem_info.name == "UInt64"):
            return "set_int"
        return "set"
    if info.kind == "tuple":
        return "tuple"
    if info.kind == "struct":
        return info.name
    if info.kind == "channel":
        return "channel"
    if info.kind == "task":
        return "task"
    return ""

fn ir_checked_type(idx: Int) -> String:
    return ir_type_from_tid(c_get_expr_type(idx))

fn ir_checked_result_kind(idx: Int) -> String:
    tid := c_get_expr_type(idx)
    if tid < 0:
        return ""
    info := get_type_info(tid)
    if info.kind != "result":
        return ""
    inner_type := ir_type_from_tid(info.inner)
    if inner_type == "int":
        return "result_int"
    if inner_type == "bool":
        return "result_bool"
    if inner_type == "bytes":
        return "bytes"
    return inner_type

fn ir_call_retkind(idx: Int, uses_result_abi: Bool) -> String:
    if uses_result_abi:
        result_kind := ir_checked_result_kind(idx)
        if result_kind.len() > 0:
            return result_kind
    return ir_infer_type(idx)

fn ir_checked_index_type(idx: Int) -> String:
    node := get_node(idx)
    if node.kind != "index" or node.children.len() == 0:
        return ir_checked_type(idx)
    coll_tid := c_get_expr_type(node.children[0])
    if coll_tid < 0:
        return ir_checked_type(idx)
    mut coll_info := get_type_info(coll_tid)
    if coll_info.kind == "optional" or coll_info.kind == "result":
        if coll_info.inner < 0:
            return ir_checked_type(idx)
        coll_info = get_type_info(coll_info.inner)
    if coll_info.kind == "map" and coll_info.value_type >= 0:
        return ir_type_from_tid(coll_info.value_type)
    if coll_info.kind == "list" and coll_info.inner >= 0:
        return ir_type_from_tid(coll_info.inner)
    return ir_checked_type(idx)

# --- centralized type inference for AST nodes ---
# Returns: "int", "float", "bool", "string", "list", "list_string",
#          "map", "map_int", "set", "set_int", or "" (unknown)
fn ir_infer_type(idx: Int) -> String:
    checked := ir_checked_type(idx)
    if checked.len() > 0:
        return checked
    node := get_node(idx)
    kind := node_kind(idx)
    # literals
    if kind == "int_lit" or kind == "int" or kind == "integer":
        return "int"
    if kind == "float_lit" or kind == "float":
        return "float"
    if kind == "bool_lit" or kind == "bool":
        return "bool"
    if kind == "string_lit" or kind == "string" or kind == "str_lit" or kind == "string_interp":
        return "string"
    if kind == "list":
        if node.children.len() > 0:
            first := get_node(node.children[0])
            if first.kind == "string_lit" or first.kind == "string":
                return "list_string"
        return "list"
    if kind == "map":
        return "map"
    if kind == "set":
        if node.children.len() > 0:
            first := get_node(node.children[0])
            if first.kind == "int_lit" or first.kind == "int" or first.kind == "integer":
                return "set_int"
        return "set"
    if kind == "tuple":
        return "tuple"
    # identifiers — look up tracked type
    if kind == "ident":
        if ir_var_types.contains_key(node.value):
            return ir_var_types[node.value]
        if ir_global_int_names.contains(node.value):
            return "int"
        if ir_global_string_names.contains(node.value):
            return "string"
        if ir_global_list_string_names.contains(node.value):
            return "list_string"
        if ir_global_list_names.contains(node.value):
            return "list"
        if ir_global_map_int_names.contains(node.value):
            return "map_int"
        if ir_global_map_names.contains(node.value):
            return "map"
        if ir_global_set_int_names.contains(node.value):
            return "set_int"
        if ir_global_set_names.contains(node.value):
            return "set"
        if ir_global_bool_names.contains(node.value):
            return "bool"
        return ""
    if kind == "self":
        return "struct"
    # grouped expression — infer inner
    if kind == "grouped" and node.children.len() > 0:
        return ir_infer_type(node.children[0])
    # binary ops
    if kind == "binary":
        op := node.value
        if op == "eq" or op == "neq" or op == "lt" or op == "gt" or op == "lte" or op == "gte" or op == "and" or op == "or":
            return "bool"
        if op == "add" or op == "sub" or op == "mul" or op == "div" or op == "mod":
            # check if either operand is float
            if node.children.len() >= 2:
                lt := ir_infer_type(node.children[0])
                rt := ir_infer_type(node.children[1])
                if lt == "float" or rt == "float":
                    return "float"
                if lt == "string" or rt == "string":
                    return "string"
            return "int"
        return "int"
    # unary
    if kind == "unary":
        if node.value == "not" or node.value == "!" or node.value == "not_op":
            return "bool"
        return "int"
    # function calls
    if kind == "call" and node.children.len() > 0:
        fn_node := get_node(node.children[0])
        if fn_node.kind == "ident":
            mut fname := fn_node.value
            if ir_import_renames.contains_key(fname):
                fname = ir_import_renames[fname]
            if ir_struct_names.contains_key(fname):
                return fname
            if fname == "get_node":
                return "Node"
            if fname == "advance_token" or fname == "expect":
                return "Token"
            if fname == "ti_primitive" or fname == "ti_struct" or fname == "ti_enum" or fname == "ti_function" or fname == "ti_optional" or fname == "ti_result" or fname == "ti_tuple" or fname == "ti_list" or fname == "ti_map" or fname == "ti_set" or fname == "ti_task" or fname == "ti_channel" or fname == "get_type_info":
                return "TypeInfo"
            if FLOAT_RETURNING_FUNCS.contains(fname):
                return "float"
            if BOOL_RETURNING_FUNCS.contains(fname):
                return "bool"
            if INT_RETURNING_FUNCS.contains(fname):
                return "int"
            if STRING_RETURNING_FUNCS.contains(fname):
                return "string"
            if BYTES_RETURNING_FUNCS.contains(fname):
                return "bytes"
            if LIST_RETURNING_FUNCS.contains(fname):
                return "list"
            if LIST_STRING_RETURNING_FUNCS.contains(fname):
                return "list_string"
            if ir_func_returns.contains_key(fname):
                ret_kind := ir_func_returns[fname]
                if ret_kind == "result_int":
                    return "int"
                if ret_kind == "result_bool":
                    return "bool"
                return ir_resolve_type_hint(ret_kind)
        return ""
    # method calls
    if kind == "method_call":
        alias_fname := ir_resolve_module_alias_method_call_name(idx)
        if alias_fname.len() > 0:
            if ir_struct_names.contains_key(alias_fname):
                return alias_fname
            if FLOAT_RETURNING_FUNCS.contains(alias_fname):
                return "float"
            if BOOL_RETURNING_FUNCS.contains(alias_fname):
                return "bool"
            if INT_RETURNING_FUNCS.contains(alias_fname):
                return "int"
            if STRING_RETURNING_FUNCS.contains(alias_fname):
                return "string"
            if BYTES_RETURNING_FUNCS.contains(alias_fname):
                return "bytes"
            if LIST_RETURNING_FUNCS.contains(alias_fname):
                return "list"
            if LIST_STRING_RETURNING_FUNCS.contains(alias_fname):
                return "list_string"
            if ir_func_returns.contains_key(alias_fname):
                ret_kind := ir_func_returns[alias_fname]
                if ret_kind == "result_int":
                    return "int"
                if ret_kind == "result_bool":
                    return "bool"
                return ir_resolve_type_hint(ret_kind)
        mut meth := node_value(idx)
        if meth.starts_with("."):
            meth = meth.substring(1, meth.len())
        mut obj_type := ""
        if node.children.len() > 0:
            obj_type = ir_infer_type(node.children[0])
        impl_name := ir_lookup_impl_method_name(obj_type, meth)
        if impl_name.len() > 0 and ir_func_returns.contains_key(impl_name):
            ret_kind := ir_func_returns[impl_name]
            if ret_kind == "result_int":
                return "int"
            if ret_kind == "result_bool":
                return "bool"
            return ir_resolve_type_hint(ret_kind)
        if BOOL_RETURNING_METHODS.contains(meth):
            return "bool"
        if STRING_RETURNING_METHODS.contains(meth):
            return "string"
        if meth == "to_string_utf8":
            return "string"
        if meth == "to_float":
            return "float"
        if meth == "len":
            return "int"
        if meth == "slice" and obj_type == "bytes":
            return "bytes"
        if meth == "concat" and obj_type == "bytes":
            return "bytes"
        if meth == "index_of" and (obj_type == "list" or obj_type == "list_string" or obj_type.starts_with("list:")):
            return "int"
        if meth == "slice" or meth == "sort":
            if obj_type == "list_string":
                return "list_string"
            if obj_type == "list" or obj_type.starts_with("list:"):
                return "list"
        if meth == "keys" or meth == "values" or meth == "split" or meth == "chars":
            return "list_string"
        return ""
    if kind == "field_access":
        if node.children.len() > 0:
            fname := node_value(idx)
            if fname == "is_ok" or fname == "is_err":
                return "bool"
            if fname == "ok":
                checked := ir_checked_type(node.children[0])
                if checked.len() > 0:
                    return checked
            obj_type := ir_infer_type(node.children[0])
            if obj_type.len() > 0:
                lookup_key := obj_type + "." + fname
                if ir_struct_field_lookup.contains_key(lookup_key):
                    return ir_struct_field_lookup[lookup_key]
        return ""
    if kind == "struct_init":
        return ir_resolve_type_hint(node.value)
    # index — depends on collection type
    if kind == "index" and node.children.len() > 0:
        checked_index := ir_checked_index_type(idx)
        if checked_index.len() > 0:
            return checked_index
        coll_type := ir_infer_type(node.children[0])
        if coll_type == "string":
            return "string"
        if coll_type == "bytes":
            return "int"
        if coll_type == "list_string":
            return "string"
        if coll_type == "map" or coll_type == "map_int":
            return ir_lookup_map_value_type_for_expr(node.children[0])
        return ""
    return ""

fn ir_lookup_name_type(name: String) -> String:
    if ir_var_types.contains_key(name):
        return ir_var_types[name]
    if ir_global_int_names.contains(name):
        return "int"
    if ir_global_string_names.contains(name):
        return "string"
    if ir_global_list_string_names.contains(name):
        return "list_string"
    if ir_global_list_names.contains(name):
        return "list"
    if ir_global_map_int_names.contains(name):
        return "map_int"
    if ir_global_map_names.contains(name):
        return "map"
    if ir_global_set_int_names.contains(name):
        return "set_int"
    if ir_global_set_names.contains(name):
        return "set"
    if ir_global_bool_names.contains(name):
        return "bool"
    return ""

fn ir_emit_value_for_target(val_idx: Int, target_type: String) -> Int:
    vn := get_node(val_idx)
    if vn.kind == "map" and vn.children.len() == 0 and target_type == "map_int":
        r := ir_reg()
        ir_emit_call0(r, "__map_new_int", "map_int")
        return r
    if vn.kind == "set" and vn.children.len() == 0 and target_type == "set_int":
        r := ir_reg()
        ir_emit_call0(r, "__set_new_int", "set_int")
        return r
    return ir_expr(val_idx)

fn ir_checked_target_type(target_idx: Int, fallback_name: String) -> String:
    checked := ir_checked_type(target_idx)
    if checked.len() > 0:
        return checked
    if fallback_name.len() > 0:
        return ir_lookup_name_type(fallback_name)
    return ""

# --- method call dispatch (extracted from ir_expr) ---
fn ir_emit_method_call(idx: Int) -> Int:
    node := get_node(idx)
    # first child is object, then args. value is method_name (may have leading dot)
    mut mname := node_value(idx)
    if mname.starts_with("."):
        mname = mname.substring(1, mname.len())

    alias_fname := ir_resolve_module_alias_method_call_name(idx)
    if alias_fname.len() > 0:
        mut arg_regs: List[Int] := []
        mut arg_idx := 1
        while arg_idx < node.children.len():
            child := node.children[arg_idx]
            child_kind := node_kind(child)
            if child_kind == "arg":
                cn := get_node(child)
                if cn.children.len() > 0:
                    arg_regs.push(ir_expr(cn.children[0]))
            else:
                arg_regs.push(ir_expr(child))
            arg_idx = arg_idx + 1
        r := ir_reg()
        mut call_text := ""
        mut ai := 0
        while ai < arg_regs.len():
            call_text = call_text + " " + arg_regs[ai].to_string()
            ai = ai + 1
        uses_result_abi := ir_func_returns.contains_key(alias_fname) or ir_checked_result_kind(idx).len() > 0
        ir_emit_call_text(r, alias_fname, ir_call_retkind(idx, uses_result_abi), arg_regs.len(), call_text)
        return r

    # infer receiver type using centralized type inference
    mut obj_type := ""
    if node.children.len() > 0:
        obj_type = ir_checked_type(node.children[0])
        if obj_type.len() == 0:
            obj_type = ir_infer_type(node.children[0])

    obj_is_string := obj_type == "string"
    obj_is_bytes := obj_type == "bytes"
    obj_is_bool := obj_type == "bool"
    obj_is_float := obj_type == "float"
    obj_is_map := obj_type == "map" or obj_type == "map_int"
    obj_is_map_int := obj_type == "map_int"
    obj_is_set_int := obj_type == "set_int"
    obj_is_set := obj_type == "set" or obj_type == "set_int"
    obj_is_list := obj_type == "list" or obj_type == "list_string" or obj_type.starts_with("list:")

    mut emit_name := mname
    if mname == "to_string":
        if obj_is_float:
            emit_name = "float_to_string"
        elif obj_is_bool:
            emit_name = "bool_to_string"
        elif obj_is_string:
            emit_name = "identity"
        elif obj_type == "":
            emit_name = "smart_to_string"
    elif mname == "len":
        if obj_is_string:
            emit_name = "string_len"
        elif obj_is_bytes:
            emit_name = "bytes_len"
        elif obj_is_list:
            emit_name = "forge_list_len"
        elif obj_is_map:
            emit_name = "map_len"
        elif obj_is_set:
            emit_name = "set_len"
    elif mname == "contains":
        if obj_type == "list_string":
            emit_name = "list_contains_string"
        elif obj_is_list:
            emit_name = "list_contains"
        elif obj_is_set_int:
            emit_name = "set_contains_int"
        elif obj_is_set:
            emit_name = "set_contains"
    elif mname == "index_of":
        if obj_type == "list_string":
            emit_name = "list_index_of_string"
        elif obj_is_list:
            emit_name = "list_index_of"
    elif mname == "sort":
        if obj_type == "list_string":
            emit_name = "sort_strings"
    elif mname == "reverse":
        if obj_is_list:
            emit_name = "list_reverse"
    elif mname == "add":
        if obj_is_set_int:
            emit_name = "set_add_int"
        elif obj_is_set:
            emit_name = "set_add"
    elif mname == "is_empty":
        if obj_is_string:
            emit_name = "string_is_empty"
        elif obj_is_bytes:
            emit_name = "bytes_is_empty"
        elif obj_is_list:
            emit_name = "list_is_empty"
        elif obj_is_map:
            emit_name = "map_is_empty"
        elif obj_is_set:
            emit_name = "set_is_empty"
    elif mname == "clear":
        if obj_is_list:
            emit_name = "list_clear"
        elif obj_is_map:
            emit_name = "map_clear"
        elif obj_is_set:
            emit_name = "set_clear"
    elif mname == "remove":
        if obj_is_map_int:
            emit_name = "map_remove_ikey"
        elif obj_is_map:
            emit_name = "map_remove"
        elif obj_is_set_int:
            emit_name = "set_remove_int"
        elif obj_is_set:
            emit_name = "set_remove"
    elif mname == "keys":
        if obj_is_map:
            emit_name = "map_keys"
    elif mname == "values":
        if obj_is_map:
            emit_name = "map_values"
    elif mname == "contains_key" and obj_is_map_int:
        emit_name = "map_contains_ikey"
    elif mname == "insert" and obj_is_map_int:
        emit_name = "map_insert_ikey"
    elif mname == "slice" and obj_is_bytes:
        emit_name = "bytes_slice"
    elif mname == "concat" and obj_is_bytes:
        emit_name = "bytes_concat"
    elif mname == "to_string_utf8" and obj_is_bytes:
        emit_name = "bytes_to_string_utf8"
    if BOOL_RETURNING_METHODS.contains(emit_name):
        ir_var_types.insert("__last_call", "bool")

    impl_name := ir_lookup_impl_method_name(obj_type, mname)
    impl_dispatch := impl_name.len() > 0
    if impl_dispatch:
        emit_name = impl_name

    mut obj_r := 0 - 1
    mut arg_regs: List[Int] := []
    mut _fi3 := 0
    kids3_children := node.children
    while _fi3 < kids3_children.len():
        child := kids3_children[_fi3]
        if obj_r < 0:
            obj_r = ir_expr(child)
        else:
            child_kind := node_kind(child)
            if child_kind == "arg":
                cn := get_node(child)
                if cn.children.len() > 0:
                    ar := ir_expr(cn.children[0])
                    arg_regs.push(ar)
            else:
                arg_regs.push(ir_expr(child))
        _fi3 = _fi3 + 1
    mut call_regs: List[Int] := []
    call_regs.push(obj_r)
    mut ci := 0
    while ci < arg_regs.len():
        call_regs.push(arg_regs[ci])
        ci = ci + 1
    r := ir_reg()
    uses_result_abi := impl_dispatch or ir_func_returns.contains_key(emit_name) or ir_checked_result_kind(idx).len() > 0
    mut ret_type := ir_call_retkind(idx, uses_result_abi)
    if VOID_METHODS.contains(emit_name):
        ret_type = "void"
    mut call_text := " " + obj_r.to_string()
    mut ci2 := 0
    while ci2 < arg_regs.len():
        call_text = call_text + " " + arg_regs[ci2].to_string()
        ci2 = ci2 + 1
    ir_emit_call_text(r, emit_name, ret_type, call_regs.len(), call_text)
    if VOID_METHODS.contains(emit_name):
        return obj_r
    return r

# --- string interpolation (extracted from ir_expr) ---
fn ir_emit_string_interp(idx: Int) -> Int:
    node := get_node(idx)
    # concatenate literal parts and expression parts
    mut result_r := 0 - 1
    mut _fi4 := 0
    kids4_children := node.children
    while _fi4 < kids4_children.len():
        child := kids4_children[_fi4]
        mut cn := get_node(child)
        mut part_r := 0
        if cn.kind == "lit":
            si := ir_str(cn.value)
            part_r = ir_reg()
            ir_emit("strref " + part_r.to_string() + " " + si)
        else:
            part_r = ir_expr(child)
            # wrap non-string expressions with appropriate to_string
            expr_type := ir_infer_type(child)
            if expr_type == "bool":
                br := ir_reg()
                ir_emit_call1(br, "bool_to_string", "string", part_r)
                part_r = br
            elif expr_type == "float":
                fr := ir_reg()
                ir_emit_call1(fr, "float_to_string", "string", part_r)
                part_r = fr
            elif expr_type == "int":
                ts_r := ir_reg()
                ir_emit_call1(ts_r, "to_string", "string", part_r)
                part_r = ts_r
            elif expr_type == "":
                # unknown type — use smart_to_string for safety
                ts_r := ir_reg()
                ir_emit_call1(ts_r, "smart_to_string", "string", part_r)
                part_r = ts_r
        if result_r < 0:
            result_r = part_r
        else:
            nr := ir_reg()
            ir_emit("concat " + nr.to_string() + " " + result_r.to_string() + " " + part_r.to_string())
            result_r = nr
        _fi4 = _fi4 + 1
    if result_r < 0:
        result_r = ir_reg()
        ir_emit("strref " + result_r.to_string() + " " + ir_str(""))
    return result_r

# --- lambda compilation (extracted from ir_expr) ---
fn ir_emit_lambda(idx: Int) -> Int:
    # compile lambda body as a separate function
    lambda_name := "__lambda_" + ir_lambda_count.to_string()
    ir_lambda_count = ir_lambda_count + 1
    # collect params
    mut lparams: List[String] := []
    mut lbody_idx := 0 - 1
    mut _fi5 := 0
    while _fi5 < node_child_count(idx):
        child := node_child(idx, _fi5)
        mut cn := get_node(child)
        if cn.kind == "param":
            lparams.push(cn.value)
        elif cn.kind == "body":
            lbody_idx = child
        _fi5 = _fi5 + 1
    # detect captured variables: free vars in body that aren't params
    mut captures: List[String] := []
    if lbody_idx >= 0:
        captures = ir_find_free_vars(lbody_idx, lparams)
    # emit capture setup: store captured vars in closure env
    mut ci := 0
    while ci < captures.len():
        cap_val := ir_reg()
        ir_emit("load " + cap_val.to_string() + " " + captures[ci])
        slot := ir_reg()
        ir_emit("iconst " + slot.to_string() + " " + ci.to_string())
        ir_emit_call2(ir_reg(), "__closure_set_env", "void", slot, cap_val)
        ci = ci + 1

    # save current state and emit lambda to deferred buffer
    saved_regs := ir_next_reg
    saved_vars := ir_copy_var_regs(ir_var_regs)
    saved_types := ir_copy_var_types(ir_var_types)
    saved_lines := ir_copy_lines(ir_lines)
    ir_next_reg = 0
    ir_var_regs = {}
    ir_var_types = {}
    ir_lines = []
    ir_emit_func_header(lambda_name, lparams.len(), "unknown")
    mut lpi := 0
    while lpi < lparams.len():
        lr := ir_reg()
        ir_var_regs.insert(lparams[lpi], lr)
        ir_emit("param " + lparams[lpi])
        lpi = lpi + 1
    # load captured variables from closure env
    mut ce := 0
    while ce < captures.len():
        cap_r := ir_reg()
        slot_r := ir_reg()
        ir_emit("iconst " + slot_r.to_string() + " " + ce.to_string())
        ir_emit_call1(cap_r, "__closure_get_env", "unknown", slot_r)
        ir_var_regs.insert(captures[ce], cap_r)
        ir_emit("store " + captures[ce] + " " + cap_r.to_string())
        ce = ce + 1
    if lbody_idx >= 0:
        if node_kind(lbody_idx) == "body" and node_child_count(lbody_idx) > 0:
            br := ir_expr(node_child(lbody_idx, 0))
            ir_emit("ret " + br.to_string())
        else:
            br := ir_expr(lbody_idx)
            ir_emit("ret " + br.to_string())
    dr := ir_reg()
    ir_emit("iconst " + dr.to_string() + " 0")
    ir_emit("ret " + dr.to_string())
    ir_emit("endfunc")
    # save lambda IR and restore state
    mut li := 0
    while li < ir_lines.len():
        ir_lambda_bodies.push(ir_lines[li])
        li = li + 1
    ir_lines = saved_lines
    ir_next_reg = saved_regs
    ir_var_regs = saved_vars
    ir_var_types = saved_types
    # return function reference
    r := ir_reg()
    ir_emit("funcref " + r.to_string() + " " + lambda_name)
    return r

# --- emit expression, return register ---
fn ir_expr(idx: Int) -> Int:
    node := get_node(idx)

    if node.kind == "int_lit" or node.kind == "int" or node.kind == "integer":
        r := ir_reg()
        ir_emit("iconst " + r.to_string() + " " + node.value)
        return r

    if node.kind == "string_lit" or node.kind == "string" or node.kind == "str_lit":
        si := ir_str(node.value)
        r := ir_reg()
        ir_emit("strref " + r.to_string() + " " + si)
        return r

    if node.kind == "float_lit" or node.kind == "float":
        r := ir_reg()
        ir_emit("fconst " + r.to_string() + " " + node.value)
        return r

    if node.kind == "bool" or node.kind == "bool_lit":
        r := ir_reg()
        if node.value == "true":
            ir_emit("iconst " + r.to_string() + " 1")
        else:
            ir_emit("iconst " + r.to_string() + " 0")
        return r

    if node.kind == "ident":
        name := node.value
        r := ir_reg()
        ir_emit("load " + r.to_string() + " " + name)
        return r

    if node.kind == "self":
        r := ir_reg()
        ir_emit("load " + r.to_string() + " self")
        return r

    if node.kind == "unary":
        operand_r := ir_expr(node.children[0])
        r := ir_reg()
        if node.value == "not" or node.value == "!" or node.value == "not_op":
            # boolean not: 1 - x (flips 0→1, 1→0)
            one := ir_reg()
            ir_emit("iconst " + one.to_string() + " 1")
            ir_emit("sub " + r.to_string() + " " + one.to_string() + " " + operand_r.to_string())
        elif node.value == "neg" or node.value == "-" or node.value == "negate":
            zero := ir_reg()
            ir_emit("iconst " + zero.to_string() + " 0")
            ir_emit("sub " + r.to_string() + " " + zero.to_string() + " " + operand_r.to_string())
        elif node.value == "bit_not" or node.value == "~":
            ir_emit("bnot " + r.to_string() + " " + operand_r.to_string())
        else:
            ir_emit("iconst " + r.to_string() + " 0")
        return r

    if node.kind == "binary":
        left_r := ir_expr(node.children[0])
        right_r := ir_expr(node.children[1])
        r := ir_reg()
        op := node.value
        # detect operand types using centralized inference
        left_type := ir_infer_type(node.children[0])
        right_type := ir_infer_type(node.children[1])
        is_str_op := left_type == "string" or right_type == "string"
        is_bytes_op := left_type == "bytes" and right_type == "bytes"
        is_float_op := left_type == "float" or right_type == "float"
        if is_float_op and (op == "add" or op == "sub" or op == "mul" or op == "div"):
            ir_emit("f" + op + " " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
            return r
        if op == "add" and is_str_op:
            ir_emit("concat " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "add" and not is_str_op:
            ir_emit("add " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "sub":
            ir_emit("sub " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "mul":
            ir_emit("mul " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "div":
            ir_emit("div " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "mod":
            ir_emit("mod " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "eq":
            if is_str_op:
                ir_emit_call2(r, "__str_eq", "bool", left_r, right_r)
            elif is_bytes_op:
                ir_emit_call2(r, "bytes_eq", "bool", left_r, right_r)
            else:
                ir_emit("eq " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "neq":
            if is_str_op:
                # str_neq = 1 - str_eq
                eq_r := ir_reg()
                ir_emit_call2(eq_r, "__str_eq", "bool", left_r, right_r)
                one_r := ir_reg()
                ir_emit("iconst " + one_r.to_string() + " 1")
                ir_emit("sub " + r.to_string() + " " + one_r.to_string() + " " + eq_r.to_string())
            elif is_bytes_op:
                eq_r := ir_reg()
                ir_emit_call2(eq_r, "bytes_eq", "bool", left_r, right_r)
                one_r := ir_reg()
                ir_emit("iconst " + one_r.to_string() + " 1")
                ir_emit("sub " + r.to_string() + " " + one_r.to_string() + " " + eq_r.to_string())
            else:
                ir_emit("neq " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "lt":
            ir_emit("lt " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "gt":
            ir_emit("gt " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "lte":
            ir_emit("lte " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "gte":
            ir_emit("gte " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "bit_and":
            ir_emit("band " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "bit_or":
            ir_emit("bor " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "bit_xor":
            ir_emit("bxor " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "shl":
            ir_emit("shl " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "shr":
            ir_emit("shr " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "and":
            ir_emit("and " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        elif op == "or":
            ir_emit("or " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        else:
            ir_emit("binop " + r.to_string() + " " + op + " " + left_r.to_string() + " " + right_r.to_string())
        return r

    if node.kind == "call":
        # children: callee, then arg nodes
        mut fname := ""
        mut arg_regs: List[Int] := []
        mut _fi6 := 0
        kids6_children := node.children
        while _fi6 < kids6_children.len():
            child := kids6_children[_fi6]
            child_kind := node_kind(child)
            if _fi6 == 0:
                fname = ir_resolve_static_callee_name(child)
            elif child_kind == "arg":
                cn := get_node(child)
                if cn.children.len() > 0:
                    ar := ir_expr(cn.children[0])
                    arg_regs.push(ar)
            _fi6 = _fi6 + 1
        if fname.len() == 0:
            fname = "unknown"

        if ir_emit_tests and fname == "assert" and arg_regs.len() >= 1:
            ok_l := ir_label()
            fail_l := ir_label()
            ir_emit("brif " + arg_regs[0].to_string() + " " + ok_l + " " + fail_l)
            ir_emit("label " + fail_l)
            assert_r := ir_reg()
            ir_emit_call1(assert_r, "assert", "unknown", arg_regs[0])
            one_r := ir_reg()
            ir_emit("iconst " + one_r.to_string() + " 1")
            exit_r := ir_reg()
            ir_emit_call1(exit_r, "exit", "unknown", one_r)
            ir_emit("label " + ok_l)
            r := ir_reg()
            ir_emit("iconst " + r.to_string() + " 0")
            return r
        if ir_emit_tests and fname == "assert_eq" and arg_regs.len() >= 2:
            cmp_r := ir_reg()
            mut left_type := ""
            mut right_type := ""
            if node.children.len() > 1:
                mut left_idx := node.children[1]
                left_node := get_node(left_idx)
                if left_node.kind == "arg" and left_node.children.len() > 0:
                    left_idx = left_node.children[0]
                left_type = ir_infer_type(left_idx)
            if node.children.len() > 2:
                mut right_idx := node.children[2]
                right_node := get_node(right_idx)
                if right_node.kind == "arg" and right_node.children.len() > 0:
                    right_idx = right_node.children[0]
                right_type = ir_infer_type(right_idx)
            if left_type == "bytes" and right_type == "bytes":
                ir_emit_call2(cmp_r, "bytes_eq", "bool", arg_regs[0], arg_regs[1])
            else:
                ir_emit("eq " + cmp_r.to_string() + " " + arg_regs[0].to_string() + " " + arg_regs[1].to_string())
            ok_l := ir_label()
            fail_l := ir_label()
            ir_emit("brif " + cmp_r.to_string() + " " + ok_l + " " + fail_l)
            ir_emit("label " + fail_l)
            assert_r := ir_reg()
            ir_emit_call2(assert_r, "assert_eq", "int", arg_regs[0], arg_regs[1])
            one_r := ir_reg()
            ir_emit("iconst " + one_r.to_string() + " 1")
            exit_r := ir_reg()
            ir_emit_call1(exit_r, "exit", "unknown", one_r)
            ir_emit("label " + ok_l)
            r := ir_reg()
            ir_emit("iconst " + r.to_string() + " 0")
            return r
        if ir_emit_tests and fname == "assert_ne" and arg_regs.len() >= 2:
            cmp_r := ir_reg()
            mut left_type := ""
            mut right_type := ""
            if node.children.len() > 1:
                mut left_idx := node.children[1]
                left_node := get_node(left_idx)
                if left_node.kind == "arg" and left_node.children.len() > 0:
                    left_idx = left_node.children[0]
                left_type = ir_infer_type(left_idx)
            if node.children.len() > 2:
                mut right_idx := node.children[2]
                right_node := get_node(right_idx)
                if right_node.kind == "arg" and right_node.children.len() > 0:
                    right_idx = right_node.children[0]
                right_type = ir_infer_type(right_idx)
            if left_type == "bytes" and right_type == "bytes":
                eq_r := ir_reg()
                ir_emit_call2(eq_r, "bytes_eq", "bool", arg_regs[0], arg_regs[1])
                one_r := ir_reg()
                ir_emit("iconst " + one_r.to_string() + " 1")
                ir_emit("sub " + cmp_r.to_string() + " " + one_r.to_string() + " " + eq_r.to_string())
            else:
                ir_emit("neq " + cmp_r.to_string() + " " + arg_regs[0].to_string() + " " + arg_regs[1].to_string())
            ok_l := ir_label()
            fail_l := ir_label()
            ir_emit("brif " + cmp_r.to_string() + " " + ok_l + " " + fail_l)
            ir_emit("label " + fail_l)
            assert_r := ir_reg()
            ir_emit_call2(assert_r, "assert_ne", "int", arg_regs[0], arg_regs[1])
            one_r := ir_reg()
            ir_emit("iconst " + one_r.to_string() + " 1")
            exit_r := ir_reg()
            ir_emit_call1(exit_r, "exit", "unknown", one_r)
            ir_emit("label " + ok_l)
            r := ir_reg()
            ir_emit("iconst " + r.to_string() + " 0")
            return r

        r := ir_reg()
        mut call_text := ""
        mut ai := 0
        while ai < arg_regs.len():
            call_text = call_text + " " + arg_regs[ai].to_string()
            ai = ai + 1
        uses_result_abi := ir_static_callee_uses_result_abi(node.children[0]) or ir_checked_result_kind(idx).len() > 0
        ir_emit_call_text(r, fname, ir_call_retkind(idx, uses_result_abi), arg_regs.len(), call_text)
        return r

    else:
        return ir_expr_complex(idx, node)

fn ir_expr_complex(idx: Int, node: Node) -> Int:
    kind := node_kind(idx)
    if kind == "method_call":
        return ir_emit_method_call(idx)

    if kind == "string_interp":
        return ir_emit_string_interp(idx)

    if kind == "map":
        # map literal: create map and insert entries
        map_r := ir_reg()
        # check if entries have int keys
        mut has_int_keys := false
        if node.children.len() > 0:
            first_entry := get_node(node.children[0])
            if first_entry.kind == "entry" and first_entry.children.len() > 0:
                k_node := get_node(first_entry.children[0])
                if k_node.kind == "int_lit" or k_node.kind == "int":
                    has_int_keys = true
        if has_int_keys:
            ir_emit_call0(map_r, "__map_new_int", "map_int")
        else:
            ir_emit_call0(map_r, "__map_new", "map")
        # insert each entry (children are entry nodes with key/value pairs)
        mut _fi7 := 0
        kids7_children := node.children
        while _fi7 < kids7_children.len():
            child := kids7_children[_fi7]
            entry := get_node(child)
            if entry.kind == "entry" and entry.children.len() >= 2:
                k_r := ir_expr(entry.children[0])
                v_r := ir_expr(entry.children[1])
                ir_emit_call3(ir_reg(), "insert", "void", map_r, k_r, v_r)
            _fi7 = _fi7 + 1
        return map_r

    if kind == "set":
        set_r := ir_reg()
        mut set_type := ir_checked_type(idx)
        if set_type.len() == 0:
            set_type = ir_infer_type(idx)
        if set_type == "set_int":
            ir_emit_call0(set_r, "__set_new_int", "set_int")
        else:
            ir_emit_call0(set_r, "__set_new", "set")
        mut _fi8 := 0
        kids8_children := node.children
        while _fi8 < kids8_children.len():
            child := kids8_children[_fi8]
            elem_r := ir_expr(child)
            ir_emit_call2(ir_reg(), "set_add", "void", set_r, elem_r)
            _fi8 = _fi8 + 1
        return set_r

    if kind == "list":
        # list literal: create list, push each element
        list_r := ir_reg()
        ir_emit_call0(list_r, "__list_new", "list")
        mut _fi9 := 0
        kids9_children := node.children
        while _fi9 < kids9_children.len():
            child := kids9_children[_fi9]
            elem_r := ir_expr(child)
            ir_emit_call2(ir_reg(), "__list_push", "void", list_r, elem_r)
            _fi9 = _fi9 + 1
        return list_r

    if kind == "tuple":
        # tuple literal: allocate struct and store elements
        mut elem_regs: List[Int] := []
        mut _fi10 := 0
        kids10_children := node.children
        while _fi10 < kids10_children.len():
            child := kids10_children[_fi10]
            elem_regs.push(ir_expr(child))
            _fi10 = _fi10 + 1
        r := ir_reg()
        nf := ir_reg()
        ir_emit("iconst " + nf.to_string() + " " + elem_regs.len().to_string())
        ir_emit_call1(r, "__struct_alloc", "struct:tuple", nf)
        mut ti := 0
        while ti < elem_regs.len():
            ir_emit("sstore " + r.to_string() + " " + ti.to_string() + " " + elem_regs[ti].to_string())
            ti = ti + 1
        return r

    if kind == "struct_init":
        # struct initialization: allocate struct and store fields
        sname := node.value
        # count fields
        mut field_regs: List[Int] := []
        mut _fi11 := 0
        kids11_children := node.children
        while _fi11 < kids11_children.len():
            child := kids11_children[_fi11]
            cn := get_node(child)
            if cn.kind == "field_init":
                if cn.children.len() > 0:
                    fr := ir_expr(cn.children[0])
                    field_regs.push(fr)
            else:
                fr := ir_expr(child)
                field_regs.push(fr)
            _fi11 = _fi11 + 1
        # emit struct alloc + field stores
        r := ir_reg()
        ir_emit_call1(r, "__struct_alloc", "struct:" + sname, field_regs.len())
        mut fi := 0
        while fi < field_regs.len():
            ir_emit("sstore " + r.to_string() + " " + fi.to_string() + " " + field_regs[fi].to_string())
            fi = fi + 1
        return r

    if kind == "field_access":
        # obj.field — emit field load instruction
        fname := node_value(idx)
        if node.children.len() > 0:
            obj_r := ir_expr(node.children[0])
            obj_tid := c_get_expr_type(node.children[0])
            expr_result_kind := ir_expr_result_kind(node.children[0])
            if obj_tid >= 0:
                obj_info := get_type_info(obj_tid)
                if obj_info.kind == "result":
                    if fname == "ok":
                        if expr_result_kind == "result_int" or expr_result_kind == "result_bool":
                            return ir_decode_result_value(obj_r, expr_result_kind)
                        result_kind := ir_retkind(get_type_name(obj_info.inner))
                        if result_kind == "result_int" or result_kind == "result_bool":
                            return ir_decode_result_value(obj_r, result_kind)
                        return obj_r
                    if fname == "is_ok" or fname == "is_err":
                        zero := ir_reg()
                        ir_emit("iconst " + zero.to_string() + " 0")
                        r := ir_reg()
                        if fname == "is_ok":
                            ir_emit("neq " + r.to_string() + " " + obj_r.to_string() + " " + zero.to_string())
                        else:
                            ir_emit("eq " + r.to_string() + " " + obj_r.to_string() + " " + zero.to_string())
                        return r
            if fname == "ok":
                if expr_result_kind == "result_int" or expr_result_kind == "result_bool":
                    return ir_decode_result_value(obj_r, expr_result_kind)
                return obj_r
            if fname == "is_ok" or fname == "is_err":
                zero := ir_reg()
                ir_emit("iconst " + zero.to_string() + " 0")
                r := ir_reg()
                if fname == "is_ok":
                    ir_emit("neq " + r.to_string() + " " + obj_r.to_string() + " " + zero.to_string())
                else:
                    ir_emit("eq " + r.to_string() + " " + obj_r.to_string() + " " + zero.to_string())
                return r
            r := ir_reg()
            obj_type := ir_infer_type(node.children[0])
            lookup_key := obj_type + "." + fname
            if ir_struct_field_index_lookup.contains_key(lookup_key):
                field_offset := ir_unpack_field_index(ir_struct_field_index_lookup[lookup_key]) * 8
                mut field_kind := "unknown"
                if ir_struct_field_lookup.contains_key(lookup_key):
                    field_kind = ir_retkind(ir_struct_field_lookup[lookup_key])
                ir_emit("field " + r.to_string() + " " + obj_r.to_string() + " " + field_offset.to_string() + " " + field_kind + " " + fname)
            else:
                ir_emit("field " + r.to_string() + " " + obj_r.to_string() + " " + fname)
            return r
        r := ir_reg()
        ir_emit("iconst " + r.to_string() + " 0")
        return r

    if kind == "lambda":
        return ir_emit_lambda(idx)

    if kind == "spawn":
        # spawn func(args) — get function address and first arg, call forge_spawn
        if node.children.len() > 0:
            inner := get_node(node.children[0])
            if inner.kind == "call":
                mut spawn_fname := "unknown"
                mut spawn_arg_r := 0 - 1
                mut _fi12 := 0
                kids12_children := inner.children
                while _fi12 < kids12_children.len():
                    sc := kids12_children[_fi12]
                    scn := get_node(sc)
                    if scn.kind == "ident" and spawn_fname == "unknown":
                        spawn_fname = scn.value
                    if scn.kind == "arg" and spawn_arg_r < 0:
                        if scn.children.len() > 0:
                            spawn_arg_r = ir_expr(scn.children[0])
                    _fi12 = _fi12 + 1
                if spawn_arg_r < 0:
                    spawn_arg_r = ir_reg()
                    ir_emit("iconst " + spawn_arg_r.to_string() + " 0")
                fn_r := ir_reg()
                ir_emit("funcref " + fn_r.to_string() + " " + spawn_fname)
                r := ir_reg()
                ir_emit_call2(r, "spawn", "unknown", fn_r, spawn_arg_r)
                return r
        r := ir_reg()
        ir_emit("iconst " + r.to_string() + " 0")
        return r

    if kind == "await":
        if node.children.len() > 0:
            task_r := ir_expr(node.children[0])
            r := ir_reg()
            ir_emit_call1(r, "await", "unknown", task_r)
            return r
        r := ir_reg()
        ir_emit("iconst " + r.to_string() + " 0")
        return r

    if kind == "try" or kind == "try_expr":
        # try expr! — evaluate and check for error
        if node.children.len() > 0:
            result_kind := ir_expr_result_kind(node.children[0])
            val_r := ir_expr(node.children[0])
            mut cond_r := val_r
            mut decoded_r := val_r
            if result_kind == "result_int" or result_kind == "result_bool":
                decoded_r = ir_decode_result_value(val_r, result_kind)
            elif result_kind.len() > 0:
                zero_cmp := ir_reg()
                ir_emit("iconst " + zero_cmp.to_string() + " 0")
                cond_r = ir_reg()
                ir_emit("neq " + cond_r.to_string() + " " + val_r.to_string() + " " + zero_cmp.to_string())
            # check if result is 0 (error sentinel)
            ok_l := ir_label()
            err_l := ir_label()
            merge_l := ir_label()
            ir_emit("brif " + cond_r.to_string() + " " + ok_l + " " + err_l)
            ir_emit("label " + ok_l)
            ir_emit("jmp " + merge_l)
            ir_emit("label " + err_l)
            zero := ir_reg()
            ir_emit("iconst " + zero.to_string() + " 0")
            ir_emit("ret " + zero.to_string())
            ir_emit("label " + merge_l)
            return decoded_r
        r := ir_reg()
        ir_emit("iconst " + r.to_string() + " 0")
        return r

    if kind == "fail":
        # fail "msg" — return 0 (error sentinel)
        if node.children.len() > 0:
            ir_expr(node.children[0])  # evaluate error msg (discard)
        zero := ir_reg()
        ir_emit("iconst " + zero.to_string() + " 0")
        ir_emit("ret " + zero.to_string())
        # unreachable block
        ub := ir_label()
        ir_emit("label " + ub)
        r := ir_reg()
        ir_emit("iconst " + r.to_string() + " 0")
        return r

    if kind == "grouped":
        if node.children.len() > 0:
            return ir_expr(node.children[0])
        r := ir_reg()
        ir_emit("iconst " + r.to_string() + " 0")
        return r

    if kind == "index":
        obj_r := ir_expr(node.children[0])
        idx_r := ir_expr(node.children[1])
        r := ir_reg()
        mut obj_type := ir_checked_type(node.children[0])
        mut value_type := ir_checked_index_type(idx)
        if obj_type.len() == 0:
            obj_type = ir_infer_type(node.children[0])
        if value_type.len() == 0:
            value_type = ir_lookup_map_value_type_for_expr(node.children[0])
        if value_type.len() == 0:
            value_type = ir_infer_type(idx)
        if obj_type == "string":
            ir_emit_call2(r, "char_at", "string", obj_r, idx_r)
        elif obj_type == "bytes":
            ir_emit_call2(r, "bytes_get", "int", obj_r, idx_r)
        elif obj_type == "map_int":
            if value_type.len() == 0:
                value_type = "unknown"
            ir_emit_call2(r, "map_get_ikey", value_type, obj_r, idx_r)
        elif obj_type == "map":
            if value_type.len() == 0:
                value_type = "unknown"
            ir_emit_call2(r, "map_get", value_type, obj_r, idx_r)
        else:
            ir_emit_call2(r, "__list_get", ir_infer_type(idx), obj_r, idx_r)
        return r

    # fallback
    r := ir_reg()
    ir_emit("iconst " + r.to_string() + " 0")
    return r

# --- emit statement ---
fn ir_stmt(idx: Int):
    node := get_node(idx)
    kind := node.kind

    if kind == "call":
        ir_expr(idx)
        return
    if kind == "method_call":
        ir_expr(idx)
        return
    if kind == "spawn":
        ir_expr(idx)
        return
    if kind == "await":
        ir_expr(idx)
        return
    if kind == "try" or kind == "try_expr":
        ir_expr(idx)
        return
    if kind == "fail":
        ir_expr(idx)
        return

    if kind == "block":
        ir_block(idx)
        return

    if kind == "return":
        if node.children.len() > 0:
            mut r := ir_expr(node.children[0])
            result_kind := ir_expr_result_kind(node.children[0])
            if ir_current_func_return_kind == "result_int" or ir_current_func_return_kind == "result_bool":
                if result_kind != ir_current_func_return_kind:
                    r = ir_encode_result_value(r, ir_current_func_return_kind)
            ir_emit("ret " + r.to_string())
        else:
            r := ir_reg()
            ir_emit("iconst " + r.to_string() + " 0")
            ir_emit("ret " + r.to_string())
        ir_last_was_ret = true
        return

    if kind == "bind" or kind == "binding":
        mut name := node.value
        # strip " mut" suffix from binding names
        if name.contains(" mut"):
            name = name.substring(0, name.len() - 4)
        elif name.contains(" "):
            name = name.split(" ")[0]
        # find type annotation and value expression
        mut val_idx := 0 - 1
        mut type_idx := 0 - 1
        mut _fi13 := 0
        kids13_children := node.children
        while _fi13 < kids13_children.len():
            child := kids13_children[_fi13]
            cn := get_node(child)
            if cn.kind == "type" or cn.kind == "generic_type":
                type_idx = child
            else:
                val_idx = child
            _fi13 = _fi13 + 1
        mut target_type := ""
        # track type from annotation with full generic information
        if type_idx >= 0:
            target_type = ir_resolve_type_node(type_idx)
            if target_type.len() > 0:
                ir_var_types.insert(name, target_type)
            map_value_type := ir_resolve_map_value_type_node(type_idx)
            if map_value_type.len() > 0:
                ir_map_value_types.insert(name, map_value_type)
        if val_idx >= 0:
            r := ir_emit_value_for_target(val_idx, target_type)
            ir_var_regs.insert(name, r)
            ir_emit("store " + name + " " + r.to_string())
            # track type from value expression using centralized inference
            if not ir_var_types.contains_key(name):
                inferred := ir_infer_type(val_idx)
                if inferred.len() > 0:
                    ir_var_types.insert(name, inferred)
        return

    if kind == "assign":
        name := node.value
        if node.children.len() > 0:
            r := ir_emit_value_for_target(node.children[0], ir_lookup_name_type(name))
            ir_var_regs.insert(name, r)
            ir_emit("store " + name + " " + r.to_string())
        return

    if kind == "assignment":
        op := node.value
        if op == "=" and node.children.len() >= 2:
            tn := get_node(node.children[0])
            name := tn.value
            target_type := ir_checked_target_type(node.children[0], name)
            r := ir_emit_value_for_target(node.children[1], target_type)
            ir_emit("store " + name + " " + r.to_string())
        elif (op == "+=" or op == "-=" or op == "*=" or op == "/=") and node.children.len() >= 2:
            tn := get_node(node.children[0])
            name := tn.value
            cur := ir_reg()
            ir_emit("load " + cur.to_string() + " " + name)
            rhs := ir_expr(node.children[1])
            res := ir_reg()
            if op == "+=":
                ir_emit("add " + res.to_string() + " " + cur.to_string() + " " + rhs.to_string())
            elif op == "-=":
                ir_emit("sub " + res.to_string() + " " + cur.to_string() + " " + rhs.to_string())
            elif op == "*=":
                ir_emit("mul " + res.to_string() + " " + cur.to_string() + " " + rhs.to_string())
            elif op == "/=":
                ir_emit("div " + res.to_string() + " " + cur.to_string() + " " + rhs.to_string())
            ir_emit("store " + name + " " + res.to_string())
        return

    ir_stmt_control(idx, node)

fn ir_stmt_control(idx: Int, node: Node):
    if node.kind == "if" or node.kind == "if_stmt":
        # children: condition, then, [elif...], [else]
        # collect all branches
        mut cond_idx := 0 - 1
        mut then_idx := 0 - 1
        mut elif_indices: List[Int] := []
        mut else_idx := 0 - 1
        mut _fi15 := 0
        kids15_children := node.children
        while _fi15 < kids15_children.len():
            child := kids15_children[_fi15]
            cn := get_node(child)
            if cond_idx < 0 and cn.kind != "then" and cn.kind != "else" and cn.kind != "elif":
                cond_idx = child
            elif cn.kind == "then":
                then_idx = child
            elif cn.kind == "elif":
                elif_indices.push(child)
            elif cn.kind == "else":
                else_idx = child

            _fi15 = _fi15 + 1
        end_label := ir_label()

        # main if
        then_label := ir_label()
        next_label := ir_label()
        if cond_idx >= 0:
            cr := ir_expr(cond_idx)
            ir_emit("brif " + cr.to_string() + " " + then_label + " " + next_label)
        ir_emit("label " + then_label)
        ir_last_was_ret = false
        if then_idx >= 0:
            ir_block(then_idx)
        if not ir_last_was_ret:
            ir_emit("jmp " + end_label)
        ir_emit("label " + next_label)

        # elif chains
        mut ei := 0
        while ei < elif_indices.len():
            elif_node := get_node(elif_indices[ei])
            # elif has: condition, block
            mut elif_cond := 0 - 1
            mut elif_body := 0 - 1
            mut _fi16 := 0
            kids16_children := elif_node.children
            while _fi16 < kids16_children.len():
                ec := kids16_children[_fi16]
                ecn := get_node(ec)
                if elif_cond < 0 and ecn.kind != "block" and ecn.kind != "then":
                    elif_cond = ec
                elif ecn.kind == "block" or ecn.kind == "then":
                    elif_body = ec
                _fi16 = _fi16 + 1
            elif_then := ir_label()
            elif_next := ir_label()
            if elif_cond >= 0:
                ecr := ir_expr(elif_cond)
                ir_emit("brif " + ecr.to_string() + " " + elif_then + " " + elif_next)
            ir_emit("label " + elif_then)
            ir_last_was_ret = false
            if elif_body >= 0:
                ir_block(elif_body)
            if not ir_last_was_ret:
                ir_emit("jmp " + end_label)
            ir_emit("label " + elif_next)
            ei = ei + 1

        # else
        if else_idx >= 0:
            ir_block(else_idx)
        ir_emit("label " + end_label)

    elif node.kind == "while" or node.kind == "while_stmt":
        head_label := ir_label()
        body_label := ir_label()
        end_label := ir_label()
        ir_emit("label " + head_label)
        if node.children.len() >= 2:
            cr := ir_expr(node.children[0])
            ir_emit("brif " + cr.to_string() + " " + body_label + " " + end_label)
            ir_emit("label " + body_label)
            ir_break_stack.push(end_label)
            ir_continue_stack.push(head_label)
            ir_block(node.children[1])
            ir_break_stack.remove(ir_break_stack.len() - 1)
            ir_continue_stack.remove(ir_continue_stack.len() - 1)
            ir_emit("jmp " + head_label)
        ir_emit("label " + end_label)

    elif node.kind == "for" or node.kind == "for_stmt":
        mut var_name := node.value
        mut idx_var_name := ""
        # handle "var, idx" syntax
        if var_name.contains(","):
            parts := var_name.split(",")
            var_name = parts[0].trim()
            if parts.len() > 1:
                idx_var_name = parts[1].trim()
        # children: iterable, body
        if node.children.len() >= 2:
            # detect string iteration
            iter_node := get_node(node.children[0])
            mut is_string_iter := false
            if iter_node.kind == "string_lit" or iter_node.kind == "string":
                is_string_iter = true
            elif iter_node.kind == "ident" and ir_var_types.contains_key(iter_node.value):
                if ir_var_types[iter_node.value] == "string":
                    is_string_iter = true

            iter_r := ir_expr(node.children[0])
            # unique for-loop variable names to support nesting
            fid := ir_for_count
            ir_for_count = ir_for_count + 1
            fi := "__for_idx_" + fid.to_string()
            fl := "__for_len_" + fid.to_string()
            ft := "__for_iter_" + fid.to_string()
            # __len = len(iter)
            len_r := ir_reg()
            if is_string_iter:
                ir_emit_call1(len_r, "string_len", "int", iter_r)
            else:
                ir_emit_call1(len_r, "len", "int", iter_r)
            # __i = 0
            idx_r := ir_reg()
            ir_emit("iconst " + idx_r.to_string() + " 0")
            ir_emit("store " + fi + " " + idx_r.to_string())
            ir_emit("store " + fl + " " + len_r.to_string())
            ir_emit("store " + ft + " " + iter_r.to_string())
            head_l := ir_label()
            body_l := ir_label()
            step_l := ir_label()
            end_l := ir_label()
            ir_emit("label " + head_l)
            # load current index and length
            ci := ir_reg()
            ir_emit("load " + ci.to_string() + " " + fi)
            cl := ir_reg()
            ir_emit("load " + cl.to_string() + " " + fl)
            cmp_r := ir_reg()
            ir_emit("lt " + cmp_r.to_string() + " " + ci.to_string() + " " + cl.to_string())
            ir_emit("brif " + cmp_r.to_string() + " " + body_l + " " + end_l)
            ir_emit("label " + body_l)
            # elem = iter[i]
            it_r := ir_reg()
            ir_emit("load " + it_r.to_string() + " " + ft)
            idx2 := ir_reg()
            ir_emit("load " + idx2.to_string() + " " + fi)
            elem_r := ir_reg()
            if is_string_iter:
                ir_emit_call2(elem_r, "char_at", "string", it_r, idx2)
                ir_var_types.insert(var_name, "string")
            else:
                ir_emit_call2(elem_r, "__list_get", "unknown", it_r, idx2)
            ir_emit("store " + var_name + " " + elem_r.to_string())
            # store index variable if present
            if idx_var_name.len() > 0:
                idx_val := ir_reg()
                ir_emit("load " + idx_val.to_string() + " " + fi)
                ir_emit("store " + idx_var_name + " " + idx_val.to_string())
                ir_var_types.insert(idx_var_name, "int")
            # body
            ir_break_stack.push(end_l)
            ir_continue_stack.push(step_l)
            ir_block(node.children[1])
            ir_break_stack.remove(ir_break_stack.len() - 1)
            ir_continue_stack.remove(ir_continue_stack.len() - 1)
            ir_emit("label " + step_l)
            # i = i + 1
            idx3 := ir_reg()
            ir_emit("load " + idx3.to_string() + " " + fi)
            one_r := ir_reg()
            ir_emit("iconst " + one_r.to_string() + " 1")
            inc_r := ir_reg()
            ir_emit("add " + inc_r.to_string() + " " + idx3.to_string() + " " + one_r.to_string())
            ir_emit("store " + fi + " " + inc_r.to_string())
            ir_emit("jmp " + head_l)
            ir_emit("label " + end_l)

# --- emit block ---
# Recursive block walker — unwrap block/body/then/else wrappers
# and emits statements in source order.
fn ir_block(idx: Int):
    kind := node_kind(idx)
    if kind == "block" or kind == "then" or kind == "else" or kind == "body":
        mut i := 0
        child_count := node_child_count(idx)
        while i < child_count:
            ir_block(node_child(idx, i))
            i = i + 1
    else:
        if kind == "call":
            ir_expr(idx)
            return
        if kind == "break":
            if ir_break_stack.len() > 0:
                ir_emit("jmp " + ir_break_stack[ir_break_stack.len() - 1])
                ir_last_was_ret = true
            return
        if kind == "continue":
            if ir_continue_stack.len() > 0:
                ir_emit("jmp " + ir_continue_stack[ir_continue_stack.len() - 1])
                ir_last_was_ret = true
            return
        if kind == "return":
            if node_child_count(idx) > 0:
                mut r := ir_expr(node_child(idx, 0))
                result_kind := ir_expr_result_kind(node_child(idx, 0))
                if ir_current_func_return_kind == "result_int" or ir_current_func_return_kind == "result_bool":
                    if result_kind != ir_current_func_return_kind:
                        r = ir_encode_result_value(r, ir_current_func_return_kind)
                ir_emit("ret " + r.to_string())
            else:
                r := ir_reg()
                ir_emit("iconst " + r.to_string() + " 0")
                ir_emit("ret " + r.to_string())
            ir_last_was_ret = true
            return
        if kind == "bind" or kind == "binding":
            mut name := node_value(idx)
            if name.contains(" mut"):
                name = name.substring(0, name.len() - 4)
            elif name.contains(" "):
                name = name.split(" ")[0]
            mut val_idx := 0 - 1
            mut type_ann := ""
            mut _bi1 := 0
            while _bi1 < node_child_count(idx):
                child := node_child(idx, _bi1)
                cn := get_node(child)
                if cn.kind == "type":
                    type_ann = cn.value
                elif cn.kind == "generic_type":
                    type_ann = cn.value
                else:
                    val_idx = child
                _bi1 = _bi1 + 1
            mut is_int_key_map := false
            if type_ann == "Map":
                mut _bi2 := 0
                while _bi2 < node_child_count(idx):
                    child2 := node_child(idx, _bi2)
                    cn2 := get_node(child2)
                    if cn2.kind == "generic_type" and cn2.children.len() > 0:
                        first_type := get_node(cn2.children[0])
                        if first_type.kind == "type" and first_type.value == "Int":
                            is_int_key_map = true
                    _bi2 = _bi2 + 1
            if type_ann.contains("Map[") or type_ann == "Map":
                if is_int_key_map:
                    ir_var_types.insert(name, "map_int")
                else:
                    ir_var_types.insert(name, "map")
                mut _bi2v := 0
                while _bi2v < node_child_count(idx):
                    child2v := node_child(idx, _bi2v)
                    if get_node(child2v).kind == "generic_type":
                        map_value_type := ir_resolve_map_value_type_node(child2v)
                        if map_value_type.len() > 0:
                            ir_map_value_types.insert(name, map_value_type)
                    _bi2v = _bi2v + 1
            else:
                resolved_type := ir_resolve_type_hint(type_ann)
                if resolved_type.len() > 0:
                    ir_var_types.insert(name, resolved_type)
            if val_idx >= 0:
                r := ir_expr(val_idx)
                ir_var_regs.insert(name, r)
                ir_emit("store " + name + " " + r.to_string())
                if not ir_var_types.contains_key(name):
                    inferred := ir_infer_type(val_idx)
                    if inferred.len() > 0:
                        ir_var_types.insert(name, inferred)
            return
        ir_stmt(idx)

# --- helpers for function emission ---

fn ir_extract_param_type(param_idx: Int) -> String:
    mut stack: List[Int] := [param_idx]
    while stack.len() > 0:
        last := stack.len() - 1
        cur_idx := stack[last]
        stack.remove(last)
        tn := get_node(cur_idx)
        if tn.kind == "type" or tn.kind == "generic_type":
            return ir_resolve_type_node(cur_idx)
        mut ci := 0
        while ci < tn.children.len():
            stack.push(tn.children[ci])
            ci = ci + 1
    return "Int"

fn ir_find_body(fn_idx: Int) -> Int:
    node := get_node(fn_idx)
    nk := node.children
    mut i := 0
    while i < nk.len():
        cn := get_node(nk[i])
        if cn.kind == "body":
            return nk[i]
        i = i + 1
    if nk.len() > 0:
        return nk[nk.len() - 1]
    return 0 - 1

fn ir_param_count(fn_idx: Int) -> Int:
    node := get_node(fn_idx)
    nk := node.children
    mut count := 0
    mut i := 0
    while i < nk.len():
        cn := get_node(nk[i])
        if cn.kind == "param":
            count = count + 1
        i = i + 1
    return count

fn ir_emit_named_param(name: String, param_type: String):
    r := ir_reg()
    ir_var_regs.insert(name, r)
    if param_type.len() > 0:
        ir_var_types.insert(name, param_type)
    ir_emit("param " + name)

fn ir_emit_fn_params(fn_idx: Int):
    node := get_node(fn_idx)
    nk := node.children
    mut i := 0
    while i < nk.len():
        cn := get_node(nk[i])
        if cn.kind == "param":
            ir_emit_named_param(cn.value, ir_extract_param_type(nk[i]))
        i = i + 1

fn ir_extract_return_type(fn_idx: Int) -> String:
    node := get_node(fn_idx)
    mut i := 0
    while i < node.children.len():
        cn := get_node(node.children[i])
        if cn.kind == "returns":
            mut j := 0
            while j < cn.children.len():
                rn := get_node(cn.children[j])
                if rn.kind == "type" or rn.kind == "generic_type" or rn.kind == "result_type":
                    return ir_resolve_type_node(cn.children[j])
                j = j + 1
        i = i + 1
    return "unknown"

fn ir_impl_method_key(type_name: String, method_name: String) -> String:
    return type_name + "." + method_name

fn ir_lookup_impl_method_name(type_name: String, method_name: String) -> String:
    if type_name.len() == 0:
        return ""
    key := ir_impl_method_key(type_name, method_name)
    if ir_impl_methods.contains_key(key):
        return ir_impl_methods[key]
    resolved := ir_resolve_type_hint(type_name)
    if resolved != type_name:
        resolved_key := ir_impl_method_key(resolved, method_name)
        if ir_impl_methods.contains_key(resolved_key):
            return ir_impl_methods[resolved_key]
    if type_name.contains("["):
        base := type_name.substring(0, type_name.index_of("["))
        base_key := ir_impl_method_key(base, method_name)
        if ir_impl_methods.contains_key(base_key):
            return ir_impl_methods[base_key]
    return ""

fn ir_collect_impl_methods(root_idx: Int):
    root := get_node(root_idx)
    mut i := 0
    while i < root.children.len():
        child := root.children[i]
        mut cn := get_node(child)
        if cn.kind == "pub" and cn.children.len() > 0:
            cn = get_node(cn.children[0])
        if cn.kind == "impl_decl":
            mut impl_type := ""
            mut j := 0
            while j < cn.children.len():
                ic := cn.children[j]
                icn := get_node(ic)
                if icn.kind == "type" and impl_type == "":
                    impl_type = icn.value
                elif icn.kind == "for_type":
                    mut k := 0
                    while k < icn.children.len():
                        ftc := icn.children[k]
                        ftn := get_node(ftc)
                        if ftn.kind == "type" or ftn.kind == "generic_type":
                            impl_type = ftn.value
                        k = k + 1
                elif icn.kind == "generic_type" and impl_type == "":
                    impl_type = icn.value
                elif icn.kind == "fn_decl" or icn.kind == "pub":
                    mut method_idx := ic
                    mut method_node := icn
                    if icn.kind == "pub" and icn.children.len() > 0:
                        method_idx = icn.children[0]
                        method_node = get_node(method_idx)
                    if method_node.kind == "fn_decl" and impl_type.len() > 0:
                        method_name := method_node.value
                        full_name := impl_type + "_" + method_name
                        key := ir_impl_method_key(impl_type, method_name)
                        ret_type := ir_extract_return_type(method_idx)
                        ir_impl_methods.insert(key, full_name)
                        ir_func_returns.insert(key, ret_type)
                        ir_func_returns.insert(full_name, ret_type)
                j = j + 1
        i = i + 1

fn ir_emit_default_return():
    dr := ir_reg()
    ir_emit("iconst " + dr.to_string() + " 0")
    ir_emit("ret " + dr.to_string())
    ir_emit("endfunc")

fn ir_collect_test_decls(root_idx: Int) -> List[Int]:
    root := get_node(root_idx)
    mut tests: List[Int] := []
    mut i := 0
    while i < root.children.len():
        child := root.children[i]
        mut cn := get_node(child)
        mut actual := child
        if cn.kind == "pub" and cn.children.len() > 0:
            actual = cn.children[0]
            cn = get_node(actual)
        if cn.kind == "test_decl":
            tests.push(actual)
        i = i + 1
    return tests

fn ir_emit_test_func(idx: Int, ordinal: Int):
    body_idx := ir_find_body(idx)

    ir_next_reg = 0
    ir_var_regs = {}
    ir_var_types = {}
    ir_map_value_types = {}
    ir_seed_global_types()
    ir_current_func_return_kind = "int"
    ir_emit_func_header("__test_" + ordinal.to_string(), 0, "int")

    if body_idx >= 0:
        ir_block(body_idx)

    ir_emit_default_return()

fn ir_emit_test_main(root_idx: Int):
    tests := ir_collect_test_decls(root_idx)
    if tests.len() == 0:
        return

    ir_next_reg = 0
    ir_var_regs = {}
    ir_var_types = {}
    ir_map_value_types = {}
    ir_seed_global_types()
    ir_current_func_return_kind = "int"
    ir_emit_func_header("main", 0, "int")

    mut i := 0
    while i < tests.len():
        test_r := ir_reg()
        ir_emit_call0(test_r, "__test_" + i.to_string(), "int")
        i = i + 1

    ir_emit_default_return()

# --- emit function ---
fn ir_func(idx: Int):
    node := get_node(idx)
    mut name := node.value
    mut full_name := name
    if name.contains("["):
        name = name.substring(0, name.index_of("["))
        full_name = name

    body_idx := ir_find_body(idx)
    param_count := ir_param_count(idx)

    ir_next_reg = 0
    ir_var_regs = {}
    ir_var_types = {}
    ir_map_value_types = {}
    ir_seed_global_types()
    mut ret_type := "unknown"
    if ir_func_returns.contains_key(full_name):
        ret_type = ir_func_returns[full_name]
    elif ir_func_returns.contains_key(name):
        ret_type = ir_func_returns[name]
    ir_current_func_return_kind = ret_type
    ir_emit_func_header(name, param_count, ret_type)
    ir_emit_fn_params(idx)

    if body_idx >= 0:
        ir_block(body_idx)

    ir_emit_default_return()

# --- emit impl method ---
fn ir_impl_func(idx: Int, impl_type: String):
    node := get_node(idx)
    orig_name := node.value
    full_name := impl_type + "_" + orig_name
    method_key := ir_impl_method_key(impl_type, orig_name)
    ir_impl_methods.insert(method_key, full_name)

    body_idx := ir_find_body(idx)
    param_count := ir_param_count(idx) + 1

    ir_next_reg = 0
    ir_var_regs = {}
    ir_var_types = {}
    ir_map_value_types = {}
    ir_seed_global_types()
    ret_type := ir_extract_return_type(idx)
    ir_current_func_return_kind = ret_type
    ir_emit_func_header(full_name, param_count, ret_type)
    ir_emit_named_param("self", impl_type)
    ir_emit_fn_params(idx)
    ir_func_returns.insert(method_key, ret_type)
    ir_func_returns.insert(full_name, ret_type)

    if body_idx >= 0:
        ir_block(body_idx)

    ir_emit_default_return()

# --- collect import renames ---
fn ir_collect_imports(root_idx: Int):
    root := get_node(root_idx)
    mut ci := 0
    while ci < root.children.len():
        cn := get_node(root.children[ci])
        if cn.kind == "import":
            mut path := cn.value
            mut alias := ""
            mut has_alias := false
            mut si := 0
            while si < cn.value.len() - 3:
                if cn.value[si] == " " and cn.value[si + 1] == "a" and cn.value[si + 2] == "s" and cn.value[si + 3] == " ":
                    path = cn.value.substring(0, si)
                    alias = cn.value.substring(si + 4, cn.value.len())
                    has_alias = true
                    break
                si = si + 1
            if has_alias:
                ir_module_aliases.insert(alias, path)
            else:
                ir_module_aliases.insert(ir_module_default_alias(path), path)
        if cn.kind == "from_import":
            parts := cn.value.split(" ")
            if parts.len() > 1:
                mod_path := parts[0]
                mut pi := 1
                while pi < parts.len():
                    iname := parts[pi]
                    if iname.len() > 0:
                        renamed := ir_import_target_name(mod_path, iname)
                        if renamed != iname:
                            ir_import_renames.insert(iname, renamed)
                    pi = pi + 1
        ci = ci + 1

# --- main entry ---
pub fn emit_ir(root_idx: Int) -> String:
    ir_reset()

    root := get_node(root_idx)
    ir_collect_strings(root_idx)

    # emit string data
    mut i := 0
    while i < ir_strings.len():
        sid := "m" + ir_module_count.to_string() + "s" + i.to_string()
        ir_emit("string " + sid + " " + chr(34) + ir_strings[i] + chr(34))
        i = i + 1

    # collect import renames
    ir_import_renames = {}
    ir_collect_imports(root_idx)

    # collect type aliases
    ir_type_aliases = {}
    mut _fi21 := 0
    kids21_children := root.children
    while _fi21 < kids21_children.len():
        child := kids21_children[_fi21]
        mut cn := get_node(child)
        if cn.kind == "type_alias":
            mut target := ""
            mut _fi33 := 0
            kids33_children := cn.children
            while _fi33 < kids33_children.len():
                tc := kids33_children[_fi33]
                tn := get_node(tc)
                if tn.kind == "type":
                    target = tn.value
                _fi33 = _fi33 + 1
            if target.len() > 0:
                ir_type_aliases.insert(cn.value, target)

        _fi21 = _fi21 + 1
    # emit struct declarations and register names (unwrap pub)
    ir_struct_names = {}
    ir_struct_field_lookup = {}
    ir_struct_field_index_lookup = {}
    ir_register_known_import_structs()
    mut _fi22 := 0
    kids22_children := root.children
    while _fi22 < kids22_children.len():
        child := kids22_children[_fi22]
        mut cn := get_node(child)
        if cn.kind == "pub" and cn.children.len() > 0:
            cn = get_node(cn.children[0])
        if cn.kind == "struct_decl":
            mut sname := cn.value
            # strip generic params like Wrapper[T] -> Wrapper
            if sname.contains("["):
                sname = sname.substring(0, sname.index_of("["))
            mut field_names: List[String] := []
            mut _fi34 := 0
            kids34_children := cn.children
            while _fi34 < kids34_children.len():
                fc := kids34_children[_fi34]
                fn_node := get_node(fc)
                if fn_node.kind == "field":
                    mut field_name := fn_node.value
                    if field_name.contains(" "):
                        field_name = field_name.split(" ")[0]
                    field_index := field_names.len()
                    field_names.push(field_name)
                    if fn_node.children.len() > 0:
                        type_node := get_node(fn_node.children[0])
                        if type_node.kind == "type" or type_node.kind == "generic_type":
                            ir_struct_field_lookup.insert(sname + "." + field_name, ir_resolve_type_node(fn_node.children[0]))
                    ir_struct_field_index_lookup.insert(sname + "." + field_name, field_index.to_string())
                _fi34 = _fi34 + 1
            ir_struct_names.insert(sname, field_names.len())
            ir_emit("struct " + sname + " " + field_names.join(" "))

        _fi22 = _fi22 + 1
    # register type aliases that point to structs
    mut _fi23 := 0
    kids23_children := root.children
    while _fi23 < kids23_children.len():
        child := kids23_children[_fi23]
        mut cn := get_node(child)
        if cn.kind == "type_alias":
            aname := cn.value
            if ir_type_aliases.contains_key(aname):
                target := ir_type_aliases[aname]
                if ir_struct_names.contains_key(target):
                    nfields := ir_struct_names[target]
                    ir_struct_names.insert(aname, nfields)
                    ir_emit("struct_alias " + aname + " " + target)

        _fi23 = _fi23 + 1
    ir_lambda_count = 0
    ir_lambda_bodies = []

    # collect function return types (unwrap pub wrappers)
    ir_func_returns = {}
    mut _fi24 := 0
    kids24_children := root.children
    while _fi24 < kids24_children.len():
        child := kids24_children[_fi24]
        mut cn := get_node(child)
        if cn.kind == "pub" and cn.children.len() > 0:
            cn = get_node(cn.children[0])
        if cn.kind == "fn" or cn.kind == "fn_decl":
            mut _fi35 := 0
            kids35_children := cn.children
            while _fi35 < kids35_children.len():
                fc := kids35_children[_fi35]
                fcn := get_node(fc)
                if fcn.kind == "returns":
                    mut _fi40 := 0
                    kids40_children := fcn.children
                    while _fi40 < kids40_children.len():
                        rc := kids40_children[_fi40]
                        rn := get_node(rc)
                        if rn.kind == "type" or rn.kind == "generic_type" or rn.kind == "result_type":
                            ir_func_returns.insert(cn.value, ir_resolve_type_node(rc))

                        _fi40 = _fi40 + 1
                _fi35 = _fi35 + 1
        _fi24 = _fi24 + 1
    mut preload_i := 0
    while preload_i < ir_preloaded_import_roots.len():
        ir_collect_impl_methods(ir_preloaded_import_roots[preload_i])
        preload_i = preload_i + 1
    ir_collect_impl_methods(root_idx)
    # emit global variables (unwrap pub)
    mut _fi25 := 0
    kids25_children := root.children
    while _fi25 < kids25_children.len():
        child := kids25_children[_fi25]
        mut cn := get_node(child)
        if cn.kind == "pub" and cn.children.len() > 0:
            cn = get_node(cn.children[0])
        if cn.kind == "bind" or cn.kind == "binding":
            mut gname := cn.value
            if gname.contains(" mut"):
                gname = gname.substring(0, gname.len() - 4)
            elif gname.contains(" "):
                gname = gname.split(" ")[0]
            # find initial value
            mut init_val := "0"
            mut global_type := ""
            mut global_map_value_type := ""
            mut _fi36 := 0
            kids36_children := cn.children
            while _fi36 < kids36_children.len():
                gc := kids36_children[_fi36]
                gcn := get_node(gc)
                if gcn.kind == "type" or gcn.kind == "generic_type":
                    global_type = ir_resolve_type_node(gc)
                    if global_map_value_type.len() == 0:
                        global_map_value_type = ir_resolve_map_value_type_node(gc)
                elif gcn.kind == "int_lit":
                    init_val = gcn.value
                    if global_type.len() == 0:
                        global_type = "int"
                elif gcn.kind == "string_lit":
                    si := ir_str(gcn.value)
                    init_val = "str:" + si
                    if global_type.len() == 0:
                        global_type = "string"
                elif gcn.kind == "list":
                    init_val = "list"
                    if global_type.len() == 0:
                        global_type = "list"
                elif gcn.kind == "map":
                    init_val = "map"
                    if global_type.len() == 0:
                        global_type = "map"
                elif gcn.kind == "set":
                    init_val = ir_checked_type(gc)
                    if init_val.len() == 0:
                        init_val = ir_infer_type(gc)
                    if init_val.len() == 0:
                        init_val = "set"
                    if global_type.len() == 0:
                        global_type = init_val
                elif gcn.kind == "bool_lit":
                    if gcn.value == "true":
                        init_val = "1"
                    else:
                        init_val = "0"
                    if global_type.len() == 0:
                        global_type = "bool"
                _fi36 = _fi36 + 1
            if global_type.len() > 0:
                if global_type == "int":
                    ir_global_int_names.push(gname)
                elif global_type == "string":
                    ir_global_string_names.push(gname)
                elif global_type == "list_string":
                    ir_global_list_string_names.push(gname)
                elif global_type == "list":
                    ir_global_list_names.push(gname)
                elif global_type == "map_int":
                    ir_global_map_int_names.push(gname)
                elif global_type == "map":
                    ir_global_map_names.push(gname)
                elif global_type == "set":
                    ir_global_set_names.push(gname)
                elif global_type == "set_int":
                    ir_global_set_int_names.push(gname)
                elif global_type == "bool":
                    ir_global_bool_names.push(gname)
            if global_map_value_type.len() > 0:
                ir_global_map_value_types.insert(gname, global_map_value_type)
            ir_emit("global " + gname + " " + init_val)

        _fi25 = _fi25 + 1
    # emit __init_globals to initialize list/map/set globals
    mut has_collection_globals := false
    mut _fi26 := 0
    kids26_children := root.children
    while _fi26 < kids26_children.len():
        child := kids26_children[_fi26]
        mut cn := get_node(child)
        if cn.kind == "pub" and cn.children.len() > 0:
            cn = get_node(cn.children[0])
        if cn.kind == "bind" or cn.kind == "binding":
            mut _fi37 := 0
            kids37_children := cn.children
            while _fi37 < kids37_children.len():
                gc := kids37_children[_fi37]
                gcn := get_node(gc)
                if gcn.kind == "list" or gcn.kind == "map" or gcn.kind == "set":
                    has_collection_globals = true
                _fi37 = _fi37 + 1
        _fi26 = _fi26 + 1
    if has_collection_globals:
        ir_emit_func_header("__init_globals", 0, "int")
        mut _fi27 := 0
        kids27_children := root.children
        while _fi27 < kids27_children.len():
            child := kids27_children[_fi27]
            mut cn := get_node(child)
            if cn.kind == "pub" and cn.children.len() > 0:
                cn = get_node(cn.children[0])
            if cn.kind == "bind" or cn.kind == "binding":
                mut gname := cn.value
                if gname.contains(" mut"):
                    gname = gname.substring(0, gname.len() - 4)
                elif gname.contains(" "):
                    gname = gname.split(" ")[0]
                mut _fi38 := 0
                kids38_children := cn.children
                while _fi38 < kids38_children.len():
                    gc := kids38_children[_fi38]
                    gcn := get_node(gc)
                    if gcn.kind == "list":
                        list_r := ir_reg()
                        ir_emit_call0(list_r, "__list_new", "list")
                        ir_emit("store " + gname + " " + list_r.to_string())
                    elif gcn.kind == "map":
                        map_r := ir_reg()
                        if ir_global_map_int_names.contains(gname):
                            ir_emit_call0(map_r, "__map_new_int", "map_int")
                        else:
                            ir_emit_call0(map_r, "__map_new", "map")
                        ir_emit("store " + gname + " " + map_r.to_string())
                    elif gcn.kind == "set":
                        set_r := ir_reg()
                        if ir_global_set_int_names.contains(gname):
                            ir_emit_call0(set_r, "__set_new_int", "set_int")
                        else:
                            ir_emit_call0(set_r, "__set_new", "set")
                        ir_emit("store " + gname + " " + set_r.to_string())
                    _fi38 = _fi38 + 1
            _fi27 = _fi27 + 1
        dr := ir_reg()
        ir_emit("iconst " + dr.to_string() + " 0")
        ir_emit("ret " + dr.to_string())
        ir_emit("endfunc")

    # emit functions (unwrap pub wrappers)
    mut _fi28 := 0
    mut test_ord := 0
    kids28_children := root.children
    while _fi28 < kids28_children.len():
        child := kids28_children[_fi28]
        cn := get_node(child)
        mut actual := child
        mut actual_node := cn
        if cn.kind == "pub" and cn.children.len() > 0:
            actual = cn.children[0]
            actual_node = get_node(actual)
        if actual_node.kind == "fn" or actual_node.kind == "fn_decl":
            if not (ir_emit_tests and actual_node.value == "main"):
                ir_func(actual)
        elif actual_node.kind == "test_decl":
            if ir_emit_tests:
                ir_emit_test_func(actual, test_ord)
                test_ord = test_ord + 1
        elif actual_node.kind == "impl_decl":
            # emit methods from impl blocks
            mut impl_type := ""
            mut _fi39 := 0
            kids39_children := cn.children
            while _fi39 < kids39_children.len():
                ic := kids39_children[_fi39]
                icn := get_node(ic)
                if icn.kind == "type":
                    impl_type = icn.value
                elif icn.kind == "for_type":
                    # impl X for TYPE — get type from for_type child
                    mut _fi41 := 0
                    kids41_children := icn.children
                    while _fi41 < kids41_children.len():
                        ftc := kids41_children[_fi41]
                        ftn := get_node(ftc)
                        if ftn.kind == "type":
                            impl_type = ftn.value
                        _fi41 = _fi41 + 1
                elif icn.kind == "generic_type" and impl_type == "":
                    # impl TYPE: — simple impl on the generic_type
                    impl_type = icn.value
                elif icn.kind == "fn_decl":
                    ir_impl_func(ic, impl_type)

                _fi39 = _fi39 + 1
        _fi28 = _fi28 + 1
    if ir_emit_tests:
        ir_emit_test_main(root_idx)
    # append deferred lambda function bodies
    mut li := 0
    while li < ir_lambda_bodies.len():
        ir_lines.push(ir_lambda_bodies[li])
        li = li + 1

    ir_module_count = ir_module_count + 1
    ir_preloaded_import_roots = []
    ir_emit_tests = false
    return ir_lines.join(chr(10))
