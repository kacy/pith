from std.fmt import format, format1, format2, format3

fn main() -> Int:
    slot := chr(123) + chr(125)
    left_escape := chr(123) + chr(123)
    right_escape := chr(125) + chr(125)
    print(format("coords: " + slot + ", " + slot, ["3", "4"]))
    print(format1("answer: " + slot, "42"))
    print(format2("user " + slot + " score " + slot, "forge", "7"))
    print(format3(slot + " " + slot + " " + slot, "a", "b", "c"))
    print(format(left_escape + slot + right_escape, ["x"]))
    print(format("left " + slot, []))
    return 0
