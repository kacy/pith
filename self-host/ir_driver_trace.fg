from lexer import lex_all
from parser import parse
from ast import reset_arena
from ir_emitter import emit_ir

fn emit_file() -> String!:
    print("[trace] start")
    source := read_file(args()[1])!
    print("[trace] read")
    tokens := lex_all(source)
    print("[trace] lexed")
    reset_arena()
    root := parse(tokens)
    print("[trace] parsed")
    ir := emit_ir(root)
    print("[trace] emitted")
    print(ir)
    return ""

fn main():
    emit_file()
