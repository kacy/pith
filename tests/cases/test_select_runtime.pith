import std.time as time

fn delayed_send(ch: Channel[Int], value: Int, ms: Int):
    time.delay(ms)
    ch.send(value)

fn main():
    immediate := Channel[Int](1)
    immediate.send(4)
    first := select:
        msg := immediate.recv() => msg?
        default => 9
    print("recv-ready:{first}")

    filled := Channel[Int](1)
    filled.send(1)
    blocked_send := select:
        filled.send(2) => 10
        default => 20
    print("send-blocked:{blocked_send}")

    ready_send_ch := Channel[Int](1)
    ready_send := select:
        ready_send_ch.send(3) => 30
        default => 40
    print("send-ready:{ready_send}")
    print("send-value:{ready_send_ch.recv()?}")

    delayed := Channel[Int](1)
    spawn delayed_send(delayed, 7, 5)
    second := select:
        msg := delayed.recv() => msg?
        timeout 50 => 11
    print("recv-timeout:{second}")

    idle := Channel[Int](1)
    timed_out := select:
        msg := idle.recv() => msg?
        timeout 5 => 12
    print("timeout-fired:{timed_out}")

    mut left_picks := 0
    mut right_picks := 0
    mut i := 0
    while i < 6:
        left := Channel[Int](1)
        right := Channel[Int](1)
        left.send(1)
        right.send(2)
        picked := select:
            l := left.recv() => l?
            r := right.recv() => r?
        if picked == 1:
            left_picks = left_picks + 1
        else:
            right_picks = right_picks + 1
        i = i + 1
    print("fair-left:{left_picks > 0}")
    print("fair-right:{right_picks > 0}")
