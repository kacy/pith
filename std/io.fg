fn process_stdin_write(writer: ProcessStdin, data: String) -> Int!:
    return process_stdin_write_bytes(writer, encode_utf8(data))

fn process_stdout_read(reader: ProcessStdout, max_bytes: Int) -> String!:
    return decode_utf8(process_stdout_read_bytes(reader, max_bytes)!)

fn process_stderr_read(reader: ProcessStderr, max_bytes: Int) -> String!:
    return decode_utf8(process_stderr_read_bytes(reader, max_bytes)!)

fn normalized_chunk_size(chunk_size: Int) -> Int:
    if chunk_size <= 0:
        return DEFAULT_CHUNK_SIZE
    return chunk_size

fn allocate_string_reader_handle(data: String) -> Int:
    handle := next_string_reader_handle
    next_string_reader_handle = next_string_reader_handle + 1
    string_reader_data.insert(handle, data)
    string_reader_offsets.insert(handle, 0)
    return handle

fn allocate_string_buffer_handle() -> Int:
    handle := next_string_buffer_handle
    next_string_buffer_handle = next_string_buffer_handle + 1
    string_buffer_parts.insert(handle, empty_string_parts())
    string_buffer_lengths.insert(handle, 0)
    return handle

fn allocate_bytes_reader_handle(data: Bytes) -> Int:
    handle := next_bytes_reader_handle
    next_bytes_reader_handle = next_bytes_reader_handle + 1
    bytes_reader_data.insert(handle, data)
    bytes_reader_offsets.insert(handle, 0)
    return handle

fn allocate_buffered_bytes_reader_handle(source_kind: Int, source_handle: Int, chunk_size: Int) -> Int:
    handle := next_buffered_bytes_reader_handle
    next_buffered_bytes_reader_handle = next_buffered_bytes_reader_handle + 1
    buffered_bytes_reader_source_kinds.insert(handle, source_kind)
    buffered_bytes_reader_source_handles.insert(handle, source_handle)
    buffered_bytes_reader_chunk_sizes.insert(handle, normalized_chunk_size(chunk_size))
    buffered_bytes_reader_cache.insert(handle, bytes.empty())
    return handle

fn make_buffered_bytes_reader(source_kind: Int, source_handle: Int, chunk_size: Int) -> BufferedBytesReader:
    return BufferedBytesReader(allocate_buffered_bytes_reader_handle(source_kind, source_handle, chunk_size))

fn allocate_buffered_bytes_writer_handle(target_kind: Int, target_handle: Int, chunk_size: Int) -> Int:
    handle := next_buffered_bytes_writer_handle
    next_buffered_bytes_writer_handle = next_buffered_bytes_writer_handle + 1
    buffered_bytes_writer_target_kinds.insert(handle, target_kind)
    buffered_bytes_writer_target_handles.insert(handle, target_handle)
    buffered_bytes_writer_chunk_sizes.insert(handle, normalized_chunk_size(chunk_size))
    buffered_bytes_writer_cache.insert(handle, bytes.empty())
    return handle

fn make_buffered_bytes_writer(target_kind: Int, target_handle: Int, chunk_size: Int) -> BufferedBytesWriter:
    return BufferedBytesWriter(allocate_buffered_bytes_writer_handle(target_kind, target_handle, chunk_size))

fn allocate_buffered_string_reader_handle(source_handle: Int, chunk_size: Int) -> Int:
    handle := next_buffered_string_reader_handle
    next_buffered_string_reader_handle = next_buffered_string_reader_handle + 1
