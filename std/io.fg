fn empty_string_parts() -> List[String]:
    mut parts: List[String] := []
    return parts

fn string_buffer_chunks(buf: StringBuffer) -> List[String]:
    if string_buffer_parts.contains_key(buf.handle):
        return string_buffer_parts[buf.handle]
    return empty_string_parts()

fn string_buffer_len(buf: StringBuffer) -> Int:
    if string_buffer_lengths.contains_key(buf.handle):
        return string_buffer_lengths[buf.handle]
    return 0

fn string_buffer_string(buf: StringBuffer) -> String:
    parts := string_buffer_chunks(buf)
    if parts.len() == 0:
        return ""
    if parts.len() == 1:
        return parts[0]
    return parts.join("")

fn string_buffer_write_line(buf: StringBuffer, data: String) -> Int!:
    wrote := string_buffer_write_internal(buf, data)
    if wrote.is_err:
        return wrote
    wrote_nl := string_buffer_write_internal(buf, chr(10))
    if wrote_nl.is_err:
        return wrote_nl
    return wrote.ok + wrote_nl.ok

fn string_buffer_reset(buf: StringBuffer):
    string_buffer_parts.insert(buf.handle, empty_string_parts())
    string_buffer_lengths.insert(buf.handle, 0)

fn string_buffer_append_chunk(buf: StringBuffer, data: String):
    parts := string_buffer_chunks(buf)
    parts.push(data)
    string_buffer_parts.insert(buf.handle, parts)
    string_buffer_lengths.insert(buf.handle, string_buffer_len(buf) + data.len())

fn string_buffer_compact(buf: StringBuffer):
    parts := string_buffer_chunks(buf)
    if parts.len() <= 1:
        return
    joined := parts.join("")
    mut compacted: List[String] := []
    compacted.push(joined)
    string_buffer_parts.insert(buf.handle, compacted)
    string_buffer_lengths.insert(buf.handle, joined.len())

fn string_buffer_maybe_compact(buf: StringBuffer):
    if string_buffer_chunks(buf).len() >= 32:
        string_buffer_compact(buf)

fn string_buffer_clear(buf: StringBuffer):
    string_buffer_reset(buf)

