fn write_all_buffered_bytes_writer(writer: BufferedBytesWriter, data: Bytes) -> Int!:
    mut total := 0
    mut remaining := data
    while not remaining.is_empty():
        wrote := writer.write_bytes(remaining)!
        if wrote <= 0:
            fail "write returned 0"
        total = total + wrote
        remaining = bytes_after_write(remaining, wrote)
    return total

fn buffered_bytes_reader_read_internal(reader: BufferedBytesReader, max_bytes: Int) -> Bytes!:
    if max_bytes <= 0:
        return bytes.empty()
    if not buffered_bytes_reader_source_handles.contains_key(reader.handle):
        return bytes.empty()

    buf := bytes.buffer_with_capacity(max_bytes)
    while buf.bytes().len() < max_bytes:
        mut cached := buffered_bytes_reader_cache_get(reader.handle)
        if cached.is_empty():
            filled := buffered_bytes_reader_fill(reader.handle)!
            if filled <= 0:
                return buf.bytes()
            cached = buffered_bytes_reader_cache_get(reader.handle)
        mut take := max_bytes - buf.bytes().len()
        if take > cached.len():
            take = cached.len()
        buf.write(cached.slice(0, take))!
        buffered_bytes_reader_consume(reader.handle, take)
    return buf.bytes()

fn buffered_bytes_reader_fill(handle: Int) -> Int!:
    if not buffered_bytes_reader_source_handles.contains_key(handle):
        return 0

    source_kind := buffered_bytes_reader_source_kinds[handle]
    source_handle := buffered_bytes_reader_source_handles[handle]
    mut chunk_size := DEFAULT_CHUNK_SIZE
    if buffered_bytes_reader_chunk_sizes.contains_key(handle):
        chunk_size = buffered_bytes_reader_chunk_sizes[handle]

    mut chunk := bytes.empty()
    if source_kind == BUFFERED_BYTES_SOURCE_CURSOR:
        chunk = bytes_cursor_read(BytesCursor(source_handle), chunk_size)!
    elif source_kind == BUFFERED_BYTES_SOURCE_TCP:
        chunk = tcp_stream_read_bytes(TcpStream(source_handle), chunk_size)!
    elif source_kind == BUFFERED_BYTES_SOURCE_FILE:
        chunk = file_stream_read_bytes(FileStream(source_handle), chunk_size)!
    elif source_kind == BUFFERED_BYTES_SOURCE_PROCESS_STDOUT:
        chunk = process_stdout_read_bytes(ProcessStdout(source_handle), chunk_size)!
    elif source_kind == BUFFERED_BYTES_SOURCE_PROCESS_STDERR:
        chunk = process_stderr_read_bytes(ProcessStderr(source_handle), chunk_size)!
    buffered_bytes_reader_cache.insert(handle, chunk)
    return chunk.len()

fn buffered_bytes_writer_write_internal(writer: BufferedBytesWriter, data: Bytes) -> Int!:
    if not buffered_bytes_writer_target_handles.contains_key(writer.handle):
        return 0

    cached := buffered_bytes_writer_cache_get(writer.handle)
    buffered_bytes_writer_cache.insert(writer.handle, cached.concat(data))
    if buffered_bytes_writer_should_flush(writer.handle):
        buffered_bytes_writer_flush_internal(writer)!
    return data.len()

fn buffered_bytes_writer_flush_internal(writer: BufferedBytesWriter) -> Int!:
    if not buffered_bytes_writer_target_handles.contains_key(writer.handle):
        return 0

    cached := buffered_bytes_writer_cache_get(writer.handle)
    if cached.is_empty():
        return 0

    target_kind := buffered_bytes_writer_target_kinds[writer.handle]
    target_handle := buffered_bytes_writer_target_handles[writer.handle]
    mut wrote := 0
    if target_kind == BUFFERED_BYTES_TARGET_BUFFER:
        wrote = write_all_byte_buffer(ByteBuffer(target_handle), cached)!
    elif target_kind == BUFFERED_BYTES_TARGET_TCP:
        wrote = write_all_tcp_stream_bytes(TcpStream(target_handle), cached)!
    elif target_kind == BUFFERED_BYTES_TARGET_FILE:
        wrote = write_all_file_stream_bytes(FileStream(target_handle), cached)!
    elif target_kind == BUFFERED_BYTES_TARGET_PROCESS_STDIN:
        wrote = write_all_process_stdin_bytes(ProcessStdin(target_handle), cached)!
    buffered_bytes_writer_cache.insert(writer.handle, bytes.empty())
    return wrote

fn buffered_string_reader_read_internal(reader: BufferedStringReader, max_bytes: Int) -> String!:
    if max_bytes <= 0:
        return ""
    if not buffered_string_reader_sources.contains_key(reader.handle):
        return ""

    mut result := ""
    while result.len() < max_bytes:
        mut cached := buffered_string_reader_cache_get(reader.handle)
        if cached.len() == 0:
            filled := buffered_string_reader_fill(reader.handle)!
            if filled <= 0:
                return result
            cached = buffered_string_reader_cache_get(reader.handle)
        mut take := max_bytes - result.len()
        if take > cached.len():
            take = cached.len()
        result = result + cached.substring(0, take)
        buffered_string_reader_consume(reader.handle, take)
    return result

fn buffered_string_reader_read_line_internal(reader: BufferedStringReader) -> String!:
    if not buffered_string_reader_sources.contains_key(reader.handle):
        return ""

    mut result := ""
    while true:
        mut cached := buffered_string_reader_cache_get(reader.handle)
        if cached.len() == 0:
            filled := buffered_string_reader_fill(reader.handle)!
            if filled <= 0:
                return result
            cached = buffered_string_reader_cache_get(reader.handle)
        newline := find_newline(cached)
        if newline >= 0:
            result = result + cached.substring(0, newline)
            buffered_string_reader_consume(reader.handle, newline + 1)
            return trim_trailing_cr(result)
        result = result + cached
        buffered_string_reader_cache.insert(reader.handle, "")

fn buffered_string_reader_fill(handle: Int) -> Int!:
    if not buffered_string_reader_sources.contains_key(handle):
        return 0

    source_handle := buffered_string_reader_sources[handle]
    mut chunk_size := DEFAULT_CHUNK_SIZE
    if buffered_string_reader_chunk_sizes.contains_key(handle):
        chunk_size = buffered_string_reader_chunk_sizes[handle]

