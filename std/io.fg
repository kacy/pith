fn remaining_after_write(data: String, wrote: Int) -> String:
    if wrote >= data.len():
        return ""
    return data.substring(wrote, data.len())

fn cache_after_consume(cached: String, consumed: Int) -> String:
    if consumed >= cached.len():
        return ""
    return cached.substring(consumed, cached.len())

fn trim_trailing_cr(line: String) -> String:
    if line.len() == 0:
        return ""
    end := line.len()
    if line.substring(end - 1, end) == chr(13):
        return line.substring(0, end - 1)
    return line

fn find_newline(data: String) -> Int:
    mut i := 0
    while i < data.len():
        if data.substring(i, i + 1) == chr(10):
            return i
        i = i + 1
    return -1

pub fn read_all_string(reader: StringReader) -> String!:
    return read_all_string_chunked(reader, DEFAULT_CHUNK_SIZE)

pub fn read_all_string_chunked(reader: StringReader, chunk_size: Int) -> String!:
    size := normalized_chunk_size(chunk_size)
    mut result := ""
    mut chunk := string_reader_read(reader, size)!
    while chunk.len() > 0:
        result = result + chunk
        chunk = string_reader_read(reader, size)!
    return result

pub fn write_all_string(writer: StringBuffer, data: String) -> Int!:
    mut total := 0
    mut remaining := data
    while remaining.len() > 0:
        wrote := string_buffer_write(writer, remaining)!
        if wrote <= 0:
            fail "write returned 0"
        total = total + wrote
        remaining = remaining_after_write(remaining, wrote)
    return total

pub fn write_all_tcp_stream(writer: TcpStream, data: String) -> Int!:
    mut total := 0
    mut remaining := data
    while remaining.len() > 0:
        wrote := tcp_stream_write(writer, remaining)!
        if wrote <= 0:
            fail "write returned 0"
        total = total + wrote
        remaining = remaining_after_write(remaining, wrote)
    return total

pub fn write_all_file_stream(writer: FileStream, data: String) -> Int!:
    mut total := 0
    mut remaining := data
    while remaining.len() > 0:
        wrote := file_stream_write(writer, remaining)!
        if wrote <= 0:
            fail "write returned 0"
        total = total + wrote
        remaining = remaining_after_write(remaining, wrote)
    return total

pub fn copy_string(reader: StringReader, writer: StringBuffer) -> Int!:
    return copy_string_chunked(reader, writer, DEFAULT_CHUNK_SIZE)

pub fn copy_string_chunked(reader: StringReader, writer: StringBuffer, chunk_size: Int) -> Int!:
    size := normalized_chunk_size(chunk_size)
    mut total := 0
    mut chunk := string_reader_read(reader, size)!
    while chunk.len() > 0:
        total = total + write_all_string(writer, chunk)!
        chunk = string_reader_read(reader, size)!
    return total

pub fn read_all_tcp_stream(stream: TcpStream) -> String!:
    return read_all_tcp_stream_chunked(stream, DEFAULT_CHUNK_SIZE)

pub fn read_all_tcp_stream_chunked(stream: TcpStream, chunk_size: Int) -> String!:
    size := normalized_chunk_size(chunk_size)
    mut result := ""
    mut chunk := tcp_stream_read(stream, size)!
    while chunk.len() > 0:
        result = result + chunk
        chunk = tcp_stream_read(stream, size)!
    return result

pub fn read_all_file_stream(stream: FileStream) -> String!:
    return read_all_file_stream_chunked(stream, DEFAULT_CHUNK_SIZE)

pub fn read_all_file_stream_chunked(stream: FileStream, chunk_size: Int) -> String!:
    size := normalized_chunk_size(chunk_size)
    mut result := ""
    mut chunk := file_stream_read(stream, size)!
    while chunk.len() > 0:
        result = result + chunk
        chunk = file_stream_read(stream, size)!
    return result

pub fn read_file_text(path: String) -> String!:
    return read_file_text_chunked(path, DEFAULT_CHUNK_SIZE)

pub fn read_file_text_chunked(path: String, chunk_size: Int) -> String!:
    stream := file_stream_open_read(path)!
    content := read_all_file_stream_chunked(stream, chunk_size)!
    file_stream_close(stream)
    return content

pub fn write_file_text(path: String, data: String) -> Int!:
    return write_file_text_chunked(path, data, DEFAULT_CHUNK_SIZE)

pub fn write_file_text_chunked(path: String, data: String, chunk_size: Int) -> Int!:
    stream := file_stream_open_write(path)!
    writer := buffered_file_writer_chunked(stream, chunk_size)
    mut total := buffered_file_writer_write(writer, data)!
    total = total + buffered_file_writer_flush(writer)!
    file_stream_close(stream)
    return total

pub fn append_file_text(path: String, data: String) -> Int!:
    return append_file_text_chunked(path, data, DEFAULT_CHUNK_SIZE)

pub fn append_file_text_chunked(path: String, data: String, chunk_size: Int) -> Int!:
    stream := file_stream_open_append(path)!
    writer := buffered_file_writer_chunked(stream, chunk_size)
    mut total := buffered_file_writer_write(writer, data)!
    total = total + buffered_file_writer_flush(writer)!
    file_stream_close(stream)
    return total

pub fn write_all_process_stdin(writer: ProcessStdin, data: String) -> Int!:
    mut total := 0
    mut remaining := data
    while remaining.len() > 0:
        wrote := process_stdin_write(writer, remaining)!
        if wrote <= 0:
            fail "write returned 0"
        total = total + wrote
        remaining = remaining_after_write(remaining, wrote)
    return total

pub fn read_all_process_stdout(reader: ProcessStdout) -> String!:
    return read_all_process_stdout_chunked(reader, DEFAULT_CHUNK_SIZE)

pub fn read_all_process_stdout_chunked(reader: ProcessStdout, chunk_size: Int) -> String!:
    size := normalized_chunk_size(chunk_size)
    mut result := ""
    mut chunk := process_stdout_read(reader, size)!
    while chunk.len() > 0:
        result = result + chunk
        chunk = process_stdout_read(reader, size)!
    return result

pub fn read_all_process_stderr(reader: ProcessStderr) -> String!:
    return read_all_process_stderr_chunked(reader, DEFAULT_CHUNK_SIZE)

pub fn read_all_process_stderr_chunked(reader: ProcessStderr, chunk_size: Int) -> String!:
    size := normalized_chunk_size(chunk_size)
    mut result := ""
    mut chunk := process_stderr_read(reader, size)!
    while chunk.len() > 0:
        result = result + chunk
        chunk = process_stderr_read(reader, size)!
    return result

fn string_reader_read_internal(reader: StringReader, max_bytes: Int) -> String!:
    if max_bytes <= 0:
        return ""
    if not string_reader_data.contains_key(reader.handle):
        return ""

    data := string_reader_data[reader.handle]
    mut offset := 0
    if string_reader_offsets.contains_key(reader.handle):
        offset = string_reader_offsets[reader.handle]
    if offset >= data.len():
        return ""

    mut end := offset + max_bytes
    if end > data.len():
        end = data.len()
    chunk := data.substring(offset, end)
    string_reader_offsets.insert(reader.handle, end)
    return chunk

fn string_buffer_write_internal(buf: StringBuffer, data: String) -> Int!:
    mut current := ""
    if string_buffer_data.contains_key(buf.handle):
        current = string_buffer_data[buf.handle]
    string_buffer_data.insert(buf.handle, current + data)
    return data.len()

fn buffered_string_reader_read_internal(reader: BufferedStringReader, max_bytes: Int) -> String!:
    if max_bytes <= 0:
        return ""
    if not buffered_string_reader_sources.contains_key(reader.handle):
        return ""

    mut result := ""
    while result.len() < max_bytes:
        mut cached := buffered_string_reader_cache_get(reader.handle)
        if cached.len() == 0:
            filled := buffered_string_reader_fill(reader.handle)!
            if filled <= 0:
                return result
            cached = buffered_string_reader_cache_get(reader.handle)
        mut take := max_bytes - result.len()
        if take > cached.len():
            take = cached.len()
        result = result + cached.substring(0, take)
        buffered_string_reader_consume(reader.handle, take)
    return result

fn buffered_string_reader_read_line_internal(reader: BufferedStringReader) -> String!:
    if not buffered_string_reader_sources.contains_key(reader.handle):
        return ""

    mut result := ""
    while true:
        mut cached := buffered_string_reader_cache_get(reader.handle)
        if cached.len() == 0:
            filled := buffered_string_reader_fill(reader.handle)!
            if filled <= 0:
                return result
            cached = buffered_string_reader_cache_get(reader.handle)
        newline := find_newline(cached)
        if newline >= 0:
            result = result + cached.substring(0, newline)
            buffered_string_reader_consume(reader.handle, newline + 1)
            return trim_trailing_cr(result)
        result = result + cached
        buffered_string_reader_cache.insert(reader.handle, "")

fn buffered_string_reader_fill(handle: Int) -> Int!:
    if not buffered_string_reader_sources.contains_key(handle):
        return 0

    source_handle := buffered_string_reader_sources[handle]
    mut chunk_size := DEFAULT_CHUNK_SIZE
    if buffered_string_reader_chunk_sizes.contains_key(handle):
        chunk_size = buffered_string_reader_chunk_sizes[handle]

    chunk := string_reader_read(StringReader(source_handle), chunk_size)!
    buffered_string_reader_cache.insert(handle, chunk)
    return chunk.len()

fn buffered_string_writer_write_internal(writer: BufferedStringWriter, data: String) -> Int!:
    if not buffered_string_writer_targets.contains_key(writer.handle):
        return 0

    cached := buffered_string_writer_cache_get(writer.handle)
    buffered_string_writer_cache.insert(writer.handle, cached + data)
    if buffered_string_writer_should_flush(writer.handle):
        buffered_string_writer_flush_internal(writer)!
    return data.len()

fn buffered_string_writer_flush_internal(writer: BufferedStringWriter) -> Int!:
    if not buffered_string_writer_targets.contains_key(writer.handle):
        return 0

    cached := buffered_string_writer_cache_get(writer.handle)
    if cached.len() == 0:
        return 0

    target_handle := buffered_string_writer_targets[writer.handle]
    wrote := write_all_string(StringBuffer(target_handle), cached)!
    buffered_string_writer_cache.insert(writer.handle, "")
    return wrote

