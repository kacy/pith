# function declarations, calls, and return types

fn add(a: Int, b: Int) -> Int:
    return a + b

fn greet(name: String) -> String:
    return "hello, {name}!"

fn is_positive(n: Int) -> Bool:
    return n > 0

fn negate(x: Float) -> Float:
    return 0.0 - x

fn do_nothing():
    return

fn main():
    sum := add(1, 2)
    msg := greet("pith")
    print(msg)

    ok := is_positive(sum)
    val := negate(3.14)
