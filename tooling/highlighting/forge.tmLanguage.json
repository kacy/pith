{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Forge",
  "scopeName": "source.forge",
  "fileTypes": [
    "fg"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#types"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.forge",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.forge",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.forge"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.forge"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.forge",
              "match": "\\\\[nrt\\\"{0]"
            },
            {
              "name": "meta.interpolation.forge",
              "begin": "\\{",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.begin.forge"
                }
              },
              "end": "\\}",
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.end.forge"
                }
              },
              "patterns": [
                {
                  "include": "#keywords"
                },
                {
                  "include": "#numbers"
                },
                {
                  "include": "#types"
                },
                {
                  "include": "#operators"
                }
              ]
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.forge",
          "match": "\\b(if|elif|else|for|in|while|match|return|fail|break|continue|spawn|await)\\b"
        },
        {
          "name": "keyword.declaration.forge",
          "match": "\\b(fn|struct|enum|interface|impl|type|import|from|as|pub|mut|ref|weak)\\b"
        },
        {
          "name": "keyword.operator.word.forge",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.forge",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.none.forge",
          "match": "\\bnone\\b"
        },
        {
          "name": "variable.language.self.forge",
          "match": "\\bself\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.forge",
          "match": "\\b(Int|UInt|Float|Bool|String|Bytes|Void|Task|Channel|List|Map|Set|Option|Result|Error|Int8|Int16|Int32|Int64|UInt8|UInt16|UInt32|UInt64)\\b"
        },
        {
          "name": "entity.name.type.forge",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.forge",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d[\\d_]*)?\\b"
        },
        {
          "name": "constant.numeric.integer.hex.forge",
          "match": "\\b0x[0-9A-Fa-f][0-9A-Fa-f_]*\\b"
        },
        {
          "name": "constant.numeric.integer.binary.forge",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.integer.octal.forge",
          "match": "\\b0o[0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.integer.decimal.forge",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.forge",
          "match": "(:=|\\+=|-=|\\*=|/=|=)"
        },
        {
          "name": "keyword.operator.comparison.forge",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arrow.forge",
          "match": "(->|=>)"
        },
        {
          "name": "keyword.operator.arithmetic.forge",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.other.forge",
          "match": "(\\?|!|\\.|,|:|\\|)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.forge",
          "match": "(?<=\\bfn\\s)([a-zA-Z_][a-zA-Z0-9_]*)"
        },
        {
          "name": "variable.parameter.forge",
          "match": "(?<=\\()([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*:)|(?<=,\\s*)([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*:)"
        }
      ]
    }
  }
}
