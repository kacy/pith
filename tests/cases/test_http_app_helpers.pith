import std.bytes as bytes
import std.fs as fs
import std.io as io
import std.json as json
import std.net.http as http
import std.time as time
from std.net.http import ClientConn, HttpRequestBytes, HttpResponse

fn build_payload() -> Int:
    obj := json.make_object()
    json.object_set(obj, "kind", json.make_string("item"))
    json.object_set(obj, "count", json.make_int(2))
    return obj

fn app(req: HttpRequestBytes) -> HttpResponse:
    if http.post_route(req, "/items/:id") catch false:
        payload := req.body_json_or(-1)
        if payload < 0:
            return http.server_error_response()
        out := json.make_object()
        json.object_set(out, "id", json.make_string(req.path_param_or("/items/:id", "id", "")))
        json.object_set(out, "mode", json.make_string(req.query_param_or("mode", "")))
        json.object_set(out, "has_empty", json.make_bool(req.has_query_param("empty") catch false))
        json.object_set(out, "kind", json.make_string(json.get_string(json.object_get(payload, "kind"))))
        return http.response(201).json_body(out).header("X-Route", "item").set_cookie(http.cookie("session", "fresh").path("/").http_only())
    return http.not_found_response()

fn auth_middleware(next: fn(HttpRequestBytes) -> HttpResponse, req: HttpRequestBytes) -> HttpResponse:
    if not (req.has_cookie("session") catch false):
        return http.unauthorized_response()
    return next(req)

fn trace_middleware(next: fn(HttpRequestBytes) -> HttpResponse, req: HttpRequestBytes) -> HttpResponse:
    return next(req).header("X-Trace", req.header_or("X-Trace", "trace-generated"))

fn temp_file_path(prefix: String, ext: String) -> String:
    return "/tmp/" + prefix + time.now().to_string() + ext

fn save_demo_download(output_path: String) -> String!:
    response_reader := io.bytes_reader(http.text(200, "saved").to_bytes()!).buffered_chunked(4)
    request_writer := bytes.buffer().buffered_chunked(4)
    conn := ClientConn(io.from_fd(1), response_reader, request_writer)
    conn.send_to_file(http.get_request("example.test", 80, "/download"), output_path)!
    return ""

fn main() -> String!:
    mut req_builder := http.request("POST", "example.com", 80, "/items/42?mode=raw&empty=")
    req_builder = req_builder.header("X-Test", "yes")
    req_builder = req_builder.header("X-Trace", "trace-req")
    req_builder = req_builder.cookie("session", "incoming")
    req_builder = req_builder.json_body(build_payload())
    req_bytes := req_builder.to_bytes()!
    req := http.read_request_buffered_bytes(io.bytes_reader(req_bytes).buffered_chunked(4))!
    req_mode := req.query_param("mode")!
    has_empty := req.has_query_param("empty")!
    path_match := req.matches_path("/items/:id")!
    path_id := req.path_param("/items/:id", "id")!
    parts := req.path_parts()!
    req_body := req.body_json()!
    body_kind := json.get_string(json.object_get(req_body, "kind"))
    print("method:" + req.method()!)
    print("path:" + req.path()!)
    print("query-mode:" + req_mode)
    print("has-empty:" + has_empty.to_string())
    print("path-match:" + path_match.to_string())
    print("path-id:" + path_id)
    print("path-id-or:" + req.path_param_or("/items/:id", "id", "missing"))
    print("path-miss-or:" + req.path_param_or("/other/:id", "id", "missing"))
    print("parts:" + parts.join(","))
    print("body-json-kind:" + body_kind)
    print("body-text-default:" + req.body_text_or("fallback"))
    print("query-mode-or:" + req.query_param_or("mode", "fallback"))
    print("query-miss-or:" + req.query_param_or("missing", "fallback"))
    print("header-hit-or:" + req.header_or("X-Test", "fallback"))
    print("header-miss-or:" + req.header_or("X-Missing", "fallback"))
    print("cookie-hit:" + req.cookie("session")!)
    print("cookie-hit-or:" + req.cookie_or("session", "fallback"))
    print("cookie-miss-or:" + req.cookie_or("missing", "fallback"))
    print("has-cookie:" + req.has_cookie("session")!.to_string())
    print("is-put:" + (req.is_put("/items/42") catch false).to_string())
    print("is-patch:" + (req.is_patch("/items/42") catch false).to_string())

    out := bytes.buffer()
    handled := app(req).header("X-Trace", req.header_or("X-Trace", "trace-generated"))
    http.send_buffered(out.buffered_chunked(4), handled)!
    served := http.parse_response_bytes(out.bytes())!
    served_json := served.body_json()!
    served_id := json.get_string(json.object_get(served_json, "id"))
    served_empty := json.get_bool(json.object_get(served_json, "has_empty"))
    print("served-status:" + served.status_code().to_string())
    print("served-type:" + served.header_value("Content-Type"))
    print("served-route:" + served.header_value("X-Route"))
    print("served-id:" + served_id)
    print("served-empty:" + served_empty.to_string())
    print("served-success:" + served.is_success().to_string())
    print("served-status-ok:" + served.status_is_ok().to_string())
    print("served-trace:" + served.header_value("X-Trace"))
    print("served-cookie-count:" + served.cookies().len().to_string())
    print("served-cookie-first:" + served.cookies()[0])
    print("bad-request-client-error:" + http.bad_request_response().is_client_error().to_string())
    print("server-error-server-error:" + http.server_error_response().is_server_error().to_string())
    print("no-content-status:" + http.no_content().status_code().to_string())
    print("forbidden-status:" + http.forbidden_response().status_code().to_string())

    mut client_builder := http.put_request("api.example", 8080, "/v1/items")
    client_builder = client_builder.header("X-Test", "yes")
    client_builder = client_builder.accept("application/json")
    client_builder = client_builder.bearer("abc123")
    client_builder = client_builder.cookie("session", "client-side")
    client_builder = client_builder.text_body("ping")
    client_builder = client_builder.query_param("mode", "fast path")
    client_req_bytes := client_builder.to_bytes()!
    client_req := http.read_request_buffered_bytes(io.bytes_reader(client_req_bytes).buffered_chunked(5))!
    print("client-method:" + client_req.method()!)
    print("client-path:" + client_req.path()!)
    print("client-query-mode:" + client_req.query_param_or("mode", ""))
    print("client-header:" + client_req.header("X-Test")!)
    print("client-accept:" + client_req.header("Accept")!)
    print("client-auth:" + client_req.header("Authorization")!)
    print("client-cookie:" + client_req.cookie("session")!)
    print("client-body:" + client_req.body_text()!)

    mut form_fields: Map[String, String] := {}
    form_fields.insert("name", "pith cli")
    form_req := http.post_request("api.example", 8080, "/submit").basic_auth("user", "pass").form_body(form_fields)
    form_req_bytes := form_req.to_bytes()!
    form_http_req := http.read_request_buffered_bytes(io.bytes_reader(form_req_bytes).buffered_chunked(5))!
    print("form-type:" + form_http_req.header("Content-Type")!)
    print("form-auth:" + form_http_req.header("Authorization")!)
    print("form-body:" + form_http_req.body_text()!)

    file_buf := bytes.buffer()
    file_buf.write_string_utf8("FG")!
    file_buf.write_byte(255)!
    file_buf.write_byte(0)!
    mut multipart_parts: List[http.MultipartPart] := []
    multipart_parts.push(http.multipart_field("note", "hello multipart"))
    multipart_parts.push(http.multipart_file("blob", "blob.bin", "application/octet-stream", file_buf.bytes()))
    multipart_req := http.post_request("upload.example", 8080, "/upload").multipart_body_with_boundary(multipart_parts, "pith-boundary-test")!
    multipart_req_bytes := multipart_req.to_bytes()!
    multipart_http_req := http.read_request_buffered_bytes(io.bytes_reader(multipart_req_bytes).buffered_chunked(7))!
    blob_part := multipart_http_req.multipart_part("blob")!
    print("multipart-type:" + multipart_http_req.header("Content-Type")!)
    print("multipart-is:" + multipart_http_req.is_multipart()!.to_string())
    print("multipart-boundary:" + multipart_http_req.multipart_boundary()!)
    print("multipart-count:" + multipart_http_req.multipart_parts()!.len().to_string())
    print("multipart-note:" + multipart_http_req.multipart_text("note")!)
    print("multipart-note-or:" + multipart_http_req.multipart_text_or("note", "fallback"))
    print("multipart-miss-or:" + multipart_http_req.multipart_text_or("missing", "fallback"))
    print("multipart-body-default:" + multipart_http_req.body_text_or("binary"))
    print("multipart-has-blob:" + multipart_http_req.has_multipart_part("blob")!.to_string())
    print("multipart-has-missing:" + multipart_http_req.has_multipart_part("missing")!.to_string())
    print("multipart-filename:" + blob_part.filename)
    print("multipart-file-type:" + blob_part.header("Content-Type"))
    print("multipart-file-len:" + blob_part.body_bytes().len().to_string())
    print("multipart-file-byte2:" + blob_part.body_bytes()[2].to_string())
    print("multipart-file-text-or:" + blob_part.text_or("binary"))

    asset_path := temp_file_path("pith-http-helper-asset-", ".html")
    fs.write(asset_path, "<h1>asset</h1>")!
    static_out := bytes.buffer()
    http.send_static_path(static_out.buffered_chunked(5), http.response(200).keep_alive(), asset_path)!
    static_resp := http.parse_response_bytes(static_out.bytes())!
    print("static-type:" + static_resp.header_value("Content-Type"))
    print("static-body:" + static_resp.body_text()!)

    download_out := bytes.buffer()
    http.send_download_path(download_out.buffered_chunked(5), http.response(200), asset_path, "asset.html")!
    download_resp := http.parse_response_bytes(download_out.bytes())!
    print("download-disposition:" + download_resp.header_value("Content-Disposition"))

    save_path := temp_file_path("pith-http-helper-download-", ".txt")
    save_demo_download(save_path)!
    print("saved-body:" + fs.read(save_path)!)
    fs.remove(save_path)
    fs.remove(asset_path)
    return ""
