# std.io — io interfaces and generic helpers
#
# this is the first pass at a shared io foundation for the stdlib.
# phase one stays string-oriented because that's what the runtime exposes today,
# but the shape is meant to grow into a bytes-first layer later.
#
# the key idea is simple:
# - transports implement a small interface surface
# - generic helpers like read_all and copy do the repetitive work once
# - higher-level stdlib modules build on the same contracts
#
# handle-backed in-memory adapters are included so the helpers are easy to test.

DEFAULT_CHUNK_SIZE := 4096

mut next_string_reader_handle: Int := 1
mut string_reader_data: Map[Int, String] := {}
mut string_reader_offsets: Map[Int, Int] := {}

mut next_string_buffer_handle: Int := 1
mut string_buffer_data: Map[Int, String] := {}

mut next_buffered_string_reader_handle: Int := 1
mut buffered_string_reader_sources: Map[Int, Int] := {}
mut buffered_string_reader_chunk_sizes: Map[Int, Int] := {}
mut buffered_string_reader_cache: Map[Int, String] := {}

mut next_buffered_string_writer_handle: Int := 1
mut buffered_string_writer_targets: Map[Int, Int] := {}
mut buffered_string_writer_chunk_sizes: Map[Int, Int] := {}
mut buffered_string_writer_cache: Map[Int, String] := {}

mut next_buffered_tcp_stream_handle: Int := 1
mut buffered_tcp_stream_fds: Map[Int, Int] := {}
mut buffered_tcp_stream_chunk_sizes: Map[Int, Int] := {}
mut buffered_tcp_stream_cache: Map[Int, String] := {}

mut next_buffered_tcp_writer_handle: Int := 1
mut buffered_tcp_writer_fds: Map[Int, Int] := {}
mut buffered_tcp_writer_chunk_sizes: Map[Int, Int] := {}
mut buffered_tcp_writer_cache: Map[Int, String] := {}

mut next_buffered_file_reader_handle: Int := 1
mut buffered_file_reader_handles: Map[Int, Int] := {}
mut buffered_file_reader_chunk_sizes: Map[Int, Int] := {}
mut buffered_file_reader_cache: Map[Int, String] := {}

mut next_buffered_file_writer_handle: Int := 1
mut buffered_file_writer_handles: Map[Int, Int] := {}
mut buffered_file_writer_chunk_sizes: Map[Int, Int] := {}
mut buffered_file_writer_cache: Map[Int, String] := {}

mut next_buffered_process_stdout_handle: Int := 1
mut buffered_process_stdout_handles: Map[Int, Int] := {}
mut buffered_process_stdout_chunk_sizes: Map[Int, Int] := {}
mut buffered_process_stdout_cache: Map[Int, String] := {}

mut next_buffered_process_stderr_handle: Int := 1
mut buffered_process_stderr_handles: Map[Int, Int] := {}
mut buffered_process_stderr_chunk_sizes: Map[Int, Int] := {}
mut buffered_process_stderr_cache: Map[Int, String] := {}

interface Reader:
    fn read(max_bytes: Int) -> String!

interface Writer:
    fn write(data: String) -> Int!

interface Closer:
    fn close()

interface Flusher:
    fn flush() -> Int!

struct StringReader:
    pub handle: Int

struct StringBuffer:
    pub handle: Int

struct BufferedStringReader:
    pub handle: Int

struct BufferedStringWriter:
    pub handle: Int

struct BufferedTcpStream:
    pub handle: Int

struct BufferedTcpWriter:
    pub handle: Int

struct BufferedFileReader:
    pub handle: Int

struct BufferedFileWriter:
    pub handle: Int

struct TcpStream:
    pub fd: Int

struct FileStream:
    pub handle: Int

struct Process:
    pub handle: Int

struct ProcessStdin:
    pub handle: Int

struct ProcessStdout:
    pub handle: Int

struct ProcessStderr:
    pub handle: Int

struct BufferedProcessStdout:
    pub handle: Int

struct BufferedProcessStderr:
    pub handle: Int

impl StringReader:
    fn read(max_bytes: Int) -> String!:
        return string_reader_read(self, max_bytes)

impl Reader for StringReader:
    fn read(max_bytes: Int) -> String!:
        return string_reader_read(self, max_bytes)

impl StringBuffer:
    fn write(data: String) -> Int!:
        return string_buffer_write(self, data)

impl Writer for StringBuffer:
    fn write(data: String) -> Int!:
        return string_buffer_write(self, data)

pub fn string_reader(data: String) -> StringReader:
    return StringReader(allocate_string_reader_handle(data))

pub fn string_buffer() -> StringBuffer:
    return StringBuffer(allocate_string_buffer_handle())

pub fn buffered_string_reader(reader: StringReader) -> BufferedStringReader:
    return buffered_string_reader_chunked(reader, DEFAULT_CHUNK_SIZE)

pub fn buffered_string_reader_chunked(reader: StringReader, chunk_size: Int) -> BufferedStringReader:
    return BufferedStringReader(allocate_buffered_string_reader_handle(reader.handle, chunk_size))

pub fn buffered_string_writer(writer: StringBuffer) -> BufferedStringWriter:
    return buffered_string_writer_chunked(writer, DEFAULT_CHUNK_SIZE)

pub fn buffered_string_writer_chunked(writer: StringBuffer, chunk_size: Int) -> BufferedStringWriter:
    return BufferedStringWriter(allocate_buffered_string_writer_handle(writer.handle, chunk_size))

pub fn buffered_tcp_stream(stream: TcpStream) -> BufferedTcpStream:
    return buffered_tcp_stream_chunked(stream, DEFAULT_CHUNK_SIZE)

pub fn buffered_tcp_stream_chunked(stream: TcpStream, chunk_size: Int) -> BufferedTcpStream:
    return BufferedTcpStream(allocate_buffered_tcp_stream_handle(stream.fd, chunk_size))

pub fn buffered_tcp_writer(writer: TcpStream) -> BufferedTcpWriter:
