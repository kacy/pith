            mut _fi37 := 0
            _kids37 := cn.children
            while _fi37 < _kids37.len():
                gc := _kids37[_fi37]
                gcn := get_node(gc)
                if gcn.kind == "list" or gcn.kind == "map" or gcn.kind == "set":
                    has_collection_globals = true
                _fi37 = _fi37 + 1
        _fi26 = _fi26 + 1
    if has_collection_globals:
        ir_emit_func_header("__init_globals", 0, "int")
        mut _fi27 := 0
        _kids27 := root.children
        while _fi27 < _kids27.len():
            child := _kids27[_fi27]
            mut cn := get_node(child)
            if cn.kind == "pub" and cn.children.len() > 0:
                cn = get_node(cn.children[0])
            if cn.kind == "bind" or cn.kind == "binding":
                mut gname := cn.value
                if gname.contains(" mut"):
                    gname = gname.substring(0, gname.len() - 4)
                elif gname.contains(" "):
                    gname = gname.split(" ")[0]
                mut _fi38 := 0
                _kids38 := cn.children
                while _fi38 < _kids38.len():
                    gc := _kids38[_fi38]
                    gcn := get_node(gc)
                    if gcn.kind == "list":
                        list_r := ir_reg()
                        ir_emit_call(list_r, "__list_new", "list", [])
                        ir_emit("store " + gname + " " + list_r.to_string())
                    elif gcn.kind == "map":
                        map_r := ir_reg()
                        if ir_global_map_int_names.contains(gname):
                            ir_emit_call(map_r, "__map_new_int", "map_int", [])
                        else:
                            ir_emit_call(map_r, "__map_new", "map", [])
                        ir_emit("store " + gname + " " + map_r.to_string())
                    elif gcn.kind == "set":
                        set_r := ir_reg()
                        ir_emit_call(set_r, "__set_new", "set", [])
                        ir_emit("store " + gname + " " + set_r.to_string())
                    _fi38 = _fi38 + 1
            _fi27 = _fi27 + 1
        dr := ir_reg()
        ir_emit("iconst " + dr.to_string() + " 0")
        ir_emit("ret " + dr.to_string())
        ir_emit("endfunc")

    # emit functions (unwrap pub wrappers)
    mut _fi28 := 0
    _kids28 := root.children
    while _fi28 < _kids28.len():
        child := _kids28[_fi28]
        cn := get_node(child)
        mut actual := child
        mut actual_node := cn
        if cn.kind == "pub" and cn.children.len() > 0:
            actual = cn.children[0]
            actual_node = get_node(actual)
        if actual_node.kind == "fn" or actual_node.kind == "fn_decl":
            ir_func(actual)
        elif actual_node.kind == "impl_decl":
            # emit methods from impl blocks
            mut impl_type := ""
            mut _fi39 := 0
            _kids39 := cn.children
            while _fi39 < _kids39.len():
                ic := _kids39[_fi39]
                icn := get_node(ic)
                if icn.kind == "type":
                    impl_type = icn.value
                elif icn.kind == "for_type":
                    # impl X for TYPE — get type from for_type child
                    mut _fi41 := 0
                    _kids41 := icn.children
                    while _fi41 < _kids41.len():
                        ftc := _kids41[_fi41]
                        ftn := get_node(ftc)
                        if ftn.kind == "type":
                            impl_type = ftn.value
                        _fi41 = _fi41 + 1
                elif icn.kind == "generic_type" and impl_type == "":
                    # impl TYPE: — simple impl on the generic_type
                    impl_type = icn.value
                elif icn.kind == "fn_decl":
                    ir_impl_func(ic, impl_type)

                _fi39 = _fi39 + 1
        _fi28 = _fi28 + 1
    # append deferred lambda function bodies
    mut li := 0
    while li < ir_lambda_bodies.len():
        ir_lines.push(ir_lambda_bodies[li])
        li = li + 1

    ir_module_count = ir_module_count + 1
    return ir_lines.join(chr(10))
