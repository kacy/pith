        return tcp_stream_read_bytes(self, max_bytes)

impl Writer for TcpStream:
    fn write(data: String) -> Int!:
        return tcp_stream_write(self, data)

impl BytesWriter for TcpStream:
    fn write_bytes(data: Bytes) -> Int!:
        return tcp_stream_write_bytes(self, data)

impl Closer for TcpStream:
    fn close():
        tcp_stream_close(self)

impl FileStream:
    fn read(max_bytes: Int) -> String!:
        return file_stream_read(self, max_bytes)

    fn read_all() -> String!:
        return read_all_file_stream(self)

    fn read_all_chunked(chunk_size: Int) -> String!:
        return read_all_file_stream_chunked(self, chunk_size)

    fn read_bytes(max_bytes: Int) -> Bytes!:
        return file_stream_read_bytes(self, max_bytes)

    fn read_all_bytes() -> Bytes!:
        return read_all_file_stream_bytes(self)

    fn read_all_bytes_chunked(chunk_size: Int) -> Bytes!:
        return read_all_file_stream_bytes_chunked(self, chunk_size)

    fn write(data: String) -> Int!:
        return file_stream_write(self, data)

    fn write_all(data: String) -> Int!:
        return write_all_file_stream(self, data)

    fn write_bytes(data: Bytes) -> Int!:
        return file_stream_write_bytes(self, data)

    fn write_all_bytes(data: Bytes) -> Int!:
        return write_all_file_stream_bytes(self, data)

    fn buffered_bytes_reader() -> BufferedBytesReader:
        return buffered_bytes_reader_from_file(self, DEFAULT_CHUNK_SIZE)

    fn buffered_bytes_reader_chunked(chunk_size: Int) -> BufferedBytesReader:
        return buffered_bytes_reader_from_file(self, chunk_size)

    fn buffered_bytes_writer() -> BufferedBytesWriter:
        return buffered_bytes_writer_to_file(self, DEFAULT_CHUNK_SIZE)

    fn buffered_bytes_writer_chunked(chunk_size: Int) -> BufferedBytesWriter:
        return buffered_bytes_writer_to_file(self, chunk_size)

    fn buffered_reader() -> BufferedFileReader:
        return buffered_file_reader(self)

    fn buffered_reader_chunked(chunk_size: Int) -> BufferedFileReader:
        return buffered_file_reader_chunked(self, chunk_size)

    fn buffered_writer() -> BufferedFileWriter:
        return buffered_file_writer(self)

    fn buffered_writer_chunked(chunk_size: Int) -> BufferedFileWriter:
        return buffered_file_writer_chunked(self, chunk_size)

    fn close():
        file_stream_close(self)

impl Reader for FileStream:
    fn read(max_bytes: Int) -> String!:
        return file_stream_read(self, max_bytes)

impl BytesReader for FileStream:
    fn read_bytes(max_bytes: Int) -> Bytes!:
        return file_stream_read_bytes(self, max_bytes)

impl Writer for FileStream:
    fn write(data: String) -> Int!:
        return file_stream_write(self, data)

impl BytesWriter for FileStream:
    fn write_bytes(data: Bytes) -> Int!:
        return file_stream_write_bytes(self, data)

impl Closer for FileStream:
    fn close():
        file_stream_close(self)

## Read a line from standard input
pub fn prompt() -> String:
    return input()

## Print a message then read a line from standard input
pub fn prompt_with(msg: String) -> String:
    print(msg)
    return input()
