## std.env — environment variable and argument access
##
## Functions:
##   get(key: String) -> String    Get environment variable (empty if not set)
##   get_args() -> List[String]    Get command-line arguments

## Get an environment variable by name. Returns empty string if not set.
pub fn get(key: String) -> String:
    return env(key)

## Get the command-line arguments as a list of strings
pub fn get_args() -> List[String]:
    return args()
