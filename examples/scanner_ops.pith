import std.text.scanner as scanner

fn main():
    source := "name: pith" + chr(10) + "version: 1"
    key := scanner.take_until(scanner.new(source), ":")
    line1 := scanner.take_line(scanner.new(source))
    line2 := scanner.take_line(line1.cursor)

    print("key: {key.slice.text}")
    print("line1: {line1.slice.text}")
    print("line2: {line2.slice.text}")
    print("done: {scanner.done(line2.cursor)}")
