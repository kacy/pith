import std.io as io
import std.net.http as http

fn main() -> Int!:
    crlf := chr(13) + chr(10)

    mut raw := "POST /submit?mode=fast HTTP/1.1" + crlf
    raw = raw + "Host: example.com" + crlf
    raw = raw + "Content-Length: 11" + crlf
    raw = raw + "X-Test: chunked" + crlf
    raw = raw + crlf
    raw = raw + "hello world"

    reader := io.string_reader(raw).buffered_chunked(3)
    req := http.read_request_buffered(reader)!
    print(http.method(req))
    print(http.path(req))
    print(http.query(req))
    print(http.version(req))
    print(http.get_header(req, "host"))
    print(http.get_header(req, "content-length"))
    print(http.get_header(req, "x-test"))
    print(http.body(req))

    mut raw2 := "GET /ping HTTP/1.1" + crlf
    raw2 = raw2 + "User-Agent: io-foundation" + crlf
    raw2 = raw2 + crlf

    reader2 := io.string_reader(raw2).buffered_chunked(2)
    req2 := http.read_request_buffered(reader2)!
    print(http.method(req2))
    print(http.path(req2))
    print(http.get_header(req2, "user-agent"))
    print("[" + http.body(req2) + "]")
    return 0
