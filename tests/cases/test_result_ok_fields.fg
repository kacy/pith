fn returns_zero() -> Int!:
    return 0

fn returns_seven() -> Int!:
    return 7

fn returns_true() -> Bool!:
    return true

fn returns_false() -> Bool!:
    return false

fn main() -> Int!:
    print(returns_zero().ok.to_string())
    print(returns_seven().ok.to_string())
    print(returns_true().ok.to_string())
    print(returns_false().ok.to_string())
    print(returns_zero().is_ok.to_string())
    print(returns_true().is_ok.to_string())
    print(returns_false().is_ok.to_string())
    return 0
