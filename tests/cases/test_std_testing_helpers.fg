from std.testing import assert_eq, assert_ne, assert_true, assert_false
from std.testing import assert_contains, done

fn main():
    assert_eq(1 + 1, 2)
    assert_eq("forge".to_upper(), "FORGE")
    assert_ne(7, 8)
    assert_true("forge".starts_with("for"))
    assert_false("forge".contains("zig"))
    assert_contains("hello forge", "forge")
    assert_eq(false, true)
    assert_ne("same", "same")
    done()
