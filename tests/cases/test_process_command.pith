import std.os.process as process

fn main() -> Int!:
    pwd_out := process.command("pwd").cwd("/tmp").output_checked()
    print(pwd_out.ok.status.to_string())
    print(pwd_out.ok.stdout_trimmed())
    print(pwd_out.ok.success().to_string())

    env_out := process.command("env").env("PITH_PROCESS_TEST", "hello world").output()!
    print(env_out.stdout.contains("PITH_PROCESS_TEST=hello world").to_string())
    print(env_out.success().to_string())

    quiet_code := process.command("printf").arg("").run()!
    print(quiet_code.to_string())

    failing_out := process.command("ls").arg("/nonexistent_path_xyz").output()!
    print(failing_out.failed().to_string())
    print((failing_out.stderr_trimmed().len() > 0).to_string())
    failing_checked := process.command("ls").arg("/nonexistent_path_xyz").output_checked()
    print(failing_checked.is_err.to_string())
    print((failing_checked.err.status != 0).to_string())

    child := process.command("head").args(["-c", "5"]).start()!
    child.stdin().write_all("abcdef")!
    print(child.stdout().read_all()!)
    print(child.wait().to_string())
    child.close()

    print(process.command("printf").arg("trimmed").text_trimmed().ok)
    print(process.output_shell("printf shell-ok")!)
    return 0
