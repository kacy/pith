# ir_emitter.pith - public IR emitter entrypoint
#
# Keep callers on the stable ir_emitter API while the implementation is
# decomposed into smaller focused modules.

import ir_emitter_core as core

pub fn set_import_roots(roots: List[Int], paths: List[String]):
    core.set_import_roots(roots, paths)

pub fn set_test_mode(enabled: Bool):
    core.set_test_mode(enabled)

pub fn emit_ir(root_idx: Int) -> String:
    return core.emit_ir(root_idx)
