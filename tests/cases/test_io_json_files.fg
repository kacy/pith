from std.json import parse, parse_file_chunked, save_chunked, type_of, object_get, get_string, get_bool, array_len
from std.fs import exists, remove

fn main() -> String!:
    json_path := "/tmp/forge_io_json.json"
    lb := chr(123)
    rb := chr(125)

    doc := lb + "\"name\":\"forge\",\"enabled\":true,\"items\":[1,2,3]" + rb
    root := parse(doc)
    print(save_chunked(json_path, root, 4).to_string())

    loaded := parse_file_chunked(json_path, 3)
    print(type_of(loaded))
    print(get_string(object_get(loaded, "name")))
    print(get_bool(object_get(loaded, "enabled")).to_string())
    print(array_len(object_get(loaded, "items")).to_string())
    print(exists(json_path).to_string())

    remove(json_path)
    return ""
