fn buffered_string_reader_cache_get(handle: Int) -> String:
    if buffered_string_reader_cache.contains_key(handle):
        return buffered_string_reader_cache[handle]
    return ""

fn buffered_string_reader_consume(handle: Int, consumed: Int):
    cached := buffered_string_reader_cache_get(handle)
    buffered_string_reader_cache.insert(handle, cache_after_consume(cached, consumed))

