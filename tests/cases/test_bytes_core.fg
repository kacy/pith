import std.bytes as bytes

fn main() -> String!:
    raw := bytes.from_string_utf8("forge")
    copy := bytes.from_string_utf8("forge")
    part := raw.slice(1, 4)

    print(raw.len().to_string())
    print(raw[0].to_string())
    print(part.to_string_utf8()!)
    print((raw == copy).to_string())
    print(raw.concat(part).len().to_string())

    buf := bytes.buffer()
    print(buf.write(raw)!.to_string())
    print(buf.write_byte(33)!.to_string())
    print(buf.bytes().to_string_utf8()!)
    print(bytes.empty().is_empty().to_string())
    return ""
