# std.hash — cryptographic and non-cryptographic hashing
#
# sha256 returns a 64-char hex string (lowercase).
# fnv1a returns a 64-bit integer hash.

# compute SHA-256 hash of a string, returned as 64-char hex.
pub fn sha256(input: String) -> String:
    return hash_sha256(input)

# compute FNV-1a hash of a string, returned as Int.
pub fn fnv1a(input: String) -> Int:
    return hash_fnv1a(input)
