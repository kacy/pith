# new stdlib builtins: time, sleep, random, exec_output, input

fn test_exec_output() -> String!:
    out := exec_output("echo hello")!
    return out

fn main():
    # time — epoch milliseconds
    t := time()
    print("time: " + t.to_string())

    # sleep — 1ms pause
    sleep(1)
    print("sleep: ok")

    # random_int — inclusive range [1, 100]
    r := random_int(1, 100)
    print("random_int: " + r.to_string())

    # random_float — [0.0, 1.0)
    f := random_float()
    print("random_float: " + f.to_string())

    # exec_output — capture command stdout
    result := test_exec_output()
    print("exec_output: ok")

    # input() — skip in automated test (needs stdin)

    print("all stdlib tests passed")
