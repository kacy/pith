from scope import reset_scope_arena, create_scope, define_binding, lookup_binding

fn main():
    reset_scope_arena()
    scope_id := create_scope(-1)
    define_binding(scope_id, "time", 1, false)
    define_binding(scope_id, "print", 2, false)
    define_binding(scope_id, "input", 3, false)
    print(lookup_binding(scope_id, "time").to_string())
    print(lookup_binding(scope_id, "print").to_string())
    print(lookup_binding(scope_id, "input").to_string())
