import std.concurrent as concurrent
import std.io as io
import std.time as time

fn main() -> Int!:
    invalid := io.from_fd(-1)

    timeout_pair := concurrent.with_timeout(concurrent.background(), 1)
    time.delay(5)
    timeout_read := invalid.read_ctx(timeout_pair.0, 8)
    print("read-timeout:{timeout_read.is_err}")
    print("read-deadline:{timeout_read.is_err and timeout_read.err.is_deadline_exceeded()}")

    cancel_pair := concurrent.with_cancel(concurrent.background())
    cancel_pair.1.cancel()
    cancelled_write := invalid.write_ctx(cancel_pair.0, "hi")
    print("write-cancelled:{cancelled_write.is_err and cancelled_write.err.is_cancelled()}")

    invalid_read := invalid.read_ctx(concurrent.background(), 8)
    print("invalid-read-failed:{invalid_read.is_err and invalid_read.err.is_failed()}")

    invalid_read_all := invalid.read_all_ctx(concurrent.background())
    print("invalid-read-all-failed:{invalid_read_all.is_err and invalid_read_all.err.is_failed()}")

    invalid_read_bytes := invalid.read_bytes_ctx(concurrent.background(), 8)
    print("invalid-read-bytes-failed:{invalid_read_bytes.is_err and invalid_read_bytes.err.is_failed()}")

    invalid_exact_bytes := invalid.read_exact_bytes_ctx(concurrent.background(), 8)
    print("invalid-read-exact-bytes-failed:{invalid_exact_bytes.is_err and invalid_exact_bytes.err.is_failed()}")

    invalid_write_all := invalid.write_all_ctx(concurrent.background(), "hi")
    print("invalid-write-all-failed:{invalid_write_all.is_err and invalid_write_all.err.is_failed()}")

    buffered_reader := invalid.buffered_reader()
    buffered_timeout_pair := concurrent.with_timeout(concurrent.background(), 1)
    time.delay(5)
    buffered_read := buffered_reader.read_ctx(buffered_timeout_pair.0, 8)
    print("buffered-read-timeout:{buffered_read.is_err and buffered_read.err.is_deadline_exceeded()}")

    buffered_line_reader := invalid.buffered_reader()
    buffered_line_pair := concurrent.with_timeout(concurrent.background(), 1)
    time.delay(5)
    buffered_line := buffered_line_reader.read_line_ctx(buffered_line_pair.0)
    print("buffered-read-line-timeout:{buffered_line.is_err and buffered_line.err.is_deadline_exceeded()}")

    buffered_until_reader := invalid.buffered_reader()
    buffered_until_pair := concurrent.with_timeout(concurrent.background(), 1)
    time.delay(5)
    buffered_until := buffered_until_reader.read_until_ctx(buffered_until_pair.0, "|")
    print("buffered-read-until-timeout:{buffered_until.is_err and buffered_until.err.is_deadline_exceeded()}")

    buffered_until_including_reader := invalid.buffered_reader()
    buffered_until_including_pair := concurrent.with_timeout(concurrent.background(), 1)
    time.delay(5)
    buffered_until_including := buffered_until_including_reader.read_until_including_ctx(buffered_until_including_pair.0, "|")
    print("buffered-read-until-including-timeout:{buffered_until_including.is_err and buffered_until_including.err.is_deadline_exceeded()}")

    buffered_writer := invalid.buffered_writer()
    buffered_write := buffered_writer.write_ctx(concurrent.background(), "hi")
    print("buffered-write-buffered:{buffered_write.is_ok and buffered_write.ok == 2}")

    buffered_cancel_pair := concurrent.with_cancel(concurrent.background())
    buffered_cancel_pair.1.cancel()
    buffered_cancel_flush := buffered_writer.flush_ctx(buffered_cancel_pair.0)
    print("buffered-flush-cancelled:{buffered_cancel_flush.is_err and buffered_cancel_flush.err.is_cancelled()}")

    buffered_flush := buffered_writer.flush_ctx(concurrent.background())
    print("buffered-flush-failed:{buffered_flush.is_err and buffered_flush.err.is_failed()}")
    return 0
