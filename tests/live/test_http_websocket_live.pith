import std.io as io
import std.net.http as http
import std.net.websocket as websocket
from std.net.http import HttpRequestBytes
fn choose_port(start: Int) -> Int!:
    mut port := start
    while port < start + 200:
        probe := tcp_listen("127.0.0.1", port)
        if probe.is_ok:
            tcp_close(probe.ok)
            return port
        port = port + 1
    fail "no free tcp port"
fn handle_http(fd: Int) -> Int!:
    req := http.read_request_bytes(fd)!
    if websocket.route_echo(fd, req, "/ws", "", "echo:", "quit")!:
        return 0
    return http.send_response(fd, http.html_response(200, "<h1>Hello, pith!</h1>"))
fn run_server(port: Int) -> Int!:
    server_fd := tcp_listen("127.0.0.1", port)!
    handle_http(tcp_accept(server_fd)!)!
    handle_http(tcp_accept(server_fd)!)!
    tcp_close(server_fd)
    return 0
fn main() -> Int!:
    port := choose_port(18843)!
    server_task := spawn run_server(port)
    sleep(200)
    conn := io.connect("127.0.0.1", port)!
    conn.write_all("GET /greet HTTP/1.1\r\nHost: localhost\r\n\r\n")!
    response := conn.read_all()!
    print(response.contains("Hello, pith!").to_string())
    ws := websocket.dial("127.0.0.1", port, "/ws")!
    ws.send_text("pith")!
    print(ws.recv_text()!)
    ws.send_text("quit")!
    closed := ws.recv()
    print(closed.is_err.to_string())
    print(ws.is_closed().to_string())
    await server_task
    return 0
