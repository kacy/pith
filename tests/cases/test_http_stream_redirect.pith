import std.bytes as bytes
import std.io as io
import std.net.http as http

fn main() -> String!:
    crlf := chr(13) + chr(10)
    raw := "HTTP/1.1 200 OK" + crlf + "Content-Type: text/plain" + crlf + "Content-Length: 19" + crlf + "Connection: close" + crlf + crlf + "streamed final body"
    out := bytes.buffer()
    meta := http.read_response_buffered_bytes_into(io.bytes_reader(bytes.from_string_utf8(raw)).buffered_chunked(4), out.buffered_chunked(4))!

    print("status:" + meta.status.to_string())
    print("content-type:" + meta.header_value("Content-Type"))
    print("body-size:" + meta.body_size.to_string())
    print("body:" + out.bytes().to_string_utf8()!)
    return ""
