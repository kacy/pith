pub fn buffered_file_writer(stream: FileStream) -> BufferedFileWriter:
    return buffered_file_writer_chunked(stream, DEFAULT_CHUNK_SIZE)

pub fn buffered_file_writer_chunked(stream: FileStream, chunk_size: Int) -> BufferedFileWriter:
    return BufferedFileWriter(allocate_buffered_file_writer_handle(stream.handle, chunk_size))

pub fn buffered_process_stdout(reader: ProcessStdout) -> BufferedProcessStdout:
