    define_builtin_function("tcp_read_bytes", create_function_type([TID_INT, TID_INT], bytes_result))
    define_builtin_function("tcp_write_bytes", create_function_type([TID_INT, tid_bytes], int_result))
    define_builtin_function("tcp_wait_readable", create_function_type([TID_INT, TID_INT], TID_INT))
    define_builtin_function("tcp_wait_writable", create_function_type([TID_INT, TID_INT], TID_INT))
    # (Int, Int) -> Void
    define_builtin_function("tcp_set_timeout", create_function_type([TID_INT, TID_INT], TID_VOID))

    # process management builtins
    # (String) -> Int!
    define_builtin_function("process_spawn", create_function_type([TID_STRING], int_result))
    define_builtin_function("process_spawn_argv", create_function_type([TID_STRING, list_string, TID_STRING, list_string, list_string], int_result))
    define_builtin_function("process_output_argv", create_function_type([TID_STRING, list_string, TID_STRING, list_string, list_string], int_result))
    # (Int, String) -> Int!
    define_builtin_function("process_write", create_function_type([TID_INT, TID_STRING], int_result))
    # (Int, Int) -> String!
    define_builtin_function("process_read", create_function_type([TID_INT, TID_INT], str_result))
    define_builtin_function("process_read_err", create_function_type([TID_INT, TID_INT], str_result))
    define_builtin_function("process_write_bytes", create_function_type([TID_INT, tid_bytes], int_result))
    define_builtin_function("process_read_bytes", create_function_type([TID_INT, TID_INT], bytes_result))
    define_builtin_function("process_read_err_bytes", create_function_type([TID_INT, TID_INT], bytes_result))
    # (Int) -> Int
    define_builtin_function("process_wait", int_to_int)
    # (Int) -> Bool
    define_builtin_function("process_kill", create_function_type([TID_INT], TID_BOOL))
    # (Int) -> Void
    define_builtin_function("process_close", int_to_void)
    define_builtin_function("process_output_status", int_to_int)
    define_builtin_function("process_output_stdout", create_function_type([TID_INT], TID_STRING))
    define_builtin_function("process_output_stderr", create_function_type([TID_INT], TID_STRING))
    define_builtin_function("process_output_close", int_to_void)

    # concurrency primitives (stub types)
    register_sync_primitive_type("Mutex", [])
    register_sync_primitive_type("WaitGroup", [])
    register_sync_primitive_type("Semaphore", [tid_int])

    # Rebind builtin names at the end. On the active self-hosted path,
    # the long registration sequence above can leave some earlier
    # function type entries with corrupted return_type fields. Rebinding
    # after all mutations makes the final scope bindings authoritative.
    fix_builtin_binding("time", [], tid_int)
    fix_builtin_binding("random_float", [], tid_float)
    fix_builtin_binding("input", [], tid_string)
    fix_builtin_binding("args", [], list_string)
    fix_builtin_binding("assert", [tid_bool], tid_void)
    fix_builtin_binding("exit", [tid_int], tid_void)
    fix_builtin_binding("sleep", [tid_int], tid_void)
    fix_builtin_binding("random_seed", [tid_int], tid_void)
    fix_builtin_binding("tcp_close", [tid_int], tid_void)
    fix_builtin_binding("abs", [tid_int], tid_int)
    fix_builtin_binding("bit_not", [tid_int], tid_int)
    fix_builtin_binding("chr", [tid_int], tid_string)
