# file I/O and OS interaction

fn main():
    # command-line arguments
    cli_args := args()
    print("arg count: {cli_args.len()}")

    # write a temp file and read it back
    path := "/tmp/forge_test_file_io.txt"
    content := "hello from forge"
    write_file(path, content)
    read_back := read_file(path)
    print("file I/O works")
