    define_builtin_function("process_read", create_function_type([TID_INT, TID_INT], str_result))
    define_builtin_function("process_read_err", create_function_type([TID_INT, TID_INT], str_result))
    define_builtin_function("process_write_bytes", create_function_type([TID_INT, tid_bytes], int_result))
    define_builtin_function("process_read_bytes", create_function_type([TID_INT, TID_INT], bytes_result))
    define_builtin_function("process_read_err_bytes", create_function_type([TID_INT, TID_INT], bytes_result))
    define_builtin_function("process_wait", int_to_int)
    define_builtin_function("process_kill", create_function_type([TID_INT], TID_BOOL))
