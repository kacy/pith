import std.archive.zip as zip
import std.binary as bin
import std.bytes as bytes
import std.checksum as checksum
import std.fs as fs
import std.os.path as path
from std.bytes import ByteBuffer

fn test_write_bytes(out: ByteBuffer, data: Bytes) -> Int!:
    if data.len() == 0:
        return 0
    return out.write(data)

fn write_u16(out: ByteBuffer, value: Int) -> Int!:
    wrote := bin.write_u16_le(out, value)
    if wrote.is_err:
        fail wrote.err.message
    return wrote.ok

fn write_u32(out: ByteBuffer, value: Int) -> Int!:
    wrote := bin.write_u32_le(out, value)
    if wrote.is_err:
        fail wrote.err.message
    return wrote.ok

fn manual_zip(name: String, content: Bytes, method: Int, crc_value: Int) -> Bytes!:
    out := bytes.buffer()
    name_bytes := bytes.from_string_utf8(name)
    write_u32(out, 67324752)!
    write_u16(out, 20)!
    write_u16(out, 0)!
    write_u16(out, method)!
    write_u16(out, 0)!
    write_u16(out, 0)!
    write_u32(out, crc_value)!
    write_u32(out, content.len())!
    write_u32(out, content.len())!
    write_u16(out, name_bytes.len())!
    write_u16(out, 0)!
    test_write_bytes(out, name_bytes)!
    test_write_bytes(out, content)!
    central_offset := out.bytes().len()

    write_u32(out, 33639248)!
    write_u16(out, 20)!
    write_u16(out, 20)!
    write_u16(out, 0)!
    write_u16(out, method)!
    write_u16(out, 0)!
    write_u16(out, 0)!
    write_u32(out, crc_value)!
    write_u32(out, content.len())!
    write_u32(out, content.len())!
    write_u16(out, name_bytes.len())!
    write_u16(out, 0)!
    write_u16(out, 0)!
    write_u16(out, 0)!
    write_u16(out, 0)!
    write_u32(out, 0)!
    write_u32(out, 0)!
    test_write_bytes(out, name_bytes)!
    central_size := out.bytes().len() - central_offset

    write_u32(out, 101010256)!
    write_u16(out, 0)!
    write_u16(out, 0)!
    write_u16(out, 1)!
    write_u16(out, 1)!
    write_u32(out, central_size)!
    write_u32(out, central_offset)!
    write_u16(out, 0)!
    return out.bytes()

fn main() -> Int!:
    root := fs.make_temp_dir("forge_zip_")!
    bundle := path.join(root, "bundle")
    fs.make_dirs(path.join(bundle, "nested"))
    fs.write(path.join(bundle, "hello.txt"), "hello zip")!
    fs.write_bytes(path.join(path.join(bundle, "nested"), "data.bin"), bytes.from_string_utf8("bin"))!

    archive := zip.create([bundle])!
    entries := zip.list(archive)!
    print("entries:" + entries.len().to_string())
    print("entry0:" + entries[0].name + ":" + entries[0].size.to_string())
    print("entry1:" + entries[1].name + ":" + entries[1].size.to_string())

    out_dir := path.join(root, "out")
    zip.extract(archive, out_dir)!
    print("roundtrip:" + fs.read(path.join(path.join(out_dir, "bundle"), "hello.txt"))!)
    print("nested:" + fs.read(path.join(path.join(path.join(out_dir, "bundle"), "nested"), "data.bin"))!)

    archive_path := path.join(root, "bundle.zip")
    zip.create_file([bundle], archive_path)!
    out_dir2 := path.join(root, "out2")
    zip.extract_file(archive_path, out_dir2)!
    print("file-api:" + fs.read(path.join(path.join(out_dir2, "bundle"), "hello.txt"))!)

    content := bytes.from_string_utf8("bad")
    bad_crc := zip.extract(manual_zip("bad.txt", content, 0, checksum.crc32(content) + 1)!, path.join(root, "bad-crc"))
    print("bad-crc:" + bad_crc.is_err.to_string())
    compressed := zip.list(manual_zip("compressed.txt", content, 8, checksum.crc32(content))!)
    print("compressed:" + compressed.is_err.to_string())
    unsafe := zip.extract(manual_zip("../evil.txt", bytes.empty(), 0, checksum.crc32(bytes.empty()))!, path.join(root, "unsafe"))
    print("unsafe:" + unsafe.is_err.to_string())
    print("cleanup:" + fs.remove_tree(root).to_string())
    return 0
