# checker.fg — semantic analysis and type checking
#
# two-pass approach:
#   pass 1 (register): walk top-level declarations, record names and
#     type signatures in the module scope.
#   pass 2 (check): walk function bodies and top-level bindings,
#     creating child scopes for functions and blocks.
#
# uses an error sentinel pattern: when a sub-expression has type
# TID_ERR, further checks are skipped to prevent cascading noise.
#
# all globals use c_ prefix to avoid collisions with lexer/parser
# globals in the flat C namespace.

from types import TypeInfo, ti_primitive, ti_struct, ti_enum, ti_function, ti_optional, ti_result, ti_tuple, ti_list, ti_map, ti_set, ti_task, ti_channel, add_type_info, get_type_count, register_type_name, lookup_type_id, get_type_info, get_type_name, is_numeric_type, is_integer_type, is_error_type, initialize_type_table, TID_INT, TID_UINT, TID_FLOAT, TID_BOOL, TID_STRING, TID_BYTES, TID_VOID, TID_INT8, TID_INT16, TID_INT32, TID_INT64, TID_UINT8, TID_UINT16, TID_UINT32, TID_UINT64, TID_ERR, TID_FIRST_USER
from scope import reset_scope_arena, create_scope, define_binding, lookup_binding, is_binding_mutable, get_scope_return_type, is_in_loop_scope, create_function_scope, create_loop_scope
from ast import Node, get_node, add_node, add_leaf
from errors import Diagnostic, render_diagnostics_json

mut checker_diagnostics: List[Diagnostic] := []
mut current_file_path: String := ""

# Module alias tracking - maps alias name to module path
mut module_aliases: Map[String, String] := {}

# Module exports tracking - flat list of "module_path<TAB>export_name".
# Qualified resolution currently uses scope bindings directly, so this is
# retained only as lightweight bookkeeping for future module APIs.
mut module_export_entries: List[String] := []

# Wildcard import tracking - which modules have been wildcard imported
# This enables from X import * functionality
mut wildcard_imports: List[String] := []
mut generic_named_import_entries: List[String] := []
mut generic_wildcard_import_entries: List[String] := []
mut current_checker_module_path: String := ""
mut generic_inference_subst: Map[String, Int] := {}

# Get position from AST node
fn get_node_position(node_idx: Int) -> (Int, Int):
    if node_idx < 0:
        return (0, 0)
    node := get_node(node_idx)
    return (node.line, node.col)

# Report error with position from node
fn report_error_at(node_idx: Int, code: String, message: String):
    mut pos := get_node_position(node_idx)
    checker_diagnostics.push(Diagnostic("error", code, message, current_file_path, pos.0, pos.1, ""))

# Report error without specific node (uses 0,0)
fn report_error(code: String, message: String):
    checker_diagnostics.push(Diagnostic("error", code, message, current_file_path, 0, 0, ""))

# Report error with fix suggestion
fn report_error_with_fix_at(node_idx: Int, code: String, message: String, fix: String):
    mut pos := get_node_position(node_idx)
    checker_diagnostics.push(Diagnostic("error", code, message, current_file_path, pos.0, pos.1, fix))

fn report_error_with_fix(code: String, message: String, fix: String):
    checker_diagnostics.push(Diagnostic("error", code, message, current_file_path, 0, 0, fix))

# Report warning with position from node
fn report_warning_at(node_idx: Int, code: String, message: String):
    mut pos := get_node_position(node_idx)
    checker_diagnostics.push(Diagnostic("warning", code, message, current_file_path, pos.0, pos.1, ""))

fn report_warning(code: String, message: String):
    checker_diagnostics.push(Diagnostic("warning", code, message, current_file_path, 0, 0, ""))

# ---------------------------------------------------------------
# checker state
# ---------------------------------------------------------------

pub mut current_scope := -1
pub mut method_type_map: Map[String, Int] := {}
pub mut method_visibility_map: Map[String, Bool] := {}
mut method_decl_index_map: Map[String, Int] := {}
# legacy map kept for probes; generic declaration lookup uses flat lists
pub mut generic_declaration_map: Map[String, Int] := {}
mut generic_declaration_names: List[String] := []
mut interface_declaration_names: List[String] := []
mut checking_test_decl := false
# impl set: "Type\tInterface" -> 1
mut implementation_set: Map[String, Int] := {}
# expression type cache — populated by c_check_expr, queried by codegen
pub mut expression_type_cache: Map[Int, Int] := {}

# ---------------------------------------------------------------
# initialization
# ---------------------------------------------------------------

pub fn initialize_checker(file_path: String):
    initialize_type_table()
    reset_scope_arena()
    checker_diagnostics = []
    current_file_path = file_path
    method_type_map = {}
    method_visibility_map = {}
    method_decl_index_map = {}
    generic_declaration_map = {}
    generic_declaration_names = []
    interface_declaration_names = []
    implementation_set = {}
    expression_type_cache = {}
    module_aliases = {}
    module_export_entries = []
    wildcard_imports = []
    generic_named_import_entries = []
    generic_wildcard_import_entries = []
    current_checker_module_path = ""
    generic_inference_subst = {}
    current_scope = create_scope(-1)
    register_builtin_types()

pub fn set_checker_module_path(module_path: String):
    current_checker_module_path = module_path

# Register an import alias for module namespace resolution
pub fn register_import_alias(alias: String, module_path: String):
    module_aliases.insert(alias, module_path)

fn module_symbol_prefix(module_path: String) -> String:
    mut prefix := ""
    for ch in module_path:
        if ch == ".":
            prefix = prefix + "_"
        else:
            prefix = prefix + ch
    return prefix + "_"

fn module_generic_target_name(module_path: String, name: String) -> String:
    if module_path.len() == 0:
        return name
    return module_symbol_prefix(module_path) + name

fn clean_import_part(part: String) -> String:
    mut start := 0
    mut end := part.len()
    while start < end and part[start] == ",":
        start = start + 1
    while end > start and part[end - 1] == ",":
        end = end - 1
    return part.substring(start, end)

fn module_default_alias(module_path: String) -> String:
    mut last_dot := 0 - 1
    mut i := 0
    while i < module_path.len():
        if module_path[i] == ".":
            last_dot = i
        i = i + 1
    if last_dot < 0:
        return module_path
    return module_path.substring(last_dot + 1, module_path.len())

fn module_import_target_name(module_path: String, name: String) -> String:
    if module_path == "std.json":
        return "json_" + name
    if module_path == "std.toml":
        return "toml_" + name
    if module_path == "std.encoding":
        return "encoding_" + name
    if module_path == "std.hash":
        return "hash_" + name
    if module_path == "std.log":
        return "log_" + name
    if module_path == "std.net.url":
        return "url_" + name
    return name

# Process import declarations from AST and register aliases
pub fn process_import_aliases(root_idx: Int):
    root := get_node(root_idx)
    for child in root.children:
        node := get_node(child)
        mut kind := node.kind
        mut value := node.value
        if kind == "pub":
            if node.children.len() > 0:
                inner := get_node(node.children[0])
                kind = inner.kind
                value = inner.value
        if kind == "import":
            # Parse "path" or "path as alias"
            mut path := value
            mut has_alias := false
            mut alias := ""
            mut si := 0
            while si < value.len() - 3:
                if ord(value[si]) == 32:
                    if ord(value[si + 1]) == 97:
                        if ord(value[si + 2]) == 115:
                            if ord(value[si + 3]) == 32:
                                path = value.substring(0, si)
                                alias = value.substring(si + 4, value.len())
                                has_alias = true
                                break
                si = si + 1
            if has_alias:
                register_import_alias(alias, path)
            else:
                register_import_alias(module_default_alias(path), path)
        elif kind == "from_import":
            # Parse "path name1 name2 ..." or "path *" for wildcard
            mut parts: List[String] := []
            mut part_start := 0
            mut i := 0
            while i <= value.len():
                mut at_boundary := false
                if i == value.len():
                    at_boundary = true
                elif ord(value[i]) == 32:
                    at_boundary = true
                if at_boundary:
                    if part_start < i:
                        parts.push(value.substring(part_start, i))
                    part_start = i + 1
                i = i + 1

            if parts.len() > 0:
                mod_path := parts[0]
                # Check for wildcard import (second part is "*")
                if parts.len() > 1:
                    if parts[1] == "*":
                        wildcard_imports.push(mod_path)
                        generic_wildcard_import_entries.push(current_checker_module_path + chr(9) + mod_path)
                    else:
                        mut pi := 1
                        while pi < parts.len():
                            imported_name := clean_import_part(parts[pi])
                            if imported_name.len() > 0:
                                generic_named_import_entries.push(current_checker_module_path + chr(9) + imported_name + chr(9) + mod_path)
                            pi = pi + 1

# Collect all pub exports from a module.
pub fn collect_module_exports(module_path: String, root_idx: Int):
    root := get_node(root_idx)

    for child in root.children:
        node := get_node(child)
        if node.kind == "pub":
            if node.children.len() > 0:
                inner := get_node(node.children[0])
                if inner.kind == "fn_decl":
                    module_export_entries.push(module_path + chr(9) + inner.value)
                elif inner.kind == "struct_decl":
                    module_export_entries.push(module_path + chr(9) + inner.value)
                elif inner.kind == "enum_decl":
                    module_export_entries.push(module_path + chr(9) + inner.value)
                elif inner.kind == "type_alias":
                    module_export_entries.push(module_path + chr(9) + inner.value)
                elif inner.kind == "binding":
                    # Extract binding name from value (format: "name mut" or "name")
                    mut name_end := inner.value.len()
                    mut si := 0
                    while si < inner.value.len():
                        if ord(inner.value[si]) == 32:
                            name_end = si
                            break
                        si = si + 1
                    binding_name := inner.value.substring(0, name_end)
                    module_export_entries.push(module_path + chr(9) + binding_name)

fn register_builtin_types():
    tid_int := lookup_type_id("Int")
    tid_float := lookup_type_id("Float")
    tid_bool := lookup_type_id("Bool")
    tid_string := lookup_type_id("String")
    tid_bytes := lookup_type_id("Bytes")
    tid_void := lookup_type_id("Void")
    tid_err := lookup_type_id("<error>")

    # pre-register List[String] — used by String.split() and args()
    intern_list_type(tid_string)
    list_string := lookup_type_id("List[String]")

    # result types used by multiple builtins
    int_result := add_type_info(ti_result(tid_int, tid_string))
    float_result := add_type_info(ti_result(tid_float, tid_string))
    str_result := add_type_info(ti_result(tid_string, tid_string))
    bytes_result := add_type_info(ti_result(tid_bytes, tid_string))
    bool_result := add_type_info(ti_result(tid_bool, tid_string))
    opt_string := add_type_info(ti_optional(tid_string))

    # --- shared function signatures, one type per group ---

    # () -> Int
    void_to_int := create_function_type([], TID_INT)
    define_builtin_function("time", void_to_int)
    # () -> Float
    define_builtin_function("random_float", create_function_type([], TID_FLOAT))
    # () -> String
    define_builtin_function("input", create_function_type([], TID_STRING))
    # () -> List[String]
    define_builtin_function("args", create_function_type([], list_string))

    # (Bool) -> Void
    define_builtin_function("assert", create_function_type([TID_BOOL], TID_VOID))

    # (Int) -> Void
    int_to_void := create_function_type([TID_INT], TID_VOID)
    define_builtin_function("exit", int_to_void)
    define_builtin_function("sleep", int_to_void)
    define_builtin_function("random_seed", int_to_void)
    define_builtin_function("tcp_close", int_to_void)
    # (Int) -> Int
    int_to_int := create_function_type([TID_INT], TID_INT)
    define_builtin_function("abs", int_to_int)
    # (Int) -> Int (bitwise unary)
    define_builtin_function("bit_not", int_to_int)

    # (Int) -> String
    int_to_str := create_function_type([TID_INT], TID_STRING)
    define_builtin_function("chr", int_to_str)
    define_builtin_function("random_string", int_to_str)
    # (Int, Int) -> Int
    two_int_to_int := create_function_type([TID_INT, TID_INT], TID_INT)
    define_builtin_function("min", two_int_to_int)
    define_builtin_function("max", two_int_to_int)
    define_builtin_function("random_int", two_int_to_int)
    define_builtin_function("bit_and", two_int_to_int)
    define_builtin_function("bit_or", two_int_to_int)
    define_builtin_function("bit_xor", two_int_to_int)
    define_builtin_function("bit_shl", two_int_to_int)
    define_builtin_function("bit_shr", two_int_to_int)
    define_builtin_function("UInt", create_function_type([TID_INT], TID_UINT))
    define_builtin_function("Int8", create_function_type([TID_INT], TID_INT8))
    define_builtin_function("Int16", create_function_type([TID_INT], TID_INT16))
    define_builtin_function("Int32", create_function_type([TID_INT], TID_INT32))
    define_builtin_function("Int64", create_function_type([TID_INT], TID_INT64))
    define_builtin_function("UInt8", create_function_type([TID_INT], TID_UINT8))
    define_builtin_function("UInt16", create_function_type([TID_INT], TID_UINT16))
    define_builtin_function("UInt32", create_function_type([TID_INT], TID_UINT32))
    define_builtin_function("UInt64", create_function_type([TID_INT], TID_UINT64))
    # (Int, Int, Int) -> Int
    define_builtin_function("clamp", create_function_type([TID_INT, TID_INT, TID_INT], TID_INT))

    # (Int, String) -> String
    int_str_to_str := create_function_type([TID_INT, TID_STRING], TID_STRING)
    define_builtin_function("format_time", int_str_to_str)
    # (Float) -> Float
    float_to_float := create_function_type([TID_FLOAT], TID_FLOAT)
    define_builtin_function("sqrt", float_to_float)
    define_builtin_function("floor", float_to_float)
    define_builtin_function("ceil", float_to_float)
    define_builtin_function("round", float_to_float)
    # (Float, Float) -> Float
    define_builtin_function("pow", create_function_type([TID_FLOAT, TID_FLOAT], TID_FLOAT))
    # (Float, Int) -> String
    define_builtin_function("fmt_float", create_function_type([TID_FLOAT, TID_INT], TID_STRING))

    # (String) -> Void
    str_to_void := create_function_type([TID_STRING], TID_VOID)
    define_builtin_function("print", str_to_void)
    define_builtin_function("print_err", str_to_void)
    # (String) -> Int
    str_to_int := create_function_type([TID_STRING], TID_INT)
    define_builtin_function("exec", str_to_int)
    define_builtin_function("ord", str_to_int)
    # (String) -> Bool
    str_to_bool := create_function_type([TID_STRING], TID_BOOL)
    define_builtin_function("file_exists", str_to_bool)
    define_builtin_function("dir_exists", str_to_bool)
    define_builtin_function("mkdir", str_to_bool)
    define_builtin_function("remove_file", str_to_bool)
    define_builtin_function("fs_remove_dir", str_to_bool)
    define_builtin_function("fs_remove_tree", str_to_bool)
    # (String) -> String?
    define_builtin_function("env", create_function_type([TID_STRING], tid_string))
    define_builtin_function("fs_file_size", str_to_int)
    # (String) -> List[String]
    define_builtin_function("list_dir", create_function_type([TID_STRING], list_string))
    define_builtin_function("os_getcwd", create_function_type([], tid_string))
    define_builtin_function("os_temp_dir", create_function_type([], tid_string))
    define_builtin_function("os_home_dir", create_function_type([], tid_string))
    define_builtin_function("os_cert_roots_pem", create_function_type([], tid_string))
    define_builtin_function("os_chdir", str_to_bool)
    define_builtin_function("os_unset_env", str_to_bool)

    # (String) -> Int!
    define_builtin_function("parse_int", create_function_type([TID_STRING], int_result))
    # (String) -> Float!
    define_builtin_function("parse_float", create_function_type([TID_STRING], float_result))
    define_builtin_function("bytes_from_string_utf8", create_function_type([TID_STRING], tid_bytes))
    # (String) -> String!
    str_to_str_result := create_function_type([TID_STRING], str_result)
    define_builtin_function("read_file", str_to_str_result)
    define_builtin_function("exec_output", str_to_str_result)
    define_builtin_function("dns_resolve", str_to_str_result)
    define_builtin_function("read_file_bytes", create_function_type([TID_STRING], bytes_result))
    define_builtin_function("b64_decode", create_function_type([TID_STRING], bytes_result))
    define_builtin_function("from_hex", create_function_type([TID_STRING], bytes_result))
    # (String) -> Int!
    define_builtin_function("file_open_read", create_function_type([TID_STRING], int_result))
    define_builtin_function("file_open_write", create_function_type([TID_STRING], int_result))
    define_builtin_function("file_open_append", create_function_type([TID_STRING], int_result))

    # (String, String) -> Bool
    define_builtin_function("rename_file", create_function_type([TID_STRING, TID_STRING], TID_BOOL))
    define_builtin_function("os_set_env", create_function_type([TID_STRING, TID_STRING], TID_BOOL))
    # (String, String) -> Bool!
    two_str_to_bool_result := create_function_type([TID_STRING, TID_STRING], bool_result)
    define_builtin_function("write_file", two_str_to_bool_result)
    define_builtin_function("append_file", two_str_to_bool_result)
    define_builtin_function("write_file_bytes", create_function_type([TID_STRING, tid_bytes], bool_result))
    define_builtin_function("append_file_bytes", create_function_type([TID_STRING, tid_bytes], bool_result))
    define_builtin_function("bytes_eq", create_function_type([tid_bytes, tid_bytes], TID_BOOL))
    define_builtin_function("bytes_concat", create_function_type([tid_bytes, tid_bytes], tid_bytes))
    define_builtin_function("bytes_len", create_function_type([tid_bytes], TID_INT))
    define_builtin_function("bytes_is_empty", create_function_type([tid_bytes], TID_BOOL))
    define_builtin_function("bytes_get", create_function_type([tid_bytes, TID_INT], TID_INT))
    define_builtin_function("bytes_slice", create_function_type([tid_bytes, TID_INT, TID_INT], tid_bytes))
    define_builtin_function("bytes_to_string_utf8", create_function_type([tid_bytes], str_result))
    define_builtin_function("crypto_constant_time_eq", create_function_type([tid_bytes, tid_bytes], TID_BOOL))
    define_builtin_function("secure_random_bytes", create_function_type([TID_INT], tid_bytes))
    define_builtin_function("crypto_x25519_keygen", create_function_type([], int_result))
    define_builtin_function("crypto_x25519_public_key", create_function_type([TID_INT], bytes_result))
    define_builtin_function("crypto_x25519_shared_secret", create_function_type([TID_INT, tid_bytes], bytes_result))
    define_builtin_function("crypto_x25519_close", create_function_type([TID_INT], TID_VOID))
    define_builtin_function("crypto_aes_128_gcm_seal", create_function_type([tid_bytes, tid_bytes, tid_bytes, tid_bytes], bytes_result))
    define_builtin_function("crypto_aes_128_gcm_open", create_function_type([tid_bytes, tid_bytes, tid_bytes, tid_bytes], bytes_result))
    define_builtin_function("crypto_chacha20_poly1305_seal", create_function_type([tid_bytes, tid_bytes, tid_bytes, tid_bytes], bytes_result))
    define_builtin_function("crypto_chacha20_poly1305_open", create_function_type([tid_bytes, tid_bytes, tid_bytes, tid_bytes], bytes_result))
    define_builtin_function("crypto_verify_ed25519", create_function_type([tid_bytes, tid_bytes, tid_bytes], TID_BOOL))
    define_builtin_function("crypto_verify_ecdsa_p256_sha256_asn1", create_function_type([tid_bytes, tid_bytes, tid_bytes], TID_BOOL))
    define_builtin_function("crypto_verify_rsa_pkcs1_sha256", create_function_type([tid_bytes, tid_bytes, tid_bytes], TID_BOOL))
