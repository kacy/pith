struct Node:
    kind: String
    children: List[Int]

fn main():
    mut kids: List[Int] := []
    kids.push(10)
    kids.push(20)
    kids.push(30)
    print("kids len before struct: " + kids.len().to_string())

    node := Node("test", kids)
    print("node.kind: " + node.kind)
    print("node.children.len: " + node.children.len().to_string())
    for c in node.children:
        print("child: " + c.to_string())
