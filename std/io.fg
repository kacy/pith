impl BufferedStringReader:
    fn read(max_bytes: Int) -> String!:
        return buffered_string_reader_read(self, max_bytes)

    fn read_line() -> String!:
        return buffered_string_reader_read_line(self)

impl Reader for BufferedStringReader:
    fn read(max_bytes: Int) -> String!:
        return buffered_string_reader_read(self, max_bytes)

impl BufferedStringWriter:
    fn write(data: String) -> Int!:
        return buffered_string_writer_write(self, data)

    fn flush() -> Int!:
        return buffered_string_writer_flush(self)

impl Writer for BufferedStringWriter:
    fn write(data: String) -> Int!:
        return buffered_string_writer_write(self, data)

impl Flusher for BufferedStringWriter:
    fn flush() -> Int!:
        return buffered_string_writer_flush(self)

impl BufferedTcpStream:
    fn read(max_bytes: Int) -> String!:
        return buffered_tcp_stream_read(self, max_bytes)

    fn read_line() -> String!:
        return buffered_tcp_stream_read_line(self)

impl Reader for BufferedTcpStream:
    fn read(max_bytes: Int) -> String!:
        return buffered_tcp_stream_read(self, max_bytes)

impl BufferedProcessStdout:
    fn read(max_bytes: Int) -> String!:
