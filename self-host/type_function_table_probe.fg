from types import TID_INT, TID_STRING, TID_VOID, add_type_info, get_type_info, initialize_type_table, ti_function

fn show(ret: Int, params: List[Int]):
    tid := add_type_info(ti_function(params, ret))
    info := get_type_info(tid)
    print(tid.to_string())
    print(info.param_types.len().to_string())
    print(info.return_type.to_string())

fn main():
    initialize_type_table()
    show(TID_INT, [])
    show(TID_STRING, [])
    show(TID_VOID, [TID_STRING])
