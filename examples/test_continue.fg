fn main():
    mut items: List[Int] := []
    items.push(10)
    items.push(20)
    items.push(30)
    items.push(40)

    mut result: List[Int] := []
    mut skip := 1
    for item in items:
        if skip > 0:
            skip = skip - 1
            continue
        result.push(item)

    print("result len: " + to_string(result.len()))
    for r in result:
        print(to_string(r))
