import std.bytes as bytes
import std.fs as fs
import std.os.path as path

fn main() -> Int!:
    root := fs.make_temp_dir("pith_fs_followup_")!
    src := path.join(root, "src")
    dst := path.join(root, "dst")
    print(fs.make_dirs(path.join(src, "nested")).to_string())
    fs.write(path.join(src, "nested/data.txt"), "alpha")!
    fs.write_bytes(path.join(src, "blob.bin"), bytes.from_string_utf8("bb"))!
    print(fs.make_dirs(path.join(dst, "nested")).to_string())
    fs.copy(path.join(src, "nested/data.txt"), path.join(dst, "nested/data.txt"))!
    fs.copy(path.join(src, "blob.bin"), path.join(dst, "blob.bin"))!

    copied := path.join(dst, "nested/data.txt")
    info := fs.info(copied)!
    print(info.exists.to_string())
    print(info.is_dir.to_string())
    print(info.size.to_string())
    print(fs.size(copied)!.to_string())
    print(fs.read(copied)!)
    print(fs.read_bytes(path.join(dst, "blob.bin"))!.to_string_utf8()!)

    empty := path.join(root, "empty")
    print(fs.make_dir(empty).to_string())
    print(fs.remove_empty_dir(empty).to_string())
    print(fs.remove_tree(root).to_string())
    print(fs.exists(root).to_string())
    return 0
