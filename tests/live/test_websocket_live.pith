import std.net.websocket as websocket
fn choose_port(start: Int) -> Int!:
    mut port := start
    while port < start + 200:
        probe := tcp_listen("127.0.0.1", port)
        if probe.is_ok:
            tcp_close(probe.ok)
            return port
        port = port + 1
    fail "no free tcp port"
fn run_server(port: Int) -> Int!:
    server_fd := tcp_listen("127.0.0.1", port)!
    ws := websocket.accept(tcp_accept(server_fd)!)!
    text := ws.recv_text()!
    ws.send_text("echo:" + text)!
    ws.close(1000, "done")!
    tcp_close(server_fd)
    return 0
fn main() -> Int!:
    port := choose_port(18842)!
    server_task := spawn run_server(port)
    sleep(200)
    ws := websocket.dial("127.0.0.1", port, "/live")!
    ws.send_text("pith")!
    print(ws.recv_text()!)
    closed := ws.recv()
    print(closed.is_err.to_string())
    print(ws.is_closed().to_string())
    await server_task
    return 0
