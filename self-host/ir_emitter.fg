# ir_emitter.fg — Forge-to-IR compiler (Stage 2)
#
# reads the parsed AST and emits a simple text IR that a thin Rust
# wrapper translates to Cranelift API calls.
#
# IR format:
#   string N "content"                  — string data
#   func NAME NPARAM RETTYPE            — function header (RETTYPE uses IR return-kind vocabulary)
#   param NAME                          — function parameter
#   endfunc                             — end of function
#   iconst REG VALUE                    — integer constant
#   strref REG STRIDX                   — reference to string data
#   call REG FNAME RETTYPE NARGS ARG... — function call
#   closure_ref REG FNAME               — closure handle for a lambda function
#   callv FNAME NARGS ARG...            — void call (no return)
#   add REG A B                         — integer add
#   sub REG A B                         — integer sub
#   mul REG A B                         — integer mul
#   div REG A B                         — integer div
#   mod REG A B                         — integer mod
#   eq REG A B                          — compare equal
#   neq REG A B                         — compare not equal
#   lt REG A B                          — compare less than
#   gt REG A B                          — compare greater than
#   lte REG A B                         — compare less or equal
#   gte REG A B                         — compare greater or equal
#   brif COND THEN_LABEL ELSE_LABEL     — conditional branch
#   label NAME                          — label
#   jmp LABEL                           — unconditional jump
#   ret REG                             — return value
#   load REG VARNAME                    — load variable
#   store VARNAME REG                   — store variable
#   concat REG A B                      — string concatenation

from ast import get_node, node_kind, node_value, node_child, node_child_count, Node
from checker import c_get_expr_type
from types import TypeInfo, get_type_info

# --- type knowledge constants (single source of truth) ---
FLOAT_RETURNING_FUNCS := "pow,sqrt,floor,ceil,round,to_float,get_float"
BOOL_RETURNING_FUNCS := "file_exists,dir_exists,fs_remove_dir,fs_remove_tree,os_chdir,os_set_env,os_unset_env,get_bool,object_has,has,crypto_constant_time_eq,crypto_verify_ed25519,crypto_verify_ecdsa_p256_sha256_asn1,crypto_verify_rsa_pkcs1_sha256,crypto_verify_rsa_pss_sha256,byte_buffer_set"
INT_RETURNING_FUNCS := "abs,min,max,clamp,len,fnv1a,ord,exec,fs_file_size,byte_buffer_len,byte_buffer_get,crypto_x25519_keygen,UInt,Int8,Int16,Int32,Int64,UInt8,UInt16,UInt32,UInt64"
STRING_RETURNING_FUNCS := "sha256,hex_encode,hex_decode,to_hex,b64_encode,chr,read_file,env,os_getcwd,os_temp_dir,os_home_dir,os_cert_roots_pem,scheme,host,query,fragment,decode,exec_output,type_of,get_string"
BYTES_RETURNING_FUNCS := "bytes_from_string_utf8,read_file_bytes,file_read_bytes,tcp_read_bytes,process_read_bytes,process_read_err_bytes,byte_buffer_bytes,b64_decode,from_hex,bytes_slice,bytes_concat,secure_random_bytes,crypto_x25519_public_key,crypto_x25519_shared_secret,crypto_aes_128_gcm_seal,crypto_aes_128_gcm_open,crypto_chacha20_poly1305_seal,crypto_chacha20_poly1305_open,crypto_sign_rsa_pss_sha256_pkcs8"
LIST_RETURNING_FUNCS := "args,range,repeat_val,zeros,sort,sort_desc,reversed,take,drop,slice,unique,without,intersection,difference,flatten,chunks"
LIST_STRING_RETURNING_FUNCS := "sort_strings,zip,enumerate,toml_keys"
BOOL_RETURNING_METHODS := "contains,starts_with,ends_with,is_empty,string_contains,string_is_empty,contains_key,map_contains_key,map_contains_ikey,map_is_empty,set_contains,set_contains_int,set_is_empty,list_contains,list_contains_string,list_is_empty,send,try_send,close,is_closed,is_done"
VOID_METHODS := "reverse,clear,push,remove,insert,add,list_remove,list_clear,list_reverse,map_insert,map_insert_ikey,map_remove,map_remove_ikey,map_clear,set_add,set_add_int,set_remove,set_remove_int,set_clear,detach"
STRING_RETURNING_METHODS := "trim,substring,to_upper,to_lower,reverse,replace,repeat,pad_left,pad_right,char_at,join,list_join,read_file,env,chr"

# --- emitted ir buffers ---
mut ir_lines: List[String] := []
mut ir_next_reg := 0
mut ir_next_label := 0
mut ir_strings: List[String] := []
mut ir_string_indices: Map[String, Int] := {}

# --- current function locals ---
mut ir_var_regs: Map[String, Int] := {}
mut ir_var_types: Map[String, String] := {} # variable name -> type hint or struct name
mut ir_map_value_types: Map[String, String] := {} # map variable name -> value type

# --- module globals collected during the prepass ---
mut ir_global_int_names: List[String] := []
mut ir_global_string_names: List[String] := []
mut ir_global_list_string_names: List[String] := []
mut ir_global_list_names: List[String] := []
mut ir_global_map_names: List[String] := []
mut ir_global_map_int_names: List[String] := []
mut ir_global_map_value_types: Map[String, String] := {}
mut ir_global_set_names: List[String] := []
mut ir_global_set_int_names: List[String] := []
mut ir_global_bool_names: List[String] := []

# --- type and symbol metadata copied from the checker ---
mut ir_struct_names: Map[String, Int] := {} # struct name -> field count
mut ir_struct_field_lookup: Map[String, String] := {} # "Struct.field" -> field type
mut ir_struct_field_index_lookup: Map[String, String] := {} # "Struct.field" -> field index string
mut ir_type_aliases: Map[String, String] := {} # alias name -> target type
mut ir_last_was_ret := false # tracks if the last emitted instruction was a return
mut ir_func_returns: Map[String, String] := {} # function name -> return type hint
mut ir_named_fn_value_wrappers: Map[String, String] := {}
mut ir_lambda_count := 0
mut ir_for_count := 0
mut ir_break_stack: List[String] := []
mut ir_continue_stack: List[String] := []
mut ir_lambda_bodies: List[String] := [] # deferred lambda function IR
mut ir_module_count := 0 # increments per emit_ir call for unique naming
mut ir_impl_methods: Map[String, String] := {}
mut ir_import_renames: Map[String, String] := {}
mut ir_module_aliases: Map[String, String] := {}
mut ir_import_declared_functions: Map[String, Bool] := {}
mut ir_import_declared_globals: Map[String, Bool] := {}
mut ir_current_func_return_kind := ""
mut ir_preloaded_import_roots: List[Int] := []
mut ir_preloaded_import_paths: List[String] := []
mut ir_emit_tests := false
mut ir_emitting_test_func := false
mut ir_generic_decl_indices: Map[String, Int] := {}
mut ir_generic_decl_module_paths: Map[String, String] := {}
mut ir_generic_specialization_keys: List[String] := []
mut ir_generic_specialization_names: Map[String, String] := {}
mut ir_generic_specialization_type_lists: Map[String, String] := {}
mut ir_generic_emitted_specializations: Map[String, Int] := {}
mut ir_active_generic_params: List[String] := []
mut ir_active_generic_concrete_types: List[String] := []
mut ir_generic_runtime_subst: Map[String, String] := {}
mut ir_active_generic_module_path := ""
mut ir_root_items_cache: Map[Int, List[Int]] := {}
mut ir_string_node_cache_roots: List[Int] := []
mut ir_string_node_cache_values: List[String] := []

fn ir_new_temp_name(prefix: String) -> String:
    return "__" + prefix + "_" + ir_next_reg.to_string() + "_" + ir_next_label.to_string()

fn ir_push_string(items: List[String], value: String) -> List[String]:
    mut updated: List[String] := items
    updated.push(value)
    return updated

fn ir_encode_int_list(items: List[Int]) -> String:
    mut encoded: List[String] := []
    for item in items:
        encoded.push(item.to_string())
    return encoded.join(chr(9))

fn ir_parse_cached_int(text: String) -> Int:
    mut value := 0
    mut i := 0
    while i < text.len():
        value = (value * 10) + (ord(text.substring(i, i + 1)) - ord("0"))
        i = i + 1
    return value

fn ir_parse_field_index(text: String) -> Int:
    if text.len() == 0:
        return 0 - 1
    mut value := 0
    mut i := 0
    while i < text.len():
        ch := text[i]
        code := ord(ch)
        if code < 48 or code > 57:
            return 0 - 1
        value = (value * 10) + (code - 48)
        i = i + 1
    return value

fn ir_decode_int_list(encoded: String) -> List[Int]:
    mut decoded: List[Int] := []
    if encoded.len() == 0:
        return decoded
    parts := encoded.split(chr(9))
    for part in parts:
        decoded.push(ir_parse_cached_int(part))
    return decoded

pub fn set_import_roots(roots: List[Int], paths: List[String]):
    ir_preloaded_import_roots = roots
    ir_preloaded_import_paths = paths

pub fn set_test_mode(enabled: Bool):
    ir_emit_tests = enabled

fn ir_reset_local_state():
    ir_lines = []
    ir_next_reg = 0
    ir_next_label = 0
    ir_strings = []
    ir_string_indices = {}
    ir_var_regs = {}
    ir_var_types = {}
    ir_map_value_types = {}

fn ir_reset_global_state():
    ir_global_int_names = []
    ir_global_string_names = []
    ir_global_list_string_names = []
    ir_global_list_names = []
    ir_global_map_names = []
    ir_global_map_int_names = []
    ir_global_map_value_types = {}
    ir_global_set_names = []
    ir_global_set_int_names = []
    ir_global_bool_names = []

fn ir_reset_type_state():
    ir_struct_field_lookup = {}
    ir_struct_field_index_lookup = {}
    ir_impl_methods = {}
    ir_import_renames = {}
    ir_func_returns = {}
    ir_named_fn_value_wrappers = {}
    ir_module_aliases = {}
    ir_import_declared_functions = {}
    ir_import_declared_globals = {}
    ir_current_func_return_kind = ""
    ir_generic_decl_indices = {}
    ir_generic_decl_module_paths = {}
    ir_generic_specialization_keys = []
    ir_generic_specialization_names = {}
    ir_generic_specialization_type_lists = {}
    ir_generic_emitted_specializations = {}
    ir_active_generic_params = []
    ir_active_generic_concrete_types = []
    ir_generic_runtime_subst = {}
    ir_active_generic_module_path = ""

fn ir_reset_control_flow_state():
    ir_break_stack = []
    ir_continue_stack = []

pub fn ir_reset():
    ir_reset_local_state()
    ir_reset_global_state()
    ir_reset_type_state()
    ir_reset_control_flow_state()

fn ir_emit(line: String):
    ir_lines = ir_push_string(ir_lines, line)

fn ir_reg() -> Int:
    r := ir_next_reg
    ir_next_reg = ir_next_reg + 1
    return r

fn ir_label() -> String:
    n := ir_next_label
    ir_next_label = ir_next_label + 1
    return "L" + n.to_string()

fn ir_strip_quotes(s: String) -> String:
    mut result := s
    if result.len() >= 2:
        if result.substring(0, 1) == chr(34):
            result = result.substring(1, result.len())
        if result.len() > 0 and result.substring(result.len() - 1, result.len()) == chr(34):
            result = result.substring(0, result.len() - 1)
    return result

fn ir_resolve_type_hint(type_name: String) -> String:
    mut resolved := type_name
    if ir_type_aliases.contains_key(resolved):
        resolved = ir_type_aliases[resolved]
    if resolved.starts_with("opaque:"):
        resolved = resolved.substring(7, resolved.len())
    if resolved == "String":
        return "string"
    if resolved == "Bytes":
        return "bytes"
    if resolved == "Bool":
        return "bool"
    if resolved == "Int":
        return "int"
    if resolved == "Float":
        return "float"
    if resolved.contains("List[String]"):
        return "list_string"
    if resolved.contains("List[") or resolved == "List":
        return "list"
    if resolved.contains("Map[Int,") or resolved.contains("Map[Int, "):
        return "map_int"
    if resolved.contains("Map[") or resolved == "Map":
        return "map"
    if resolved.contains("Set[Int]") or resolved.contains("Set[UInt]") or resolved.contains("Set[Int8]") or resolved.contains("Set[Int16]") or resolved.contains("Set[Int32]") or resolved.contains("Set[Int64]") or resolved.contains("Set[UInt8]") or resolved.contains("Set[UInt16]") or resolved.contains("Set[UInt32]") or resolved.contains("Set[UInt64]"):
        return "set_int"
    if resolved.contains("Set[") or resolved == "Set":
        return "set"
    if resolved.contains("Channel[") or resolved == "Channel":
        return "channel"
    if resolved.contains("Task[") or resolved == "Task":
        return "task"
    mut base := resolved
    if base.contains("["):
        base = base.substring(0, base.index_of("["))
    if ir_struct_names.contains_key(base):
        return base
    return resolved

fn ir_resolve_generic_type_node(tn: Node) -> String:
    if tn.value == "List":
        if tn.children.len() > 0:
            first := get_node(tn.children[0])
            if first.kind == "type" and first.value == "String":
                return "list_string"
        return "list"
    if tn.value == "Map":
        if tn.children.len() > 0:
            first := get_node(tn.children[0])
            if first.kind == "type" and first.value == "Int":
                return "map_int"
        return "map"
    if tn.value == "Set":
        return "set"
    return ""

fn ir_resolve_result_type_kind(inner_type: String) -> String:
    return "tuple"

fn ir_resolve_type_node(type_idx: Int) -> String:
    if ir_active_generic_params.len() > 0:
        resolved := ir_resolve_type_node_with_subst(type_idx, ir_active_generic_params, ir_active_generic_concrete_types)
        if resolved.len() > 0:
            return resolved
    tn := get_node(type_idx)
    if tn.kind == "type":
        return ir_resolve_type_hint(tn.value)
    if tn.kind == "generic_type":
        generic_type := ir_resolve_generic_type_node(tn)
        if generic_type.len() > 0:
            return generic_type
        return ir_resolve_type_hint(tn.value)
    if tn.kind == "result_type" and tn.children.len() > 0:
        inner_type := ir_resolve_type_node(tn.children[0])
        return ir_resolve_result_type_kind(inner_type)
    if tn.kind == "optional_type" and tn.children.len() > 0:
        return ir_resolve_type_node(tn.children[0])
    if tn.kind == "fn_type":
        return "closure"
    if tn.kind == "tuple_type":
        return "tuple"
    return ""

fn ir_resolve_map_value_type_node(type_idx: Int) -> String:
    tn := get_node(type_idx)
    if tn.kind == "generic_type" and tn.value == "Map" and tn.children.len() > 1:
        if ir_active_generic_params.len() > 0:
            return ir_resolve_type_node_with_subst(tn.children[1], ir_active_generic_params, ir_active_generic_concrete_types)
        return ir_resolve_type_node(tn.children[1])
    return ""

fn ir_lookup_map_value_type(name: String) -> String:
    if ir_map_value_types.contains_key(name):
        return ir_map_value_types[name]
    return ""

fn ir_lookup_map_value_type_for_expr(idx: Int) -> String:
    node := get_node(idx)
    if node.kind == "ident":
        return ir_lookup_map_value_type(node.value)
    return ""

fn ir_expr_result_kind(idx: Int) -> String:
    checked_kind := ir_checked_result_kind(idx)
    if checked_kind.len() > 0:
        return checked_kind
    return ir_expr_legacy_result_kind(idx)

fn ir_uses_result_abi(result_kind: String) -> Bool:
    return result_kind.len() > 0 and result_kind != "tuple"

fn ir_encode_result_value(value_reg: Int, result_kind: String) -> Int:
    if ir_uses_result_abi(result_kind):
        one := ir_reg()
        ir_emit("iconst " + one.to_string() + " 1")
        encoded := ir_reg()
        ir_emit("add " + encoded.to_string() + " " + value_reg.to_string() + " " + one.to_string())
        return encoded
    return value_reg

fn ir_decode_result_value(value_reg: Int, result_kind: String) -> Int:
    if ir_uses_result_abi(result_kind):
        one := ir_reg()
        ir_emit("iconst " + one.to_string() + " 1")
        decoded := ir_reg()
        ir_emit("sub " + decoded.to_string() + " " + value_reg.to_string() + " " + one.to_string())
        return decoded
    return value_reg

fn ir_list_contains(items: List[String], value: String) -> Bool:
    for item in items:
        if item == value:
            return true
    return false

fn ir_is_string_literal_kind(kind: String) -> Bool:
    return kind == "string_lit" or kind == "string" or kind == "str_lit" or kind == "lit"

fn ir_string_symbol_name(index: Int) -> String:
    return "m" + ir_module_count.to_string() + "s" + index.to_string()

fn ir_should_capture_name(name: String, bound: List[String], free: List[String]) -> Bool:
    if ir_list_contains(bound, name) or ir_list_contains(free, name):
        return false
    if ir_module_aliases.contains_key(name):
        return false
    if ir_import_renames.contains_key(name):
        return false
    return ir_known_callable_return_type(name).len() == 0

fn ir_copy_names(names: List[String]) -> List[String]:
    mut copy: List[String] := []
    for name in names:
        copy.push(name)
    return copy

fn ir_csv_contains(csv: String, name: String) -> Bool:
    if name.len() == 0:
        return false
    items := csv.split(",")
    for item in items:
        if item == name:
            return true
    return false

fn ir_is_float_returning_func(fname: String) -> Bool:
    return ir_csv_contains(FLOAT_RETURNING_FUNCS, fname)

fn ir_is_bool_returning_func(fname: String) -> Bool:
    return ir_csv_contains(BOOL_RETURNING_FUNCS, fname)

fn ir_is_int_returning_func(fname: String) -> Bool:
    return ir_csv_contains(INT_RETURNING_FUNCS, fname)

fn ir_is_string_returning_func(fname: String) -> Bool:
    return ir_csv_contains(STRING_RETURNING_FUNCS, fname)

fn ir_is_bytes_returning_func(fname: String) -> Bool:
    return ir_csv_contains(BYTES_RETURNING_FUNCS, fname)

fn ir_is_list_returning_func(fname: String) -> Bool:
    return ir_csv_contains(LIST_RETURNING_FUNCS, fname)

fn ir_is_list_string_returning_func(fname: String) -> Bool:
    return ir_csv_contains(LIST_STRING_RETURNING_FUNCS, fname)

fn ir_is_bool_returning_method(meth: String) -> Bool:
    return ir_csv_contains(BOOL_RETURNING_METHODS, meth)

fn ir_is_void_method(meth: String) -> Bool:
    return ir_csv_contains(VOID_METHODS, meth)

fn ir_is_string_returning_method(meth: String) -> Bool:
    return ir_csv_contains(STRING_RETURNING_METHODS, meth)

fn ir_find_free_vars_walk(idx: Int, bound: List[String], free: List[String]) -> List[String]:
    node := get_node(idx)
    if node.kind == "ident":
        name := node.value
        if ir_should_capture_name(name, bound, free):
            mut updated := ir_copy_names(free)
            updated.push(name)
            return updated
        return free
    if node.kind == "lambda":
        inner_bound := ir_copy_names(bound)
        for child in node.children:
            cn := get_node(child)
            if cn.kind == "param":
                inner_bound.push(cn.value)
        mut updated_free := ir_copy_names(free)
        for child in node.children:
            cn := get_node(child)
            if cn.kind == "body":
                updated_free = ir_find_free_vars_walk(child, inner_bound, updated_free)
        return updated_free
    if node.kind == "body":
        mut scoped_bound := ir_copy_names(bound)
        mut updated_free := ir_copy_names(free)
        for child in node.children:
            updated_free = ir_find_free_vars_walk(child, scoped_bound, updated_free)
            child_node := get_node(child)
            if ir_is_binding_kind(child_node.kind):
                bind_name := ir_binding_name(child_node)
                if bind_name.len() > 0 and not ir_list_contains(scoped_bound, bind_name):
                    scoped_bound.push(bind_name)
        return updated_free
    mut updated_free := ir_copy_names(free)
    for child in node.children:
        updated_free = ir_find_free_vars_walk(child, bound, updated_free)
    return updated_free

fn ir_find_free_vars(idx: Int, bound: List[String]) -> List[String]:
    return ir_find_free_vars_walk(idx, bound, [])

fn ir_str(s: String) -> String:
    cleaned := ir_strip_quotes(s)
    if ir_string_indices.contains_key(cleaned):
        return ir_string_symbol_name(ir_string_indices[cleaned])
    idx := ir_strings.len()
    ir_strings = ir_push_string(ir_strings, cleaned)
    ir_string_indices.insert(cleaned, idx)
    return ir_string_symbol_name(idx)

fn ir_collect_string_nodes(idx: Int) -> List[Int]:
    mut string_nodes: List[Int] := []
    mut stack: List[Int] := [idx]
    while stack.len() > 0:
        current := stack[stack.len() - 1]
        stack.remove(stack.len() - 1)
        node := get_node(current)
        if ir_is_string_literal_kind(node.kind):
            string_nodes.push(current)
        kids := node.children
        for kid in kids:
            stack.push(kid)
    return string_nodes

fn ir_cached_string_nodes(root_idx: Int) -> List[Int]:
    for cached_root, i in ir_string_node_cache_roots:
        if cached_root == root_idx:
            return ir_decode_int_list(ir_string_node_cache_values[i])
    nodes := ir_collect_string_nodes(root_idx)
    ir_string_node_cache_roots.push(root_idx)
    ir_string_node_cache_values.push(ir_encode_int_list(nodes))
    return nodes

# --- collect strings (iterative to avoid deep recursion crashes) ---
fn ir_collect_strings(idx: Int):
    nodes := ir_cached_string_nodes(idx)
    for node_idx in nodes:
        ir_str(get_node(node_idx).value)

fn ir_struct_field_name(field_node: Node) -> String:
    mut field_name := field_node.value
    if field_name.contains(" "):
        field_name = field_name.split(" ")[0]
    return field_name

fn ir_collect_struct_field_strings(root_idx: Int):
    for item_idx in ir_root_items(root_idx):
        actual := ir_unwrap_pub_node(item_idx)
        if actual.kind == "struct_decl" or actual.kind == "struct":
            for child in actual.children:
                field_node := get_node(child)
                if field_node.kind == "field":
                    ir_str(ir_struct_field_name(field_node))

fn ir_retkind(type_name: String) -> String:
    if type_name.len() == 0:
        return "unknown"
    resolved := ir_resolve_type_hint(type_name)
    if resolved == "int":
        return "int"
    if resolved == "float":
        return "float"
    if resolved == "bool":
        return "bool"
    if resolved == "string":
        return "string"
    if resolved == "list":
        return "list"
    if resolved == "list_string":
        return "list_string"
    if resolved == "map":
        return "map"
    if resolved == "map_int":
        return "map_int"
    if resolved == "set_int":
        return "set_int"
    if resolved == "set":
        return "set"
    if resolved == "void":
        return "void"
    if resolved == "Mutex" or resolved == "WaitGroup" or resolved == "Semaphore":
        return "opaque:" + resolved
    if ir_struct_names.contains_key(resolved):
        return "struct:" + resolved
    return resolved

fn ir_is_declared_callable(name: String) -> Bool:
    return ir_func_returns.contains_key(name)

fn ir_runtime_call_name(name: String) -> String:
    if name == "print":
        return "forge_print_cstr"
    if name == "spawn":
        return "forge_spawn"
    if name == "await":
        return "forge_await"
    if name == "int_to_string":
        return "int_to_string"
    if name == "float_to_string":
        return "float_to_string"
    if name == "bool_to_string":
        return "bool_to_string"
    if name == "len":
        return "forge_auto_len"
    if name == "contains" or name == "string_contains":
        return "forge_cstring_contains"
    if name == "substring":
        return "forge_cstring_substring"
    if name == "starts_with":
        return "forge_cstring_starts_with"
    if name == "ends_with":
        return "forge_cstring_ends_with"
    if name == "trim":
        return "forge_cstring_trim"
    if name == "split":
        return "forge_string_split_to_list"
    if name == "to_upper":
        return "forge_cstring_to_upper"
    if name == "to_lower":
        return "forge_cstring_to_lower"
    if name == "replace":
        return "forge_cstring_replace"
    if name == "repeat":
        return "forge_cstring_repeat"
    if name == "index_of" or name == "string_index_of":
        return "forge_cstring_index_of"
    if name == "last_index_of" or name == "string_last_index_of":
        return "forge_cstring_last_index_of"
    if name == "char_at":
        return "forge_cstring_char_at"
    if name == "chars":
        return "forge_cstring_chars"
    if name == "reverse":
        return "forge_cstring_reverse"
    if name == "is_empty" or name == "string_is_empty":
        return "forge_cstring_is_empty"
    if name == "join":
        return "list_join"
    if name == "slice":
        return "list_slice_copy"
    if name == "push":
        return "forge_list_push_value"
    if name == "pop":
        return "forge_list_pop"
    if name == "set":
        return "forge_list_set_value"
    if name == "map" or name == "list_map":
        return "forge_list_map"
    if name == "filter" or name == "list_filter":
        return "forge_list_filter"
    if name == "reduce" or name == "list_reduce":
        return "forge_list_reduce"
    if name == "each" or name == "list_each":
        return "forge_list_each"
    if name == "sort_strings":
        return "forge_list_sort_strings"
    if name == "__list_get" or name == "__index":
        return "forge_list_get_value"
    if name == "__list_get_unchecked":
        return "forge_list_get_value_unchecked"
    if name == "__list_new":
        return "forge_list_new_default"
    if name == "__list_push":
        return "forge_list_push_value"
    if name == "__map_new":
        return "forge_map_new_default"
    if name == "__map_new_int":
        return "forge_map_new_int"
    if name == "__set_new":
        return "forge_set_new_default"
    if name == "__set_new_int":
        return "forge_set_new_int"
    if name == "__set_to_list":
        return "forge_set_to_list_cstr"
    if name == "__set_to_list_int":
        return "forge_set_to_list_int_handle"
    if name == "__struct_alloc":
        return "forge_struct_alloc"
    if name == "__closure_set_env":
        return "forge_closure_set_env"
    if name == "__closure_get_env":
        return "forge_closure_get_env"
    if name == "__str_eq":
        return "forge_cstring_eq"
    return name

fn ir_emit_func_header(name: String, param_count: Int, ret_type: String):
    ir_emit("func " + name + " " + param_count.to_string() + " " + ir_retkind(ret_type))

fn ir_emit_call_text(result_reg: Int, fname: String, ret_type: String, arg_count: Int, arg_text: String):
    mut emit_name := fname
    if not ir_is_declared_callable(fname):
        emit_name = ir_runtime_call_name(fname)
    mut call_line := "call " + result_reg.to_string() + " " + emit_name + " " + ir_retkind(ret_type) + " " + arg_count.to_string()
    if arg_text.len() > 0:
        call_line = call_line + arg_text
    ir_emit(call_line)

fn ir_emit_call0(result_reg: Int, fname: String, ret_type: String):
    ir_emit_call_text(result_reg, fname, ret_type, 0, "")

fn ir_emit_call1(result_reg: Int, fname: String, ret_type: String, arg0: Int):
    ir_emit_call_text(result_reg, fname, ret_type, 1, " " + arg0.to_string())

fn ir_module_default_alias(module_path: String) -> String:
    mut last_dot := 0 - 1
    mut i := 0
    while i < module_path.len():
        if module_path[i] == ".":
            last_dot = i
        i = i + 1
    if last_dot < 0:
        return module_path
    return module_path.substring(last_dot + 1, module_path.len())

fn ir_import_symbol_prefix(module_path: String) -> String:
    if module_path.len() == 0:
        return ""
    mut prefix := ""
    mut i := 0
    while i < module_path.len():
        if module_path[i] == ".":
            prefix = prefix + "_"
        else:
            prefix = prefix + module_path[i]
        i = i + 1
    return prefix + "_"

fn ir_import_target_name(module_path: String, name: String) -> String:
    return ir_import_symbol_prefix(module_path) + name

struct ResolvedCallee:
    name: String
    imported: Bool

fn ir_module_alias_member_name(alias: String, member: String) -> String:
    if not ir_module_aliases.contains_key(alias):
        return ""
    module_path := ir_module_aliases[alias]
    if ir_import_declares_function(module_path, member):
        return ir_import_target_name(module_path, member)
    if ir_import_declares_global(module_path, member):
        return ir_import_target_name(module_path, member)
    return member

fn ir_import_declares_function(module_path: String, name: String) -> Bool:
    return ir_import_declared_functions.contains_key(module_path + "." + name)

fn ir_import_declares_global(module_path: String, name: String) -> Bool:
    return ir_import_declared_globals.contains_key(module_path + "." + name)

fn ir_collect_import_declared_functions(root_idx: Int, module_path: String):
    for item_idx in ir_root_items(root_idx):
        node := get_node(item_idx)
        if ir_is_fn_decl_kind(node.kind):
            ir_import_declared_functions.insert(module_path + "." + ir_base_decl_name(node.value), true)
        elif ir_is_binding_kind(node.kind):
            ir_import_declared_globals.insert(module_path + "." + ir_binding_name(node), true)

fn ir_record_generic_function_decl(item_idx: Int, node: Node, module_path: String):
    mut full_name := node.value
    if module_path.len() > 0:
        full_name = ir_import_target_name(module_path, node.value)
    ir_generic_decl_indices.insert(full_name, item_idx)
    ir_generic_decl_module_paths.insert(full_name, module_path)

fn ir_collect_preloaded_root_metadata(root_idx: Int, module_path: String):
    for item_idx in ir_root_items(root_idx):
        node := get_node(item_idx)
        if ir_is_fn_decl_kind(node.kind):
            ir_import_declared_functions.insert(module_path + "." + ir_base_decl_name(node.value), true)
        elif ir_is_binding_kind(node.kind):
            ir_import_declared_globals.insert(module_path + "." + ir_binding_name(node), true)

fn ir_plain_method_name(name: String) -> String:
    if name.starts_with("."):
        return name.substring(1, name.len())
    return name

fn ir_ident_callee(name: String) -> ResolvedCallee:
    if ir_import_renames.contains_key(name):
        return ResolvedCallee(ir_import_renames[name], true)
    if ir_active_generic_module_path.len() > 0 and ir_import_declares_function(ir_active_generic_module_path, name):
        return ResolvedCallee(ir_import_target_name(ir_active_generic_module_path, name), true)
    return ResolvedCallee(name, false)

fn ir_resolve_module_alias_call_name(idx: Int) -> String:
    node := get_node(idx)
    if node.kind != "field_access" or node.children.len() == 0:
        return ""
    recv := get_node(node.children[0])
    if recv.kind != "ident":
        return ""
    return ir_module_alias_member_name(recv.value, node.value)

fn ir_resolve_module_alias_method_call_name(idx: Int) -> String:
    node := get_node(idx)
    if node.kind != "method_call" or node.children.len() == 0:
        return ""
    recv := get_node(node.children[0])
    if recv.kind != "ident":
        return ""
    return ir_module_alias_member_name(recv.value, ir_plain_method_name(node.value))

fn ir_resolve_static_callee(idx: Int) -> ResolvedCallee:
    node := get_node(idx)
    if node.kind == "ident":
        return ir_ident_callee(node.value)
    if node.kind == "index" and node.children.len() > 0:
        base_node := get_node(node.children[0])
        if base_node.kind == "ident" and base_node.value == "Channel":
            return ResolvedCallee("Channel", false)
    if node.kind == "field_access":
        alias_name := ir_resolve_module_alias_call_name(idx)
        if alias_name.len() > 0:
            return ResolvedCallee(alias_name, true)
    return ResolvedCallee("", false)

fn ir_is_json_decode_callee(index_idx: Int, member_name: String) -> Bool:
    index_node := get_node(index_idx)
    if index_node.kind != "index" or index_node.children.len() < 2:
        return false
    base_node := get_node(index_node.children[0])
    if base_node.kind != "field_access" or base_node.value != member_name:
        return false
    if base_node.children.len() < 1:
        return false
    recv := get_node(base_node.children[0])
    if recv.kind != "ident":
        return false
    if ir_module_aliases.contains_key(recv.value):
        if ir_module_aliases[recv.value] == "std.json":
            return true
    return recv.value == "json" or recv.value == "json_mod"

fn ir_callee_uses_result_abi(callee: ResolvedCallee, idx: Int) -> Bool:
    raw_kind := ir_declared_callable_ir_retkind(callee.name)
    if raw_kind == "tuple" or raw_kind == "result_int" or raw_kind == "result_bool":
        return true
    return ir_builtin_result_retkind(callee.name).len() > 0

fn ir_emit_call2(result_reg: Int, fname: String, ret_type: String, arg0: Int, arg1: Int):
    ir_emit_call_text(result_reg, fname, ret_type, 2, " " + arg0.to_string() + " " + arg1.to_string())

fn ir_emit_call3(result_reg: Int, fname: String, ret_type: String, arg0: Int, arg1: Int, arg2: Int):
    ir_emit_call_text(result_reg, fname, ret_type, 3, " " + arg0.to_string() + " " + arg1.to_string() + " " + arg2.to_string())

fn ir_declared_callable_ir_retkind(fname: String) -> String:
    if not ir_func_returns.contains_key(fname):
        return ""
    return ir_func_returns[fname]

fn ir_declared_callable_return_type(fname: String) -> String:
    ret_kind := ir_declared_callable_ir_retkind(fname)
    if ret_kind.len() == 0:
        return ""
    if ret_kind == "result_int":
        return "int"
    if ret_kind == "result_bool":
        return "bool"
    if ret_kind == "tuple":
        return "tuple"
    return ir_resolve_type_hint(ret_kind)

fn ir_collect_call_arg_regs(node: Node, start_idx: Int) -> List[Int]:
    mut arg_regs: List[Int] := []
    for child, i in node.children:
        if i < start_idx:
            continue
        child_kind := node_kind(child)
        if child_kind == "arg":
            cn := get_node(child)
            if cn.children.len() > 0:
                arg_regs.push(ir_expr(cn.children[0]))
        else:
            arg_regs.push(ir_expr(child))
    return arg_regs

fn ir_join_arg_regs(arg_regs: List[Int]) -> String:
    mut call_text := ""
    for arg_reg in arg_regs:
        call_text = call_text + " " + arg_reg.to_string()
    return call_text

fn ir_emit_resolved_call(result_reg: Int, fname: String, idx: Int, arg_regs: List[Int], uses_result_abi: Bool):
    ir_emit_call_text(result_reg, fname, ir_call_retkind(idx, uses_result_abi), arg_regs.len(), ir_join_arg_regs(arg_regs))

fn ir_method_call_arg_regs(obj_r: Int, arg_regs: List[Int]) -> List[Int]:
    mut call_args := [obj_r]
    for arg_reg in arg_regs:
        call_args.push(arg_reg)
    return call_args

fn ir_copy_lines(lines: List[String]) -> List[String]:
    mut copy: List[String] := []
    for line in lines:
        copy.push(line)
    return copy

fn ir_copy_var_regs(src: Map[String, Int]) -> Map[String, Int]:
    mut copy: Map[String, Int] := {}
    for key in src.keys():
        copy.insert(key, src[key])
    return copy

fn ir_copy_var_types(src: Map[String, String]) -> Map[String, String]:
    mut copy: Map[String, String] := {}
    for key in src.keys():
        copy.insert(key, src[key])
    return copy

fn ir_unpack_field_index(meta: String) -> Int:
    mut value := 0
    mut i := 0
    while i < meta.len():
        value = (value * 10) + (ord(meta.substring(i, i + 1)) - ord("0"))
        i = i + 1
    return value

fn ir_register_struct_layout(name: String, field_names: List[String], field_types: List[String]):
    if ir_struct_names.contains_key(name):
        return
    for field_name, i in field_names:
        ir_struct_field_lookup.insert(name + "." + field_name, field_types[i])
        ir_struct_field_index_lookup.insert(name + "." + field_name, i.to_string())
    ir_struct_names.insert(name, field_names.len())
    ir_emit("struct " + name + " " + field_names.join(" "))

fn ir_unwrap_pub_node(idx: Int) -> Node:
    mut node := get_node(idx)
    if node.kind == "pub" and node.children.len() > 0:
        node = get_node(node.children[0])
    return node

fn ir_is_binding_kind(kind: String) -> Bool:
    return kind == "bind" or kind == "binding"

fn ir_binding_name(node: Node) -> String:
    mut name := node.value
    if name.contains(" mut"):
        name = name.substring(0, name.len() - 4)
    elif name.contains(" "):
        name = name.split(" ")[0]
    return name

fn ir_binding_has_collection_init(node: Node) -> Bool:
    for child in node.children:
        kind := get_node(child).kind
        if kind == "list" or kind == "map" or kind == "set":
            return true
    return false

fn ir_record_global_type(name: String, global_type: String):
    if global_type == "int":
        ir_global_int_names = ir_push_string(ir_global_int_names, name)
    elif global_type == "string":
        ir_global_string_names = ir_push_string(ir_global_string_names, name)
    elif global_type == "list_string":
        ir_global_list_string_names = ir_push_string(ir_global_list_string_names, name)
    elif global_type == "list":
        ir_global_list_names = ir_push_string(ir_global_list_names, name)
    elif global_type == "map_int":
        ir_global_map_int_names = ir_push_string(ir_global_map_int_names, name)
    elif global_type == "map":
        ir_global_map_names = ir_push_string(ir_global_map_names, name)
    elif global_type == "set":
        ir_global_set_names = ir_push_string(ir_global_set_names, name)
    elif global_type == "set_int":
        ir_global_set_int_names = ir_push_string(ir_global_set_int_names, name)
    elif global_type == "bool":
        ir_global_bool_names = ir_push_string(ir_global_bool_names, name)

fn ir_unwrap_pub_child(idx: Int) -> Int:
    node := get_node(idx)
    if node.kind == "pub" and node.children.len() > 0:
        return node.children[0]
    return idx

fn ir_impl_target_type(node: Node) -> String:
    mut impl_type := ""
    for child in node.children:
        child_node := get_node(child)
        if child_node.kind == "type":
            impl_type = child_node.value
        elif child_node.kind == "for_type":
            for type_idx in child_node.children:
                type_child := get_node(type_idx)
                if type_child.kind == "type":
                    impl_type = type_child.value
        elif child_node.kind == "generic_type" and impl_type == "":
            impl_type = child_node.value
    return impl_type

fn ir_emit_impl_methods(node: Node, impl_type: String):
    for child in node.children:
        child_node := get_node(child)
        if child_node.kind == "fn_decl":
            ir_impl_func(child, impl_type)

fn ir_declared_struct_name(node: Node) -> String:
    if node.value.contains("["):
        return node.value.substring(0, node.value.index_of("["))
    return node.value

fn ir_record_struct_field(struct_name: String, field_names: List[String], field_node: Node) -> List[String]:
    field_name := ir_struct_field_name(field_node)
    mut updated_fields := field_names
    field_index := updated_fields.len()
    updated_fields.push(field_name)
    if field_node.children.len() > 0:
        type_node := get_node(field_node.children[0])
        if type_node.kind == "type" or type_node.kind == "generic_type":
            ir_struct_field_lookup.insert(struct_name + "." + field_name, ir_resolve_type_node(field_node.children[0]))
    ir_struct_field_index_lookup.insert(struct_name + "." + field_name, field_index.to_string())
    return updated_fields

fn ir_collect_struct_decl(node: Node, emit_decl: Bool):
    sname := ir_declared_struct_name(node)
    mut field_names: List[String] := []
    for child in node.children:
        field_node := ir_unwrap_pub_node(child)
        if field_node.kind == "field":
            field_names = ir_record_struct_field(sname, field_names, field_node)
    ir_struct_names.insert(sname, field_names.len())
    if emit_decl:
        ir_emit("struct " + sname + " " + field_names.join(" "))

fn ir_collect_enum_decl(node: Node, emit_decl: Bool):
    sname := node.value
    mut variant_names: List[String] := []
    for child in node.children:
        variant_node := ir_unwrap_pub_node(child)
        if variant_node.kind == "variant":
            variant_index := variant_names.len()
            variant_names.push(variant_node.value)
            ir_struct_field_lookup.insert(sname + "." + variant_node.value, sname)
            ir_struct_field_index_lookup.insert(sname + "." + variant_node.value, variant_index.to_string())
    ir_struct_names.insert(sname, variant_names.len())
    if emit_decl:
        ir_emit("struct " + sname + " " + variant_names.join(" "))

fn ir_collect_struct_decls(root_idx: Int, emit_decl: Bool):
    for item_idx in ir_root_items(root_idx):
        cn := get_node(item_idx)
        if cn.kind == "struct_decl" or cn.kind == "struct":
            ir_collect_struct_decl(cn, emit_decl)
        elif cn.kind == "enum_decl" or cn.kind == "enum":
            ir_collect_enum_decl(cn, emit_decl)

fn ir_seed_global_types():
    for name in ir_global_int_names:
        ir_var_types.insert(name, "int")
    for name in ir_global_string_names:
        ir_var_types.insert(name, "string")
    for name in ir_global_list_string_names:
        ir_var_types.insert(name, "list_string")
    for name in ir_global_list_names:
        ir_var_types.insert(name, "list")
    for name in ir_global_map_int_names:
        ir_var_types.insert(name, "map_int")
    for name in ir_global_map_names:
        ir_var_types.insert(name, "map")
    for name in ir_global_set_int_names:
        ir_var_types.insert(name, "set_int")
    for name in ir_global_set_names:
        ir_var_types.insert(name, "set")
    for name in ir_global_bool_names:
        ir_var_types.insert(name, "bool")
    for name in ir_global_map_value_types.keys():
        ir_map_value_types.insert(name, ir_global_map_value_types[name])

fn ir_register_known_import_structs():
    ir_register_struct_layout("Node", ["kind", "value", "children", "line", "col"], ["string", "string", "list", "int", "int"])
    ir_register_struct_layout("Token", ["kind", "value", "current_line", "current_column"], ["string", "string", "int", "int"])
    ir_register_struct_layout("TypeInfo", ["kind", "name", "fields", "field_types", "field_pub", "field_mut", "param_types", "return_type", "inner", "key_type", "value_type", "elements", "variants", "variant_types"], ["string", "string", "list_string", "list", "list", "list", "list", "int", "int", "int", "int", "list", "list_string", "list"])
    ir_register_struct_layout("Diagnostic", ["severity", "code", "message", "file", "line", "col", "fix"], ["string", "string", "string", "string", "int", "int", "string"])

fn ir_type_from_tid(tid: Int) -> String:
    if tid < 0:
        return ""
    mut info := get_type_info(tid)
    if info.kind == "result":
        return "tuple"
    if info.kind == "optional":
        return "tuple"
    if info.kind == "primitive":
        if info.name == "Int" or info.name == "UInt" or info.name == "Int8" or info.name == "Int16" or info.name == "Int32" or info.name == "Int64" or info.name == "UInt8" or info.name == "UInt16" or info.name == "UInt32" or info.name == "UInt64":
            return "int"
        if info.name == "Float":
            return "float"
        if info.name == "Bool":
            return "bool"
        if info.name == "String":
            return "string"
        if info.name == "Bytes":
            return "bytes"
        return ""
    if info.kind == "list":
        elem_info := get_type_info(info.inner)
        if elem_info.kind == "primitive" and elem_info.name == "String":
            return "list_string"
        return "list"
    if info.kind == "map":
        key_info := get_type_info(info.key_type)
        if key_info.kind == "primitive" and (key_info.name == "Int" or key_info.name == "UInt" or key_info.name == "Int8" or key_info.name == "Int16" or key_info.name == "Int32" or key_info.name == "Int64" or key_info.name == "UInt8" or key_info.name == "UInt16" or key_info.name == "UInt32" or key_info.name == "UInt64"):
            return "map_int"
        return "map"
    if info.kind == "set":
        elem_info := get_type_info(info.inner)
        if elem_info.kind == "primitive" and (elem_info.name == "Int" or elem_info.name == "UInt" or elem_info.name == "Int8" or elem_info.name == "Int16" or elem_info.name == "Int32" or elem_info.name == "Int64" or elem_info.name == "UInt8" or elem_info.name == "UInt16" or elem_info.name == "UInt32" or elem_info.name == "UInt64"):
            return "set_int"
        return "set"
    if info.kind == "tuple":
        return "tuple"
    if info.kind == "enum":
        return "int"
    if info.kind == "struct":
        return info.name
    if info.kind == "channel":
        return "channel"
    if info.kind == "task":
        return "task"
    return ""

fn ir_checked_type(idx: Int) -> String:
    return ir_type_from_tid(c_get_expr_type(idx))

fn ir_checked_result_kind(idx: Int) -> String:
    tid := c_get_expr_type(idx)
    if tid < 0:
        return ""
    info := get_type_info(tid)
    if info.kind != "result":
        return ""
    return "tuple"

fn ir_builtin_result_retkind(name: String) -> String:
    if name == "parse_int":
        return "tuple"
    if name == "file_open_read" or name == "file_open_write" or name == "file_open_append" or name == "byte_buffer_write" or name == "byte_buffer_write_string_utf8" or name == "byte_buffer_write_byte" or name == "file_write" or name == "file_write_bytes" or name == "tcp_connect" or name == "tcp_listen" or name == "tcp_accept" or name == "tcp_write" or name == "tcp_write_bytes" or name == "process_spawn" or name == "process_spawn_argv" or name == "process_output_argv" or name == "process_write" or name == "process_write_bytes" or name == "crypto_x25519_keygen":
        return "result_int"
    if name == "write_file" or name == "append_file" or name == "write_file_bytes" or name == "append_file_bytes":
        return "result_bool"
    if name == "parse_float":
        return "float"
    if name == "read_file" or name == "exec_output" or name == "dns_resolve" or name == "bytes_to_string_utf8" or name == "file_read" or name == "tcp_read" or name == "process_read" or name == "process_read_err":
        return "string"
    if name == "read_file_bytes" or name == "b64_decode" or name == "from_hex" or name == "file_read_bytes" or name == "tcp_read_bytes" or name == "process_read_bytes" or name == "process_read_err_bytes" or name == "crypto_x25519_public_key" or name == "crypto_x25519_shared_secret" or name == "crypto_aes_128_gcm_seal" or name == "crypto_aes_128_gcm_open" or name == "crypto_chacha20_poly1305_seal" or name == "crypto_chacha20_poly1305_open" or name == "crypto_sign_rsa_pss_sha256_pkcs8":
        return "bytes"
    return ""

fn ir_expr_legacy_result_kind(idx: Int) -> String:
    node := get_node(idx)
    if node.kind == "call" and node.children.len() > 0:
        callee := ir_resolve_static_callee(node.children[0])
        if ir_declared_callable_ir_retkind(callee.name).len() > 0:
            return ""
        return ir_builtin_result_retkind(callee.name)
    if node.kind == "method_call":
        alias_name := ir_resolve_module_alias_method_call_name(idx)
        if alias_name.len() > 0:
            if ir_declared_callable_ir_retkind(alias_name).len() > 0:
                return ""
            return ir_builtin_result_retkind(alias_name)
        obj_type := ir_method_receiver_type(node)
        emit_name := ir_method_emit_name(ir_plain_method_name(node.value), obj_type)
        if ir_declared_callable_ir_retkind(emit_name).len() > 0:
            return ""
        return ir_builtin_result_retkind(emit_name)
    return ""

fn ir_call_retkind(idx: Int, uses_result_abi: Bool) -> String:
    if uses_result_abi:
        node := get_node(idx)
        if node.kind == "call" and node.children.len() > 0:
            callee := ir_resolve_static_callee(node.children[0])
            declared_kind := ir_declared_callable_ir_retkind(callee.name)
            if declared_kind.len() > 0:
                return declared_kind
        if node.kind == "method_call":
            alias_name := ir_resolve_module_alias_method_call_name(idx)
            if alias_name.len() > 0:
                declared_kind := ir_declared_callable_ir_retkind(alias_name)
                if declared_kind.len() > 0:
                    return declared_kind
            obj_type := ir_method_receiver_type(node)
            method_name := ir_plain_method_name(node.value)
            impl_name := ir_lookup_impl_method_name(obj_type, method_name)
            if impl_name.len() > 0:
                declared_kind := ir_declared_callable_ir_retkind(impl_name)
                if declared_kind.len() > 0:
                    return declared_kind
            emit_name := ir_method_emit_name(method_name, obj_type)
            declared_kind := ir_declared_callable_ir_retkind(emit_name)
            if declared_kind.len() > 0:
                return declared_kind
        legacy_kind := ir_expr_legacy_result_kind(idx)
        if legacy_kind.len() > 0:
            return legacy_kind
        result_kind := ir_checked_result_kind(idx)
        if result_kind.len() > 0:
            return result_kind
    return ir_infer_type(idx)

fn ir_checked_index_type(idx: Int) -> String:
    node := get_node(idx)
    if node.kind != "index" or node.children.len() == 0:
        return ir_checked_type(idx)
    coll_tid := c_get_expr_type(node.children[0])
    if coll_tid < 0:
        return ir_checked_type(idx)
    mut coll_info := get_type_info(coll_tid)
    if coll_info.kind == "optional" or coll_info.kind == "result":
        if coll_info.inner < 0:
            return ir_checked_type(idx)
        coll_info = get_type_info(coll_info.inner)
    if coll_info.kind == "map" and coll_info.value_type >= 0:
        return ir_type_from_tid(coll_info.value_type)
    if coll_info.kind == "list" and coll_info.inner >= 0:
        return ir_type_from_tid(coll_info.inner)
    return ir_checked_type(idx)

fn ir_known_struct_return_type(fname: String) -> String:
    if ir_struct_names.contains_key(fname):
        return fname
    if fname == "get_node":
        return "Node"
    if fname == "advance_token" or fname == "expect":
        return "Token"
    if fname == "ti_primitive" or fname == "ti_struct" or fname == "ti_enum" or fname == "ti_function" or fname == "ti_optional" or fname == "ti_result" or fname == "ti_tuple" or fname == "ti_list" or fname == "ti_map" or fname == "ti_set" or fname == "ti_task" or fname == "ti_channel" or fname == "get_type_info":
        return "TypeInfo"
    return ""

fn ir_known_scalar_return_type(fname: String) -> String:
    if ir_is_float_returning_func(fname):
        return "float"
    if ir_is_bool_returning_func(fname):
        return "bool"
    if ir_is_int_returning_func(fname):
        return "int"
    if ir_is_string_returning_func(fname):
        return "string"
    if ir_is_bytes_returning_func(fname):
        return "bytes"
    return ""

fn ir_known_collection_return_type(fname: String) -> String:
    if ir_is_list_returning_func(fname):
        return "list"
    if ir_is_list_string_returning_func(fname):
        return "list_string"
    return ""

fn ir_known_callable_return_type(fname: String) -> String:
    struct_type := ir_known_struct_return_type(fname)
    if struct_type.len() > 0:
        return struct_type
    scalar_type := ir_known_scalar_return_type(fname)
    if scalar_type.len() > 0:
        return scalar_type
    collection_type := ir_known_collection_return_type(fname)
    if collection_type.len() > 0:
        return collection_type
    return ir_declared_callable_return_type(fname)

fn ir_field_receiver_type(recv_idx: Int) -> String:
    mut obj_type := ir_infer_type(recv_idx)
    if obj_type.contains("["):
        base := obj_type.substring(0, obj_type.index_of("["))
        if ir_struct_names.contains_key(base):
            obj_type = base
    if obj_type.len() == 0:
        recv := get_node(recv_idx)
        if recv.kind == "ident" and ir_struct_names.contains_key(recv.value):
            obj_type = recv.value
    return obj_type

fn ir_known_string_method_return_type(meth: String) -> String:
    if ir_is_string_returning_method(meth) or meth == "to_string_utf8":
        return "string"
    if meth == "keys" or meth == "values" or meth == "split" or meth == "chars":
        return "list_string"
    return ""

fn ir_known_collection_method_return_type(obj_type: String, meth: String) -> String:
    if obj_type == "channel" or obj_type.starts_with("channel:"):
        if meth == "recv":
            return "tuple"
        if meth == "try_recv":
            return "tuple"
        if meth == "len" or meth == "cap":
            return "int"
        if meth == "send" or meth == "try_send" or meth == "close" or meth == "is_closed":
            return "bool"
    if (obj_type == "task" or obj_type.starts_with("task:")) and meth == "is_done":
        return "bool"
    if meth == "index_of" and (obj_type == "list" or obj_type == "list_string" or obj_type.starts_with("list:")):
        return "int"
    if meth == "slice" or meth == "sort":
        if obj_type == "list_string":
            return "list_string"
        if obj_type == "list" or obj_type.starts_with("list:"):
            return "list"
    return ""

fn ir_known_method_return_type(obj_type: String, meth: String) -> String:
    impl_name := ir_lookup_impl_method_name(obj_type, meth)
    if impl_name.len() > 0:
        declared := ir_declared_callable_return_type(impl_name)
        if declared.len() > 0:
            return declared
    if ir_is_bool_returning_method(meth):
        return "bool"
    string_type := ir_known_string_method_return_type(meth)
    if string_type.len() > 0:
        return string_type
    if meth == "to_float":
        return "float"
    if meth == "len" or meth == "cap":
        return "int"
    if (meth == "slice" or meth == "concat") and obj_type == "bytes":
        return "bytes"
    collection_type := ir_known_collection_method_return_type(obj_type, meth)
    if collection_type.len() > 0:
        return collection_type
    return ""

fn ir_literal_expr_type(node: Node, kind: String) -> String:
    if kind == "int_lit" or kind == "int" or kind == "integer":
        return "int"
    if kind == "float_lit" or kind == "float":
        return "float"
    if kind == "bool_lit" or kind == "bool":
        return "bool"
    if kind == "string_lit" or kind == "string" or kind == "str_lit" or kind == "string_interp":
        return "string"
    if kind == "list":
        if node.children.len() > 0:
            first := get_node(node.children[0])
            if first.kind == "string_lit" or first.kind == "string":
                return "list_string"
        return "list"
    if kind == "map":
        return "map"
    if kind == "set":
        if node.children.len() > 0:
            first := get_node(node.children[0])
            if first.kind == "int_lit" or first.kind == "int" or first.kind == "integer":
                return "set_int"
        return "set"
    if kind == "tuple":
        return "tuple"
    return ""

fn ir_binary_expr_type(node: Node) -> String:
    op := node.value
    if op == "eq" or op == "neq" or op == "lt" or op == "gt" or op == "lte" or op == "gte" or op == "and" or op == "or":
        return "bool"
    if op == "add" or op == "sub" or op == "mul" or op == "div" or op == "mod":
        if node.children.len() >= 2:
            lt := ir_infer_type(node.children[0])
            rt := ir_infer_type(node.children[1])
            if lt == "float" or rt == "float":
                return "float"
            if lt == "string" or rt == "string":
                return "string"
        return "int"
    return "int"

fn ir_unary_expr_type(node: Node) -> String:
    if node.value == "not" or node.value == "!" or node.value == "not_op":
        return "bool"
    return "int"

fn ir_index_expr_type(idx: Int, node: Node) -> String:
    checked_index := ir_checked_index_type(idx)
    if checked_index.len() > 0:
        return checked_index
    if node.children.len() == 0:
        return ""
    coll_type := ir_infer_type(node.children[0])
    if coll_type == "string":
        return "string"
    if coll_type == "bytes":
        return "int"
    if coll_type == "list_string":
        return "string"
    if coll_type == "map" or coll_type == "map_int":
        return ir_lookup_map_value_type_for_expr(node.children[0])
    return ""

fn ir_call_expr_type(idx: Int, node: Node) -> String:
    if node.children.len() == 0:
        return ""
    callee := ir_resolve_static_callee(node.children[0])
    if callee.name.len() == 0:
        return ""
    return ir_known_callable_return_type(callee.name)

fn ir_method_expr_type(idx: Int, node: Node) -> String:
    alias_fname := ir_resolve_module_alias_method_call_name(idx)
    if alias_fname.len() > 0:
        return ir_known_callable_return_type(alias_fname)
    mut obj_type := ""
    if node.children.len() > 0:
        obj_type = ir_infer_type(node.children[0])
    return ir_known_method_return_type(obj_type, ir_plain_method_name(node_value(idx)))

fn ir_field_expr_type(node: Node) -> String:
    if node.children.len() == 0:
        return ""
    fname := node.value
    if fname == "is_ok" or fname == "is_err":
        return "bool"
    if fname == "ok":
        obj_tid := c_get_expr_type(node.children[0])
        if obj_tid >= 0:
            obj_info := get_type_info(obj_tid)
            if obj_info.kind == "result":
                return ir_type_from_tid(obj_info.inner)
    if fname == "err":
        obj_tid := c_get_expr_type(node.children[0])
        if obj_tid >= 0:
            obj_info := get_type_info(obj_tid)
            if obj_info.kind == "result":
                return ir_type_from_tid(obj_info.value_type)
    obj_type := ir_field_receiver_type(node.children[0])
    if obj_type.len() == 0:
        return ""
    lookup_key := obj_type + "." + fname
    if ir_struct_field_lookup.contains_key(lookup_key):
        return ir_struct_field_lookup[lookup_key]
    return ""

# --- centralized type inference for AST nodes ---
# Returns: "int", "float", "bool", "string", "list", "list_string",
#          "map", "map_int", "set", "set_int", or "" (unknown)
fn ir_infer_type(idx: Int) -> String:
    checked := ir_checked_type(idx)
    if checked.len() > 0:
        return checked
    node := get_node(idx)
    kind := node_kind(idx)
    literal_type := ir_literal_expr_type(node, kind)
    if literal_type.len() > 0:
        return literal_type
    # identifiers — look up tracked type
    if kind == "ident":
        return ir_lookup_name_type(node.value)
    if kind == "self":
        return "struct"
    # grouped expression — infer inner
    if kind == "grouped" and node.children.len() > 0:
        return ir_infer_type(node.children[0])
    # binary ops
    if kind == "binary":
        return ir_binary_expr_type(node)
    # unary
    if kind == "unary":
        return ir_unary_expr_type(node)
    # function calls
    if kind == "call":
        return ir_call_expr_type(idx, node)
    # method calls
    if kind == "method_call":
        return ir_method_expr_type(idx, node)
    if kind == "field_access":
        return ir_field_expr_type(node)
    if kind == "struct_init":
        return ir_resolve_type_hint(node.value)
    # index — depends on collection type
    if kind == "index" and node.children.len() > 0:
        return ir_index_expr_type(idx, node)
    return ""

fn ir_lookup_name_type(name: String) -> String:
    if ir_var_types.contains_key(name):
        return ir_var_types[name]
    if ir_global_int_names.contains(name):
        return "int"
    if ir_global_string_names.contains(name):
        return "string"
    if ir_global_list_string_names.contains(name):
        return "list_string"
    if ir_global_list_names.contains(name):
        return "list"
    if ir_global_map_int_names.contains(name):
        return "map_int"
    if ir_global_map_names.contains(name):
        return "map"
    if ir_global_set_int_names.contains(name):
        return "set_int"
    if ir_global_set_names.contains(name):
        return "set"
    if ir_global_bool_names.contains(name):
        return "bool"
    return ""

fn ir_optional_flag_field(obj_r: Int) -> Int:
    r := ir_reg()
    ir_emit("field " + r.to_string() + " " + obj_r.to_string() + " 0 bool is_some")
    return r

fn ir_optional_value_field(obj_r: Int, opt_tid: Int) -> Int:
    info := get_type_info(opt_tid)
    if info.kind != "optional" or info.inner < 0:
        return ir_zero_reg()
    r := ir_reg()
    ir_emit("field " + r.to_string() + " " + obj_r.to_string() + " 8 " + ir_type_from_tid(info.inner) + " value")
    return r

fn ir_emit_value_for_target(val_idx: Int, target_type: String) -> Int:
    vn := get_node(val_idx)
    if vn.kind == "map" and vn.children.len() == 0 and target_type == "set":
        r := ir_reg()
        ir_emit_call0(r, "__set_new", "set")
        return r
    if vn.kind == "map" and vn.children.len() == 0 and target_type == "set_int":
        r := ir_reg()
        ir_emit_call0(r, "__set_new_int", "set_int")
        return r
    if vn.kind == "map" and vn.children.len() == 0 and target_type == "map":
        r := ir_reg()
        ir_emit_call0(r, "__map_new", "map")
        return r
    if vn.kind == "map" and vn.children.len() == 0 and target_type == "map_int":
        r := ir_reg()
        ir_emit_call0(r, "__map_new_int", "map_int")
        return r
    if vn.kind == "set" and vn.children.len() == 0 and target_type == "set":
        r := ir_reg()
        ir_emit_call0(r, "__set_new", "set")
        return r
    if vn.kind == "set" and vn.children.len() == 0 and target_type == "set_int":
        r := ir_reg()
        ir_emit_call0(r, "__set_new_int", "set_int")
        return r
    return ir_expr(val_idx)

fn ir_checked_target_type(target_idx: Int, fallback_name: String) -> String:
    checked := ir_checked_type(target_idx)
    if checked.len() > 0:
        return checked
    if fallback_name.len() > 0:
        return ir_lookup_name_type(fallback_name)
    return ""

fn ir_method_receiver_type(node: Node) -> String:
    if node.children.len() == 0:
        return ""
    recv_tid := c_get_expr_type(node.children[0])
    if recv_tid >= 0:
        recv_info := get_type_info(recv_tid)
        if recv_info.kind == "channel" and recv_info.inner >= 0:
            return "channel:" + ir_type_from_tid(recv_info.inner)
        if recv_info.kind == "task" and recv_info.inner >= 0:
            return "task:" + ir_type_from_tid(recv_info.inner)
        known := ir_type_from_tid(recv_tid)
        if known.len() > 0:
            return known
    checked := ir_checked_type(node.children[0])
    if checked.len() > 0:
        return checked
    return ir_infer_type(node.children[0])

fn ir_method_string_emit_name(mname: String) -> String:
    if mname == "len":
        return "string_len"
    if mname == "is_empty":
        return "string_is_empty"
    return mname

fn ir_method_bytes_emit_name(mname: String) -> String:
    if mname == "len":
        return "bytes_len"
    if mname == "is_empty":
        return "bytes_is_empty"
    if mname == "slice":
        return "bytes_slice"
    if mname == "concat":
        return "bytes_concat"
    if mname == "to_string_utf8":
        return "bytes_to_string_utf8"
    return mname

fn ir_method_list_emit_name(mname: String, obj_type: String) -> String:
    if mname == "len":
        return "forge_list_len"
    if mname == "slice":
        return "list_slice_copy"
    if mname == "sort":
        if obj_type == "list_string":
            return "list_sort_strings_copy"
        return "list_sort_copy"
    if mname == "contains":
        if obj_type == "list_string":
            return "list_contains_string"
        return "list_contains"
    if mname == "index_of":
        if obj_type == "list_string":
            return "list_index_of_string"
        return "list_index_of"
    if mname == "join":
        return "list_join"
    if mname == "reverse":
        return "list_reverse"
    if mname == "is_empty":
        return "list_is_empty"
    if mname == "clear":
        return "list_clear"
    return mname

fn ir_method_map_emit_name(mname: String, obj_type: String) -> String:
    obj_is_map_int := obj_type == "map_int"
    if mname == "len":
        return "map_len"
    if mname == "is_empty":
        return "map_is_empty"
    if mname == "clear":
        return "map_clear"
    if mname == "keys":
        return "map_keys"
    if mname == "values":
        return "map_values"
    if mname == "contains_key" and obj_is_map_int:
        return "map_contains_ikey"
    if mname == "insert":
        if obj_is_map_int:
            return "map_insert_ikey"
        return "map_insert"
    if mname == "remove":
        if obj_is_map_int:
            return "map_remove_ikey"
        return "map_remove"
    return mname

fn ir_method_set_emit_name(mname: String, obj_type: String) -> String:
    obj_is_set_int := obj_type == "set_int"
    if mname == "len":
        return "set_len"
    if mname == "add":
        if obj_is_set_int:
            return "set_add_int"
        return "set_add"
    if mname == "contains":
        if obj_is_set_int:
            return "set_contains_int"
        return "set_contains"
    if mname == "is_empty":
        return "set_is_empty"
    if mname == "clear":
        return "set_clear"
    if mname == "remove":
        if obj_is_set_int:
            return "set_remove_int"
        return "set_remove"
    return mname

fn ir_method_emit_name(mname: String, obj_type: String) -> String:
    obj_is_string := obj_type == "string"
    obj_is_bytes := obj_type == "bytes"
    obj_is_bool := obj_type == "bool"
    obj_is_float := obj_type == "float"
    obj_is_int := obj_type == "int"
    obj_is_map := obj_type == "map" or obj_type == "map_int"
    obj_is_set := obj_type == "set" or obj_type == "set_int"
    obj_is_list := obj_type == "list" or obj_type == "list_string" or obj_type.starts_with("list:")
    obj_is_channel := obj_type == "channel" or obj_type.starts_with("channel:")
    obj_is_task := obj_type == "task" or obj_type.starts_with("task:")

    mut emit_name := mname
    if mname == "to_string":
        if obj_is_float:
            emit_name = "float_to_string"
        elif obj_is_bool:
            emit_name = "bool_to_string"
        elif obj_is_int:
            emit_name = "int_to_string"
        elif obj_is_string:
            emit_name = "identity"
    elif obj_is_string:
        emit_name = ir_method_string_emit_name(mname)
    elif obj_is_bytes:
        emit_name = ir_method_bytes_emit_name(mname)
    elif obj_is_list:
        emit_name = ir_method_list_emit_name(mname, obj_type)
    elif obj_is_map:
        emit_name = ir_method_map_emit_name(mname, obj_type)
    elif obj_is_set:
        emit_name = ir_method_set_emit_name(mname, obj_type)
    elif obj_is_channel:
        if mname == "len":
            emit_name = "forge_channel_len"
        elif mname == "cap":
            emit_name = "forge_channel_cap"
        elif mname == "send":
            emit_name = "forge_channel_send"
        elif mname == "try_send":
            emit_name = "forge_channel_try_send"
        elif mname == "recv":
            emit_name = "forge_channel_recv"
        elif mname == "try_recv":
            emit_name = "forge_channel_try_recv"
        elif mname == "close":
            emit_name = "forge_channel_close"
        elif mname == "is_closed":
            emit_name = "forge_channel_is_closed"
    elif obj_is_task:
        if mname == "is_done":
            emit_name = "forge_task_is_done"
        elif mname == "detach":
            emit_name = "forge_task_detach"
    return emit_name

fn ir_emit_optional_unwrap(node: Node) -> Int:
    recv_r := ir_expr(node.children[0])
    opt_tid := c_get_expr_type(node.children[0])
    return ir_optional_value_field(recv_r, opt_tid)

fn ir_collect_method_call_regs(node: Node) -> List[Int]:
    mut regs: List[Int] := []
    for child, i in node.children:
        if i == 0:
            regs.push(ir_expr(child))
        else:
            child_kind := node_kind(child)
            if child_kind == "arg":
                cn := get_node(child)
                if cn.children.len() > 0:
                    regs.push(ir_expr(cn.children[0]))
            else:
                regs.push(ir_expr(child))
    return regs

fn ir_string_interp_expr_part(expr_idx: Int) -> Int:
    mut part_r := ir_expr(expr_idx)
    part_tid := c_get_expr_type(expr_idx)
    part_type := ir_infer_type(expr_idx)
    if part_type == "string":
        return part_r
    if part_type == "bool":
        converted := ir_reg()
        ir_emit_call1(converted, "bool_to_string", "string", part_r)
        return converted
    if part_type == "float":
        converted := ir_reg()
        ir_emit_call1(converted, "float_to_string", "string", part_r)
        return converted
    if part_type == "int":
        converted := ir_reg()
        ir_emit_call1(converted, "int_to_string", "string", part_r)
        return converted
    if part_tid >= 0:
        part_info := get_type_info(part_tid)
        if part_info.kind == "result":
            return ir_emit_result_value_to_string(part_r, part_tid)
    return part_r

fn ir_emit_lambda_capture_setup(closure_r: Int, captures: List[String]):
    for capture_name, i in captures:
        cap_val := ir_reg()
        ir_emit("load " + cap_val.to_string() + " " + capture_name)
        slot := ir_reg()
        ir_emit("iconst " + slot.to_string() + " " + i.to_string())
        ir_emit_call3(ir_reg(), "__closure_set_env", "void", closure_r, slot, cap_val)

fn ir_emit_lambda_hidden_param():
    closure_r := ir_reg()
    ir_var_regs.insert("__closure", closure_r)
    ir_emit("param __closure")

fn ir_emit_lambda_capture_loads(captures: List[String]):
    closure_r := ir_var_regs["__closure"]
    for capture_name, i in captures:
        cap_r := ir_reg()
        slot_r := ir_reg()
        ir_emit("iconst " + slot_r.to_string() + " " + i.to_string())
        ir_emit_call2(cap_r, "__closure_get_env", "unknown", closure_r, slot_r)
        ir_var_regs.insert(capture_name, cap_r)
        ir_emit("store " + capture_name + " " + cap_r.to_string())

fn ir_append_deferred_lambda_body():
    lines: List[String] := ir_lines
    mut bodies: List[String] := ir_lambda_bodies
    for line in lines:
        bodies.push(line)
    ir_lambda_bodies = bodies

fn ir_emit_unary_expr(node: Node) -> Int:
    operand_r := ir_expr(node.children[0])
    r := ir_reg()
    if node.value == "not" or node.value == "!" or node.value == "not_op":
        one := ir_reg()
        ir_emit("iconst " + one.to_string() + " 1")
        ir_emit("sub " + r.to_string() + " " + one.to_string() + " " + operand_r.to_string())
    elif node.value == "neg" or node.value == "-" or node.value == "negate":
        zero := ir_reg()
        ir_emit("iconst " + zero.to_string() + " 0")
        ir_emit("sub " + r.to_string() + " " + zero.to_string() + " " + operand_r.to_string())
    elif node.value == "bit_not" or node.value == "~":
        ir_emit("bnot " + r.to_string() + " " + operand_r.to_string())
    else:
        ir_emit("iconst " + r.to_string() + " 0")
    return r

fn ir_emit_binary_neq(result_reg: Int, left_r: Int, right_r: Int, is_str_op: Bool, is_bytes_op: Bool):
    if is_str_op:
        eq_r := ir_reg()
        ir_emit_call2(eq_r, "__str_eq", "bool", left_r, right_r)
        one_r := ir_reg()
        ir_emit("iconst " + one_r.to_string() + " 1")
        ir_emit("sub " + result_reg.to_string() + " " + one_r.to_string() + " " + eq_r.to_string())
        return
    if is_bytes_op:
        eq_r := ir_reg()
        ir_emit_call2(eq_r, "bytes_eq", "bool", left_r, right_r)
        one_r := ir_reg()
        ir_emit("iconst " + one_r.to_string() + " 1")
        ir_emit("sub " + result_reg.to_string() + " " + one_r.to_string() + " " + eq_r.to_string())
        return
    ir_emit("neq " + result_reg.to_string() + " " + left_r.to_string() + " " + right_r.to_string())

fn ir_emit_simple_binary(result_reg: Int, op: String, left_r: Int, right_r: Int):
    ir_emit(op + " " + result_reg.to_string() + " " + left_r.to_string() + " " + right_r.to_string())

fn ir_emit_binary_expr(node: Node) -> Int:
    left_r := ir_expr(node.children[0])
    right_r := ir_expr(node.children[1])
    r := ir_reg()
    op := node.value
    left_type := ir_infer_type(node.children[0])
    right_type := ir_infer_type(node.children[1])
    is_str_op := left_type == "string" or right_type == "string"
    is_bytes_op := left_type == "bytes" and right_type == "bytes"
    is_float_op := left_type == "float" or right_type == "float"
    if is_float_op and (op == "add" or op == "sub" or op == "mul" or op == "div"):
        ir_emit("f" + op + " " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
        return r
    if op == "add" and is_str_op:
        ir_emit("concat " + r.to_string() + " " + left_r.to_string() + " " + right_r.to_string())
    elif op == "add" and not is_str_op:
        ir_emit_simple_binary(r, "add", left_r, right_r)
    elif op == "sub":
        ir_emit_simple_binary(r, "sub", left_r, right_r)
    elif op == "mul":
        ir_emit_simple_binary(r, "mul", left_r, right_r)
    elif op == "div":
        ir_emit_simple_binary(r, "div", left_r, right_r)
    elif op == "mod":
        ir_emit_simple_binary(r, "mod", left_r, right_r)
    elif op == "eq":
        if is_str_op:
            ir_emit_call2(r, "__str_eq", "bool", left_r, right_r)
        elif is_bytes_op:
            ir_emit_call2(r, "bytes_eq", "bool", left_r, right_r)
        else:
            ir_emit_simple_binary(r, "eq", left_r, right_r)
    elif op == "neq":
        ir_emit_binary_neq(r, left_r, right_r, is_str_op, is_bytes_op)
    elif op == "lt":
        ir_emit_simple_binary(r, "lt", left_r, right_r)
    elif op == "gt":
        ir_emit_simple_binary(r, "gt", left_r, right_r)
    elif op == "lte":
        ir_emit_simple_binary(r, "lte", left_r, right_r)
    elif op == "gte":
        ir_emit_simple_binary(r, "gte", left_r, right_r)
    elif op == "bit_and":
        ir_emit_simple_binary(r, "band", left_r, right_r)
    elif op == "bit_or":
        ir_emit_simple_binary(r, "bor", left_r, right_r)
    elif op == "bit_xor":
        ir_emit_simple_binary(r, "bxor", left_r, right_r)
    elif op == "shl":
        ir_emit_simple_binary(r, "shl", left_r, right_r)
    elif op == "shr":
        ir_emit_simple_binary(r, "shr", left_r, right_r)
    elif op == "and":
        ir_emit_simple_binary(r, "and", left_r, right_r)
    elif op == "or":
        ir_emit_simple_binary(r, "or", left_r, right_r)
    else:
        ir_emit("binop " + r.to_string() + " " + op + " " + left_r.to_string() + " " + right_r.to_string())
    return r

fn ir_test_assert_fail():
    one_r := ir_reg()
    ir_emit("iconst " + one_r.to_string() + " 1")
    exit_r := ir_reg()
    ir_emit_call1(exit_r, "exit", "unknown", one_r)

fn ir_test_assert_fail_return():
    ir_test_assert_fail()
    one_r := ir_reg()
    ir_emit("iconst " + one_r.to_string() + " 1")
    ir_emit("ret " + one_r.to_string())

fn ir_assert_eq_operand_type(node: Node, child_idx: Int) -> String:
    if node.children.len() <= child_idx:
        return ""
    mut expr_idx := node.children[child_idx]
    child_node := get_node(expr_idx)
    if child_node.kind == "arg" and child_node.children.len() > 0:
        expr_idx = child_node.children[0]
    return ir_infer_type(expr_idx)

fn ir_emit_test_assert(arg_regs: List[Int]) -> Int:
    ok_l := ir_label()
    fail_l := ir_label()
    ir_emit("brif " + arg_regs[0].to_string() + " " + ok_l + " " + fail_l)
    ir_emit("label " + fail_l)
    assert_r := ir_reg()
    ir_emit_call1(assert_r, "assert", "unknown", arg_regs[0])
    ir_test_assert_fail()
    ir_emit("label " + ok_l)
    r := ir_reg()
    ir_emit("iconst " + r.to_string() + " 0")
    return r

fn ir_emit_test_assert_eq(node: Node, arg_regs: List[Int]) -> Int:
    cmp_r := ir_reg()
    left_type := ir_assert_eq_operand_type(node, 1)
    right_type := ir_assert_eq_operand_type(node, 2)
    if left_type == "string" or right_type == "string":
        ir_emit_call2(cmp_r, "__str_eq", "bool", arg_regs[0], arg_regs[1])
    else:
        ir_emit_simple_binary(cmp_r, "eq", arg_regs[0], arg_regs[1])
    ok_l := ir_label()
    fail_l := ir_label()
    ir_emit("brif " + cmp_r.to_string() + " " + ok_l + " " + fail_l)
    ir_emit("label " + fail_l)
    fail_r := ir_reg()
    ir_emit_call2(fail_r, "assert_eq", "unknown", arg_regs[0], arg_regs[1])
    ir_test_assert_fail()
    ir_emit("label " + ok_l)
    r := ir_reg()
    ir_emit("iconst " + r.to_string() + " 0")
    return r

fn ir_json_field_helper_name(field_tid: Int) -> String:
    info := get_type_info(field_tid)
    if info.kind == "primitive":
        if info.name == "String":
            return "std_json_scan_required_string_bytes"
        if info.name == "Int":
            return "std_json_scan_required_int_bytes"
        if info.name == "Bool":
            return "std_json_scan_required_bool_bytes"
    return ""

fn ir_json_require_helper_name(field_tid: Int) -> String:
    info := get_type_info(field_tid)
    if info.kind == "primitive":
        if info.name == "String":
            return "std_json_require_string"
        if info.name == "Int":
            return "std_json_require_int"
        if info.name == "Bool":
            return "std_json_require_bool"
    return ""

fn ir_json_field_type_tag(field_tid: Int) -> Int:
    info := get_type_info(field_tid)
    if info.kind == "primitive":
        if info.name == "String":
            return 0
        if info.name == "Int":
            return 1
        if info.name == "Bool":
            return 2
    return 0 - 1

fn ir_emit_json_field_ok(result_r: Int, field_tid: Int) -> Int:
    ok_r := ir_reg()
    ir_emit("field " + ok_r.to_string() + " " + result_r.to_string() + " 8 " + ir_type_from_tid(field_tid) + " ok")
    return ok_r

fn ir_emit_json_decode_map_call(input_r: Int, target_info: TypeInfo) -> Int:
    temp_name := ir_new_temp_name("json_decode")
    ir_var_types.insert(temp_name, "tuple")
    done_l := ir_label()

    scan_r := ir_reg()
    ir_emit_call1(scan_r, "std_json_decode_scalars_bytes", "tuple", input_r)
    scan_ok_r := ir_emit_result_flag_field(scan_r, "is_ok")
    scan_ok_l := ir_label()
    scan_err_l := ir_label()
    ir_emit("brif " + scan_ok_r.to_string() + " " + scan_ok_l + " " + scan_err_l)
    ir_emit("label " + scan_err_l)
    ir_emit("store " + temp_name + " " + scan_r.to_string())
    ir_emit("jmp " + done_l)
    ir_emit("label " + scan_ok_l)
    fields_r := ir_emit_result_value_field(scan_r, -1, "ok")

    mut field_regs: List[Int] := []
    for field_name, i in target_info.fields:
        if i >= target_info.field_types.len():
            continue
        field_tid := target_info.field_types[i]
        helper_name := ir_json_require_helper_name(field_tid)
        if helper_name.len() == 0:
            continue
        key_r := ir_reg()
        ir_emit("strref " + key_r.to_string() + " " + ir_str(field_name))
        field_result_r := ir_reg()
        ir_emit_call2(field_result_r, helper_name, "tuple", fields_r, key_r)
        ok_flag_r := ir_emit_result_flag_field(field_result_r, "is_ok")
        ok_l := ir_label()
        err_l := ir_label()
        ir_emit("brif " + ok_flag_r.to_string() + " " + ok_l + " " + err_l)
        ir_emit("label " + err_l)
        ir_emit("store " + temp_name + " " + field_result_r.to_string())
        ir_emit("jmp " + done_l)
        ir_emit("label " + ok_l)
        field_regs.push(ir_emit_json_field_ok(field_result_r, field_tid))

    struct_r := ir_reg()
    field_count_r := ir_reg()
    ir_emit("iconst " + field_count_r.to_string() + " " + field_regs.len().to_string())
    ir_emit_call1(struct_r, "__struct_alloc", "struct:" + target_info.name, field_count_r)
    for field_reg, fi in field_regs:
        ir_emit("sstore " + struct_r.to_string() + " " + fi.to_string() + " " + field_reg.to_string())
    ir_emit("store " + temp_name + " " + ir_emit_ok_result_tuple(struct_r).to_string())
    ir_emit("label " + done_l)
    r := ir_reg()
    ir_emit("load " + r.to_string() + " " + temp_name)
    return r

fn ir_emit_json_decode_flat6_call(input_r: Int, target_info: TypeInfo) -> Int:
    result_r := ir_reg()
    mut arg_text := " " + input_r.to_string()

    for field_name, i in target_info.fields:
        if i >= target_info.field_types.len():
            continue
        field_tid := target_info.field_types[i]
        tag := ir_json_field_type_tag(field_tid)
        if tag < 0:
            return ir_zero_reg()
        key_r := ir_reg()
        ir_emit("strref " + key_r.to_string() + " " + ir_str(field_name))
        tag_r := ir_reg()
        ir_emit("iconst " + tag_r.to_string() + " " + tag.to_string())
        arg_text = arg_text + " " + key_r.to_string() + " " + tag_r.to_string()

    ir_emit_call_text(result_r, "json_decode_flat6", "tuple", 13, arg_text)
    return result_r

fn ir_emit_json_decode_call(idx: Int, node: Node, text_input: Bool) -> Int:
    arg_regs := ir_collect_call_arg_regs(node, 1)
    if arg_regs.len() == 0:
        return ir_zero_reg()

    mut input_r := arg_regs[0]
    if text_input:
        converted_r := ir_reg()
        ir_emit_call1(converted_r, "std_bytes_from_string_utf8", "bytes", input_r)
        input_r = converted_r

    ret_tid := c_get_expr_type(idx)
    if ret_tid < 0:
        return ir_zero_reg()
    ret_info := get_type_info(ret_tid)
    if ret_info.kind != "result":
        return ir_zero_reg()
    target_tid := ret_info.inner
    target_info := get_type_info(target_tid)
    if target_info.kind != "struct":
        return ir_zero_reg()
    if target_info.fields.len() == 6:
        return ir_emit_json_decode_flat6_call(input_r, target_info)
    if target_info.fields.len() > 3:
        return ir_emit_json_decode_map_call(input_r, target_info)

    temp_name := ir_new_temp_name("json_decode")
    ir_var_types.insert(temp_name, "tuple")
    done_l := ir_label()
    mut field_regs: List[Int] := []

    for field_name, i in target_info.fields:
        if i >= target_info.field_types.len():
            continue
        field_tid := target_info.field_types[i]
        helper_name := ir_json_field_helper_name(field_tid)
        if helper_name.len() == 0:
            continue
        key_r := ir_reg()
        ir_emit("strref " + key_r.to_string() + " " + ir_str(field_name))
        field_result_r := ir_reg()
        ir_emit_call2(field_result_r, helper_name, "tuple", input_r, key_r)
        ok_flag_r := ir_emit_result_flag_field(field_result_r, "is_ok")
        ok_l := ir_label()
        err_l := ir_label()
        ir_emit("brif " + ok_flag_r.to_string() + " " + ok_l + " " + err_l)
        ir_emit("label " + err_l)
        ir_emit("store " + temp_name + " " + field_result_r.to_string())
        ir_emit("jmp " + done_l)
        ir_emit("label " + ok_l)
        field_regs.push(ir_emit_json_field_ok(field_result_r, field_tid))

    struct_r := ir_reg()
    field_count_r := ir_reg()
    ir_emit("iconst " + field_count_r.to_string() + " " + field_regs.len().to_string())
    ir_emit_call1(struct_r, "__struct_alloc", "struct:" + target_info.name, field_count_r)
    for field_reg, fi in field_regs:
        ir_emit("sstore " + struct_r.to_string() + " " + fi.to_string() + " " + field_reg.to_string())
    ir_emit("store " + temp_name + " " + ir_emit_ok_result_tuple(struct_r).to_string())
    ir_emit("label " + done_l)
    r := ir_reg()
    ir_emit("load " + r.to_string() + " " + temp_name)
    return r

fn ir_emit_static_call(idx: Int, node: Node) -> Int:
    if node.children.len() > 0:
        callee_node := get_node(node.children[0])
        if callee_node.kind == "index":
            if ir_is_json_decode_callee(node.children[0], "decode"):
                return ir_emit_json_decode_call(idx, node, false)
            if ir_is_json_decode_callee(node.children[0], "decode_text"):
                return ir_emit_json_decode_call(idx, node, true)

    mut callee := ResolvedCallee("unknown", false)
    if node.children.len() > 0:
        callee = ir_resolve_static_callee(node.children[0])
        if callee.name.len() == 0:
            callee = ResolvedCallee("unknown", false)
    if ir_is_generic_function_name(callee.name):
        mut generic_ret_type := ir_checked_type(idx)
        if generic_ret_type.len() == 0:
            generic_ret_type = ir_infer_type(idx)
        callee = ResolvedCallee(ir_queue_generic_specialization(callee.name, ir_infer_generic_concrete_types(callee.name, node), generic_ret_type), false)
    arg_regs := ir_collect_call_arg_regs(node, 1)
    if callee.name == "Channel" and arg_regs.len() == 0:
        zero_r := ir_reg()
        ir_emit("iconst " + zero_r.to_string() + " 0")
        arg_regs.push(zero_r)

    if ir_emit_tests and callee.name == "assert" and arg_regs.len() >= 1:
        return ir_emit_test_assert(arg_regs)
    if ir_emit_tests and callee.name == "assert_eq" and arg_regs.len() >= 2:
        return ir_emit_test_assert_eq(node, arg_regs)

    r := ir_reg()
    uses_result_abi := ir_callee_uses_result_abi(callee, idx)
    ret_type := ir_call_retkind(idx, uses_result_abi)
    ir_emit_call_text(r, callee.name, ret_type, arg_regs.len(), ir_join_arg_regs(arg_regs))
    if uses_result_abi and ret_type != "tuple" and ir_checked_result_kind(idx) == "tuple":
        return ir_emit_wrapped_legacy_result(r, ret_type, callee.name)
    return r

fn ir_map_uses_int_keys(node: Node) -> Bool:
    if node.children.len() == 0:
        return false
    first_entry := get_node(node.children[0])
    if first_entry.kind != "entry" or first_entry.children.len() == 0:
        return false
    k_node := get_node(first_entry.children[0])
    return k_node.kind == "int_lit" or k_node.kind == "int"

fn ir_emit_map_entry_insert(map_r: Int, has_int_keys: Bool, entry: Node):
    if entry.kind != "entry" or entry.children.len() < 2:
        return
    k_r := ir_expr(entry.children[0])
    v_r := ir_expr(entry.children[1])
    if has_int_keys:
        ir_emit_call3(ir_reg(), "map_insert_ikey", "void", map_r, k_r, v_r)
    else:
        ir_emit_call3(ir_reg(), "map_insert", "void", map_r, k_r, v_r)

fn ir_emit_map_literal(node: Node) -> Int:
    map_r := ir_reg()
    has_int_keys := ir_map_uses_int_keys(node)
    if has_int_keys:
        ir_emit_call0(map_r, "__map_new_int", "map_int")
    else:
        ir_emit_call0(map_r, "__map_new", "map")
    for child in node.children:
        ir_emit_map_entry_insert(map_r, has_int_keys, get_node(child))
    return map_r

fn ir_set_new_name(literal_type: String) -> String:
    if literal_type == "set_int":
        return "__set_new_int"
    return "__set_new"

fn ir_set_add_name(literal_type: String) -> String:
    if literal_type == "set_int":
        return "set_add_int"
    return "set_add"

fn ir_emit_set_literal(node: Node) -> Int:
    set_r := ir_reg()
    literal_type := ir_literal_expr_type(node, "set")
    ir_emit_call0(set_r, ir_set_new_name(literal_type), literal_type)
    for child in node.children:
        elem_r := ir_expr(child)
        ir_emit_call2(ir_reg(), ir_set_add_name(literal_type), "void", set_r, elem_r)
    return set_r

fn ir_emit_list_literal(node: Node) -> Int:
    list_r := ir_reg()
    ir_emit_call0(list_r, "__list_new", "list")
    for child in node.children:
        elem_r := ir_expr(child)
        ir_emit_call2(ir_reg(), "__list_push", "void", list_r, elem_r)
    return list_r

fn ir_emit_tuple_stores(tuple_r: Int, elem_regs: List[Int]):
    for elem_reg, i in elem_regs:
        ir_emit("sstore " + tuple_r.to_string() + " " + i.to_string() + " " + elem_reg.to_string())

fn ir_emit_tuple_literal(node: Node) -> Int:
    mut elem_regs: List[Int] := []
    for child in node.children:
        elem_regs.push(ir_expr(child))
    r := ir_reg()
    nf := ir_reg()
    ir_emit("iconst " + nf.to_string() + " " + elem_regs.len().to_string())
    ir_emit_call1(r, "__struct_alloc", "struct:tuple", nf)
    ir_emit_tuple_stores(r, elem_regs)
    return r

fn ir_field_lookup_key(recv_idx: Int, field_name: String) -> String:
    return ir_field_receiver_type(recv_idx) + "." + field_name

fn ir_unique_field_offset(field_name: String) -> Int:
    keys := ir_struct_field_index_lookup.keys()
    mut matched := false
    mut offset := 0
    for key in keys:
        if key.ends_with("." + field_name):
            next_offset := ir_unpack_field_index(ir_struct_field_index_lookup[key]) * 8
            if not matched:
                matched = true
                offset = next_offset
            elif offset != next_offset:
                return 0 - 1
            continue
    if not matched:
        return 0 - 1
    return offset

fn ir_unique_field_kind(field_name: String) -> String:
    keys := ir_struct_field_lookup.keys()
    mut matched := false
    mut field_kind := "unknown"
    for key in keys:
        if key.ends_with("." + field_name):
            next_kind := ir_retkind(ir_struct_field_lookup[key])
            if not matched:
                matched = true
                field_kind = next_kind
            elif field_kind != next_kind:
                return "unknown"
            continue
    return field_kind

fn ir_emit_named_field_access(result_reg: Int, obj_r: Int, lookup_key: String, field_name: String):
    if ir_struct_field_index_lookup.contains_key(lookup_key):
        field_offset := ir_unpack_field_index(ir_struct_field_index_lookup[lookup_key]) * 8
        mut field_kind := "unknown"
        if ir_struct_field_lookup.contains_key(lookup_key):
            field_kind = ir_retkind(ir_struct_field_lookup[lookup_key])
        ir_emit("field " + result_reg.to_string() + " " + obj_r.to_string() + " " + field_offset.to_string() + " " + field_kind + " " + field_name)
    else:
        unique_offset := ir_unique_field_offset(field_name)
        if unique_offset >= 0:
            ir_emit("field " + result_reg.to_string() + " " + obj_r.to_string() + " " + unique_offset.to_string() + " " + ir_unique_field_kind(field_name) + " " + field_name)
        else:
            ir_emit("field " + result_reg.to_string() + " " + obj_r.to_string() + " " + field_name)

fn ir_emit_tuple_field_access(result_reg: Int, obj_r: Int, recv_idx: Int, field_name: String) -> Bool:
    recv_tid := c_get_expr_type(recv_idx)
    if recv_tid < 0:
        return false
    recv_info := get_type_info(recv_tid)
    if recv_info.kind != "tuple":
        return false
    field_index := ir_parse_field_index(field_name)
    if field_index < 0 or field_index >= recv_info.elements.len():
        return false
    field_tid := recv_info.elements[field_index]
    field_offset := field_index * 8
    ir_emit("field " + result_reg.to_string() + " " + obj_r.to_string() + " " + field_offset.to_string() + " " + ir_type_from_tid(field_tid) + " " + field_name)
    return true

fn ir_emit_field_access(idx: Int, node: Node) -> Int:
    fname := node_value(idx)
    if node.children.len() == 0:
        r := ir_reg()
        ir_emit("iconst " + r.to_string() + " 0")
        return r
    recv_node := get_node(node.children[0])
    if recv_node.kind == "ident":
        lookup_key := recv_node.value + "." + fname
        if ir_struct_field_index_lookup.contains_key(lookup_key):
            if ir_struct_field_lookup.contains_key(lookup_key):
                if ir_struct_field_lookup[lookup_key] == recv_node.value:
                    r := ir_reg()
                    ir_emit("iconst " + r.to_string() + " " + ir_struct_field_index_lookup[lookup_key])
                    return r
    recv_idx := node.children[0]
    obj_r := ir_expr(recv_idx)
    r := ir_reg()
    if ir_emit_tuple_field_access(r, obj_r, recv_idx, fname):
        return r
    ir_emit_named_field_access(r, obj_r, ir_field_lookup_key(recv_idx, fname), fname)
    return r

fn ir_emit_result_flag_field(obj_r: Int, fname: String) -> Int:
    flag_r := ir_reg()
    ir_emit("field " + flag_r.to_string() + " " + obj_r.to_string() + " 0 bool is_ok")
    if fname == "is_ok":
        return flag_r
    zero := ir_reg()
    ir_emit("iconst " + zero.to_string() + " 0")
    r := ir_reg()
    ir_emit("eq " + r.to_string() + " " + flag_r.to_string() + " " + zero.to_string())
    return r

fn ir_zero_reg() -> Int:
    r := ir_reg()
    ir_emit("iconst " + r.to_string() + " 0")
    return r

fn ir_emit_result_tuple(is_ok_r: Int, ok_r: Int, err_r: Int) -> Int:
    count_r := ir_reg()
    ir_emit("iconst " + count_r.to_string() + " 3")
    result_r := ir_reg()
    ir_emit_call1(result_r, "__struct_alloc", "struct:tuple", count_r)
    ir_emit("sstore " + result_r.to_string() + " 0 " + is_ok_r.to_string())
    ir_emit("sstore " + result_r.to_string() + " 1 " + ok_r.to_string())
    ir_emit("sstore " + result_r.to_string() + " 2 " + err_r.to_string())
    return result_r

fn ir_emit_ok_result_tuple(ok_r: Int) -> Int:
    one := ir_reg()
    ir_emit("iconst " + one.to_string() + " 1")
    return ir_emit_result_tuple(one, ok_r, ir_zero_reg())

fn ir_emit_err_result_tuple(err_r: Int) -> Int:
    zero := ir_zero_reg()
    return ir_emit_result_tuple(zero, zero, err_r)

fn ir_result_field_kind(obj_tid: Int, fname: String) -> String:
    if obj_tid < 0:
        if fname == "is_ok" or fname == "is_err":
            return "bool"
        return "unknown"
    obj_info := get_type_info(obj_tid)
    if obj_info.kind != "result":
        if fname == "is_ok" or fname == "is_err":
            return "bool"
        return "unknown"
    if fname == "ok":
        return ir_type_from_tid(obj_info.inner)
    if fname == "err":
        return ir_type_from_tid(obj_info.value_type)
    return "bool"

fn ir_emit_result_value_field(obj_r: Int, obj_tid: Int, fname: String) -> Int:
    mut offset := 8
    if fname == "err":
        offset = 16
    r := ir_reg()
    ir_emit("field " + r.to_string() + " " + obj_r.to_string() + " " + offset.to_string() + " " + ir_result_field_kind(obj_tid, fname) + " " + fname)
    return r

fn ir_emit_result_error_message(callee_name: String) -> Int:
    msg_r := ir_reg()
    ir_emit("strref " + msg_r.to_string() + " " + ir_str(callee_name + " failed"))
    return msg_r

fn ir_emit_wrapped_legacy_result(raw_r: Int, legacy_kind: String, callee_name: String) -> Int:
    temp_name := ir_new_temp_name("legacy_result")
    ir_var_types.insert(temp_name, "tuple")
    zero_r := ir_reg()
    if legacy_kind == "float":
        ir_emit("fconst " + zero_r.to_string() + " 0.0")
    else:
        ir_emit("iconst " + zero_r.to_string() + " 0")
    cond_r := ir_reg()
    ir_emit("neq " + cond_r.to_string() + " " + raw_r.to_string() + " " + zero_r.to_string())
    ok_l := ir_label()
    err_l := ir_label()
    merge_l := ir_label()
    ir_emit("brif " + cond_r.to_string() + " " + ok_l + " " + err_l)
    ir_emit("label " + ok_l)
    mut ok_r := raw_r
    if legacy_kind == "result_int" or legacy_kind == "result_bool":
        ok_r = ir_decode_result_value(raw_r, legacy_kind)
    ok_tuple := ir_emit_ok_result_tuple(ok_r)
    ir_emit("store " + temp_name + " " + ok_tuple.to_string())
    ir_emit("jmp " + merge_l)
    ir_emit("label " + err_l)
    err_tuple := ir_emit_err_result_tuple(ir_emit_result_error_message(callee_name))
    ir_emit("store " + temp_name + " " + err_tuple.to_string())
    ir_emit("label " + merge_l)
    r := ir_reg()
    ir_emit("load " + r.to_string() + " " + temp_name)
    return r

fn ir_emit_result_field_access(idx: Int, obj_r: Int, fname: String) -> Int:
    obj_tid := c_get_expr_type(node_child(idx, 0))
    if obj_tid >= 0:
        obj_info := get_type_info(obj_tid)
        if obj_info.kind == "result":
            if fname == "ok":
                return ir_emit_result_value_field(obj_r, obj_tid, "ok")
            if fname == "err":
                return ir_emit_result_value_field(obj_r, obj_tid, "err")
            if fname == "is_ok" or fname == "is_err":
                return ir_emit_result_flag_field(obj_r, fname)
    return 0 - 1

fn ir_method_call_arg_expr(node: Node, arg_index: Int) -> Int:
    actual_index := arg_index + 1
    if actual_index >= node.children.len():
        return 0 - 1
    child := node.children[actual_index]
    cn := get_node(child)
    if cn.kind == "arg" and cn.children.len() > 0:
        return cn.children[0]
    return child

fn ir_emit_result_unwrap_or(node: Node) -> Int:
    recv_r := ir_expr(node.children[0])
    cond_r := ir_emit_result_flag_field(recv_r, "is_ok")
    temp_name := ir_new_temp_name("unwrap_or")
    arg_idx := ir_method_call_arg_expr(node, 0)
    fallback_r := ir_expr(arg_idx)
    ok_l := ir_label()
    fallback_l := ir_label()
    merge_l := ir_label()
    ir_emit("brif " + cond_r.to_string() + " " + ok_l + " " + fallback_l)
    ir_emit("label " + ok_l)
    ir_emit("store " + temp_name + " " + ir_emit_result_value_field(recv_r, c_get_expr_type(node.children[0]), "ok").to_string())
    ir_emit("jmp " + merge_l)
    ir_emit("label " + fallback_l)
    ir_emit("store " + temp_name + " " + fallback_r.to_string())
    ir_emit("label " + merge_l)
    r := ir_reg()
    ir_emit("load " + r.to_string() + " " + temp_name)
    return r

fn ir_emit_result_value_to_string(recv_r: Int, recv_tid: Int) -> Int:
    mut ok_tid := 0 - 1
    mut err_tid := 0 - 1
    if recv_tid >= 0:
        recv_info := get_type_info(recv_tid)
        if recv_info.kind == "result":
            ok_tid = recv_info.inner
            err_tid = recv_info.value_type
    cond_r := ir_emit_result_flag_field(recv_r, "is_ok")
    temp_name := ir_new_temp_name("result_to_string")
    ok_l := ir_label()
    err_l := ir_label()
    merge_l := ir_label()
    ir_emit("brif " + cond_r.to_string() + " " + ok_l + " " + err_l)
    ir_emit("label " + ok_l)
    ok_r := ir_emit_result_value_field(recv_r, recv_tid, "ok")
    ir_emit("store " + temp_name + " " + ir_emit_stringify_value(ok_r, ok_tid).to_string())
    ir_emit("jmp " + merge_l)
    ir_emit("label " + err_l)
    err_r := ir_emit_result_value_field(recv_r, recv_tid, "err")
    ir_emit("store " + temp_name + " " + ir_emit_stringify_value(err_r, err_tid).to_string())
    ir_emit("label " + merge_l)
    r := ir_reg()
    ir_emit("load " + r.to_string() + " " + temp_name)
    return r

fn ir_emit_stringify_value(value_r: Int, value_tid: Int) -> Int:
    value_type := ir_type_from_tid(value_tid)
    if value_type == "string":
        return value_r
    out_r := ir_reg()
    if value_type == "bool":
        ir_emit_call1(out_r, "bool_to_string", "string", value_r)
        return out_r
    if value_type == "float":
        ir_emit_call1(out_r, "float_to_string", "string", value_r)
        return out_r
    if value_type == "int":
        ir_emit_call1(out_r, "int_to_string", "string", value_r)
        return out_r
    if value_tid >= 0:
        value_info := get_type_info(value_tid)
        if value_info.kind == "result":
            return ir_emit_result_value_to_string(value_r, value_tid)
    return value_r

fn ir_emit_result_to_string(node: Node) -> Int:
    recv_r := ir_expr(node.children[0])
    recv_tid := c_get_expr_type(node.children[0])
    return ir_emit_result_value_to_string(recv_r, recv_tid)

fn ir_emit_named_handler_call(handler_idx: Int, arg_r: Int, ret_type: String) -> Int:
    handler_node := get_node(handler_idx)
    callee := ir_resolve_static_callee(handler_idx)
    mut call_name := callee.name
    if call_name.len() == 0 and handler_node.kind == "ident":
        call_name = handler_node.value
    if call_name.len() > 0:
        out_r := ir_reg()
        legacy_kind := ir_builtin_result_retkind(call_name)
        mut call_type := ret_type
        if legacy_kind.len() > 0:
            call_type = legacy_kind
        ir_emit_call_text(out_r, call_name, call_type, 1, " " + arg_r.to_string())
        if legacy_kind.len() > 0 and ret_type == "tuple":
            return ir_emit_wrapped_legacy_result(out_r, legacy_kind, call_name)
        return out_r
    handler_r := ir_expr(handler_idx)
    handler_name := ir_new_temp_name("handler")
    ir_emit("store " + handler_name + " " + handler_r.to_string())
    out_r := ir_reg()
    ir_emit_call_text(out_r, handler_name, ret_type, 1, " " + arg_r.to_string())
    return out_r

fn ir_emit_result_or_else(idx: Int, node: Node) -> Int:
    recv_r := ir_expr(node.children[0])
    cond_r := ir_emit_result_flag_field(recv_r, "is_ok")
    temp_name := ir_new_temp_name("or_else")
    ir_var_types.insert(temp_name, "tuple")
    handler_idx := ir_method_call_arg_expr(node, 0)
    ok_l := ir_label()
    err_l := ir_label()
    merge_l := ir_label()
    ir_emit("brif " + cond_r.to_string() + " " + ok_l + " " + err_l)
    ir_emit("label " + ok_l)
    ir_emit("store " + temp_name + " " + recv_r.to_string())
    ir_emit("jmp " + merge_l)
    ir_emit("label " + err_l)
    err_r := ir_emit_result_value_field(recv_r, c_get_expr_type(node.children[0]), "err")
    handled_r := ir_emit_named_handler_call(handler_idx, err_r, ir_checked_type(idx))
    ir_emit("store " + temp_name + " " + handled_r.to_string())
    ir_emit("label " + merge_l)
    r := ir_reg()
    ir_emit("load " + r.to_string() + " " + temp_name)
    return r

fn ir_emit_select_recv_probe(recv_idx: Int) -> Int:
    recv_node := get_node(recv_idx)
    if recv_node.kind != "method_call" or recv_node.children.len() == 0:
        return ir_zero_reg()
    ch_r := ir_expr(recv_node.children[0])
    r := ir_reg()
    ir_emit_call1(r, "forge_channel_try_recv", "tuple", ch_r)
    return r

fn ir_emit_select_send_probe(send_idx: Int) -> Int:
    send_node := get_node(send_idx)
    if send_node.kind != "method_call" or send_node.children.len() == 0:
        return ir_zero_reg()
    ch_r := ir_expr(send_node.children[0])
    arg_idx := ir_method_call_arg_expr(send_node, 0)
    if arg_idx < 0:
        return ir_zero_reg()
    val_r := ir_expr(arg_idx)
    r := ir_reg()
    ir_emit_call2(r, "forge_channel_try_send", "bool", ch_r, val_r)
    return r

fn ir_emit_select_arm_body(body_idx: Int, bind_name: String, bind_r: Int, bind_type: String) -> Int:
    saved_vars := ir_copy_var_regs(ir_var_regs)
    saved_types := ir_copy_var_types(ir_var_types)
    if bind_name.len() > 0:
        if bind_type.len() > 0:
            ir_var_types.insert(bind_name, bind_type)
        ir_emit("store " + bind_name + " " + bind_r.to_string())
    body_node := get_node(body_idx)
    mut body_r := ir_zero_reg()
    if body_node.kind == "body":
        if body_node.children.len() > 0:
            body_r = ir_expr(body_node.children[0])
    elif body_node.kind == "block":
        ir_block(body_idx)
    else:
        body_r = ir_expr(body_idx)
    ir_var_regs = saved_vars
    ir_var_types = saved_types
    return body_r

fn ir_select_probe_arm_indices(node: Node) -> List[Int]:
    mut probe_arms: List[Int] := []
    for arm_idx in node.children:
        arm_node := get_node(arm_idx)
        if arm_node.kind == "select_recv_arm" or arm_node.kind == "select_send_arm":
            probe_arms.push(arm_idx)
    return probe_arms

fn ir_emit_select_probe_arm(arm_idx: Int, result_temp: String, end_l: String):
    arm_node := get_node(arm_idx)
    if arm_node.kind == "select_recv_arm" and arm_node.children.len() >= 2:
        maybe_r := ir_emit_select_recv_probe(arm_node.children[0])
        ready_r := ir_optional_flag_field(maybe_r)
        hit_l := ir_label()
        next_l := ir_label()
        ir_emit("brif " + ready_r.to_string() + " " + hit_l + " " + next_l)
        ir_emit("label " + hit_l)
        body_r := ir_emit_select_arm_body(arm_node.children[1], arm_node.value, maybe_r, ir_checked_type(arm_node.children[0]))
        ir_emit("store " + result_temp + " " + body_r.to_string())
        ir_emit("jmp " + end_l)
        ir_emit("label " + next_l)
    elif arm_node.kind == "select_send_arm" and arm_node.children.len() >= 2:
        ready_r := ir_emit_select_send_probe(arm_node.children[0])
        hit_l := ir_label()
        next_l := ir_label()
        ir_emit("brif " + ready_r.to_string() + " " + hit_l + " " + next_l)
        ir_emit("label " + hit_l)
        body_r := ir_emit_select_arm_body(arm_node.children[1], "", 0, "")
        ir_emit("store " + result_temp + " " + body_r.to_string())
        ir_emit("jmp " + end_l)
        ir_emit("label " + next_l)

fn ir_emit_select_expr(node: Node) -> Int:
    result_temp := ir_new_temp_name("select")
    mut timeout_idx := 0 - 1
    mut default_idx := 0 - 1
    probe_arms := ir_select_probe_arm_indices(node)
    probe_count := probe_arms.len()
    for child in node.children:
        arm_node := get_node(child)
        if arm_node.kind == "select_timeout_arm" and timeout_idx < 0:
            timeout_idx = child
        elif arm_node.kind == "select_default_arm" and default_idx < 0:
            default_idx = child

    mut deadline_name := ""
    if timeout_idx >= 0:
        deadline_name = ir_new_temp_name("select_deadline")
        timeout_node := get_node(timeout_idx)
        timeout_r := ir_expr(timeout_node.children[0])
        now_r := ir_reg()
        ir_emit_call0(now_r, "time", "int")
        deadline_r := ir_reg()
        ir_emit("add " + deadline_r.to_string() + " " + now_r.to_string() + " " + timeout_r.to_string())
        ir_emit("store " + deadline_name + " " + deadline_r.to_string())

    loop_l := ir_label()
    end_l := ir_label()
    ir_emit("label " + loop_l)

    mut offset_name := ""
    if probe_count > 1:
        offset_name = ir_new_temp_name("select_offset")
        count_r := ir_reg()
        ir_emit("iconst " + count_r.to_string() + " " + probe_count.to_string())
        seed_r := ir_reg()
        ir_emit_call1(seed_r, "forge_select_next_index", "int", count_r)
        ir_emit("store " + offset_name + " " + seed_r.to_string())

    if probe_count <= 1:
        if probe_count == 1:
            ir_emit_select_probe_arm(probe_arms[0], result_temp, end_l)
    else:
        probe_done_l := ir_label()
        offset_r := ir_reg()
        ir_emit("load " + offset_r.to_string() + " " + offset_name)
        mut i := 0
        while i < probe_count:
            case_l := ir_label()
            next_case_l := ir_label()
            match_r := ir_reg()
            case_r := ir_reg()
            ir_emit("iconst " + case_r.to_string() + " " + i.to_string())
            ir_emit("eq " + match_r.to_string() + " " + offset_r.to_string() + " " + case_r.to_string())
            ir_emit("brif " + match_r.to_string() + " " + case_l + " " + next_case_l)
            ir_emit("label " + case_l)
            mut j := 0
            while j < probe_count:
                probe_idx := (i + j) % probe_count
                ir_emit_select_probe_arm(probe_arms[probe_idx], result_temp, end_l)
                j = j + 1
            ir_emit("jmp " + probe_done_l)
            ir_emit("label " + next_case_l)
            i = i + 1
        ir_emit("label " + probe_done_l)

    if default_idx >= 0:
        default_node := get_node(default_idx)
        if default_node.children.len() > 0:
            body_r := ir_emit_select_arm_body(default_node.children[0], "", 0, "")
            ir_emit("store " + result_temp + " " + body_r.to_string())
            ir_emit("jmp " + end_l)

    if timeout_idx >= 0:
        now_r := ir_reg()
        ir_emit_call0(now_r, "time", "int")
        deadline_r := ir_reg()
        ir_emit("load " + deadline_r.to_string() + " " + deadline_name)
        expired_r := ir_reg()
        ir_emit("gte " + expired_r.to_string() + " " + now_r.to_string() + " " + deadline_r.to_string())
        timeout_l := ir_label()
        wait_l := ir_label()
        ir_emit("brif " + expired_r.to_string() + " " + timeout_l + " " + wait_l)
        ir_emit("label " + timeout_l)
        timeout_node := get_node(timeout_idx)
        body_r := ir_emit_select_arm_body(timeout_node.children[1], "", 0, "")
        ir_emit("store " + result_temp + " " + body_r.to_string())
        ir_emit("jmp " + end_l)
        ir_emit("label " + wait_l)

    delay_r := ir_reg()
    if probe_count > 1:
        next_offset_r := ir_reg()
        cur_offset_r := ir_reg()
        one_r := ir_reg()
        count_r := ir_reg()
        ir_emit("load " + cur_offset_r.to_string() + " " + offset_name)
        ir_emit("iconst " + one_r.to_string() + " 1")
        ir_emit("iconst " + count_r.to_string() + " " + probe_count.to_string())
        next_sum_r := ir_reg()
        ir_emit("add " + next_sum_r.to_string() + " " + cur_offset_r.to_string() + " " + one_r.to_string())
        ir_emit("mod " + next_offset_r.to_string() + " " + next_sum_r.to_string() + " " + count_r.to_string())
        ir_emit("store " + offset_name + " " + next_offset_r.to_string())
    ir_emit("iconst " + delay_r.to_string() + " 1")
    sleep_r := ir_reg()
    ir_emit_call1(sleep_r, "sleep", "unknown", delay_r)
    ir_emit("jmp " + loop_l)
    ir_emit("label " + end_l)
    r := ir_reg()
    ir_emit("load " + r.to_string() + " " + result_temp)
    return r

# --- method call dispatch (extracted from ir_expr) ---
fn ir_emit_method_call(idx: Int) -> Int:
    node := get_node(idx)
    # first child is object, then args. value is method_name (may have leading dot)
    mname := ir_plain_method_name(node_value(idx))

    if node.children.len() > 0:
        recv_tid := c_get_expr_type(node.children[0])
        if recv_tid >= 0:
            recv_info := get_type_info(recv_tid)
            if recv_info.kind == "primitive" and mname == "to_string":
                if recv_info.name == "UInt" or recv_info.name == "UInt8" or recv_info.name == "UInt16" or recv_info.name == "UInt32" or recv_info.name == "UInt64":
                    obj_r := ir_expr(node.children[0])
                    out_r := ir_reg()
                    ir_emit_call1(out_r, "uint_to_string", "string", obj_r)
                    return out_r
            if recv_info.kind == "result":
                if mname == "unwrap_or":
                    return ir_emit_result_unwrap_or(node)
                if mname == "or_else":
                    return ir_emit_result_or_else(idx, node)
                if mname == "to_string":
                    return ir_emit_result_to_string(node)

    alias_fname := ir_resolve_module_alias_method_call_name(idx)
    if alias_fname.len() > 0:
        mut call_name := alias_fname
        if ir_is_generic_function_name(call_name):
            mut generic_ret_type := ir_checked_type(idx)
            if generic_ret_type.len() == 0:
                generic_ret_type = ir_infer_type(idx)
            call_name = ir_queue_generic_specialization(call_name, ir_infer_generic_concrete_types(call_name, node), generic_ret_type)
        arg_regs := ir_collect_call_arg_regs(node, 1)
        r := ir_reg()
        uses_result_abi := ir_callee_uses_result_abi(ResolvedCallee(call_name, true), idx)
        ret_type := ir_call_retkind(idx, uses_result_abi)
        ir_emit_call_text(r, call_name, ret_type, arg_regs.len(), ir_join_arg_regs(arg_regs))
        if uses_result_abi and ret_type != "tuple" and ir_checked_result_kind(idx) == "tuple":
            return ir_emit_wrapped_legacy_result(r, ret_type, call_name)
        return r

    obj_type := ir_method_receiver_type(node)
    mut emit_name := ir_method_emit_name(mname, obj_type)
    if ir_is_bool_returning_method(emit_name):
        ir_var_types.insert("__last_call", "bool")

    impl_name := ir_lookup_impl_method_name(obj_type, mname)
    impl_dispatch := impl_name.len() > 0
    if impl_dispatch:
        emit_name = impl_name

    call_regs := ir_collect_method_call_regs(node)
    obj_r := call_regs[0]
    mut arg_regs: List[Int] := []
    mut ci := 0
    while ci + 1 < call_regs.len():
        arg_regs.push(call_regs[ci + 1])
        ci = ci + 1
    r := ir_reg()
    uses_result_abi := ir_callee_uses_result_abi(ResolvedCallee(emit_name, impl_dispatch), idx)
    mut ret_type := ir_call_retkind(idx, uses_result_abi)
    if ir_is_void_method(emit_name):
        ret_type = "void"
    call_args := ir_method_call_arg_regs(obj_r, arg_regs)
    if emit_name == "identity" and not impl_dispatch:
        return obj_r
    ir_emit_call_text(r, emit_name, ret_type, call_args.len(), ir_join_arg_regs(call_args))
    if uses_result_abi and ret_type != "tuple" and ir_checked_result_kind(idx) == "tuple":
        return ir_emit_wrapped_legacy_result(r, ret_type, emit_name)
    if ir_is_void_method(emit_name):
        return obj_r
    return r

# --- string interpolation (extracted from ir_expr) ---
fn ir_string_interp_part_reg(child: Int) -> Int:
    cn := get_node(child)
    if cn.kind == "lit":
        si := ir_str(cn.value)
        part_r := ir_reg()
        ir_emit("strref " + part_r.to_string() + " " + si)
        return part_r
    return ir_string_interp_expr_part(child)

fn ir_emit_string_interp(idx: Int) -> Int:
    node := get_node(idx)
    # concatenate literal parts and expression parts
    mut result_r := 0 - 1
    mut _fi4 := 0
    kids4_children := node.children
    while _fi4 < kids4_children.len():
        child := kids4_children[_fi4]
        part_r := ir_string_interp_part_reg(child)
        if result_r < 0:
            result_r = part_r
        else:
            nr := ir_reg()
            ir_emit("concat " + nr.to_string() + " " + result_r.to_string() + " " + part_r.to_string())
            result_r = nr
        _fi4 = _fi4 + 1
    if result_r < 0:
        result_r = ir_reg()
        ir_emit("strref " + result_r.to_string() + " " + ir_str(""))
    return result_r

# --- lambda compilation (extracted from ir_expr) ---
struct LambdaParts:
    params: List[String]
    body_idx: Int
    captures: List[String]

fn ir_collect_lambda_parts(idx: Int) -> LambdaParts:
    mut params: List[String] := []
    mut body_idx := 0 - 1
    mut i := 0
    while i < node_child_count(idx):
        child := node_child(idx, i)
        cn := get_node(child)
        if cn.kind == "param":
            params.push(cn.value)
        elif cn.kind == "body":
            body_idx = child
        i = i + 1
    mut captures: List[String] := []
    if body_idx >= 0:
        captures = ir_find_free_vars(body_idx, params)
    return LambdaParts(params, body_idx, captures)

fn ir_reset_lambda_emit_state():
    ir_next_reg = 0
    ir_var_regs = {}
    ir_var_types = {}
    ir_lines = []

fn ir_emit_lambda_params(params: List[String]):
    for param in params:
        lr := ir_reg()
        ir_var_regs.insert(param, lr)
        ir_emit("param " + param)

fn ir_emit_lambda_body_value(body_idx: Int):
    if body_idx < 0:
        return
    if node_kind(body_idx) == "body" and node_child_count(body_idx) > 0:
        br := ir_expr(node_child(body_idx, 0))
        ir_emit("ret " + br.to_string())
        return
    br := ir_expr(body_idx)
    ir_emit("ret " + br.to_string())

fn ir_emit_lambda_default_return():
    dr := ir_reg()
    ir_emit("iconst " + dr.to_string() + " 0")
    ir_emit("ret " + dr.to_string())
    ir_emit("endfunc")

fn ir_finish_lambda_emit(saved_regs: Int, saved_vars: Map[String, Int], saved_types: Map[String, String], saved_lines: List[String]):
    ir_append_deferred_lambda_body()
    ir_lines = saved_lines
    ir_next_reg = saved_regs
    ir_var_regs = saved_vars
    ir_var_types = saved_types

fn ir_emit_lambda(idx: Int) -> Int:
    # compile lambda body as a separate function
    lambda_name := "__lambda_" + ir_lambda_count.to_string()
    ir_lambda_count = ir_lambda_count + 1
    parts := ir_collect_lambda_parts(idx)

    # save current state and emit lambda to deferred buffer
    saved_regs := ir_next_reg
    saved_vars := ir_copy_var_regs(ir_var_regs)
    saved_types := ir_copy_var_types(ir_var_types)
    saved_lines := ir_copy_lines(ir_lines)
    ir_reset_lambda_emit_state()
    ir_emit_func_header(lambda_name, parts.params.len() + 1, "unknown")
    ir_emit_lambda_hidden_param()
    ir_emit_lambda_params(parts.params)
    ir_emit_lambda_capture_loads(parts.captures)
    ir_emit_lambda_body_value(parts.body_idx)
    ir_emit_lambda_default_return()
    ir_finish_lambda_emit(saved_regs, saved_vars, saved_types, saved_lines)
    # return closure handle and fill captures
    r := ir_reg()
    ir_emit("closure_ref " + r.to_string() + " " + lambda_name)
    ir_emit_lambda_capture_setup(r, parts.captures)
    return r

fn ir_emit_spawn_wrapper(call_idx: Int) -> Int:
    wrapper_name := "__spawn_" + ir_lambda_count.to_string()
    ir_lambda_count = ir_lambda_count + 1
    mut captures: List[String] := []
    call_node := get_node(call_idx)
    if call_node.children.len() > 0:
        callee := ir_resolve_static_callee(call_node.children[0])
        if callee.name.len() == 0:
            captures = ir_find_free_vars(call_node.children[0], [])
        mut i := 1
        while i < call_node.children.len():
            free_in_arg := ir_find_free_vars(call_node.children[i], [])
            mut j := 0
            while j < free_in_arg.len():
                if not ir_list_contains(captures, free_in_arg[j]):
                    captures.push(free_in_arg[j])
                j = j + 1
            i = i + 1

    saved_regs := ir_next_reg
    saved_vars := ir_copy_var_regs(ir_var_regs)
    saved_types := ir_copy_var_types(ir_var_types)
    saved_lines := ir_copy_lines(ir_lines)

    ir_reset_lambda_emit_state()
    ir_emit_func_header(wrapper_name, 1, "unknown")
    ir_emit_lambda_hidden_param()
    ir_emit_lambda_capture_loads(captures)
    ir_emit("ret " + ir_expr(call_idx).to_string())
    ir_emit_lambda_default_return()
    ir_finish_lambda_emit(saved_regs, saved_vars, saved_types, saved_lines)

    closure_r := ir_reg()
    ir_emit("closure_ref " + closure_r.to_string() + " " + wrapper_name)
    ir_emit_lambda_capture_setup(closure_r, captures)
    return closure_r

fn ir_emit_int_literal(node: Node) -> Int:
    r := ir_reg()
    ir_emit("iconst " + r.to_string() + " " + node.value)
    return r

fn ir_emit_string_literal(node: Node) -> Int:
    si := ir_str(node.value)
    r := ir_reg()
    ir_emit("strref " + r.to_string() + " " + si)
    return r

fn ir_emit_float_literal(node: Node) -> Int:
    r := ir_reg()
    ir_emit("fconst " + r.to_string() + " " + node.value)
    return r

fn ir_emit_bool_literal(node: Node) -> Int:
    r := ir_reg()
    if node.value == "true":
        ir_emit("iconst " + r.to_string() + " 1")
    else:
        ir_emit("iconst " + r.to_string() + " 0")
    return r

fn ir_resolve_storage_name(name: String) -> String:
    if ir_import_renames.contains_key(name):
        return ir_import_renames[name]
    if ir_active_generic_module_path.len() > 0 and ir_import_declares_global(ir_active_generic_module_path, name):
        return ir_import_target_name(ir_active_generic_module_path, name)
    return name

fn ir_ident_is_function_value(idx: Int, name: String) -> Bool:
    if ir_var_regs.contains_key(name) or ir_var_types.contains_key(name):
        return false
    callee := ir_ident_callee(name)
    return ir_is_declared_callable(callee.name)

# named functions need a small adapter so they can travel through the same
# closure abi lambdas already use.
fn ir_named_function_value_wrapper(idx: Int, target_name: String) -> String:
    if ir_named_fn_value_wrappers.contains_key(target_name):
        return ir_named_fn_value_wrappers[target_name]

    wrapper_name := "__fnval_" + ir_lambda_count.to_string()
    ir_lambda_count = ir_lambda_count + 1
    tid := c_get_expr_type(idx)
    info := get_type_info(tid)
    mut ret_type := ir_declared_callable_return_type(target_name)
    if ret_type.len() == 0:
        ret_type = "unknown"

    saved_regs := ir_next_reg
    saved_vars := ir_copy_var_regs(ir_var_regs)
    saved_types := ir_copy_var_types(ir_var_types)
    saved_lines := ir_copy_lines(ir_lines)

    ir_reset_lambda_emit_state()
    mut param_count := 1
    if info.kind == "function":
        param_count = info.param_types.len() + 1
    ir_emit_func_header(wrapper_name, param_count, ret_type)
    ir_emit_lambda_hidden_param()

    mut arg_names: List[String] := []
    if info.kind == "function":
        mut i := 0
        while i < info.param_types.len():
            arg_name := "__arg_" + i.to_string()
            arg_names.push(arg_name)
            ir_emit_named_param(arg_name, "")
            i = i + 1

    mut arg_regs: List[Int] := []
    for arg_name in arg_names:
        arg_r := ir_reg()
        ir_emit("load " + arg_r.to_string() + " " + arg_name)
        arg_regs.push(arg_r)

    if ret_type == "void":
        call_r := ir_reg()
        ir_emit_call_text(call_r, target_name, "void", arg_regs.len(), ir_join_arg_regs(arg_regs))
        zero_r := ir_reg()
        ir_emit("iconst " + zero_r.to_string() + " 0")
        ir_emit("ret " + zero_r.to_string())
    else:
        call_r := ir_reg()
        ir_emit_call_text(call_r, target_name, ret_type, arg_regs.len(), ir_join_arg_regs(arg_regs))
        ir_emit("ret " + call_r.to_string())
    ir_emit_lambda_default_return()
    ir_finish_lambda_emit(saved_regs, saved_vars, saved_types, saved_lines)
    ir_named_fn_value_wrappers.insert(target_name, wrapper_name)
    return wrapper_name

fn ir_emit_ident_load(idx: Int, name: String) -> Int:
    r := ir_reg()
    if ir_ident_is_function_value(idx, name):
        callee := ir_ident_callee(name)
        wrapper_name := ir_named_function_value_wrapper(idx, callee.name)
        ir_emit("closure_ref " + r.to_string() + " " + wrapper_name)
        return r
    # normal variables and globals still load through storage.
    ir_emit("load " + r.to_string() + " " + ir_resolve_storage_name(name))
    return r

fn ir_emit_struct_init(node: Node) -> Int:
    sname := node.value
    mut field_regs: List[Int] := []
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "field_init" and cn.children.len() > 0:
            field_regs.push(ir_expr(cn.children[0]))
        else:
            field_regs.push(ir_expr(child))

    r := ir_reg()
    field_count_r := ir_reg()
    ir_emit("iconst " + field_count_r.to_string() + " " + field_regs.len().to_string())
    ir_emit_call1(r, "__struct_alloc", "struct:" + sname, field_count_r)
    for field_reg, fi in field_regs:
        ir_emit("sstore " + r.to_string() + " " + fi.to_string() + " " + field_reg.to_string())
    return r

fn ir_emit_spawn_expr(node: Node) -> Int:
    if node.children.len() > 0:
        inner := get_node(node.children[0])
        if inner.kind == "call":
            closure_r := ir_emit_spawn_wrapper(node.children[0])
            r := ir_reg()
            ir_emit_call1(r, "spawn", "unknown", closure_r)
            return r
    r := ir_reg()
    ir_emit("iconst " + r.to_string() + " 0")
    return r

fn ir_emit_try_expr(node: Node) -> Int:
    if node.children.len() > 0:
        result_kind := ir_expr_result_kind(node.children[0])
        val_r := ir_expr(node.children[0])
        if result_kind == "tuple":
            cond_r := ir_emit_result_flag_field(val_r, "is_ok")
            ok_l := ir_label()
            err_l := ir_label()
            merge_l := ir_label()
            ir_emit("brif " + cond_r.to_string() + " " + ok_l + " " + err_l)
            ir_emit("label " + ok_l)
            decoded_r := ir_emit_result_value_field(val_r, c_get_expr_type(node.children[0]), "ok")
            ir_emit("jmp " + merge_l)
            ir_emit("label " + err_l)
            if ir_emit_tests and ir_emitting_test_func:
                ir_test_assert_fail_return()
            else:
                ir_emit("ret " + val_r.to_string())
            ir_emit("label " + merge_l)
            return decoded_r
        mut cond_r := val_r
        mut decoded_r := val_r
        if ir_uses_result_abi(result_kind):
            decoded_r = ir_decode_result_value(val_r, result_kind)
        elif result_kind.len() > 0:
            zero_cmp := ir_reg()
            if result_kind == "float":
                ir_emit("fconst " + zero_cmp.to_string() + " 0.0")
            else:
                ir_emit("iconst " + zero_cmp.to_string() + " 0")
            cond_r = ir_reg()
            ir_emit("neq " + cond_r.to_string() + " " + val_r.to_string() + " " + zero_cmp.to_string())
        ok_l := ir_label()
        err_l := ir_label()
        merge_l := ir_label()
        ir_emit("brif " + cond_r.to_string() + " " + ok_l + " " + err_l)
        ir_emit("label " + ok_l)
        ir_emit("jmp " + merge_l)
        ir_emit("label " + err_l)
        if ir_emit_tests and ir_emitting_test_func:
            ir_test_assert_fail_return()
        else:
            zero := ir_reg()
            ir_emit("iconst " + zero.to_string() + " 0")
            ir_emit("ret " + zero.to_string())
        ir_emit("label " + merge_l)
        return decoded_r
    r := ir_reg()
    ir_emit("iconst " + r.to_string() + " 0")
    return r

fn ir_emit_fail_expr(node: Node) -> Int:
    if node.children.len() > 0:
        err_r := ir_expr(node.children[0])
        ir_emit("ret " + ir_emit_err_result_tuple(err_r).to_string())
    else:
        ir_emit("ret " + ir_emit_err_result_tuple(ir_zero_reg()).to_string())
    ub := ir_label()
    ir_emit("label " + ub)
    r := ir_reg()
    ir_emit("iconst " + r.to_string() + " 0")
    return r

fn ir_emit_index_expr(idx: Int, node: Node) -> Int:
    obj_r := ir_expr(node.children[0])
    idx_r := ir_expr(node.children[1])
    r := ir_reg()
    mut obj_type := ir_checked_type(node.children[0])
    mut value_type := ir_checked_index_type(idx)
    if obj_type.len() == 0:
        obj_type = ir_infer_type(node.children[0])
    if value_type.len() == 0:
        value_type = ir_lookup_map_value_type_for_expr(node.children[0])
    if value_type.len() == 0:
        value_type = ir_infer_type(idx)
    if obj_type == "string":
        ir_emit_call2(r, "char_at", "string", obj_r, idx_r)
    elif obj_type == "bytes":
        ir_emit_call2(r, "bytes_get", "int", obj_r, idx_r)
    elif obj_type == "map_int":
        if value_type.len() == 0:
            value_type = "unknown"
        ir_emit_call2(r, "map_get_ikey", value_type, obj_r, idx_r)
    elif obj_type == "map":
        if value_type.len() == 0:
            value_type = "unknown"
        ir_emit_call2(r, "map_get", value_type, obj_r, idx_r)
    else:
        ir_emit_call2(r, "__list_get", ir_infer_type(idx), obj_r, idx_r)
    return r

# --- emit expression, return register ---
fn ir_expr(idx: Int) -> Int:
    node := get_node(idx)

    if node.kind == "int_lit" or node.kind == "int" or node.kind == "integer":
        return ir_emit_int_literal(node)

    if node.kind == "string_lit" or node.kind == "string" or node.kind == "str_lit":
        return ir_emit_string_literal(node)

    if node.kind == "float_lit" or node.kind == "float":
        return ir_emit_float_literal(node)

    if node.kind == "bool" or node.kind == "bool_lit":
        return ir_emit_bool_literal(node)

    if node.kind == "ident":
        return ir_emit_ident_load(idx, node.value)

    if node.kind == "self":
        return ir_emit_ident_load(idx, "self")

    if node.kind == "unary":
        return ir_emit_unary_expr(node)

    if node.kind == "binary":
        return ir_emit_binary_expr(node)

    if node.kind == "call":
        return ir_emit_static_call(idx, node)

    else:
        return ir_expr_complex(idx, node)

fn ir_expr_complex(idx: Int, node: Node) -> Int:
    kind := node_kind(idx)
    if kind == "method_call":
        return ir_emit_method_call(idx)

    if kind == "string_interp":
        return ir_emit_string_interp(idx)

    if kind == "map":
        return ir_emit_map_literal(node)

    if kind == "set":
        return ir_emit_set_literal(node)

    if kind == "list":
        return ir_emit_list_literal(node)

    if kind == "tuple":
        return ir_emit_tuple_literal(node)

    if kind == "struct_init":
        return ir_emit_struct_init(node)

    if kind == "field_access":
        fname := node_value(idx)
        if node.children.len() > 0:
            obj_r := ir_expr(node.children[0])
            # result fields are special: `.ok` and status checks read the tagged value,
            # not a struct field.
            result_r := ir_emit_result_field_access(idx, obj_r, fname)
            if result_r >= 0:
                return result_r
        return ir_emit_field_access(idx, node)

    if kind == "lambda":
        return ir_emit_lambda(idx)

    if kind == "spawn":
        return ir_emit_spawn_expr(node)

    if kind == "await":
        if node.children.len() > 0:
            task_r := ir_expr(node.children[0])
            r := ir_reg()
            ir_emit_call1(r, "await", "unknown", task_r)
            return r
        r := ir_reg()
        ir_emit("iconst " + r.to_string() + " 0")
        return r

    if kind == "unwrap":
        return ir_emit_optional_unwrap(node)

    if kind == "try" or kind == "try_expr":
        return ir_emit_try_expr(node)

    if kind == "catch_expr":
        result_r := ir_expr(node.children[0])
        cond_r := ir_emit_result_flag_field(result_r, "is_ok")
        temp_name := ir_new_temp_name("catch")
        ok_l := ir_label()
        fallback_l := ir_label()
        merge_l := ir_label()
        ir_emit("brif " + cond_r.to_string() + " " + ok_l + " " + fallback_l)
        ir_emit("label " + ok_l)
        ir_emit("store " + temp_name + " " + ir_emit_result_value_field(result_r, c_get_expr_type(node.children[0]), "ok").to_string())
        ir_emit("jmp " + merge_l)
        ir_emit("label " + fallback_l)
        ir_emit("store " + temp_name + " " + ir_expr(node.children[1]).to_string())
        ir_emit("label " + merge_l)
        r := ir_reg()
        ir_emit("load " + r.to_string() + " " + temp_name)
        return r

    if kind == "select_expr":
        return ir_emit_select_expr(node)

    if kind == "fail":
        return ir_emit_fail_expr(node)

    if kind == "grouped":
        if node.children.len() > 0:
            return ir_expr(node.children[0])
        r := ir_reg()
        ir_emit("iconst " + r.to_string() + " 0")
        return r

    if kind == "index":
        return ir_emit_index_expr(idx, node)

    # fallback
    r := ir_reg()
    ir_emit("iconst " + r.to_string() + " 0")
    return r

fn ir_stmt_is_expr(kind: String) -> Bool:
    if kind == "call" or kind == "method_call" or kind == "spawn":
        return true
    if kind == "await" or kind == "try" or kind == "try_expr":
        return true
    if kind == "catch_expr":
        return true
    if kind == "select_expr":
        return true
    return kind == "fail"

struct IfBranch:
    cond_idx: Int
    body_idx: Int

struct ForBindingNames:
    value_name: String
    index_name: String

fn ir_emit_return_stmt(node: Node):
    if node.children.len() > 0:
        mut r := ir_expr(node.children[0])
        result_kind := ir_expr_result_kind(node.children[0])
        if ir_current_func_return_kind == "tuple":
            if result_kind != "tuple":
                r = ir_emit_ok_result_tuple(r)
        ir_emit("ret " + r.to_string())
    else:
        r := ir_reg()
        ir_emit("iconst " + r.to_string() + " 0")
        ir_emit("ret " + r.to_string())
    ir_last_was_ret = true

fn ir_emit_bind_stmt(node: Node):
    mut name := node.value
    if name.contains(" mut"):
        name = name.substring(0, name.len() - 4)
    elif name.contains(" "):
        name = name.split(" ")[0]
    mut val_idx := 0 - 1
    mut type_idx := 0 - 1
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "type" or cn.kind == "generic_type":
            type_idx = child
        else:
            val_idx = child
    mut target_type := ""
    if type_idx >= 0:
        target_type = ir_resolve_type_node(type_idx)
        if target_type.len() > 0:
            ir_var_types.insert(name, target_type)
        map_value_type := ir_resolve_map_value_type_node(type_idx)
        if map_value_type.len() > 0:
            ir_map_value_types.insert(name, map_value_type)
    if val_idx >= 0:
        r := ir_emit_value_for_target(val_idx, target_type)
        ir_var_regs.insert(name, r)
        ir_emit("store " + ir_resolve_storage_name(name) + " " + r.to_string())
        if not ir_var_types.contains_key(name):
            inferred := ir_infer_type(val_idx)
            if inferred.len() > 0:
                ir_var_types.insert(name, inferred)

fn ir_emit_assign_stmt(node: Node):
    name := node.value
    if node.children.len() > 0:
        r := ir_emit_value_for_target(node.children[0], ir_lookup_name_type(name))
        ir_var_regs.insert(name, r)
        ir_emit("store " + ir_resolve_storage_name(name) + " " + r.to_string())

fn ir_emit_compound_assignment(node: Node):
    op := node.value
    if op == "=" and node.children.len() >= 2:
        tn := get_node(node.children[0])
        name := tn.value
        target_type := ir_checked_target_type(node.children[0], name)
        r := ir_emit_value_for_target(node.children[1], target_type)
        ir_emit("store " + ir_resolve_storage_name(name) + " " + r.to_string())
        return
    if (op == "+=" or op == "-=" or op == "*=" or op == "/=") and node.children.len() >= 2:
        tn := get_node(node.children[0])
        name := tn.value
        cur := ir_reg()
        ir_emit("load " + cur.to_string() + " " + ir_resolve_storage_name(name))
        rhs := ir_expr(node.children[1])
        res := ir_reg()
        if op == "+=":
            ir_emit("add " + res.to_string() + " " + cur.to_string() + " " + rhs.to_string())
        elif op == "-=":
            ir_emit("sub " + res.to_string() + " " + cur.to_string() + " " + rhs.to_string())
        elif op == "*=":
            ir_emit("mul " + res.to_string() + " " + cur.to_string() + " " + rhs.to_string())
        elif op == "/=":
            ir_emit("div " + res.to_string() + " " + cur.to_string() + " " + rhs.to_string())
        ir_emit("store " + ir_resolve_storage_name(name) + " " + res.to_string())

fn ir_collect_if_branch(node: Node) -> IfBranch:
    mut cond_idx := 0 - 1
    mut body_idx := 0 - 1
    for child in node.children:
        cn := get_node(child)
        if cond_idx < 0 and cn.kind != "then" and cn.kind != "else" and cn.kind != "elif" and cn.kind != "block":
            cond_idx = child
        elif cn.kind == "then" or cn.kind == "block":
            body_idx = child
    return IfBranch(cond_idx, body_idx)

fn ir_emit_if_branch(branch: IfBranch, then_label: String, next_label: String, end_label: String):
    if branch.cond_idx >= 0:
        cr := ir_expr(branch.cond_idx)
        ir_emit("brif " + cr.to_string() + " " + then_label + " " + next_label)
    ir_emit("label " + then_label)
    ir_last_was_ret = false
    if branch.body_idx >= 0:
        ir_block(branch.body_idx)
    if not ir_last_was_ret:
        ir_emit("jmp " + end_label)
    ir_emit("label " + next_label)

fn ir_for_binding_names(node: Node) -> ForBindingNames:
    mut value_name := node.value
    mut index_name := ""
    if value_name.contains(","):
        parts := value_name.split(",")
        value_name = parts[0].trim()
        if parts.len() > 1:
            index_name = parts[1].trim()
    return ForBindingNames(value_name, index_name)

fn ir_is_string_iter_expr(iter_idx: Int) -> Bool:
    iter_node := get_node(iter_idx)
    if iter_node.kind == "string_lit" or iter_node.kind == "string":
        return true
    if iter_node.kind == "ident" and ir_var_types.contains_key(iter_node.value):
        return ir_var_types[iter_node.value] == "string"
    return false

fn ir_emit_for_loop_value_binding(value_name: String, index_name: String, item_kind: String, iter_name: String, index_name_internal: String):
    it_r := ir_reg()
    ir_emit("load " + it_r.to_string() + " " + iter_name)
    idx_r := ir_reg()
    ir_emit("load " + idx_r.to_string() + " " + index_name_internal)
    elem_r := ir_reg()
    if item_kind == "char":
        ir_emit_call2(elem_r, "char_at", "string", it_r, idx_r)
        ir_var_types.insert(value_name, "string")
    elif item_kind == "string":
        ir_emit_call2(elem_r, "__list_get_unchecked", "string", it_r, idx_r)
        ir_var_types.insert(value_name, "string")
    elif item_kind == "int":
        ir_emit_call2(elem_r, "__list_get_unchecked", "int", it_r, idx_r)
        ir_var_types.insert(value_name, "int")
    else:
        ir_emit_call2(elem_r, "__list_get", "unknown", it_r, idx_r)
    ir_emit("store " + value_name + " " + elem_r.to_string())
    if index_name.len() > 0:
        idx_val := ir_reg()
        ir_emit("load " + idx_val.to_string() + " " + index_name_internal)
        ir_emit("store " + index_name + " " + idx_val.to_string())
        ir_var_types.insert(index_name, "int")

# --- emit statement ---
fn ir_stmt(idx: Int):
    node := get_node(idx)
    kind := node.kind

    if ir_stmt_is_expr(kind):
        ir_expr(idx)
        return

    if kind == "block":
        ir_block(idx)
        return

    if kind == "return":
        ir_emit_return_stmt(node)
        return

    if kind == "bind" or kind == "binding":
        ir_emit_bind_stmt(node)
        return

    if kind == "assign":
        ir_emit_assign_stmt(node)
        return

    if kind == "assignment":
        ir_emit_compound_assignment(node)
        return

    ir_stmt_control(idx, node)

fn ir_emit_if_stmt(node: Node):
    mut elif_indices: List[Int] := []
    mut else_idx := 0 - 1
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "elif":
            elif_indices.push(child)
        elif cn.kind == "else":
            else_idx = child
    main_branch := ir_collect_if_branch(node)
    end_label := ir_label()
    then_label := ir_label()
    next_label := ir_label()
    ir_emit_if_branch(main_branch, then_label, next_label, end_label)
    for elif_idx in elif_indices:
        branch := ir_collect_if_branch(get_node(elif_idx))
        ir_emit_if_branch(branch, ir_label(), ir_label(), end_label)
    if else_idx >= 0:
        ir_block(else_idx)
    ir_emit("label " + end_label)

fn ir_emit_while_stmt(node: Node):
    head_label := ir_label()
    body_label := ir_label()
    end_label := ir_label()
    ir_emit("label " + head_label)
    if node.children.len() >= 2:
        cr := ir_expr(node.children[0])
        ir_emit("brif " + cr.to_string() + " " + body_label + " " + end_label)
        ir_emit("label " + body_label)
        ir_break_stack = ir_push_string(ir_break_stack, end_label)
        ir_continue_stack = ir_push_string(ir_continue_stack, head_label)
        ir_block(node.children[1])
        ir_break_stack.remove(ir_break_stack.len() - 1)
        ir_continue_stack.remove(ir_continue_stack.len() - 1)
        ir_emit("jmp " + head_label)
    ir_emit("label " + end_label)

fn ir_emit_for_stmt(node: Node):
    names := ir_for_binding_names(node)
    if node.children.len() >= 2:
        iter_type := ir_infer_type(node.children[0])
        mut iter_r := ir_expr(node.children[0])
        mut item_kind := "unknown"
        if iter_type == "string":
            item_kind = "char"
        elif iter_type == "list_string":
            item_kind = "string"
        elif iter_type == "map":
            keys_r := ir_reg()
            ir_emit_call1(keys_r, "map_keys", "list_string", iter_r)
            iter_r = keys_r
            item_kind = "string"
        elif iter_type == "map_int":
            keys_r := ir_reg()
            ir_emit_call1(keys_r, "map_keys", "list", iter_r)
            iter_r = keys_r
            item_kind = "int"
        elif iter_type == "set":
            values_r := ir_reg()
            ir_emit_call1(values_r, "__set_to_list", "list_string", iter_r)
            iter_r = values_r
            item_kind = "string"
        elif iter_type == "set_int":
            values_r := ir_reg()
            ir_emit_call1(values_r, "__set_to_list_int", "list", iter_r)
            iter_r = values_r
            item_kind = "int"
        fid := ir_for_count
        ir_for_count = ir_for_count + 1
        fi := "__for_idx_" + fid.to_string()
        fl := "__for_len_" + fid.to_string()
        ft := "__for_iter_" + fid.to_string()
        len_r := ir_reg()
        if item_kind == "char":
            ir_emit_call1(len_r, "string_len", "int", iter_r)
        else:
            ir_emit_call1(len_r, "len", "int", iter_r)
        idx_r := ir_reg()
        ir_emit("iconst " + idx_r.to_string() + " 0")
        ir_emit("store " + fi + " " + idx_r.to_string())
        ir_emit("store " + fl + " " + len_r.to_string())
        ir_emit("store " + ft + " " + iter_r.to_string())
        head_l := ir_label()
        body_l := ir_label()
        step_l := ir_label()
        end_l := ir_label()
        ir_emit("label " + head_l)
        ci := ir_reg()
        ir_emit("load " + ci.to_string() + " " + fi)
        cl := ir_reg()
        ir_emit("load " + cl.to_string() + " " + fl)
        cmp_r := ir_reg()
        ir_emit("lt " + cmp_r.to_string() + " " + ci.to_string() + " " + cl.to_string())
        ir_emit("brif " + cmp_r.to_string() + " " + body_l + " " + end_l)
        ir_emit("label " + body_l)
        ir_emit_for_loop_value_binding(names.value_name, names.index_name, item_kind, ft, fi)
        ir_break_stack = ir_push_string(ir_break_stack, end_l)
        ir_continue_stack = ir_push_string(ir_continue_stack, step_l)
        ir_block(node.children[1])
        ir_break_stack.remove(ir_break_stack.len() - 1)
        ir_continue_stack.remove(ir_continue_stack.len() - 1)
        ir_emit("label " + step_l)
        idx3 := ir_reg()
        ir_emit("load " + idx3.to_string() + " " + fi)
        one_r := ir_reg()
        ir_emit("iconst " + one_r.to_string() + " 1")
        inc_r := ir_reg()
        ir_emit("add " + inc_r.to_string() + " " + idx3.to_string() + " " + one_r.to_string())
        ir_emit("store " + fi + " " + inc_r.to_string())
        ir_emit("jmp " + head_l)
        ir_emit("label " + end_l)

fn ir_stmt_control(idx: Int, node: Node):
    if node.kind == "if" or node.kind == "if_stmt":
        ir_emit_if_stmt(node)

    elif node.kind == "while" or node.kind == "while_stmt":
        ir_emit_while_stmt(node)

    elif node.kind == "for" or node.kind == "for_stmt":
        ir_emit_for_stmt(node)

# --- emit block ---
# Recursive block walker — unwrap block/body/then/else wrappers
# and emits statements in source order.
fn ir_block(idx: Int):
    kind := node_kind(idx)
    if kind == "block" or kind == "then" or kind == "else" or kind == "body":
        mut i := 0
        child_count := node_child_count(idx)
        while i < child_count:
            ir_block(node_child(idx, i))
            i = i + 1
    else:
        # loop control jumps are the one statement shape that still needs
        # direct block-level handling. everything else goes through ir_stmt.
        if kind == "break":
            if ir_break_stack.len() > 0:
                ir_emit("jmp " + ir_break_stack[ir_break_stack.len() - 1])
                ir_last_was_ret = true
            return
        if kind == "continue":
            if ir_continue_stack.len() > 0:
                ir_emit("jmp " + ir_continue_stack[ir_continue_stack.len() - 1])
                ir_last_was_ret = true
            return
        ir_stmt(idx)

# --- helpers for function emission ---

fn ir_extract_param_type(param_idx: Int) -> String:
    node := get_node(param_idx)
    if node.kind == "param" and node.children.len() > 0:
        return ir_resolve_type_node(node.children[0])
    return "Int"

fn ir_find_body(fn_idx: Int) -> Int:
    node := get_node(fn_idx)
    nk := node.children
    mut i := 0
    while i < nk.len():
        cn := get_node(nk[i])
        if cn.kind == "body":
            return nk[i]
        i = i + 1
    if nk.len() > 0:
        return nk[nk.len() - 1]
    return 0 - 1

fn ir_param_count(fn_idx: Int) -> Int:
    node := get_node(fn_idx)
    nk := node.children
    mut count := 0
    for child in nk:
        cn := get_node(child)
        if cn.kind == "param":
            count = count + 1
    return count

fn ir_emit_named_param(name: String, param_type: String):
    r := ir_reg()
    ir_var_regs.insert(name, r)
    if param_type.len() > 0:
        ir_var_types.insert(name, param_type)
    ir_emit("param " + name)

fn ir_emit_fn_params(fn_idx: Int):
    node := get_node(fn_idx)
    nk := node.children
    for child in nk:
        cn := get_node(child)
        if cn.kind == "param":
            ir_emit_named_param(cn.value, ir_extract_param_type(child))

fn ir_base_decl_name(name: String) -> String:
    if name.contains("["):
        return name.substring(0, name.index_of("["))
    return name

fn ir_extract_return_type(fn_idx: Int) -> String:
    node := get_node(fn_idx)
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "returns":
            for returns_child in cn.children:
                rn := get_node(returns_child)
                if rn.kind == "type" or rn.kind == "generic_type" or rn.kind == "result_type":
                    return ir_resolve_type_node(returns_child)
    return "unknown"

fn ir_lookup_func_return(full_name: String, base_name: String) -> String:
    if ir_func_returns.contains_key(full_name):
        return ir_func_returns[full_name]
    if ir_func_returns.contains_key(base_name):
        return ir_func_returns[base_name]
    return "unknown"

fn ir_impl_method_key(type_name: String, method_name: String) -> String:
    return type_name + "." + method_name

fn ir_import_impl_method_name(module_path: String, impl_type: String, method_name: String) -> String:
    return ir_import_target_name(module_path, impl_type + "_" + method_name)

fn ir_lookup_impl_method_name(type_name: String, method_name: String) -> String:
    if type_name.len() == 0:
        return ""
    key := ir_impl_method_key(type_name, method_name)
    if ir_impl_methods.contains_key(key):
        return ir_impl_methods[key]
    resolved := ir_resolve_type_hint(type_name)
    if resolved != type_name:
        resolved_key := ir_impl_method_key(resolved, method_name)
        if ir_impl_methods.contains_key(resolved_key):
            return ir_impl_methods[resolved_key]
    if type_name.contains("["):
        base := type_name.substring(0, type_name.index_of("["))
        base_key := ir_impl_method_key(base, method_name)
        if ir_impl_methods.contains_key(base_key):
            return ir_impl_methods[base_key]
    return ""

fn ir_collect_impl_methods(root_idx: Int, module_path: String):
    for item_idx in ir_root_items(root_idx):
        node := get_node(item_idx)
        if node.kind == "impl_decl":
            ir_collect_impl_method_signatures(node, module_path)

fn ir_root_items(root_idx: Int) -> List[Int]:
    if ir_root_items_cache.contains_key(root_idx):
        return ir_root_items_cache[root_idx]
    root := get_node(root_idx)
    mut items: List[Int] := []
    for child in root.children:
        items.push(ir_unwrap_pub_child(child))
    ir_root_items_cache.insert(root_idx, items)
    return items

fn ir_is_fn_decl_kind(kind: String) -> Bool:
    return kind == "fn" or kind == "fn_decl"

fn ir_has_generic_params(node: Node) -> Bool:
    for child in node.children:
        if get_node(child).kind == "generic_param":
            return true
    return false

fn ir_collect_generic_param_names(node: Node) -> List[String]:
    mut names: List[String] := []
    mut i := 0
    while i < node.children.len():
        child := get_node(node.children[i])
        if child.kind == "generic_param":
            names.push(child.value)
        i = i + 1
    return names

fn ir_encode_type_list(type_names: List[String]) -> String:
    return type_names.join(chr(9))

fn ir_decode_type_list(encoded: String) -> List[String]:
    if encoded.len() == 0:
        return []
    return encoded.split(chr(9))

fn ir_generic_specialization_key(name: String, type_names: List[String]) -> String:
    return name + chr(9) + ir_encode_type_list(type_names)

fn ir_sanitize_symbol_part(name: String) -> String:
    mut out := ""
    mut i := 0
    while i < name.len():
        ch := name[i]
        if ch == "[" or ch == "]" or ch == "," or ch == " " or ch == "." or ch == ":":
            out = out + "_"
        else:
            out = out + ch
        i = i + 1
    return out

fn ir_generic_specialization_name(name: String, type_names: List[String]) -> String:
    mut suffix_parts: List[String] := []
    for type_name in type_names:
        suffix_parts.push(ir_sanitize_symbol_part(type_name))
    return name + "__" + suffix_parts.join("_")

fn ir_collect_generic_function_decls_from_root(root_idx: Int, module_path: String):
    for item_idx in ir_root_items(root_idx):
        node := get_node(item_idx)
        if ir_is_fn_decl_kind(node.kind) and ir_has_generic_params(node):
            ir_record_generic_function_decl(item_idx, node, module_path)

fn ir_collect_generic_function_decls(root_idx: Int):
    ir_generic_decl_indices = {}
    for root, preload_i in ir_preloaded_import_roots:
        mut module_path := ""
        if preload_i < ir_preloaded_import_paths.len():
            module_path = ir_preloaded_import_paths[preload_i]
        ir_collect_generic_function_decls_from_root(root, module_path)
    ir_collect_generic_function_decls_from_root(root_idx, "")

fn ir_is_generic_function_name(name: String) -> Bool:
    return ir_generic_decl_indices.contains_key(name)

fn ir_specialize_type_name(name: String, generic_params: List[String], concrete_types: List[String]) -> String:
    for generic_param, i in generic_params:
        if i < concrete_types.len() and generic_param == name:
            return concrete_types[i]
    return ir_resolve_type_hint(name)

fn ir_resolve_type_node_with_subst(type_idx: Int, generic_params: List[String], concrete_types: List[String]) -> String:
    tn := get_node(type_idx)
    if tn.kind == "type":
        return ir_specialize_type_name(tn.value, generic_params, concrete_types)
    if tn.kind == "generic_type":
        if tn.value == "List":
            if tn.children.len() > 0:
                inner := ir_resolve_type_node_with_subst(tn.children[0], generic_params, concrete_types)
                if inner == "string":
                    return "list_string"
            return "list"
        if tn.value == "Map":
            if tn.children.len() > 0:
                key_type := ir_resolve_type_node_with_subst(tn.children[0], generic_params, concrete_types)
                if key_type == "int":
                    return "map_int"
            return "map"
        if tn.value == "Set":
            if tn.children.len() > 0:
                elem_type := ir_resolve_type_node_with_subst(tn.children[0], generic_params, concrete_types)
                if elem_type == "int":
                    return "set_int"
            return "set"
        return ir_resolve_type_hint(tn.value)
    if tn.kind == "result_type" and tn.children.len() > 0:
        inner_type := ir_resolve_type_node_with_subst(tn.children[0], generic_params, concrete_types)
        return ir_resolve_result_type_kind(inner_type)
    if tn.kind == "optional_type" and tn.children.len() > 0:
        return ir_resolve_type_node_with_subst(tn.children[0], generic_params, concrete_types)
    if tn.kind == "fn_type":
        return "closure"
    if tn.kind == "tuple_type":
        return "tuple"
    return ""

fn ir_extract_return_type_with_subst(fn_idx: Int, generic_params: List[String], concrete_types: List[String]) -> String:
    node := get_node(fn_idx)
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "returns":
            for returns_child in cn.children:
                rn := get_node(returns_child)
                if rn.kind == "type" or rn.kind == "generic_type" or rn.kind == "result_type" or rn.kind == "optional_type":
                    return ir_resolve_type_node_with_subst(returns_child, generic_params, concrete_types)
    return "unknown"

fn ir_extract_param_types_with_subst(fn_idx: Int, generic_params: List[String], concrete_types: List[String]) -> List[String]:
    node := get_node(fn_idx)
    mut param_types: List[String] := []
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "param":
            if cn.children.len() > 0:
                param_types.push(ir_resolve_type_node_with_subst(cn.children[0], generic_params, concrete_types))
            else:
                param_types.push("")
    return param_types

fn ir_bind_inferred_generic_runtime_type(name: String, actual_tid: Int) -> Bool:
    concrete := ir_type_from_tid(actual_tid)
    if concrete.len() == 0:
        return true
    if ir_generic_runtime_subst.contains_key(name):
        return ir_generic_runtime_subst[name] == concrete
    ir_generic_runtime_subst.insert(name, concrete)
    return true

fn ir_infer_generic_runtime_types_from_node(type_idx: Int, actual_tid: Int, generic_params: List[String]) -> Bool:
    if type_idx < 0 or actual_tid < 0:
        return true
    node := get_node(type_idx)
    if node.kind == "type":
        for gp in generic_params:
            if gp == node.value:
                return ir_bind_inferred_generic_runtime_type(gp, actual_tid)
        return true

    actual_info := get_type_info(actual_tid)

    if node.kind == "generic_type":
        if node.value == "List":
            if actual_info.kind == "list" and node.children.len() > 0:
                return ir_infer_generic_runtime_types_from_node(node.children[0], actual_info.inner, generic_params)
            return true
        if node.value == "Set":
            if actual_info.kind == "set" and node.children.len() > 0:
                return ir_infer_generic_runtime_types_from_node(node.children[0], actual_info.inner, generic_params)
            return true
        if node.value == "Task":
            if actual_info.kind == "task" and node.children.len() > 0:
                return ir_infer_generic_runtime_types_from_node(node.children[0], actual_info.inner, generic_params)
            return true
        if node.value == "Channel":
            if actual_info.kind == "channel" and node.children.len() > 0:
                return ir_infer_generic_runtime_types_from_node(node.children[0], actual_info.inner, generic_params)
            return true
        if node.value == "Map":
            if actual_info.kind == "map" and node.children.len() > 1:
                if ir_infer_generic_runtime_types_from_node(node.children[0], actual_info.key_type, generic_params) == false:
                    return false
                return ir_infer_generic_runtime_types_from_node(node.children[1], actual_info.value_type, generic_params)
            return true
        return true

    if node.kind == "optional_type":
        if actual_info.kind == "optional" and node.children.len() > 0:
            return ir_infer_generic_runtime_types_from_node(node.children[0], actual_info.inner, generic_params)
        return true

    if node.kind == "result_type":
        if actual_info.kind == "result" and node.children.len() > 0:
            if ir_infer_generic_runtime_types_from_node(node.children[0], actual_info.inner, generic_params) == false:
                return false
            if node.children.len() > 1 and actual_info.value_type >= 0:
                return ir_infer_generic_runtime_types_from_node(node.children[1], actual_info.value_type, generic_params)
        return true

    if node.kind == "tuple_type":
        if actual_info.kind == "tuple":
            for child, i in node.children:
                if i < actual_info.elements.len():
                    if ir_infer_generic_runtime_types_from_node(child, actual_info.elements[i], generic_params) == false:
                        return false
        return true

    if node.kind == "fn_type":
        if actual_info.kind == "function":
            mut param_idx := 0
            for child in node.children:
                cn := get_node(child)
                if cn.kind == "param":
                    if param_idx < actual_info.param_types.len():
                        if ir_infer_generic_runtime_types_from_node(cn.children[0], actual_info.param_types[param_idx], generic_params) == false:
                            return false
                    param_idx = param_idx + 1
                elif cn.kind == "returns" and cn.children.len() > 0:
                    return ir_infer_generic_runtime_types_from_node(cn.children[0], actual_info.return_type, generic_params)
        return true

    return true

fn ir_infer_generic_concrete_types(name: String, node: Node) -> List[String]:
    if not ir_generic_decl_indices.contains_key(name):
        return ir_generic_arg_types(node)
    decl_idx := ir_generic_decl_indices[name]
    decl_node := get_node(decl_idx)
    generic_params := ir_collect_generic_param_names(decl_node)
    mut param_type_nodes: List[Int] := []
    for child in decl_node.children:
        cn := get_node(child)
        if cn.kind == "param":
            if cn.children.len() > 0:
                param_type_nodes.push(cn.children[0])
            else:
                param_type_nodes.push(-1)
    mut arg_tids: List[Int] := []
    for child, i in node.children:
        if i == 0:
            continue
        mut expr_idx := child
        if node_kind(child) == "arg":
            cn := get_node(child)
            if cn.children.len() > 0:
                expr_idx = cn.children[0]
        arg_tids.push(c_get_expr_type(expr_idx))
    ir_generic_runtime_subst = {}
    mut arg_idx := 0
    while arg_idx < param_type_nodes.len():
        if arg_idx < arg_tids.len() and param_type_nodes[arg_idx] >= 0:
            ir_infer_generic_runtime_types_from_node(param_type_nodes[arg_idx], arg_tids[arg_idx], generic_params)
        arg_idx = arg_idx + 1
    mut concrete_types: List[String] := []
    for gp in generic_params:
        if ir_generic_runtime_subst.contains_key(gp):
            concrete_types.push(ir_generic_runtime_subst[gp])
        else:
            concrete_types.push("unknown")
    return concrete_types

fn ir_emit_fn_params_with_types(fn_idx: Int, param_types: List[String]):
    node := get_node(fn_idx)
    mut param_idx := 0
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "param":
            mut param_type := ""
            if param_idx < param_types.len():
                param_type = param_types[param_idx]
            ir_emit_named_param(cn.value, param_type)
            param_idx = param_idx + 1

fn ir_generic_arg_types(node: Node) -> List[String]:
    mut arg_types: List[String] := []
    for child, i in node.children:
        if i == 0:
            continue
        child_kind := node_kind(child)
        mut expr_idx := child
        if child_kind == "arg":
            cn := get_node(child)
            if cn.children.len() > 0:
                expr_idx = cn.children[0]
        checked := ir_checked_type(expr_idx)
        if checked.len() > 0:
            arg_types.push(checked)
        else:
            arg_types.push(ir_infer_type(expr_idx))
    return arg_types

fn ir_queue_generic_specialization(name: String, arg_types: List[String], ret_type: String) -> String:
    key := ir_generic_specialization_key(name, arg_types)
    if ir_generic_specialization_names.contains_key(key):
        return ir_generic_specialization_names[key]
    spec_name := ir_generic_specialization_name(name, arg_types)
    ir_generic_specialization_keys = ir_push_string(ir_generic_specialization_keys, key)
    ir_generic_specialization_names.insert(key, spec_name)
    ir_generic_specialization_type_lists.insert(key, ir_encode_type_list(arg_types))
    ir_func_returns.insert(spec_name, ret_type)
    return spec_name

fn ir_emit_generic_specialization(key: String):
    if not ir_generic_specialization_names.contains_key(key):
        return
    base_name := key.split(chr(9))[0]
    if not ir_generic_decl_indices.contains_key(base_name):
        return
    decl_idx := ir_generic_decl_indices[base_name]
    decl_node := get_node(decl_idx)
    generic_params := ir_collect_generic_param_names(decl_node)
    concrete_types := ir_decode_type_list(ir_generic_specialization_type_lists[key])
    spec_name := ir_generic_specialization_names[key]
    body_idx := ir_find_body(decl_idx)
    param_count := ir_param_count(decl_idx)
    ret_type := ir_extract_return_type_with_subst(decl_idx, generic_params, concrete_types)
    param_types := ir_extract_param_types_with_subst(decl_idx, generic_params, concrete_types)
    saved_params := ir_active_generic_params
    saved_types := ir_active_generic_concrete_types
    saved_module_path := ir_active_generic_module_path
    ir_active_generic_params = generic_params
    ir_active_generic_concrete_types = concrete_types
    if ir_generic_decl_module_paths.contains_key(base_name):
        ir_active_generic_module_path = ir_generic_decl_module_paths[base_name]
    else:
        ir_active_generic_module_path = ""
    ir_prepare_func_emission(ret_type)
    ir_emit_func_header(spec_name, param_count, ret_type)
    ir_emit_fn_params_with_types(decl_idx, param_types)
    ir_func_returns.insert(spec_name, ret_type)
    ir_finish_func_emission(body_idx)
    ir_active_generic_params = saved_params
    ir_active_generic_concrete_types = saved_types
    ir_active_generic_module_path = saved_module_path

fn ir_emit_generic_specializations():
    for key in ir_generic_specialization_keys:
        if not ir_generic_emitted_specializations.contains_key(key):
            ir_emit_generic_specialization(key)
            ir_generic_emitted_specializations.insert(key, 1)

fn ir_collect_impl_method_signatures(node: Node, module_path: String):
    impl_type := ir_impl_target_type(node)
    if impl_type.len() == 0:
        return
    for child in node.children:
        method_idx := ir_unwrap_pub_child(child)
        method_node := get_node(method_idx)
        if ir_is_fn_decl_kind(method_node.kind):
            ir_record_impl_method_signature(impl_type, method_idx, method_node, module_path)

fn ir_record_impl_method_signature(impl_type: String, method_idx: Int, method_node: Node, module_path: String):
    method_name := method_node.value
    mut full_name := impl_type + "_" + method_name
    if module_path.len() > 0:
        full_name = ir_import_impl_method_name(module_path, impl_type, method_name)
    key := ir_impl_method_key(impl_type, method_name)
    ret_type := ir_extract_return_type(method_idx)
    ir_impl_methods.insert(key, full_name)
    ir_func_returns.insert(key, ret_type)
    ir_func_returns.insert(full_name, ret_type)

fn ir_emit_default_return():
    dr := ir_reg()
    ir_emit("iconst " + dr.to_string() + " 0")
    ir_emit("ret " + dr.to_string())
    ir_emit("endfunc")

fn ir_prepare_func_emission(ret_type: String):
    # each function starts from a clean local register/type state but keeps
    # the seeded global type tables so lowering stays consistent.
    ir_next_reg = 0
    ir_var_regs = {}
    ir_var_types = {}
    ir_map_value_types = {}
    ir_seed_global_types()
    ir_current_func_return_kind = ret_type

fn ir_finish_func_emission(body_idx: Int):
    if body_idx >= 0:
        ir_block(body_idx)
    ir_emit_default_return()

fn ir_collect_test_decls(root_idx: Int) -> List[Int]:
    mut tests: List[Int] := []
    for item_idx in ir_root_items(root_idx):
        if get_node(item_idx).kind == "test_decl":
            tests.push(item_idx)
    return tests

fn ir_emit_test_func(idx: Int, ordinal: Int):
    body_idx := ir_find_body(idx)
    ir_prepare_func_emission("int")
    ir_emit_func_header("__test_" + ordinal.to_string(), 0, "int")
    ir_emitting_test_func = true
    ir_finish_func_emission(body_idx)
    ir_emitting_test_func = false

fn ir_emit_test_main(root_idx: Int):
    tests := ir_collect_test_decls(root_idx)
    if tests.len() == 0:
        return
    ir_prepare_func_emission("int")
    ir_emit_func_header("main", 0, "int")

    for _test_idx, i in tests:
        test_r := ir_reg()
        ir_emit_call0(test_r, "__test_" + i.to_string(), "int")

    ir_emit_default_return()

# --- emit function ---
fn ir_func(idx: Int):
    node := get_node(idx)
    full_name := node.value
    name := ir_base_decl_name(full_name)
    body_idx := ir_find_body(idx)
    param_count := ir_param_count(idx)
    ret_type := ir_lookup_func_return(full_name, name)
    ir_prepare_func_emission(ret_type)
    ir_emit_func_header(name, param_count, ret_type)
    ir_emit_fn_params(idx)
    ir_finish_func_emission(body_idx)

# --- emit impl method ---
fn ir_impl_func(idx: Int, impl_type: String):
    node := get_node(idx)
    orig_name := node.value
    full_name := impl_type + "_" + orig_name
    method_key := ir_impl_method_key(impl_type, orig_name)
    ir_impl_methods.insert(method_key, full_name)

    body_idx := ir_find_body(idx)
    param_count := ir_param_count(idx) + 1
    ret_type := ir_extract_return_type(idx)
    ir_prepare_func_emission(ret_type)
    ir_emit_func_header(full_name, param_count, ret_type)
    ir_emit_named_param("self", impl_type)
    ir_emit_fn_params(idx)
    ir_func_returns.insert(method_key, ret_type)
    ir_func_returns.insert(full_name, ret_type)
    ir_finish_func_emission(body_idx)

fn ir_register_import_alias(value: String):
    mut path := value
    mut alias := ""
    mut has_alias := false
    mut i := 0
    while i < value.len() - 3:
        if value[i] == " " and value[i + 1] == "a" and value[i + 2] == "s" and value[i + 3] == " ":
            path = value.substring(0, i)
            alias = value.substring(i + 4, value.len())
            has_alias = true
            break
        i = i + 1
    if has_alias:
        ir_module_aliases.insert(alias, path)
    else:
        ir_module_aliases.insert(ir_module_default_alias(path), path)

fn ir_collect_from_import_renames(value: String):
    parts := value.split(" ")
    if parts.len() <= 1:
        return
    mod_path := parts[0]
    for iname, i in parts:
        if i == 0:
            continue
        if iname.len() > 0:
            mut renamed := iname
            if ir_import_declares_function(mod_path, iname) or ir_import_declares_global(mod_path, iname):
                renamed = ir_import_target_name(mod_path, iname)
            ir_import_renames.insert(iname, renamed)

fn ir_type_alias_target(node: Node) -> String:
    for tc in node.children:
        tn := get_node(tc)
        if tn.kind == "type":
            return tn.value
    return ""

fn ir_collect_import_item(node: Node):
    if node.kind == "import":
        ir_register_import_alias(node.value)
    elif node.kind == "from_import":
        ir_collect_from_import_renames(node.value)

# --- collect import renames ---
fn ir_collect_imports(root_idx: Int):
    for item_idx in ir_root_items(root_idx):
        ir_collect_import_item(get_node(item_idx))

fn ir_collect_type_aliases(root_idx: Int):
    ir_type_aliases = {}
    for item_idx in ir_root_items(root_idx):
        cn := get_node(item_idx)
        if cn.kind == "type_alias":
            target := ir_type_alias_target(cn)
            if target.len() > 0:
                ir_type_aliases.insert(cn.value, target)

fn ir_register_alias_structs(root_idx: Int):
    for item_idx in ir_root_items(root_idx):
        cn := get_node(item_idx)
        if cn.kind == "type_alias":
            aname := cn.value
            if ir_type_aliases.contains_key(aname):
                target := ir_type_aliases[aname]
                if ir_struct_names.contains_key(target):
                    ir_struct_names.insert(aname, ir_struct_names[target])
                    ir_emit("struct_alias " + aname + " " + target)

fn ir_collect_function_returns(root_idx: Int):
    ir_func_returns = {}
    for item_idx in ir_root_items(root_idx):
        node := get_node(item_idx)
        if ir_is_fn_decl_kind(node.kind):
            ir_record_function_return(node)

fn ir_record_function_return(node: Node):
    for returns_idx in node.children:
        returns_node := get_node(returns_idx)
        if returns_node.kind == "returns":
            ir_record_returns_clause(node.value, returns_node)

fn ir_record_returns_clause(name: String, returns_node: Node):
    for type_idx in returns_node.children:
        type_node := get_node(type_idx)
        if type_node.kind == "type" or type_node.kind == "generic_type" or type_node.kind == "result_type":
            ir_func_returns.insert(name, ir_resolve_type_node(type_idx))

fn ir_emit_global_binding(node: Node):
    gname := ir_binding_name(node)
    mut init_val := "0"
    mut global_type := ""
    mut global_map_value_type := ""
    for gc in node.children:
        gcn := get_node(gc)
        if gcn.kind == "type" or gcn.kind == "generic_type":
            global_type = ir_resolve_type_node(gc)
            if global_map_value_type.len() == 0:
                global_map_value_type = ir_resolve_map_value_type_node(gc)
        elif gcn.kind == "int_lit":
            init_val = gcn.value
            if global_type.len() == 0:
                global_type = "int"
        elif gcn.kind == "string_lit":
            si := ir_str(gcn.value)
            init_val = "str:" + si
            if global_type.len() == 0:
                global_type = "string"
        elif gcn.kind == "list":
            init_val = "list"
            if global_type.len() == 0:
                global_type = "list"
        elif gcn.kind == "map":
            init_val = "map"
            if global_type.len() == 0:
                global_type = "map"
        elif gcn.kind == "set":
            init_val = ir_checked_type(gc)
            if init_val.len() == 0:
                init_val = ir_infer_type(gc)
            if init_val.len() == 0:
                init_val = "set"
            if global_type.len() == 0:
                global_type = init_val
        elif gcn.kind == "bool_lit":
            if gcn.value == "true":
                init_val = "1"
            else:
                init_val = "0"
            if global_type.len() == 0:
                global_type = "bool"
    if global_type.len() > 0:
        ir_record_global_type(gname, global_type)
    if global_map_value_type.len() > 0:
        ir_global_map_value_types.insert(gname, global_map_value_type)
    ir_emit("global " + gname + " " + init_val)

fn ir_emit_global_bindings(root: Node):
    for child in root.children:
        cn := ir_unwrap_pub_node(child)
        if ir_is_binding_kind(cn.kind):
            ir_emit_global_binding(cn)

fn ir_emit_collection_global_init(binding: Node):
    gname := ir_binding_name(binding)
    for gc in binding.children:
        gcn := get_node(gc)
        if gcn.kind == "list":
            list_r := ir_reg()
            ir_emit_call0(list_r, "__list_new", "list")
            ir_emit("store " + gname + " " + list_r.to_string())
        elif gcn.kind == "map":
            map_r := ir_reg()
            if ir_global_map_int_names.contains(gname):
                ir_emit_call0(map_r, "__map_new_int", "map_int")
            else:
                ir_emit_call0(map_r, "__map_new", "map")
            ir_emit("store " + gname + " " + map_r.to_string())
        elif gcn.kind == "set":
            set_r := ir_reg()
            if ir_global_set_int_names.contains(gname):
                ir_emit_call0(set_r, "__set_new_int", "set_int")
            else:
                ir_emit_call0(set_r, "__set_new", "set")
            ir_emit("store " + gname + " " + set_r.to_string())

fn ir_emit_init_globals(root: Node):
    mut has_collection_globals := false
    for child in root.children:
        cn := ir_unwrap_pub_node(child)
        if ir_is_binding_kind(cn.kind) and ir_binding_has_collection_init(cn):
            has_collection_globals = true
    if not has_collection_globals:
        return

    ir_emit_func_header("__init_globals", 0, "int")
    for child in root.children:
        cn := ir_unwrap_pub_node(child)
        if ir_is_binding_kind(cn.kind):
            ir_emit_collection_global_init(cn)
    dr := ir_reg()
    ir_emit("iconst " + dr.to_string() + " 0")
    ir_emit("ret " + dr.to_string())
    ir_emit("endfunc")

fn ir_emit_top_level_items(root_idx: Int, root: Node):
    mut test_ord := 0
    for item_idx in ir_root_items(root_idx):
        actual_node := get_node(item_idx)
        if actual_node.kind == "fn" or actual_node.kind == "fn_decl":
            if ir_has_generic_params(actual_node):
                continue
            if not (ir_emit_tests and actual_node.value == "main"):
                ir_func(item_idx)
        elif actual_node.kind == "test_decl":
            if ir_emit_tests:
                ir_emit_test_func(item_idx, test_ord)
                test_ord = test_ord + 1
        elif actual_node.kind == "impl_decl":
            impl_type := ir_impl_target_type(actual_node)
            ir_emit_impl_methods(actual_node, impl_type)
    if ir_emit_tests:
        ir_emit_test_main(root_idx)

fn ir_append_lambda_bodies():
    bodies: List[String] := ir_lambda_bodies
    mut lines: List[String] := ir_lines
    for body in bodies:
        lines.push(body)
    ir_lines = lines

fn ir_preseed_result_error_strings():
    builtin_names := "parse_int,file_open_read,file_open_write,file_open_append,byte_buffer_write,byte_buffer_write_string_utf8,byte_buffer_write_byte,file_write,file_write_bytes,tcp_connect,tcp_listen,tcp_accept,tcp_write,tcp_write_bytes,process_spawn,process_spawn_argv,process_output_argv,process_write,process_write_bytes,crypto_x25519_keygen,write_file,append_file,write_file_bytes,append_file_bytes,read_file,exec_output,dns_resolve,bytes_to_string_utf8,file_read,tcp_read,process_read,process_read_err,read_file_bytes,b64_decode,from_hex,file_read_bytes,tcp_read_bytes,process_read_bytes,process_read_err_bytes,crypto_x25519_public_key,crypto_x25519_shared_secret,crypto_aes_128_gcm_seal,crypto_aes_128_gcm_open,crypto_chacha20_poly1305_seal,crypto_chacha20_poly1305_open,crypto_sign_rsa_pss_sha256_pkcs8".split(",")
    for builtin_name in builtin_names:
        ir_str(builtin_name + " failed")

fn ir_emit_string_table():
    for value, i in ir_strings:
        sid := "m" + ir_module_count.to_string() + "s" + i.to_string()
        ir_emit("string " + sid + " " + chr(34) + value + chr(34))

fn ir_collect_root_import_metadata(root_idx: Int):
    ir_import_renames = {}
    ir_import_declared_functions = {}
    ir_import_declared_globals = {}
    for root, i in ir_preloaded_import_roots:
        ir_collect_preloaded_root_metadata(root, ir_preloaded_import_paths[i])

fn ir_collect_root_phase_one_metadata(root_idx: Int):
    ir_func_returns = {}
    ir_type_aliases = {}
    ir_generic_decl_indices = {}
    ir_generic_decl_module_paths = {}

    for root, preload_i in ir_preloaded_import_roots:
        mut module_path := ""
        if preload_i < ir_preloaded_import_paths.len():
            module_path = ir_preloaded_import_paths[preload_i]
        ir_collect_generic_function_decls_from_root(root, module_path)

    for item_idx in ir_root_items(root_idx):
        node := get_node(item_idx)
        ir_collect_import_item(node)
        if node.kind == "type_alias":
            target := ir_type_alias_target(node)
            if target.len() > 0:
                ir_type_aliases.insert(node.value, target)
        elif ir_is_fn_decl_kind(node.kind):
            ir_record_function_return(node)
            if ir_has_generic_params(node):
                ir_record_generic_function_decl(item_idx, node, "")

fn ir_collect_root_phase_two_metadata(root_idx: Int):
    ir_struct_names = {}
    ir_struct_field_lookup = {}
    ir_struct_field_index_lookup = {}
    ir_impl_methods = {}
    ir_register_known_import_structs()

    mut preload_i := 0
    while preload_i < ir_preloaded_import_roots.len():
        ir_collect_struct_decls(ir_preloaded_import_roots[preload_i], false)
        ir_collect_impl_methods(ir_preloaded_import_roots[preload_i], ir_preloaded_import_paths[preload_i])
        preload_i = preload_i + 1

    for item_idx in ir_root_items(root_idx):
        node := get_node(item_idx)
        if node.kind == "struct_decl" or node.kind == "struct":
            ir_collect_struct_decl(node, true)
        elif node.kind == "enum_decl" or node.kind == "enum":
            ir_collect_enum_decl(node, true)
        elif node.kind == "impl_decl":
            ir_collect_impl_method_signatures(node, "")

    ir_register_alias_structs(root_idx)

fn ir_emit_root_module(root_idx: Int, root: Node):
    ir_emit_global_bindings(root)
    ir_emit_init_globals(root)
    ir_emit_top_level_items(root_idx, root)
    ir_emit_generic_specializations()
    ir_append_lambda_bodies()

fn ir_finish_module_emit():
    ir_module_count = ir_module_count + 1
    ir_preloaded_import_roots = []
    ir_preloaded_import_paths = []
    ir_emit_tests = false
    ir_emitting_test_func = false

# --- main entry ---
pub fn emit_ir(root_idx: Int) -> String:
    ir_reset()

    root := get_node(root_idx)
    mut preload_i := 0
    while preload_i < ir_preloaded_import_roots.len():
        ir_collect_strings(ir_preloaded_import_roots[preload_i])
        ir_collect_struct_field_strings(ir_preloaded_import_roots[preload_i])
        preload_i = preload_i + 1
    ir_collect_strings(root_idx)
    ir_collect_struct_field_strings(root_idx)
    ir_preseed_result_error_strings()
    ir_emit_string_table()

    # collect aliases first so both type and callable metadata can resolve
    # through the same table.
    ir_collect_root_import_metadata(root_idx)
    ir_collect_root_phase_one_metadata(root_idx)
    ir_collect_root_phase_two_metadata(root_idx)

    ir_lambda_count = 0
    ir_lambda_bodies = []
    ir_emit_root_module(root_idx, root)
    lines: List[String] := ir_lines
    ir_finish_module_emit()
    return lines.join(chr(10))
