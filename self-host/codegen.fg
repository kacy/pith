# codegen.fg — C transpilation backend (self-hosted)
#
# walks the type-checked AST and emits C source code. the generated C
# is compiled by `zig cc` to produce a native binary.
#
# all globals use g_ prefix to avoid collisions with lexer/parser/checker
# globals in the flat C namespace.

from ast import Node, get_node
from types import TypeInfo, get_type_info, lookup_type_id, get_type_name, get_type_count, is_error_type, TID_INT, TID_UINT, TID_FLOAT, TID_BOOL, TID_STRING, TID_BYTES, TID_VOID, TID_INT8, TID_INT16, TID_INT32, TID_INT64, TID_UINT8, TID_UINT16, TID_UINT32, TID_UINT64, TID_ERR, TID_FIRST_USER
from checker import c_get_expr_type, c_resolve_type, method_type_map, method_visibility_map, generic_declaration_map, current_scope
from scope import lookup_binding

# ---------------------------------------------------------------
# output buffer
# ---------------------------------------------------------------

mut codegen_buffer: List[String] := []

fn emit_code(s: String):
    codegen_buffer.push(s)

# brace characters — can't use { } in forge string literals
LB := chr(123)
RB := chr(125)

# ---------------------------------------------------------------
# global state
# ---------------------------------------------------------------

mut current_indent_level := 0
mut current_function_return_type := -1
mut for_loop_counter := 0
mut try_block_counter := 0
mut lambda_counter := 0
mut spawn_counter := 0
mut push_counter := 0
mut test_mode := false
mut has_global_variables := false
mut root_node_index := -1

# mangled names for generic instantiations (TypeId -> "Pair_Int_String")
mut mangled_type_names: Map[Int, String] := {}

# dedup tracking for result/optional/tuple typedefs
mut emitted_result_types: Map[String, Bool] := {}
mut emitted_optional_types: Map[String, Bool] := {}
mut emitted_tuple_types: Map[String, Bool] := {}

# lambda tracking — parallel lists since we can't pass structs through lists
mut lambda_node_indices: List[Int] := []
mut lambda_ast_nodes: List[Int] := []
mut lambda_function_types: List[Int] := []

# captures for hoisted lambdas — per-lambda capture lists stored as flat arrays
# with a count per lambda to index into them
mut lambda_capture_names: List[String] := []   # flat list of captured var names
mut lambda_capture_type_ids: List[Int] := []       # flat list of captured var type ids
mut lambda_capture_counts: List[Int] := []     # how many captures per lambda
mut lambda_capture_offsets: List[Int] := []    # starting offset into flat lists

# lambda forward declaration buffering
mut lambda_forward_buffer: List[String] := []
mut lambda_forward_position := 0

# spawn tracking — parallel lists for hoisted spawn wrappers
mut spawn_node_indices: List[Int] := []
mut spawn_function_names: List[String] := []
mut spawn_return_types: List[Int] := []
# spawn arg types flattened (same pattern as lambda captures)
mut spawn_argument_type_ids: List[Int] := []      # flat list of all arg type IDs
mut spawn_argument_counts: List[Int] := []    # number of args per spawn
mut spawn_argument_offsets: List[Int] := []   # starting offset into spawn_argument_type_ids

# test names collected during emission
mut test_function_names: List[String] := []

# local variable types in current function
mut local_variable_types: Map[String, Int] := {}

# scope level tracking for proper cleanup
# scope_level starts at 0 (function level), increases for nested blocks
mut current_scope_level: Int := 0
mut local_variable_scopes: Map[String, Int] := {}  # variable name -> scope level

# temporary storage for capture detection (global because maps passed to
# functions are copies — mutations don't propagate back)
mut captured_identifiers: Map[String, Bool] := {}

# generic function instantiation tracking — parallel lists
# collected during pre-scan, used for forward decls + definitions
mut generic_function_instances: List[String] := []    # instantiation names like "identity[Int]"
mut generic_function_ast_nodes: List[Int] := []       # corresponding fn_decl AST node indices

# ---------------------------------------------------------------
# initialization
# ---------------------------------------------------------------

pub fn initialize_codegen():
    codegen_buffer = []
    current_indent_level = 0
    current_function_return_type = -1
    for_loop_counter = 0
    try_block_counter = 0
    lambda_counter = 0
    spawn_counter = 0
    push_counter = 0
    test_mode = false
    has_global_variables = false
    root_node_index = -1
    mangled_type_names = {}
    emitted_result_types = {}
    emitted_optional_types = {}
    emitted_tuple_types = {}
    lambda_node_indices = []
    lambda_ast_nodes = []
    lambda_function_types = []
    lambda_capture_names = []
    lambda_capture_type_ids = []
    lambda_capture_counts = []
    lambda_capture_offsets = []
    lambda_forward_buffer = []
    lambda_forward_position = 0
    spawn_node_indices = []
    spawn_function_names = []
    spawn_return_types = []
    spawn_argument_type_ids = []
    spawn_argument_counts = []
    spawn_argument_offsets = []
    test_function_names = []
    local_variable_types = {}
    current_scope_level = 0
    local_variable_scopes = {}
    captured_identifiers = {}
    generic_function_instances = []
    generic_function_ast_nodes = []

pub fn set_test_mode():
    test_mode = true

pub fn get_codegen_output() -> String:
    result := codegen_buffer.join("")
    # strip one trailing newline since print() will add one
    if result.len() > 0:
        if result[result.len() - 1] == "\n":
            return result.substring(0, result.len() - 1)
    return result


# ---------------------------------------------------------------
# output helpers
# ---------------------------------------------------------------

fn write_indent():
    mut i := 0
    while i < current_indent_level:
        emit_code("    ")
        i = i + 1

fn write_newline():
    emit_code("\n")

# ---------------------------------------------------------------
# type mapping
# ---------------------------------------------------------------

# map a forge type name to a C type string
fn map_type_name(name: String) -> String:
    if name == "Int":
        return "int64_t"
    if name == "UInt":
        return "uint64_t"
    if name == "Float":
        return "double"
    if name == "Bool":
        return "bool"
    if name == "String":
        return "forge_string_t"
    if name == "Bytes":
        return "uint8_t*"
    if name == "Void":
        return "void"
    if name == "Int8":
        return "int8_t"
    if name == "Int16":
        return "int16_t"
    if name == "Int32":
        return "int32_t"
    if name == "Int64":
        return "int64_t"
    if name == "UInt8":
        return "uint8_t"
    if name == "UInt16":
        return "uint16_t"
    if name == "UInt32":
        return "uint32_t"
    if name == "UInt64":
        return "uint64_t"
    # user-defined type — pass through as-is
    return name

# map a TypeId to a C type string (builtins only, "" for user-defined)
fn map_type_id(tid: Int) -> String:
    if tid == TID_INT:
        return "int64_t"
    if tid == TID_UINT:
        return "uint64_t"
    if tid == TID_FLOAT:
        return "double"
    if tid == TID_BOOL:
        return "bool"
    if tid == TID_STRING:
        return "forge_string_t"
    if tid == TID_BYTES:
        return "uint8_t*"
    if tid == TID_VOID:
        return "void"
    if tid == TID_INT8:
        return "int8_t"
    if tid == TID_INT16:
        return "int16_t"
    if tid == TID_INT32:
        return "int32_t"
    if tid == TID_INT64:
        return "int64_t"
    if tid == TID_UINT8:
        return "uint8_t"
    if tid == TID_UINT16:
        return "uint16_t"
    if tid == TID_UINT32:
        return "uint32_t"
    if tid == TID_UINT64:
        return "uint64_t"
    if tid == TID_ERR:
        return "/* error */"
    return ""

# check if a type needs reference counting (strings, lists, maps)
fn type_needs_reference_counting(tid: Int) -> Bool:
    if tid == TID_STRING:
        return true
    # check for List[String], Map[String, _], Map[_, String], etc.
    if tid >= 0:
        if tid < tt_count():
            info := tt_get(tid)
            if info.kind == "list":
                return type_needs_reference_counting(info.inner)
            if info.kind == "map":
                return type_needs_reference_counting(info.key_type) or type_needs_reference_counting(info.value_type)
            if info.kind == "set":
                return type_needs_reference_counting(info.inner)
    return false

# emit retain call for a variable
fn emit_retain_call(name: String, tid: Int):
    if tid == TID_STRING:
        write_indent()
        emit_code("forge_string_retain(")
        emit_code(name)
        emit_code(");\n")

# emit release call for a variable  
fn emit_release_call(name: String, tid: Int):
    if tid == TID_STRING:
        write_indent()
        emit_code("forge_string_release(")
        emit_code(name)
        emit_code(");\n")

# emit cleanup for local variables at a specific scope level that need RC
fn emit_scope_cleanup_at_level(level: Int):
    for name in local_variable_types.keys():
        if local_variable_scopes.contains_key(name):
            if local_variable_scopes[name] == level:
                tid := local_variable_types[name]
                if type_needs_reference_counting(tid):
                    emit_release_call(name, tid)

# emit cleanup for local variables at current scope level that need RC
fn emit_scope_cleanup():
    emit_scope_cleanup_at_level(current_scope_level)

# emit cleanup for all scope levels from current down to 0 (for returns)
fn emit_full_scope_cleanup():
    mut level := current_scope_level
    while level >= 0:
        emit_scope_cleanup_at_level(level)
        level = level - 1

# master type resolution: TypeId -> C type string
fn get_c_type_string(tid: Int) -> String:
    # builtins have a direct mapping
    builtin := map_type_id(tid)
    if builtin.len() > 0:
        return builtin
    # check mangled names cache (generics, result types)
    if mangled_type_names.contains_key(tid):
        return mangled_type_names[tid]
    # user-defined — look up in the type table
    if tid >= 0:
        if tid < tt_count():
            info := tt_get(tid)
            if info.kind == "struct":
                if info.name == "Mutex":
                    return "forge_mutex_t"
                if info.name == "WaitGroup":
                    return "forge_waitgroup_t"
                if info.name == "Semaphore":
                    return "forge_semaphore_t"
                return info.name
            if info.kind == "enum":
                return info.name
            if info.kind == "task":
                return "void*"
            if info.kind == "channel":
                return "forge_channel_t*"
            if info.kind == "list":
                return "forge_list_t"
            if info.kind == "map":
                return "forge_map_t"
            if info.kind == "set":
                return "forge_set_t"
            if info.kind == "function":
                return "forge_closure_t"
            if info.kind == "result":
                ok_c := get_c_type_string(info.inner)
                return "forge_result_" + ok_c
            if info.kind == "optional":
                inner_c := get_c_type_string(info.inner)
                return "forge_optional_" + inner_c
            if info.kind == "tuple":
                mut parts := "forge_tuple"
                for elem in info.elements:
                    parts = parts + "_" + get_c_type_string(elem)
                return parts
    return "/* unknown */"

# emit a C type for a TypeId — writes to output buffer
fn emit_c_type(tid: Int):
    emit_code(get_c_type_string(tid))

# ---------------------------------------------------------------
# name mangling
# ---------------------------------------------------------------

# mangle a generic type name: "Pair[Int,String]" -> "Pair_Int_String"
fn mangle_identifier(name: String) -> String:
    mut parts: List[String] := []
    mut i := 0
    while i < name.len():
        ch := name[i]
        if ch == "[" or ch == ",":
            parts.push("_")
        elif ch != "]" and ch != " ":
            parts.push(ch)
        i = i + 1
    return parts.join("")


# ---------------------------------------------------------------
# string helpers
# ---------------------------------------------------------------

# strip surrounding double quotes from a string literal
fn strip_quotes(s: String) -> String:
    if s.len() >= 2:
        if s[0] == "\"":
            if s[s.len() - 1] == "\"":
                return s.substring(1, s.len() - 1)
    return s

# write a string with C escape handling
# forge lexer preserves escape sequences as raw chars (\n = \ + n)
# since C uses the same escapes, pass them through
fn write_escaped_string(s: String):
    mut i := 0
    while i < s.len():
        ch := s[i]
        if ch == "\\":
            if i + 1 < s.len():
                next := s[i + 1]
                if next == "n":
                    emit_code("\\n")
                    i = i + 2
                    continue
                if next == "t":
                    emit_code("\\t")
                    i = i + 2
                    continue
                if next == "r":
                    emit_code("\\r")
                    i = i + 2
                    continue
                if next == "\\":
                    emit_code("\\\\")
                    i = i + 2
                    continue
                if next == "\"":
                    emit_code("\\\"")
                    i = i + 2
                    continue
                if next == "0":
                    emit_code("\\0")
                    i = i + 2
                    continue
                if next == "'":
                    emit_code("\\'")
                    i = i + 2
                    continue
                # unrecognized escape — escape the backslash
                emit_code("\\\\")
                i = i + 1
                continue
            else:
                emit_code("\\\\")
                i = i + 1
                continue
        if ch == "\"":
            emit_code("\\\"")
            i = i + 1
            continue
        if ch == "\n":
            emit_code("\\n")
            i = i + 1
            continue
        if ch == "\r":
            emit_code("\\r")
            i = i + 1
            continue
        if ch == "\t":
            emit_code("\\t")
            i = i + 1
            continue
        emit_code(ch)
        i = i + 1

# emit a string literal as FORGE_STRING_LIT("content")
fn emit_string_lit(lit: String):
    content := strip_quotes(lit)
    emit_code("FORGE_STRING_LIT(\"")
    write_escaped_string(content)
    emit_code("\")")

# ---------------------------------------------------------------
# preamble
# ---------------------------------------------------------------

fn emit_preamble():
    emit_code("// generated by forge compiler — do not edit\n")
    emit_code("#include \"forge_runtime.h\"\n\n")

# ---------------------------------------------------------------
# type queries — thin wrappers over checker data
# ---------------------------------------------------------------

# check if a TypeId is a result type
fn is_result_type(tid: Int) -> Bool:
    if tid < 0:
        return false
    if tid == TID_ERR:
        return false
    if tid >= tt_count():
        return false
    info := tt_get(tid)
    return info.kind == "result"

# check if a TypeId is an optional type
fn is_optional_type(tid: Int) -> Bool:
    if tid < 0:
        return false
    if tid == TID_ERR:
        return false
    if tid >= tt_count():
        return false
    info := tt_get(tid)
    return info.kind == "optional"

# check if an expression has string type
fn is_string_expression(node_idx: Int) -> Bool:
    tid := c_get_expr_type(node_idx)
    return tid == TID_STRING

# look up method return type from checker's method_types map
fn lookup_method_type(type_name: String, method_name: String) -> Int:
    key := type_name + "." + method_name
    if method_type_map.contains_key(key):
        return method_type_map[key]
    return -1

# ---------------------------------------------------------------
# AST helpers
# ---------------------------------------------------------------

# extract base name from "Pair[A, B]" -> "Pair"
fn extract_base_name(name: String) -> String:
    mut i := 0
    while i < name.len():
        if name[i] == "[":
            return name.substring(0, i)
        i = i + 1
    return name

# extract field name from "name pub mut" -> "name"
fn extract_field_name(value: String) -> String:
    mut i := 0
    while i < value.len():
        if value[i] == " ":
            return value.substring(0, i)
        i = i + 1
    return value

# check if a name has generic params (contains "[")
fn is_generic_type(name: String) -> Bool:
    mut i := 0
    while i < name.len():
        if name[i] == "[":
            return true
        i = i + 1
    return false

# build generic instantiation name from base + type args
# e.g. "Pair" + [TID_INT, TID_STRING] -> "Pair[Int,String]"
fn build_instantiated_name(base: String, arg_tids: List[Int]) -> String:
    mut result := base + "["
    mut first := true
    for tid in arg_tids:
        if first == false:
            result = result + ","
        first = false
        result = result + tt_type_name(tid)
    result = result + "]"
    return result

# parse generic params from fn name like "identity[T]" -> ["T"]
# handles bounds: "show[T: Display]" -> ["T"]
fn parse_generic_parameters(fn_name: String) -> List[String]:
    mut params: List[String] := []
    mut bracket_pos := -1
    mut i := 0
    while i < fn_name.len():
        if fn_name[i] == "[":
            bracket_pos = i
            break
        i = i + 1
    if bracket_pos < 0:
        return params
    inner := fn_name.substring(bracket_pos + 1, fn_name.len() - 1)
    parts := inner.split(",")
    for part in parts:
        trimmed := part.trim()
        # handle bounds: "T: Display" -> "T"
        mut colon_pos := -1
        mut j := 0
        while j < trimmed.len():
            if trimmed[j] == ":":
                colon_pos = j
                break
            j = j + 1
        if colon_pos >= 0:
            params.push(trimmed.substring(0, colon_pos).trim())
        else:
            params.push(trimmed)
    return params

# parse type args from inst name like "identity[Int]" -> ["Int"]
fn parse_type_arguments(inst_name: String) -> List[String]:
    mut type_args: List[String] := []
    mut bracket_pos := -1
    mut i := 0
    while i < inst_name.len():
        if inst_name[i] == "[":
            bracket_pos = i
            break
        i = i + 1
    if bracket_pos < 0:
        return type_args
    inner := inst_name.substring(bracket_pos + 1, inst_name.len() - 1)
    parts := inner.split(",")
    for part in parts:
        type_args.push(part.trim())
    return type_args

# build substitution map: generic param name -> TypeId
fn build_substitution_map(fn_name: String, inst_name: String) -> Map[String, Int]:
    mut subst: Map[String, Int] := {}
    params := parse_generic_parameters(fn_name)
    type_args := parse_type_arguments(inst_name)
    mut i := 0
    while i < params.len():
        if i < type_args.len():
            tid := tt_lookup(type_args[i])
            if tid >= 0:
                subst.insert(params[i], tid)
        i = i + 1
    return subst

# resolve a type annotation node with generic substitution
fn resolve_type_with_substitution(type_node_idx: Int, subst: Map[String, Int]) -> Int:
    tnode := get_node(type_node_idx)
    if tnode.kind == "type":
        if subst.contains_key(tnode.value):
            return subst[tnode.value]
    return c_resolve_type(type_node_idx)

# resolve fn return type with generic substitution
fn resolve_function_return_with_substitution(fn_node_idx: Int, subst: Map[String, Int]) -> Int:
    fn_node := get_node(fn_node_idx)
    for child in fn_node.children:
        cn := get_node(child)
        if cn.kind == "returns":
            if cn.children.len() > 0:
                return resolve_type_with_substitution(cn.children[0], subst)
    return TID_VOID

# pre-scan AST to collect all generic function instantiations
fn collect_generic_function_instances(node_idx: Int):
    node := get_node(node_idx)
    if node.kind == "call":
        name := get_call_name(node_idx)
        if generic_declaration_map.contains_key(name):
            decl_idx := generic_declaration_map[name]
            decl_node := get_node(decl_idx)
            mut actual_idx := decl_idx
            mut dk := decl_node.kind
            if dk == "pub":
                if decl_node.children.len() > 0:
                    actual_idx = decl_node.children[0]
                    dk = get_node(actual_idx).kind
            if dk == "fn_decl":
                inst := build_instantiated_name_from_arguments(name, node_idx)
                # dedup
                mut found := false
                for existing in generic_function_instances:
                    if existing == inst:
                        found = true
                        break
                if found == false:
                    generic_function_instances.push(inst)
                    generic_function_ast_nodes.push(actual_idx)
    for child in node.children:
        collect_generic_function_instances(child)

# resolve the type of a struct field from the type table
fn resolve_field_type(struct_name: String, field_name: String) -> Int:
    tid := tt_lookup(struct_name)
    if tid < 0:
        return TID_ERR
    info := tt_get(tid)
    if info.kind != "struct":
        return TID_ERR
    mut i := 0
    for f in info.fields:
        if f == field_name:
            return info.field_types[i]
        i = i + 1
    return TID_ERR

# resolve an enum variant field type
fn resolve_enum_field_type(enum_name: String, variant_name: String, field_idx: Int) -> Int:
    # workaround: List[List[Int]] doesn't work in bootstrap codegen,
    # so we resolve variant field types from the AST directly
    # find the enum_decl node in the AST
    root := get_node(root_node_index)
    for child in root.children:
        mut node := get_node(child)
        if node.kind == "pub":
            node = get_node(node.children[0])
        if node.kind == "enum_decl":
            base := extract_base_name(node.value)
            if base == enum_name:
                for vc in node.children:
                    vn := get_node(vc)
                    if vn.kind == "variant":
                        if vn.value == variant_name:
                            if field_idx < vn.children.len():
                                return c_resolve_type(vn.children[field_idx])
                            return TID_ERR
    return TID_ERR

# resolve a type expression AST node to a C type string
fn resolve_type_expression_to_c(node_idx: Int) -> String:
    tid := c_resolve_type(node_idx)
    return get_c_type_string(tid)

# emit a type expression from an AST type node
fn emit_type_expr(node_idx: Int):
    node := get_node(node_idx)
    if node.kind == "type":
        emit_code(map_type_name(node.value))
        return
    if node.kind == "generic_type":
        base := node.value
        if base == "List":
            emit_code("forge_list_t")
            return
        if base == "Map":
            emit_code("forge_map_t")
            return
        if base == "Set":
            emit_code("forge_set_t")
            return
        if base == "Channel":
            emit_code("forge_channel_t*")
            return
        if base == "Task":
            emit_code("void*")
            return
        # user-defined generic — resolve and emit mangled name
        tid := c_resolve_type(node_idx)
        emit_code(get_c_type_string(tid))
        return
    if node.kind == "optional_type":
        tid := c_resolve_type(node_idx)
        emit_code(get_c_type_string(tid))
        return
    if node.kind == "result_type":
        tid := c_resolve_type(node_idx)
        emit_code(get_c_type_string(tid))
        return
    if node.kind == "tuple_type":
        tid := c_resolve_type(node_idx)
        emit_code(get_c_type_string(tid))
        return
    if node.kind == "fn_type":
        emit_code("forge_closure_t")
        return
    # fallback
    emit_code("/* unknown type */")

# emit return type — resolves type node or writes "void"
fn emit_return_type(node_idx: Int):
    node := get_node(node_idx)
    # look for "returns" child
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "returns":
            if cn.children.len() > 0:
                emit_type_expr(cn.children[0])
                return
    emit_code("void")

# emit closure-typed parameter: forge_closure_t name
fn emit_fn_ptr_param(type_node_idx: Int, name: String):
    emit_code("forge_closure_t ")
    emit_code(name)

# emit closure-typed binding from a TypeId: forge_closure_t name
fn emit_fn_ptr_binding(fn_tid: Int, name: String):
    emit_code("forge_closure_t ")
    emit_code(name)

# ---------------------------------------------------------------
# struct definitions
# ---------------------------------------------------------------

fn emit_struct_def(node_idx: Int):
    node := get_node(node_idx)
    name := node.value
    # skip generic (uninstantiated) structs
    if is_generic_type(name):
        return
    base := extract_base_name(name)
    emit_code("typedef struct " + LB + "\n")
    current_indent_level = current_indent_level + 1
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "field":
            fname := extract_field_name(cn.value)
            write_indent()
            ftid := resolve_field_type(base, fname)
            emit_c_type(ftid)
            emit_code(" ")
            emit_code(fname)
            emit_code(";\n")
    current_indent_level = current_indent_level - 1
    emit_code(RB + " ")
    emit_code(base)
    emit_code(";\n\n")

# ---------------------------------------------------------------
# instantiated generic struct definitions
# ---------------------------------------------------------------

fn emit_instantiated_structs(root_idx: Int):
    root := get_node(root_idx)
    # find all generic struct base names
    for child in root.children:
        mut node := get_node(child)
        mut decl_idx := child
        if node.kind == "pub":
            decl_idx = node.children[0]
            node = get_node(decl_idx)
        if node.kind == "struct_decl":
            name := node.value
            if is_generic_type(name) == false:
                continue
            base := extract_base_name(name)
            # scan type table for instantiations of this struct
            emit_struct_instantiations(base)

fn emit_struct_instantiations(base: String):
    # scan the entire type table for struct types whose names start with "base["
    prefix := base + "["
    mut tid := TID_FIRST_USER
    while tid < tt_count():
        info := tt_get(tid)
        if info.kind == "struct":
            if info.name.starts_with(prefix):
                # this is an instantiation — emit typedef
                mangled := mangle_identifier(info.name)
                mangled_type_names.insert(tid, mangled)
                emit_code("typedef struct " + LB + "\n")
                current_indent_level = current_indent_level + 1
                mut fi := 0
                for f in info.fields:
                    write_indent()
                    emit_code(get_c_type_string(info.field_types[fi]))
                    emit_code(" ")
                    emit_code(f)
                    emit_code(";\n")
                    fi = fi + 1
                current_indent_level = current_indent_level - 1
                emit_code(RB + " ")
                emit_code(mangled)
                emit_code(";\n\n")
        tid = tid + 1

# ---------------------------------------------------------------
# type alias typedefs
# ---------------------------------------------------------------

fn emit_type_alias(node_idx: Int):
    node := get_node(node_idx)
    name := node.value
    if node.children.len() > 0:
        target_tid := c_resolve_type(node.children[0])
        if target_tid >= 0:
            emit_code("typedef ")
            emit_c_type(target_tid)
            emit_code(" ")
            emit_code(name)
            emit_code(";\n")

# ---------------------------------------------------------------
# enum definitions
# ---------------------------------------------------------------

fn emit_enum_def(node_idx: Int):
    node := get_node(node_idx)
    name := node.value
    # skip generic enums
    if is_generic_type(name):
        return
    base := extract_base_name(name)

    # tag enum
    emit_code("typedef enum " + LB + "\n")
    current_indent_level = current_indent_level + 1
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "variant":
            write_indent()
            emit_code(base)
            emit_code("_TAG_")
            emit_code(cn.value)
            emit_code(",\n")
    current_indent_level = current_indent_level - 1
    emit_code(RB + " ")
    emit_code(base)
    emit_code("_Tag;\n\n")

    # tagged union struct
    emit_code("typedef struct " + LB + "\n")
    current_indent_level = current_indent_level + 1
    write_indent()
    emit_code(base)
    emit_code("_Tag tag;\n")

    # check if any variant has data
    mut has_data := false
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "variant":
            if cn.children.len() > 0:
                has_data = true

    if has_data:
        write_indent()
        emit_code("union " + LB + "\n")
        current_indent_level = current_indent_level + 1
        for child in node.children:
            cn := get_node(child)
            if cn.kind == "variant":
                if cn.children.len() > 0:
                    write_indent()
                    emit_code("struct " + LB + "\n")
                    current_indent_level = current_indent_level + 1
                    mut fi := 0
                    for vc in cn.children:
                        write_indent()
                        ftid := resolve_enum_field_type(base, cn.value, fi)
                        emit_c_type(ftid)
                        emit_code(" _")
                        emit_code(fi.to_string())
                        emit_code(";\n")
                        fi = fi + 1
                    current_indent_level = current_indent_level - 1
                    write_indent()
                    emit_code(RB + " ")
                    emit_code(cn.value)
                    emit_code(";\n")
        current_indent_level = current_indent_level - 1
        write_indent()
        emit_code(RB + " data;\n")

    current_indent_level = current_indent_level - 1
    emit_code(RB + " ")
    emit_code(base)
    emit_code(";\n\n")

# ---------------------------------------------------------------
# result/optional/tuple typedefs
# ---------------------------------------------------------------

fn emit_wrapper_typedefs(kind: String, prefix: String, dedup: Map[String, Bool]):
    # shared emitter for result and optional typedefs — both iterate all
    # type IDs, build a name from the inner type, dedup, and emit a typedef.
    # the only difference is the struct body.
    mut tid := 0
    while tid < tt_count():
        info := tt_get(tid)
        if info.kind == kind:
            inner_c := get_c_type_string(info.inner)
            name := prefix + inner_c
            if dedup.contains_key(name):
                if mangled_type_names.contains_key(tid) == false:
                    mangled_type_names.insert(tid, name)
            else:
                mangled_type_names.insert(tid, name)
                dedup.insert(name, true)
                emit_code("typedef struct " + LB + " ")
                if kind == "result":
                    emit_code("bool is_ok; " + inner_c + " ok; forge_string_t err; ")
                else:
                    emit_code("bool has_value; " + inner_c + " value; ")
                emit_code(RB + " " + name + ";\n")
        tid = tid + 1
    emit_code("\n")

fn emit_tuple_typedefs():
    mut tid := 0
    while tid < tt_count():
        info := tt_get(tid)
        if info.kind == "tuple":
            # build name from element types
            mut name := "forge_tuple"
            for elem in info.elements:
                name = name + "_" + get_c_type_string(elem)
            if emitted_tuple_types.contains_key(name):
                if mangled_type_names.contains_key(tid) == false:
                    mangled_type_names.insert(tid, name)
            else:
                mangled_type_names.insert(tid, name)
                emitted_tuple_types.insert(name, true)
                emit_code("typedef struct " + LB + " ")
                mut ei := 0
                for elem in info.elements:
                    emit_code(get_c_type_string(elem))
                    emit_code(" _")
                    emit_code(ei.to_string())
                    emit_code("; ")
                    ei = ei + 1
                emit_code(RB + " ")
                emit_code(name)
                emit_code(";\n")
        tid = tid + 1
    emit_code("\n")

# ---------------------------------------------------------------
# builtin helper functions
# ---------------------------------------------------------------

fn emit_result_helper(name: String, ret_c: String, impl_call: String, params: String, err_msg: String):
    # emit a result-wrapping helper: call _impl, wrap success in forge_result_X.
    # the impl_call string should reference &__v for the output parameter.
    result_c := "forge_result_" + ret_c
    emit_code("static " + result_c + " forge_" + name + "(" + params + ") " + LB + "\n")
    emit_code("    " + ret_c + " __v;\n")
    emit_code("    if (" + impl_call + ") " + LB + "\n")
    emit_code("        " + result_c + " r; r.is_ok = true; r.ok = __v; return r;\n")
    emit_code("    " + RB + "\n")
    emit_code("    " + result_c + " r; r.is_ok = false;\n")
    emit_code("    r.err = FORGE_STRING_LIT(\"" + err_msg + "\"); return r;\n")
    emit_code(RB + "\n")

fn emit_optional_helper(name: String, ret_c: String, impl_call: String, params: String):
    # emit an optional-wrapping helper: call _impl, wrap in forge_optional_X.
    opt_c := "forge_optional_" + ret_c
    emit_code("static " + opt_c + " forge_" + name + "(" + params + ") " + LB + "\n")
    emit_code("    " + ret_c + " __v;\n")
    emit_code("    if (" + impl_call + ") " + LB + "\n")
    emit_code("        " + opt_c + " r; r.has_value = true; r.value = __v; return r;\n")
    emit_code("    " + RB + "\n")
    emit_code("    " + opt_c + " r; r.has_value = false; return r;\n")
    emit_code(RB + "\n")

fn emit_builtin_helpers():
    # parse_int and parse_float are unique (libc strtoll/strtod with buffer setup)
    emit_code("static forge_result_int64_t forge_parse_int(forge_string_t s) " + LB + "\n")
    emit_code("    char buf[64];\n")
    emit_code("    int64_t slen = s.len < 63 ? s.len : 63;\n")
    emit_code("    memcpy(buf, s.data, (size_t)slen);\n")
    emit_code("    buf[slen] = '\\0';\n")
    emit_code("    char *end;\n")
    emit_code("    int64_t val = strtoll(buf, &end, 10);\n")
    emit_code("    if (end == buf || *end != '\\0') " + LB + "\n")
    emit_code("        forge_result_int64_t r; r.is_ok = false;\n")
    emit_code("        r.err = FORGE_STRING_LIT(\"invalid integer\");\n")
    emit_code("        return r;\n")
    emit_code("    " + RB + "\n")
    emit_code("    forge_result_int64_t r; r.is_ok = true; r.ok = val;\n")
    emit_code("    return r;\n")
    emit_code(RB + "\n")

    emit_code("static forge_result_double forge_parse_float(forge_string_t s) " + LB + "\n")
    emit_code("    char buf[128];\n")
    emit_code("    int64_t slen = s.len < 127 ? s.len : 127;\n")
    emit_code("    memcpy(buf, s.data, (size_t)slen);\n")
    emit_code("    buf[slen] = '\\0';\n")
    emit_code("    char *end;\n")
    emit_code("    double val = strtod(buf, &end);\n")
    emit_code("    if (end == buf || *end != '\\0') " + LB + "\n")
    emit_code("        forge_result_double r; r.is_ok = false;\n")
    emit_code("        r.err = FORGE_STRING_LIT(\"invalid float\");\n")
    emit_code("        return r;\n")
    emit_code("    " + RB + "\n")
    emit_code("    forge_result_double r; r.is_ok = true; r.ok = val;\n")
    emit_code("    return r;\n")
    emit_code(RB + "\n")

    # write_file is unique — no output value, just success/fail -> Bool!
    emit_code("static forge_result_bool forge_write_file(forge_string_t path, forge_string_t data) " + LB + "\n")
    emit_code("    if (forge_write_file_impl(path.data, path.len, data.data, data.len)) " + LB + "\n")
    emit_code("        forge_result_bool r; r.is_ok = true; r.ok = true; return r;\n")
    emit_code("    " + RB + "\n")
    emit_code("    forge_result_bool r; r.is_ok = false;\n")
    emit_code("    r.err = FORGE_STRING_LIT(\"failed to write file\"); return r;\n")
    emit_code(RB + "\n")

    # append_file — same pattern as write_file (no output value, just success/fail)
    emit_code("static forge_result_bool forge_append_file(forge_string_t path, forge_string_t data) " + LB + "\n")
    emit_code("    if (forge_append_file_impl(path.data, path.len, data.data, data.len)) " + LB + "\n")
    emit_code("        forge_result_bool r; r.is_ok = true; r.ok = true; return r;\n")
    emit_code("    " + RB + "\n")
    emit_code("    forge_result_bool r; r.is_ok = false;\n")
    emit_code("    r.err = FORGE_STRING_LIT(\"failed to append to file\"); return r;\n")
    emit_code(RB + "\n")

    # result wrappers — all follow the same template: call _impl, wrap in result
    emit_result_helper("read_file", "forge_string_t", "forge_read_file_impl(path.data, path.len, &__v)", "forge_string_t path", "failed to read file")
    emit_result_helper("exec_output", "forge_string_t", "forge_exec_output_impl(cmd, &__v)", "forge_string_t cmd", "failed to execute command")
    emit_result_helper("tcp_connect", "int64_t", "forge_tcp_connect_impl(host, port, &__v)", "forge_string_t host, int64_t port", "failed to connect")
    emit_result_helper("tcp_listen", "int64_t", "forge_tcp_listen_impl(host, port, &__v)", "forge_string_t host, int64_t port", "failed to listen")
    emit_result_helper("tcp_accept", "int64_t", "forge_tcp_accept_impl(server_fd, &__v)", "int64_t server_fd", "failed to accept")
    emit_result_helper("tcp_read", "forge_string_t", "forge_tcp_read_impl(fd, max_bytes, &__v)", "int64_t fd, int64_t max_bytes", "failed to read")
    emit_result_helper("tcp_write", "int64_t", "forge_tcp_write_impl(fd, data, &__v)", "int64_t fd, forge_string_t data", "failed to write")
    emit_result_helper("dns_resolve", "forge_string_t", "forge_dns_resolve_impl(hostname, &__v)", "forge_string_t hostname", "failed to resolve hostname")
    emit_result_helper("process_spawn", "int64_t", "forge_process_spawn_impl(cmd, &__v)", "forge_string_t cmd", "failed to spawn process")
    emit_result_helper("process_write", "int64_t", "forge_process_write_impl(handle, data, &__v)", "int64_t handle, forge_string_t data", "failed to write to process")
    emit_result_helper("process_read", "forge_string_t", "forge_process_read_impl(handle, max_bytes, &__v)", "int64_t handle, int64_t max_bytes", "failed to read from process")
    emit_result_helper("process_read_err", "forge_string_t", "forge_process_read_err_impl(handle, max_bytes, &__v)", "int64_t handle, int64_t max_bytes", "failed to read stderr from process")

    # optional wrapper
    emit_optional_helper("env", "forge_string_t", "forge_env_impl(name.data, name.len, &__v)", "forge_string_t name")

# ---------------------------------------------------------------
# function forward declarations
# ---------------------------------------------------------------

fn emit_fn_forward_decl(node_idx: Int, skip_main: Bool):
    node := get_node(node_idx)
    name := node.value
    # skip generic functions
    if is_generic_type(name):
        return
    # main is special
    if name == "main":
        if test_mode:
            return
        if skip_main:
            return
        emit_code("int main(int __argc, char **__argv);\n")
        return
    emit_return_type(node_idx)
    emit_code(" fg_")
    emit_code(name)
    emit_param_list(node_idx)
    emit_code(";\n")

fn emit_param_list(node_idx: Int):
    node := get_node(node_idx)
    emit_code("(")
    mut has_params := false
    mut first := true
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "param":
            has_params = true
            if first == false:
                emit_code(", ")
            first = false
            if cn.children.len() > 0:
                type_node := get_node(cn.children[0])
                if type_node.kind == "fn_type":
                    emit_fn_ptr_param(cn.children[0], cn.value)
                else:
                    emit_type_expr(cn.children[0])
                    emit_code(" ")
                    emit_code(cn.value)
            else:
                emit_code("/* unknown */ ")
                emit_code(cn.value)
    if has_params == false:
        emit_code("void")
    emit_code(")")

# ---------------------------------------------------------------
# impl block forward declarations
# ---------------------------------------------------------------

# extract concrete type name from impl block AST
fn get_implementation_type_name(node_idx: Int) -> String:
    node := get_node(node_idx)
    # node.children[0] is the type being impl'd
    # if node.children[1].kind == "for_type", it's "impl Interface for Type:"
    if node.children.len() < 1:
        return ""
    first_type := get_node(node.children[0])
    if node.children.len() > 1:
        second := get_node(node.children[1])
        if second.kind == "for_type":
            # impl Interface for Type: → concrete is the for_type's child
            if second.children.len() > 0:
                for_inner := get_node(second.children[0])
                if for_inner.kind == "type":
                    return for_inner.value
            return ""
    # impl Type: → concrete is the first type
    if first_type.kind == "type":
        return first_type.value
    return ""

# count how many children to skip before methods (1 for type, +1 for for_type)
fn get_implementation_method_start(node_idx: Int) -> Int:
    node := get_node(node_idx)
    if node.children.len() > 1:
        second := get_node(node.children[1])
        if second.kind == "for_type":
            return 2
    return 1

fn emit_impl_forward_decls(node_idx: Int):
    type_name := get_implementation_type_name(node_idx)
    if type_name == "":
        return
    node := get_node(node_idx)
    method_start := get_implementation_method_start(node_idx)
    mut skip := method_start
    for child in node.children:
        if skip > 0:
            skip = skip - 1
            continue
        mut cn := get_node(child)
        mut method_idx := child
        if cn.kind == "pub":
            method_idx = cn.children[0]
            cn = get_node(method_idx)
        if cn.kind == "fn_decl":
            emit_method_forward_decl(type_name, method_idx)

fn emit_method_forward_decl(type_name: String, node_idx: Int):
    node := get_node(node_idx)
    if is_generic_type(node.value):
        return
    emit_return_type(node_idx)
    emit_code(" ")
    emit_code(type_name)
    emit_code("_")
    emit_code(node.value)
    # emit params with self as first parameter
    emit_code("(")
    emit_code(type_name)
    emit_code(" self")
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "param":
            emit_code(", ")
            if cn.children.len() > 0:
                type_node := get_node(cn.children[0])
                if type_node.kind == "fn_type":
                    emit_fn_ptr_param(cn.children[0], cn.value)
                else:
                    emit_type_expr(cn.children[0])
                    emit_code(" ")
                    emit_code(cn.value)
            else:
                emit_code("/* unknown */ ")
                emit_code(cn.value)
    emit_code(");\n")

# ---------------------------------------------------------------
# instantiated generic function forward declarations
# ---------------------------------------------------------------

fn emit_instantiated_fn_forward_decls():
    # emit forward declarations for all collected generic function instances
    mut i := 0
    while i < generic_function_instances.len():
        inst_name := generic_function_instances[i]
        fn_node_idx := generic_function_ast_nodes[i]
        fn_node := get_node(fn_node_idx)
        subst := build_substitution_map(fn_node.value, inst_name)
        mangled := mangle_identifier(inst_name)
        # emit return type
        ret_tid := resolve_function_return_with_substitution(fn_node_idx, subst)
        emit_code(get_c_type_string(ret_tid))
        emit_code(" fg_")
        emit_code(mangled)
        emit_code("(")
        mut first := true
        mut has_params := false
        for child in fn_node.children:
            cn := get_node(child)
            if cn.kind == "param":
                has_params = true
                if first == false:
                    emit_code(", ")
                first = false
                if cn.children.len() > 0:
                    ptid := resolve_type_with_substitution(cn.children[0], subst)
                    emit_code(get_c_type_string(ptid))
                emit_code(" ")
                emit_code(cn.value)
        if has_params == false:
            emit_code("void")
        emit_code(");\n")
        i = i + 1

# ---------------------------------------------------------------
# block and statements
# ---------------------------------------------------------------

fn emit_block(node_idx: Int):
    node := get_node(node_idx)
    # Enter new scope level for this block
    current_scope_level = current_scope_level + 1
    # Track which variables are created in this scope
    mut vars_in_scope: List[String] := []
    for child in node.children:
        # Track bindings created in this scope
        child_node := get_node(child)
        if child_node.kind == "binding":
            name := extract_binding_name(child_node.value)
            vars_in_scope.push(name)
        emit_stmt(child)
    # Exit scope - cleanup variables at this level
    emit_scope_cleanup()
    # Remove variables from tracking
    for name in vars_in_scope:
        if local_variable_types.contains_key(name):
            local_variable_types.remove(name)
        if local_variable_scopes.contains_key(name):
            local_variable_scopes.remove(name)
    current_scope_level = current_scope_level - 1

fn emit_stmt(node_idx: Int):
    node := get_node(node_idx)
    if node.kind == "binding":
        emit_binding(node_idx)
        return
    if node.kind == "assignment":
        emit_assignment(node_idx)
        return
    if node.kind == "if_stmt":
        emit_if_stmt(node_idx)
        return
    if node.kind == "while_stmt":
        emit_while_stmt(node_idx)
        return
    if node.kind == "for_stmt":
        emit_for_stmt(node_idx)
        return
    if node.kind == "return":
        emit_return_stmt(node_idx)
        return
    if node.kind == "break":
        write_indent()
        emit_code("break;\n")
        return
    if node.kind == "continue":
        write_indent()
        emit_code("continue;\n")
        return
    if node.kind == "match_expr":
        emit_match_stmt(node_idx)
        return
    if node.kind == "fail":
        emit_fail_stmt(node_idx)
        return
    # try expression as statement
    if node.kind == "try":
        emit_try_expr_stmt(node_idx)
        return
    # fallback — try to emit as expression
    write_indent()
    emit_expr(node_idx)
    emit_code(";\n")

# fallback type inference for bindings when the checker cache misses.
# mirrors the bootstrap compiler's inferExprType — resolves types from
# the AST structure without relying on c_expr_cache.
fn infer_expression_type(node_idx: Int) -> Int:
    node := get_node(node_idx)
    if node.kind == "int_lit":
        return TID_INT
    if node.kind == "float_lit":
        return TID_FLOAT
    if node.kind == "string_lit":
        return TID_STRING
    if node.kind == "string_interp":
        return TID_STRING
    if node.kind == "bool_lit":
        return TID_BOOL
    if node.kind == "ident":
        # check local variables first, then module scope
        if local_variable_types.contains_key(node.value):
            return local_variable_types[node.value]
        return lookup_binding(current_scope, node.value)
    if node.kind == "call":
        # look up function return type from callee
        if node.children.len() > 0:
            callee := get_node(node.children[0])
            if callee.kind == "ident":
                fn_tid := lookup_binding(current_scope, callee.value)
                if fn_tid >= 0:
                    if fn_tid < tt_count():
                        info := tt_get(fn_tid)
                        if info.kind == "function":
                            return info.return_type
                        if info.kind == "struct":
                            return fn_tid
                # struct constructor from type table
                struct_tid := tt_lookup(callee.value)
                if struct_tid >= 0:
                    return struct_tid
        return TID_ERR
    if node.kind == "method_call":
        # infer receiver type, then look up method return type
        if node.children.len() == 0:
            return TID_ERR
        receiver_idx := node.children[0]
        mut receiver_tid := c_get_expr_type(receiver_idx)
        if receiver_tid == TID_ERR:
            receiver_tid = infer_expression_type(receiver_idx)
        if receiver_tid == TID_ERR:
            return TID_ERR
        # string methods
        if receiver_tid == TID_STRING:
            return infer_string_method_type(node.value)
        if receiver_tid == TID_INT:
            return TID_STRING
        if receiver_tid == TID_FLOAT:
            return TID_STRING
        if receiver_tid == TID_BOOL:
            return TID_STRING
        # user-defined and collection methods
        type_name := tt_type_name(receiver_tid)
        key := type_name + "." + node.value
        if method_type_map.contains_key(key):
            fn_tid := method_type_map[key]
            info := tt_get(fn_tid)
            if info.kind == "function":
                return info.return_type
        return TID_ERR
    if node.kind == "field_access":
        if node.children.len() == 0:
            return TID_ERR
        mut obj_tid := c_get_expr_type(node.children[0])
        if obj_tid == TID_ERR:
            obj_tid = infer_expression_type(node.children[0])
        if obj_tid >= 0:
            if obj_tid < tt_count():
                info := tt_get(obj_tid)
                if info.kind == "struct":
                    mut fi := 0
                    while fi < info.fields.len():
                        if info.fields[fi] == node.value:
                            return info.field_types[fi]
                        fi = fi + 1
        return TID_ERR
    return TID_ERR

fn infer_string_method_type(method: String) -> Int:
    if method == "len":
        return TID_INT
    if method == "to_int":
        return TID_INT
    if method == "to_float":
        return TID_FLOAT
    if method == "contains":
        return TID_BOOL
    if method == "starts_with":
        return TID_BOOL
    if method == "ends_with":
        return TID_BOOL
    # most string methods return String
    return TID_STRING

fn emit_binding(node_idx: Int):
    node := get_node(node_idx)
    name := extract_binding_name(node.value)
    is_mut := node.value.contains(" mut")
    # determine the type
    mut tid := TID_ERR
    mut has_type_expr := false
    mut type_expr_idx := -1
    mut value_idx := -1
    # children: [type_expr?, value_expr]
    # if there's a type annotation, first child is the type, second is the value
    # if no type annotation, only child is the value
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "type":
            has_type_expr = true
            type_expr_idx = child
            tid = c_resolve_type(child)
        elif cn.kind == "generic_type":
            has_type_expr = true
            type_expr_idx = child
            tid = c_resolve_type(child)
        elif cn.kind == "optional_type":
            has_type_expr = true
            type_expr_idx = child
            tid = c_resolve_type(child)
        elif cn.kind == "result_type":
            has_type_expr = true
            type_expr_idx = child
            tid = c_resolve_type(child)
        elif cn.kind == "tuple_type":
            has_type_expr = true
            type_expr_idx = child
            tid = c_resolve_type(child)
        elif cn.kind == "fn_type":
            has_type_expr = true
            type_expr_idx = child
            tid = c_resolve_type(child)
        else:
            value_idx = child

    if value_idx < 0:
        return
    if tid == TID_ERR:
        if has_type_expr == false:
            tid = c_get_expr_type(value_idx)
    # for lambda values, c_get_expr_type may return TID_ERR because it
    # doesn't temporarily register params — fall back to find_lambda_function_type
    if tid == TID_ERR:
        val_node := get_node(value_idx)
        if val_node.kind == "lambda":
            tid = find_lambda_function_type(value_idx)
    # general fallback: infer type from AST structure (method calls, etc.)
    if tid == TID_ERR:
        tid = infer_expression_type(value_idx)
    local_variable_types.insert(name, tid)
    local_variable_scopes.insert(name, current_scope_level)

    # try propagation: x := foo()! → hoist result to temp
    inner_node := get_node(value_idx)
    if inner_node.kind == "try":
        emit_try_binding(node_idx, name, tid, value_idx)
        return

    # function pointer bindings need special C syntax
    if has_type_expr:
        type_node := get_node(type_expr_idx)
        if type_node.kind == "fn_type":
            write_indent()
            emit_fn_ptr_param(type_expr_idx, name)
            emit_code(" = ")
            emit_expr(value_idx)
            emit_code(";\n")
            return
    elif tid != TID_ERR:
        if tid >= 0:
            if tid < tt_count():
                info := tt_get(tid)
                if info.kind == "function":
                    write_indent()
                    emit_fn_ptr_binding(tid, name)
                    emit_code(" = ")
                    emit_expr(value_idx)
                    emit_code(";\n")
                    return

    write_indent()
    if has_type_expr:
        emit_type_expr(type_expr_idx)
    elif tid != TID_ERR:
        emit_c_type(tid)
    else:
        emit_code("/* unknown */")
    emit_code(" ")
    emit_code(name)
    # Only emit " = " and value if there's an actual initialization expression
    if value_idx >= 0:
        val_node := get_node(value_idx)
        if val_node.kind != "none":
            emit_code(" = ")
            emit_expr(value_idx)
    emit_code(";\n")
    # ARC: retain the value for heap-allocated types
    if value_idx >= 0:
        val_node := get_node(value_idx)
        if val_node.kind != "none":
            if type_needs_reference_counting(tid):
                emit_retain_call(name, tid)
            # For list literals with string elements, retain all elements
            if val_node.kind == "list" and val_node.children.len() > 0:
                elem_tid := c_get_expr_type(val_node.children[0])
                if elem_tid == TID_STRING:
                    write_indent()
                    emit_code("forge_list_retain_all_strings(")
                    emit_code(name)
                    emit_code(");\n")

# extract binding name from "x" or "x mut"
fn extract_binding_name(value: String) -> String:
    mut i := 0
    while i < value.len():
        if value[i] == " ":
            return value.substring(0, i)
        i = i + 1
    return value

fn is_move_eligible(value_idx: Int) -> Bool:
    # Check if value is a variable in the same scope (eligible for move optimization)
    value_node := get_node(value_idx)
    if value_node.kind != "ident":
        return false
    var_name := value_node.value
    if not local_variable_scopes.contains_key(var_name):
        return false
    # Eligible if in same scope (source will be released when scope exits)
    return local_variable_scopes[var_name] == current_scope_level

fn emit_assignment(node_idx: Int):
    node := get_node(node_idx)
    # children: [target, value]
    # node.value is the operator: "=", "+=", "-=", "*=", "/="
    # ARC: handle simple variable assignments
    target_idx := node.children[0]
    target_node := get_node(target_idx)
    is_simple_var := target_node.kind == "ident"
    mut target_name := ""
    mut target_tid := TID_ERR
    mut needs_rc := false
    if is_simple_var:
        target_name = target_node.value
        if local_variable_types.contains_key(target_name):
            target_tid = local_variable_types[target_name]
            needs_rc = type_needs_reference_counting(target_tid)
    # Check if this is a move (source variable in same scope)
    value_idx := node.children[1]
    is_move := node.value == "=" and needs_rc and is_move_eligible(value_idx)
    # ARC: release old value before simple assignment (=) for RC types
    if is_simple_var and node.value == "=" and needs_rc:
        emit_release_call(target_name, target_tid)
    write_indent()
    emit_expr(target_idx)
    if node.value == "=":
        emit_code(" = ")
    elif node.value == "+=":
        emit_code(" += ")
    elif node.value == "-=":
        emit_code(" -= ")
    elif node.value == "*=":
        emit_code(" *= ")
    elif node.value == "/=":
        emit_code(" /= ")
    else:
        emit_code(" = ")
    emit_expr(value_idx)
    emit_code(";\n")
    # ARC: retain new value after simple assignment (=) for RC types
    # Skip retain if this is a move (ownership transferred from source)
    if is_simple_var and node.value == "=" and needs_rc and not is_move:
        emit_retain_call(target_name, target_tid)

fn emit_if_stmt(node_idx: Int):
    node := get_node(node_idx)
    # children: [condition, then_node, elif*, else?]
    write_indent()
    emit_code("if (")
    emit_expr(node.children[0])
    emit_code(") " + LB + "\n")
    current_indent_level = current_indent_level + 1
    # then_node wraps the block as its child
    then_node := get_node(node.children[1])
    if then_node.children.len() > 0:
        emit_block(then_node.children[0])
    current_indent_level = current_indent_level - 1
    # process remaining children as elif/else
    mut i := 2
    while i < node.children.len():
        emit_if_branch(node.children[i])
        i = i + 1
    write_indent()
    emit_code(RB + "\n")

fn emit_if_branch(node_idx: Int):
    cn := get_node(node_idx)
    if cn.kind == "elif":
        write_indent()
        emit_code(RB + " else if (")
        emit_expr(cn.children[0])
        emit_code(") " + LB + "\n")
        current_indent_level = current_indent_level + 1
        emit_block(cn.children[1])
        current_indent_level = current_indent_level - 1
        return
    if cn.kind == "else":
        write_indent()
        emit_code(RB + " else " + LB + "\n")
        current_indent_level = current_indent_level + 1
        emit_block(cn.children[0])
        current_indent_level = current_indent_level - 1

fn emit_while_stmt(node_idx: Int):
    node := get_node(node_idx)
    # children: [condition, body]
    write_indent()
    emit_code("while (")
    emit_expr(node.children[0])
    emit_code(") " + LB + "\n")
    current_indent_level = current_indent_level + 1
    emit_block(node.children[1])
    current_indent_level = current_indent_level - 1
    write_indent()
    emit_code(RB + "\n")

fn emit_for_loop_body(node: Node, idx_name: String, elem_name: String, comma_pos: Int, elem_c: String, elem_tid: Int, iter_kind: String):
    # shared loop structure for list, map, set, and string iteration.
    write_indent()
    emit_code("for (int64_t " + idx_name + " = 0; " + idx_name + " < ")
    if iter_kind == "map":
        emit_code("forge_map_len(")
        emit_expr(node.children[0])
        emit_code(")")
    elif iter_kind == "string":
        emit_expr(node.children[0])
        emit_code(".len")
    else:
        emit_code("forge_list_len(")
        emit_expr(node.children[0])
        emit_code(")")
    emit_code("; " + idx_name + "++) " + LB + "\n")
    current_indent_level = current_indent_level + 1
    write_indent()
    emit_code(elem_c + " " + elem_name + " = ")
    if iter_kind == "map":
        emit_code("FORGE_MAP_KEY_AT(")
        emit_expr(node.children[0])
        emit_code(", " + elem_c + ", " + idx_name + ");\n")
    elif iter_kind == "string":
        emit_code("forge_string_char_at(")
        emit_expr(node.children[0])
        emit_code(", " + idx_name + ");\n")
    else:
        emit_code("FORGE_LIST_GET(")
        emit_expr(node.children[0])
        emit_code(", " + elem_c + ", " + idx_name + ");\n")
    local_variable_types.insert(elem_name, elem_tid)
    if comma_pos >= 0:
        local_variable_types.insert(idx_name, TID_INT)
    emit_block(node.children[1])
    current_indent_level = current_indent_level - 1
    write_indent()
    emit_code(RB + "\n")

fn emit_for_stmt(node_idx: Int):
    node := get_node(node_idx)
    # node.value is the binding name (e.g., "item" or "item,idx")
    # children: [iterable, body]
    binding := node.value
    mut idx_name := ""
    # check for index variable: "item,idx"
    mut comma_pos := -1
    mut ci := 0
    while ci < binding.len():
        if binding[ci] == ",":
            comma_pos = ci
        ci = ci + 1
    mut elem_name := binding
    if comma_pos >= 0:
        elem_name = binding.substring(0, comma_pos).trim()
        idx_name = binding.substring(comma_pos + 1, binding.len()).trim()

    if idx_name == "":
        idx_name = "__idx_" + for_loop_counter.to_string()
        for_loop_counter = for_loop_counter + 1

    iter_tid := c_get_expr_type(node.children[0])
    if iter_tid < 0:
        write_indent()
        emit_code("/* for loop: could not resolve iterable type */\n")
        return
    if iter_tid >= tt_count():
        write_indent()
        emit_code("/* for loop: could not resolve iterable type */\n")
        return
    iter_info := tt_get(iter_tid)

    if iter_info.kind == "list":
        emit_for_loop_body(node, idx_name, elem_name, comma_pos, get_c_type_string(iter_info.inner), iter_info.inner, "list")
        return

    if iter_tid == TID_STRING:
        emit_for_loop_body(node, idx_name, elem_name, comma_pos, "forge_string_t", TID_STRING, "string")
        return

    if iter_info.kind == "map":
        emit_for_loop_body(node, idx_name, elem_name, comma_pos, get_c_type_string(iter_info.key_type), iter_info.key_type, "map")
        return

    if iter_info.kind == "set":
        emit_for_loop_body(node, idx_name, elem_name, comma_pos, get_c_type_string(iter_info.inner), iter_info.inner, "set")
        return

    write_indent()
    emit_code("/* unreachable: checker rejected unsupported iterable type */\n")

fn emit_return_stmt(node_idx: Int):
    node := get_node(node_idx)
    # ARC: cleanup all local variables before return
    emit_full_scope_cleanup()
    write_indent()
    if node.children.len() > 0:
        if is_result_type(current_function_return_type):
            # check if the expression already returns a result type —
            # if so, return it directly without wrapping
            val_type := c_get_expr_type(node.children[0])
            if is_result_type(val_type):
                emit_code("return ")
                emit_expr(node.children[0])
                emit_code(";\n")
                return
            ret_c := get_c_type_string(current_function_return_type)
            emit_code("return (")
            emit_code(ret_c)
            emit_code(")" + LB + " .is_ok = true, .ok = ")
            emit_expr(node.children[0])
            emit_code(" " + RB + ";\n")
        elif is_optional_type(current_function_return_type):
            val_node := get_node(node.children[0])
            ret_c := get_c_type_string(current_function_return_type)
            if val_node.kind == "none_lit":
                emit_code("return (")
                emit_code(ret_c)
                emit_code(")" + LB + " .has_value = false " + RB + ";\n")
            else:
                emit_code("return (")
                emit_code(ret_c)
                emit_code(")" + LB + " .has_value = true, .value = ")
                emit_expr(node.children[0])
                emit_code(" " + RB + ";\n")
        else:
            emit_code("return ")
            emit_expr(node.children[0])
            emit_code(";\n")
    else:
        emit_code("return;\n")

fn emit_fail_stmt(node_idx: Int):
    node := get_node(node_idx)
    write_indent()
    ret_c := get_c_type_string(current_function_return_type)
    emit_code("return (")
    emit_code(ret_c)
    emit_code(")" + LB + " .is_ok = false, .err = ")
    emit_expr(node.children[0])
    emit_code(" " + RB + ";\n")

# ---------------------------------------------------------------
# expressions
# ---------------------------------------------------------------

fn emit_expr(node_idx: Int):
    node := get_node(node_idx)
    if node.kind == "int_lit":
        emit_code(node.value)
        return
    if node.kind == "float_lit":
        emit_code(node.value)
        return
    if node.kind == "string_lit":
        emit_string_lit(node.value)
        return
    if node.kind == "bool_lit":
        if node.value == "true":
            emit_code("true")
        else:
            emit_code("false")
        return
    if node.kind == "none":
        emit_code(LB + " 0 " + RB)
        return
    if node.kind == "ident":
        emit_code(node.value)
        return
    if node.kind == "self":
        emit_code("self")
        return
    if node.kind == "binary":
        emit_binary(node_idx)
        return
    if node.kind == "unary":
        emit_unary(node_idx)
        return
    if node.kind == "call":
        emit_call(node_idx)
        return
    if node.kind == "method_call":
        emit_method_call(node_idx)
        return
    if node.kind == "field_access":
        emit_field_access(node_idx)
        return
    if node.kind == "index":
        emit_index_expr(node_idx)
        return
    if node.kind == "grouped":
        emit_code("(")
        emit_expr(node.children[0])
        emit_code(")")
        return
    if node.kind == "if_expr":
        emit_if_expr(node_idx)
        return
    if node.kind == "match_expr":
        emit_match_as_if_chain(node_idx, false, false)
        return
    if node.kind == "string_interp":
        emit_string_interp(node_idx)
        return
    if node.kind == "lambda":
        emit_lambda(node_idx)
        return
    if node.kind == "list":
        emit_list_literal(node_idx)
        return
    if node.kind == "map":
        emit_map_literal(node_idx)
        return
    if node.kind == "set":
        emit_set_literal(node_idx)
        return
    if node.kind == "tuple":
        emit_tuple_expr(node_idx)
        return
    if node.kind == "unwrap":
        emit_code("(")
        emit_expr(node.children[0])
        emit_code(").value")
        return
    if node.kind == "try":
        # try in expression position — must check .is_ok before accessing .ok
        inner_idx := node.children[0]
        result_tid := c_get_expr_type(inner_idx)
        result_c := get_c_type_string(result_tid)
        try_name := "__try_" + try_block_counter.to_string()
        try_block_counter = try_block_counter + 1
        emit_code("(" + LB + " ")
        emit_code(result_c)
        emit_code(" " + try_name + " = ")
        emit_expr(inner_idx)
        emit_code("; if (!" + try_name + ".is_ok) return (")
        emit_code(get_c_type_string(current_function_return_type))
        emit_code(")" + LB + " .is_ok = false, .err = " + try_name + ".err " + RB + "; ")
        emit_code(try_name + ".ok; " + RB + ")")
        return
    if node.kind == "spawn":
        emit_spawn_expr(node_idx)
        return
    if node.kind == "await":
        emit_await_expr(node_idx)
        return

fn emit_spawn_expr(node_idx: Int):
    node := get_node(node_idx)
    # spawn node has one child: the inner call expression
    if node.children.len() < 1:
        emit_code("/* spawn: missing call */")
        return
    inner_idx := node.children[0]
    inner := get_node(inner_idx)
    if inner.kind != "call":
        emit_code("/* spawn: expected function call */")
        return
    # extract function name from the call's callee (children[0])
    if inner.children.len() < 1:
        emit_code("/* spawn: empty call */")
        return
    callee := get_node(inner.children[0])
    if callee.kind != "ident":
        emit_code("/* spawn: expected named function */")
        return
    fn_name := callee.value
    # determine the return type of the spawned function
    return_type := c_get_expr_type(inner_idx)
    # collect argument types into flat lists
    nargs := inner.children.len() - 1
    arg_offset := spawn_argument_type_ids.len()
    mut ai := 0
    while ai < nargs:
        arg_expr := get_call_argument(inner_idx, ai)
        spawn_argument_type_ids.push(c_get_expr_type(arg_expr))
        ai = ai + 1
    idx := spawn_counter
    spawn_counter = spawn_counter + 1
    # record for hoisting
    spawn_node_indices.push(idx)
    spawn_function_names.push(fn_name)
    spawn_return_types.push(return_type)
    spawn_argument_counts.push(nargs)
    spawn_argument_offsets.push(arg_offset)
    # emit gcc statement expression:
    # ({ __spawn_data_N *__sp = malloc(sizeof(__spawn_data_N));
    #    __sp->__arg_0 = arg0; ...
    #    pthread_create(&__sp->__header.thread, NULL, __spawn_wrapper_N, __sp);
    #    (void*)__sp; })
    emit_code("(" + LB + " __spawn_data_")
    emit_code(idx.to_string())
    emit_code(" *__sp = malloc(sizeof(__spawn_data_")
    emit_code(idx.to_string())
    emit_code(")); ")
    ai = 0
    while ai < nargs:
        emit_code("__sp->__arg_")
        emit_code(ai.to_string())
        emit_code(" = ")
        emit_expr(get_call_argument(inner_idx, ai))
        emit_code("; ")
        ai = ai + 1
    emit_code("pthread_create(&__sp->__header.thread, NULL, __spawn_wrapper_")
    emit_code(idx.to_string())
    emit_code(", __sp); (void*)__sp; " + RB + ")")

fn emit_await_expr(node_idx: Int):
    node := get_node(node_idx)
    if node.children.len() < 1:
        emit_code("/* await: missing expression */")
        return
    inner_idx := node.children[0]
    # infer the type of the inner expression — should be Task[T]
    inner_tid := c_get_expr_type(inner_idx)
    mut return_type := TID_ERR
    if inner_tid >= 0:
        if inner_tid < tt_count():
            info := tt_get(inner_tid)
            if info.kind == "task":
                return_type = info.inner
    ret_c := get_c_type_string(return_type)
    # emit gcc statement expression:
    # ({ void *__aw = expr;
    #    pthread_join(((forge_task_header_t *)__aw)->thread, NULL);
    #    ret_type result = *(ret_type *)((char *)__aw + sizeof(forge_task_header_t));
    #    free(__aw);
    #    result; })
    emit_code("(" + LB + " void *__aw = ")
    emit_expr(inner_idx)
    emit_code("; pthread_join(((forge_task_header_t *)__aw)->thread, NULL); ")
    emit_code(ret_c)
    emit_code(" __result = *(")
    emit_code(ret_c)
    emit_code(" *)((char *)__aw + sizeof(forge_task_header_t)); free(__aw); __result; " + RB + ")")

fn emit_binary(node_idx: Int):
    node := get_node(node_idx)
    op := node.value
    # pipe operator: x |> f  ->  fg_f(x)
    if op == "pipe":
        rhs := get_node(node.children[1])
        if rhs.kind == "ident":
            emit_code("fg_")
            emit_code(rhs.value)
        else:
            emit_expr(node.children[1])
        emit_code("(")
        emit_expr(node.children[0])
        emit_code(")")
        return
    # string operations
    is_str := is_string_expression(node.children[0])
    if is_str:
        if op == "add":
            emit_code("forge_string_concat(")
            emit_expr(node.children[0])
            emit_code(", ")
            emit_expr(node.children[1])
            emit_code(")")
            return
        if op == "eq":
            emit_string_cmp("forge_string_eq", node_idx)
            return
        if op == "neq":
            emit_string_cmp("forge_string_neq", node_idx)
            return
        if op == "lt":
            emit_string_cmp("forge_string_lt", node_idx)
            return
        if op == "gt":
            emit_string_cmp("forge_string_gt", node_idx)
            return
        if op == "lte":
            emit_string_cmp("forge_string_lte", node_idx)
            return
        if op == "gte":
            emit_string_cmp("forge_string_gte", node_idx)
            return
    # regular binary
    emit_code("(")
    emit_expr(node.children[0])
    emit_code(" ")
    emit_code(map_operator_to_c(op))
    emit_code(" ")
    emit_expr(node.children[1])
    emit_code(")")

fn map_operator_to_c(op: String) -> String:
    if op == "and":
        return "&&"
    if op == "or":
        return "||"
    if op == "eq":
        return "=="
    if op == "neq":
        return "!="
    if op == "add":
        return "+"
    if op == "sub":
        return "-"
    if op == "mul":
        return "*"
    if op == "div":
        return "/"
    if op == "mod":
        return "%"
    if op == "lt":
        return "<"
    if op == "gt":
        return ">"
    if op == "lte":
        return "<="
    if op == "gte":
        return ">="
    return op

fn emit_string_cmp(func: String, node_idx: Int):
    node := get_node(node_idx)
    emit_code(func)
    emit_code("(")
    emit_expr(node.children[0])
    emit_code(", ")
    emit_expr(node.children[1])
    emit_code(")")

fn emit_unary(node_idx: Int):
    node := get_node(node_idx)
    if node.value == "-" or node.value == "negate":
        emit_code("(-")
        emit_expr(node.children[0])
        emit_code(")")
        return
    if node.value == "not":
        emit_code("(!")
        emit_expr(node.children[0])
        emit_code(")")
        return
    emit_expr(node.children[0])

# check if a builtin follows the forge_<name>(<args>) pattern.
# these builtins need no special emit logic — just prefix and args.
fn is_forge_builtin(name: String) -> Bool:
    if name == "parse_int" or name == "parse_float":
        return true
    if name == "read_file" or name == "write_file" or name == "append_file":
        return true
    if name == "env" or name == "chr" or name == "ord" or name == "exec" or name == "exec_output":
        return true
    if name == "bit_and" or name == "bit_or" or name == "bit_xor" or name == "bit_not" or name == "bit_shl" or name == "bit_shr":
        return true
    if name == "print_err":
        return true
    if name == "time" or name == "sleep" or name == "input":
        return true
    if name == "random_int" or name == "random_float":
        return true
    if name == "math_pow" or name == "math_sqrt" or name == "math_floor" or name == "math_ceil" or name == "math_round":
        return true
    if name == "file_exists" or name == "dir_exists" or name == "mkdir" or name == "remove_file" or name == "rename_file" or name == "list_dir":
        return true
    if name == "fmt_float":
        return true
    if name == "format_time" or name == "random_seed" or name == "random_string":
        return true
    if name == "tcp_connect" or name == "tcp_listen" or name == "tcp_accept":
        return true
    if name == "tcp_read" or name == "tcp_write" or name == "tcp_close":
        return true
    if name == "dns_resolve":
        return true
    if name == "process_spawn" or name == "process_write" or name == "process_read" or name == "process_read_err":
        return true
    if name == "process_wait" or name == "process_kill" or name == "process_close":
        return true
    return false

# emit call arguments as comma-separated expressions (no parens)
fn emit_call_args(node_idx: Int):
    count := get_call_argument_count(node_idx)
    mut i := 0
    while i < count:
        if i > 0:
            emit_code(", ")
        emit_expr(get_call_argument(node_idx, i))
        i = i + 1

fn emit_call(node_idx: Int):
    node := get_node(node_idx)
    # Channel[T]() constructor — callee is an index node like Channel[Int]
    if node.children.len() > 0:
        callee_node := get_node(node.children[0])
        if callee_node.kind == "index":
            if callee_node.children.len() >= 2:
                obj_node := get_node(callee_node.children[0])
                if obj_node.kind == "ident":
                    if obj_node.value == "Channel":
                        inner_node := get_node(callee_node.children[1])
                        inner_name := inner_node.value
                        inner_tid := tt_lookup(inner_name)
                        inner_c := get_c_type_string(inner_tid)
                        emit_code("forge_channel_create(sizeof(")
                        emit_code(inner_c)
                        emit_code("))")
                        return
    # in self-hosted AST, call has ident child as first element
    name := get_call_name(node_idx)
    # builtins
    if name == "print":
        emit_code("forge_print(")
        if get_call_argument_count(node_idx) > 0:
            emit_expr(get_call_argument(node_idx, 0))
        emit_code(")")
        return
    # builtins that emit as forge_<name>(<args>)
    if is_forge_builtin(name):
        emit_code("forge_")
        emit_code(name)
        emit_code("(")
        emit_call_args(node_idx)
        emit_code(")")
        return
    if name == "args":
        emit_code("forge_get_args()")
        return
    if name == "exit":
        emit_code("exit((int)")
        emit_expr(get_call_argument(node_idx, 0))
        emit_code(")")
        return
    # sync primitive constructors
    if name == "Mutex":
        emit_code("forge_mutex_create()")
        return
    if name == "WaitGroup":
        emit_code("forge_waitgroup_create()")
        return
    if name == "Semaphore":
        emit_code("forge_semaphore_create(")
        if get_call_argument_count(node_idx) > 0:
            emit_expr(get_call_argument(node_idx, 0))
        emit_code(")")
        return
    if name == "assert":
        emit_assert(node_idx)
        return
    if name == "assert_eq":
        emit_assert_eq(node_idx, true)
        return
    if name == "assert_ne":
        emit_assert_eq(node_idx, false)
        return
    # check if struct/enum constructor
    tid := tt_lookup(name)
    if tid >= 0:
        info := tt_get(tid)
        if info.kind == "struct":
            emit_struct_constructor(node_idx, name, tid)
            return
        if info.kind == "enum":
            emit_enum_constructor(node_idx, name)
            return
    # check if generic struct constructor or function
    if generic_declaration_map.contains_key(name):
        inst := build_instantiated_name_from_arguments(name, node_idx)
        if inst != "":
            inst_tid := tt_lookup(inst)
            if inst_tid >= 0:
                inst_info := tt_get(inst_tid)
                if inst_info.kind == "struct":
                    mangled := mangle_identifier(inst)
                    emit_generic_struct_constructor(node_idx, mangled, inst_tid)
                    return
                if inst_info.kind == "function":
                    mangled := mangle_identifier(inst)
                    emit_code("fg_")
                    emit_code(mangled)
                    emit_code("(")
                    emit_arg_list(node_idx)
                    emit_code(")")
                    return
            # generic function not in type table — check AST node kind
            decl_idx := generic_declaration_map[name]
            decl_node := get_node(decl_idx)
            mut decl_kind := decl_node.kind
            if decl_kind == "pub":
                if decl_node.children.len() > 0:
                    decl_kind = get_node(decl_node.children[0]).kind
            if decl_kind == "fn_decl":
                mangled := mangle_identifier(inst)
                emit_code("fg_")
                emit_code(mangled)
                emit_code("(")
                emit_arg_list(node_idx)
                emit_code(")")
                return
    # check if local closure variable
    if local_variable_types.contains_key(name):
        local_tid := local_variable_types[name]
        if local_tid >= 0:
            if local_tid < tt_count():
                local_info := tt_get(local_tid)
                if local_info.kind == "function":
                    # closure call: cast fn_ptr and invoke with env_ptr
                    emit_code("((")
                    emit_code(get_c_type_string(local_info.return_type))
                    emit_code(" (*)(void*")
                    for pt in local_info.param_types:
                        emit_code(", ")
                        emit_code(get_c_type_string(pt))
                    emit_code("))")
                    emit_code(name)
                    emit_code(".fn_ptr)(")
                    emit_code(name)
                    emit_code(".env_ptr")
                    # emit actual arguments
                    mut skip := 1
                    for child in node.children:
                        if skip > 0:
                            skip = skip - 1
                            continue
                        cn := get_node(child)
                        emit_code(", ")
                        if cn.kind == "arg":
                            if cn.children.len() > 0:
                                emit_expr(cn.children[0])
                        else:
                            emit_expr(child)
                    emit_code(")")
                    return
    # regular user function
    emit_code("fg_")
    emit_code(name)
    emit_code("(")
    emit_arg_list(node_idx)
    emit_code(")")

fn get_call_name(node_idx: Int) -> String:
    node := get_node(node_idx)
    if node.children.len() > 0:
        first_child := get_node(node.children[0])
        if first_child.kind == "ident":
            return first_child.value
    return ""

# get the expression index for the nth argument (0-based)
fn get_call_argument(node_idx: Int, n: Int) -> Int:
    node := get_node(node_idx)
    # children[0] is the callee ident, children[1..] are arg nodes
    arg_idx := n + 1
    if arg_idx < node.children.len():
        arg_node := get_node(node.children[arg_idx])
        if arg_node.kind == "arg":
            if arg_node.children.len() > 0:
                return arg_node.children[0]
        return node.children[arg_idx]
    return -1

# get number of arguments (excluding the callee ident)
fn get_call_argument_count(node_idx: Int) -> Int:
    node := get_node(node_idx)
    return node.children.len() - 1

fn emit_arg_list(node_idx: Int):
    # for call nodes: children[0] is the callee ident, rest are arg nodes
    # for method_call nodes: children[0] is the receiver, rest are arg nodes
    # each arg node has one child which is the actual expression
    node := get_node(node_idx)
    mut first := true
    mut skip := 1
    for child in node.children:
        if skip > 0:
            skip = skip - 1
            continue
        cn := get_node(child)
        if cn.kind == "arg":
            if first == false:
                emit_code(", ")
            first = false
            if cn.children.len() > 0:
                emit_expr(cn.children[0])
        else:
            if first == false:
                emit_code(", ")
            first = false
            emit_expr(child)

fn build_instantiated_name_from_arguments(base: String, node_idx: Int) -> String:
    node := get_node(node_idx)
    mut result := base + "["
    mut first := true
    mut skip := 1
    for child in node.children:
        if skip > 0:
            skip = skip - 1
            continue
        cn := get_node(child)
        mut expr_idx := child
        if cn.kind == "arg":
            if cn.children.len() > 0:
                expr_idx = cn.children[0]
        if first == false:
            result = result + ","
        first = false
        arg_tid := c_get_expr_type(expr_idx)
        result = result + tt_type_name(arg_tid)
    result = result + "]"
    return result

fn emit_struct_constructor(node_idx: Int, name: String, tid: Int):
    info := tt_get(tid)
    emit_code("(" + name + ")" + LB + " ")
    nargs := get_call_argument_count(node_idx)
    mut fi := 0
    while fi < nargs:
        if fi > 0:
            emit_code(", ")
        if fi < info.fields.len():
            emit_code(".")
            emit_code(info.fields[fi])
            emit_code(" = ")
        emit_expr(get_call_argument(node_idx, fi))
        fi = fi + 1
    emit_code(" " + RB)

fn emit_generic_struct_constructor(node_idx: Int, mangled: String, tid: Int):
    info := tt_get(tid)
    emit_code("(" + mangled + ")" + LB + " ")
    nargs := get_call_argument_count(node_idx)
    mut fi := 0
    while fi < nargs:
        if fi > 0:
            emit_code(", ")
        if fi < info.fields.len():
            emit_code(".")
            emit_code(info.fields[fi])
            emit_code(" = ")
        emit_expr(get_call_argument(node_idx, fi))
        fi = fi + 1
    emit_code(" " + RB)

fn emit_enum_constructor(node_idx: Int, name: String):
    # enum variant constructor: EnumName.Variant(args)
    # the name is "EnumName.Variant"
    mut dot_pos := -1
    mut di := 0
    while di < name.len():
        if name[di] == ".":
            dot_pos = di
        di = di + 1
    if dot_pos < 0:
        # plain enum name used as constructor — shouldn't happen
        emit_code(name)
        return
    enum_name := name.substring(0, dot_pos)
    variant_name := name.substring(dot_pos + 1, name.len())
    node := get_node(node_idx)
    nargs := get_call_argument_count(node_idx)
    if nargs == 0:
        # no-data variant
        emit_code("(" + enum_name + ")" + LB + " .tag = " + enum_name + "_TAG_" + variant_name + " " + RB)
    else:
        emit_code("(" + enum_name + ")" + LB + " .tag = " + enum_name + "_TAG_" + variant_name + ", .data." + variant_name + " = " + LB + " ")
        mut fi := 0
        while fi < nargs:
            if fi > 0:
                emit_code(", ")
            emit_code("._")
            emit_code(fi.to_string())
            emit_code(" = ")
            emit_expr(get_call_argument(node_idx, fi))
            fi = fi + 1
        emit_code(" " + RB + " " + RB)

fn emit_assert(node_idx: Int):
    emit_code("do " + LB + " if (!(")
    emit_expr(get_call_argument(node_idx, 0))
    emit_code(")) " + LB + " fprintf(stderr, \"assertion failed\\n\"); __current_test_failed = 1; " + RB + " " + RB + " while(0)")

fn emit_assert_eq(node_idx: Int, is_eq: Bool):
    # determine if args are strings
    arg0 := get_call_argument(node_idx, 0)
    arg1 := get_call_argument(node_idx, 1)
    arg_tid := c_get_expr_type(arg0)
    is_str := arg_tid == TID_STRING
    if is_str:
        if is_eq:
            emit_code("do " + LB + " if (!forge_string_eq(")
        else:
            emit_code("do " + LB + " if (forge_string_eq(")
        emit_expr(arg0)
        emit_code(", ")
        emit_expr(arg1)
        emit_code(")) " + LB + " fprintf(stderr, \"assertion failed\\n\"); __current_test_failed = 1; " + RB + " " + RB + " while(0)")
    else:
        if is_eq:
            emit_code("do " + LB + " if ((")
        else:
            emit_code("do " + LB + " if (!((")
        emit_expr(arg0)
        emit_code(") == (")
        emit_expr(arg1)
        if is_eq:
            emit_code(")) " + LB + " fprintf(stderr, \"assertion failed\\n\"); __current_test_failed = 1; " + RB + " " + RB + " while(0)")
        else:
            emit_code("))) " + LB + " fprintf(stderr, \"assertion failed\\n\"); __current_test_failed = 1; " + RB + " " + RB + " while(0)")

# ---------------------------------------------------------------
# method calls
# ---------------------------------------------------------------

fn emit_method_call(node_idx: Int):
    node := get_node(node_idx)
    method := node.value
    # children: [receiver, arg0, arg1, ...]
    receiver_idx := node.children[0]
    receiver_tid := c_get_expr_type(receiver_idx)
    # string methods
    if receiver_tid == TID_STRING:
        emit_string_method(node_idx, method)
        return
    # primitive methods
    if receiver_tid == TID_INT:
        emit_primitive_method(node_idx, receiver_tid, method)
        return
    if receiver_tid == TID_FLOAT:
        emit_primitive_method(node_idx, receiver_tid, method)
        return
    if receiver_tid == TID_BOOL:
        emit_primitive_method(node_idx, receiver_tid, method)
        return
    # collection methods
    if receiver_tid >= 0:
        if receiver_tid < tt_count():
            info := tt_get(receiver_tid)
            if info.kind == "list":
                emit_list_method(node_idx, method, info.inner)
                return
            if info.kind == "map":
                emit_map_method(node_idx, method, info.key_type, info.value_type)
                return
            if info.kind == "set":
                emit_set_method(node_idx, method, info.inner)
                return
            if info.kind == "struct":
                if emit_sync_method(node_idx, method, info.name):
                    return
            if info.kind == "channel":
                emit_channel_method(node_idx, method, info.inner)
                return
    # user-defined method: TypeName_method(receiver, args...)
    type_name := get_type_name_for_method(receiver_tid)
    if type_name != "":
        emit_code(type_name)
        emit_code("_")
        emit_code(method)
        emit_code("(")
        emit_expr(receiver_idx)
        nargs := get_call_argument_count(node_idx)
        mut ai := 0
        while ai < nargs:
            emit_code(", ")
            emit_expr(get_call_argument(node_idx, ai))
            ai = ai + 1
        emit_code(")")
        return
    # fallback
    emit_code("/* unknown method */")

fn get_type_name_for_method(tid: Int) -> String:
    if tid < 0:
        return ""
    if tid >= tt_count():
        return ""
    info := tt_get(tid)
    if info.kind == "struct":
        return info.name
    if info.kind == "enum":
        return info.name
    return ""

# ---------------------------------------------------------------
# sync primitive methods
# ---------------------------------------------------------------

fn emit_sync_method(node_idx: Int, method: String, type_name: String) -> Bool:
    node := get_node(node_idx)
    receiver_idx := node.children[0]
    if type_name == "Mutex":
        if method == "lock":
            emit_code("forge_mutex_lock(&")
            emit_expr(receiver_idx)
            emit_code(")")
            return true
        if method == "unlock":
            emit_code("forge_mutex_unlock(&")
            emit_expr(receiver_idx)
            emit_code(")")
            return true
    if type_name == "WaitGroup":
        if method == "add":
            emit_code("forge_waitgroup_add(&")
            emit_expr(receiver_idx)
            emit_code(", ")
            emit_expr(get_call_argument(node_idx, 0))
            emit_code(")")
            return true
        if method == "done":
            emit_code("forge_waitgroup_done(&")
            emit_expr(receiver_idx)
            emit_code(")")
            return true
        if method == "wait":
            emit_code("forge_waitgroup_wait(&")
            emit_expr(receiver_idx)
            emit_code(")")
            return true
    if type_name == "Semaphore":
        if method == "acquire":
            emit_code("forge_semaphore_acquire(&")
            emit_expr(receiver_idx)
            emit_code(")")
            return true
        if method == "release":
            emit_code("forge_semaphore_release(&")
            emit_expr(receiver_idx)
            emit_code(")")
            return true
    return false

# ---------------------------------------------------------------
# channel methods
# ---------------------------------------------------------------

fn emit_channel_method(node_idx: Int, method: String, inner_tid: Int):
    node := get_node(node_idx)
    receiver_idx := node.children[0]
    inner_c := get_c_type_string(inner_tid)
    if method == "send":
        # ({ C_TYPE __ch_v = val; forge_channel_send(ch, &__ch_v); })
        emit_code("(" + LB + " ")
        emit_code(inner_c)
        emit_code(" __ch_v = ")
        emit_expr(get_call_argument(node_idx, 0))
        emit_code("; forge_channel_send(")
        emit_expr(receiver_idx)
        emit_code(", &__ch_v); " + RB + ")")
        return
    if method == "recv":
        # ({ C_TYPE __ch_v; OPT_TYPE __ch_r;
        #    __ch_r.has_value = forge_channel_recv(ch, &__ch_v);
        #    if (__ch_r.has_value) __ch_r.value = __ch_v; __ch_r; })
        opt_c := "forge_optional_" + inner_c
        emit_code("(" + LB + " ")
        emit_code(inner_c)
        emit_code(" __ch_v; ")
        emit_code(opt_c)
        emit_code(" __ch_r; __ch_r.has_value = forge_channel_recv(")
        emit_expr(receiver_idx)
        emit_code(", &__ch_v); if (__ch_r.has_value) __ch_r.value = __ch_v; __ch_r; " + RB + ")")
        return
    if method == "close":
        emit_code("forge_channel_close(")
        emit_expr(receiver_idx)
        emit_code(")")
        return
    if method == "len":
        emit_code("forge_channel_len(")
        emit_expr(receiver_idx)
        emit_code(")")
        return

# ---------------------------------------------------------------
# string methods
# ---------------------------------------------------------------

fn emit_simple_method(node_idx: Int, c_fn: String, nargs: Int):
    # emit a straightforward method call: c_fn(receiver, arg0, arg1, ...)
    node := get_node(node_idx)
    emit_code(c_fn + "(")
    emit_expr(node.children[0])
    mut i := 0
    while i < nargs:
        emit_code(", ")
        emit_expr(get_call_argument(node_idx, i))
        i = i + 1
    emit_code(")")

fn emit_string_method(node_idx: Int, method: String):
    node := get_node(node_idx)
    receiver_idx := node.children[0]
    if method == "len":
        emit_expr(receiver_idx)
        emit_code(".len")
        return
    if method == "is_empty":
        emit_code("(")
        emit_expr(receiver_idx)
        emit_code(".len == 0)")
        return
    # 0-arg passthrough methods
    if method == "trim":
        emit_simple_method(node_idx, "forge_string_trim", 0)
        return
    if method == "to_upper":
        emit_simple_method(node_idx, "forge_string_to_upper", 0)
        return
    if method == "to_lower":
        emit_simple_method(node_idx, "forge_string_to_lower", 0)
        return
    if method == "chars":
        emit_simple_method(node_idx, "forge_string_chars", 0)
        return
    # 1-arg passthrough methods
    if method == "contains":
        emit_simple_method(node_idx, "forge_string_contains", 1)
        return
    if method == "starts_with":
        emit_simple_method(node_idx, "forge_string_starts_with", 1)
        return
    if method == "ends_with":
        emit_simple_method(node_idx, "forge_string_ends_with", 1)
        return
    if method == "index_of":
        emit_simple_method(node_idx, "forge_string_index_of", 1)
        return
    if method == "last_index_of":
        emit_simple_method(node_idx, "forge_string_last_index_of", 1)
        return
    if method == "split":
        emit_simple_method(node_idx, "forge_string_split", 1)
        return
    if method == "repeat":
        emit_simple_method(node_idx, "forge_string_repeat", 1)
        return
    # 2-arg passthrough methods
    if method == "substring":
        emit_simple_method(node_idx, "forge_string_substring", 2)
        return
    if method == "replace":
        emit_simple_method(node_idx, "forge_string_replace", 2)
        return
    if method == "pad_left":
        emit_simple_method(node_idx, "forge_string_pad_left", 2)
        return
    if method == "pad_right":
        emit_simple_method(node_idx, "forge_string_pad_right", 2)
        return

# ---------------------------------------------------------------
# primitive methods
# ---------------------------------------------------------------

fn emit_primitive_method(node_idx: Int, tid: Int, method: String):
    node := get_node(node_idx)
    receiver_idx := node.children[0]
    if method == "to_string":
        if tid == TID_INT:
            emit_code("forge_int_to_string(")
        elif tid == TID_FLOAT:
            emit_code("forge_float_to_string(")
        elif tid == TID_BOOL:
            emit_code("forge_bool_to_string(")
        else:
            emit_code("forge_int_to_string(")
        emit_expr(receiver_idx)
        emit_code(")")
        return
    if method == "to_float":
        emit_code("(double)(")
        emit_expr(receiver_idx)
        emit_code(")")
        return
    if method == "to_int":
        emit_code("(int64_t)(")
        emit_expr(receiver_idx)
        emit_code(")")
        return

# ---------------------------------------------------------------
# list methods
# ---------------------------------------------------------------

fn emit_list_method(node_idx: Int, method: String, elem_tid: Int):
    node := get_node(node_idx)
    receiver_idx := node.children[0]
    elem_c := get_c_type_string(elem_tid)
    if method == "push":
        emit_collection_push(node_idx, elem_tid, elem_c)
        return
    if method == "len":
        emit_code("forge_list_len(")
        emit_expr(receiver_idx)
        emit_code(")")
        return
    if method == "is_empty":
        emit_code("(forge_list_len(")
        emit_expr(receiver_idx)
        emit_code(") == 0)")
        return
    if method == "remove":
        emit_code("forge_list_remove(&")
        emit_expr(receiver_idx)
        emit_code(", ")
        emit_expr(get_call_argument(node_idx, 0))
        emit_code(", sizeof(")
        emit_code(elem_c)
        emit_code("))")
        return
    if method == "contains":
        if elem_tid == TID_STRING:
            emit_code("forge_list_contains_string(")
        else:
            emit_code("forge_list_contains(")
        emit_expr(receiver_idx)
        emit_code(", &(")
        emit_code(elem_c)
        emit_code(")" + LB)
        emit_expr(get_call_argument(node_idx, 0))
        emit_code(RB + ", sizeof(")
        emit_code(elem_c)
        emit_code("))")
        return
    if method == "reverse":
        emit_code("forge_list_reverse(&")
        emit_expr(receiver_idx)
        emit_code(", sizeof(")
        emit_code(elem_c)
        emit_code("))")
        return
    if method == "clear":
        emit_code("forge_list_clear(&")
        emit_expr(receiver_idx)
        emit_code(")")
        return
    if method == "join":
        emit_simple_method(node_idx, "forge_list_join", 1)
        return
    if method == "index_of":
        if elem_tid == TID_STRING:
            emit_simple_method(node_idx, "forge_list_index_of_string", 1)
        else:
            emit_code("forge_list_index_of(")
            emit_expr(receiver_idx)
            emit_code(", &(")
            emit_code(elem_c)
            emit_code(")" + LB)
            emit_expr(get_call_argument(node_idx, 0))
            emit_code(RB + ", sizeof(")
            emit_code(elem_c)
            emit_code("))")
        return
    if method == "slice":
        emit_code("forge_list_slice(")
        emit_expr(receiver_idx)
        emit_code(", ")
        emit_expr(get_call_argument(node_idx, 0))
        emit_code(", ")
        emit_expr(get_call_argument(node_idx, 1))
        emit_code(", sizeof(")
        emit_code(elem_c)
        emit_code("))")
        return
    if method == "sort":
        mut tag := "0"
        if elem_tid == TID_FLOAT:
            tag = "1"
        elif elem_tid == TID_STRING:
            tag = "2"
        emit_code("forge_list_sort(")
        emit_expr(receiver_idx)
        emit_code(", sizeof(")
        emit_code(elem_c)
        emit_code("), ")
        emit_code(tag)
        emit_code(")")
        return

fn emit_collection_push(node_idx: Int, elem_tid: Int, elem_c: String):
    node := get_node(node_idx)
    receiver_idx := node.children[0]
    value_idx := get_call_argument(node_idx, 0)
    # for struct/string/collection types, use temp variable to avoid compound literal issues
    mut is_complex := elem_tid == TID_STRING
    if is_complex == false:
        if elem_tid >= TID_FIRST_USER:
            if elem_tid < tt_count():
                ei := tt_get(elem_tid)
                if ei.kind == "struct":
                    is_complex = true
                if ei.kind == "enum":
                    is_complex = true
                if ei.kind == "list":
                    is_complex = true
                if ei.kind == "map":
                    is_complex = true
                if ei.kind == "set":
                    is_complex = true
    if is_complex:
        temp := "__push_" + push_counter.to_string()
        push_counter = push_counter + 1
        emit_code(LB + " ")
        emit_code(elem_c)
        emit_code(" ")
        emit_code(temp)
        emit_code(" = ")
        emit_expr(value_idx)
        emit_code("; forge_list_push(&")
        emit_expr(receiver_idx)
        emit_code(", &")
        emit_code(temp)
        emit_code(", sizeof(")
        emit_code(elem_c)
        emit_code("));")
        # ARC: retain string elements when pushed to list
        if elem_tid == TID_STRING:
            emit_code(" forge_elem_retain_string(&")
            emit_code(temp)
            emit_code(");")
        emit_code(" " + RB)
    else:
        # ARC: for string elements, use temp to enable retain
        if elem_tid == TID_STRING:
            temp := "__push_" + push_counter.to_string()
            push_counter = push_counter + 1
            emit_code(LB + " ")
            emit_code(elem_c)
            emit_code(" ")
            emit_code(temp)
            emit_code(" = ")
            emit_expr(value_idx)
            emit_code("; forge_list_push(&")
            emit_expr(receiver_idx)
            emit_code(", &")
            emit_code(temp)
            emit_code(", sizeof(")
            emit_code(elem_c)
            emit_code("));")
            emit_code(" forge_elem_retain_string(&")
            emit_code(temp)
            emit_code("); " + RB)
        else:
            emit_code("forge_list_push(&")
            emit_expr(receiver_idx)
            emit_code(", &(")
            emit_code(elem_c)
            emit_code(")" + LB)
            emit_expr(value_idx)
            emit_code(RB + ", sizeof(")
            emit_code(elem_c)
            emit_code("))")

# ---------------------------------------------------------------
# map methods
# ---------------------------------------------------------------

fn emit_map_method(node_idx: Int, method: String, key_tid: Int, val_tid: Int):
    node := get_node(node_idx)
    receiver_idx := node.children[0]
    key_c := get_c_type_string(key_tid)
    val_c := get_c_type_string(val_tid)
    if method == "insert":
        emit_map_insert(node_idx, key_tid, val_tid, key_c, val_c)
        return
    if method == "len":
        emit_code("forge_map_len(")
        emit_expr(receiver_idx)
        emit_code(")")
        return
    if method == "is_empty":
        emit_code("(forge_map_len(")
        emit_expr(receiver_idx)
        emit_code(") == 0)")
        return
    if method == "contains_key":
        if key_tid == TID_STRING:
            emit_code("forge_map_contains_key_string(")
        else:
            emit_code("forge_map_contains_key_int(")
        emit_expr(receiver_idx)
        emit_code(", ")
        emit_expr(get_call_argument(node_idx, 0))
        emit_code(")")
        return
    if method == "remove":
        if key_tid == TID_STRING:
            emit_code("forge_map_remove_by_string(&")
        else:
            emit_code("forge_map_remove_by_int(&")
        emit_expr(receiver_idx)
        emit_code(", ")
        emit_expr(get_call_argument(node_idx, 0))
        emit_code(", sizeof(")
        emit_code(key_c)
        emit_code("), sizeof(")
        emit_code(val_c)
        emit_code("))")
        return
    if method == "keys":
        emit_code("forge_map_keys(")
        emit_expr(receiver_idx)
        emit_code(", sizeof(")
        emit_code(key_c)
        emit_code("))")
        return
    if method == "values":
        emit_code("forge_map_values(")
        emit_expr(receiver_idx)
        emit_code(", sizeof(")
        emit_code(val_c)
        emit_code("))")
        return
    if method == "clear":
        emit_code("forge_map_clear(&")
        emit_expr(receiver_idx)
        emit_code(")")
        return

fn emit_map_insert(node_idx: Int, key_tid: Int, val_tid: Int, key_c: String, val_c: String):
    # use a temp variable so &val works for both scalars and structs
    node := get_node(node_idx)
    receiver_idx := node.children[0]
    emit_code(LB + " ")
    emit_code(val_c)
    emit_code(" __mv = ")
    emit_expr(get_call_argument(node_idx, 1))
    emit_code("; ")
    if key_tid == TID_STRING:
        emit_code("forge_map_set_by_string(&")
    else:
        emit_code("forge_map_set_by_int(&")
    emit_expr(receiver_idx)
    emit_code(", ")
    emit_expr(get_call_argument(node_idx, 0))
    emit_code(", &__mv, sizeof(")
    emit_code(key_c)
    emit_code("), sizeof(")
    emit_code(val_c)
    emit_code("));")
    # ARC: retain string keys and values when inserted to map
    if key_tid == TID_STRING:
        emit_code(" forge_elem_retain_string((void*)&")
        emit_expr(get_call_argument(node_idx, 0))
        emit_code(");")
    if val_tid == TID_STRING:
        emit_code(" forge_elem_retain_string(&__mv);")
    emit_code(" " + RB)

# ---------------------------------------------------------------
# set methods
# ---------------------------------------------------------------

fn emit_set_method(node_idx: Int, method: String, elem_tid: Int):
    node := get_node(node_idx)
    receiver_idx := node.children[0]
    elem_c := get_c_type_string(elem_tid)
    if method == "add":
        # use a temp variable to avoid compound literal issues with struct types
        emit_code(LB + " ")
        emit_code(elem_c)
        emit_code(" __sv = ")
        emit_expr(get_call_argument(node_idx, 0))
        emit_code("; forge_set_add(&")
        emit_expr(receiver_idx)
        emit_code(", &__sv, sizeof(")
        emit_code(elem_c)
        emit_code(")); " + RB)
        return
    if method == "len":
        emit_code("forge_list_len(")
        emit_expr(receiver_idx)
        emit_code(")")
        return
    if method == "is_empty":
        emit_code("(forge_list_len(")
        emit_expr(receiver_idx)
        emit_code(") == 0)")
        return
    if method == "contains":
        if elem_tid == TID_STRING:
            emit_code("forge_set_contains_string(")
            emit_expr(receiver_idx)
            emit_code(", ")
            emit_expr(get_call_argument(node_idx, 0))
            emit_code(")")
        else:
            emit_code("forge_set_contains(")
            emit_expr(receiver_idx)
            emit_code(", &(")
            emit_code(elem_c)
            emit_code(")" + LB)
            emit_expr(get_call_argument(node_idx, 0))
            emit_code(RB + ", sizeof(")
            emit_code(elem_c)
            emit_code("))")
        return
    if method == "remove":
        if elem_tid == TID_STRING:
            emit_code("forge_set_remove_string(&")
            emit_expr(receiver_idx)
            emit_code(", ")
            emit_expr(get_call_argument(node_idx, 0))
            emit_code(")")
        else:
            emit_code("forge_set_remove(&")
            emit_expr(receiver_idx)
            emit_code(", &(")
            emit_code(elem_c)
            emit_code(")" + LB)
            emit_expr(get_call_argument(node_idx, 0))
            emit_code(RB + ", sizeof(")
            emit_code(elem_c)
            emit_code("))")
        return
    if method == "clear":
        emit_code("forge_set_clear(&")
        emit_expr(receiver_idx)
        emit_code(")")
        return

# ---------------------------------------------------------------
# field access
# ---------------------------------------------------------------

fn emit_field_access(node_idx: Int):
    node := get_node(node_idx)
    emit_expr(node.children[0])
    emit_code(".")
    # tuple field access: t.0 -> t._0
    field := node.value
    if field.len() > 0:
        first_ch := field[0]
        if first_ch >= "0":
            if first_ch <= "9":
                emit_code("_")
    emit_code(field)

# ---------------------------------------------------------------
# index expression
# ---------------------------------------------------------------

fn emit_index_expr(node_idx: Int):
    node := get_node(node_idx)
    obj_tid := c_get_expr_type(node.children[0])
    if obj_tid == TID_STRING:
        emit_code("forge_string_char_at(")
        emit_expr(node.children[0])
        emit_code(", ")
        emit_expr(node.children[1])
        emit_code(")")
        return
    if obj_tid >= 0:
        if obj_tid < tt_count():
            info := tt_get(obj_tid)
            if info.kind == "list":
                elem_c := get_c_type_string(info.inner)
                emit_code("FORGE_LIST_GET(")
                emit_expr(node.children[0])
                emit_code(", ")
                emit_code(elem_c)
                emit_code(", ")
                emit_expr(node.children[1])
                emit_code(")")
                return
            if info.kind == "map":
                val_c := get_c_type_string(info.value_type)
                if info.key_type == TID_STRING:
                    emit_code("*(" + val_c + "*)forge_map_get_checked(forge_map_get_by_string(")
                    emit_expr(node.children[0])
                    emit_code(", ")
                    emit_expr(node.children[1])
                    emit_code(", sizeof(" + val_c + ")))")
                else:
                    emit_code("*(" + val_c + "*)forge_map_get_checked(forge_map_get_by_int(")
                    emit_expr(node.children[0])
                    emit_code(", ")
                    emit_expr(node.children[1])
                    emit_code(", sizeof(" + val_c + ")))")
                return
    # fallback
    emit_expr(node.children[0])
    emit_code("[")
    emit_expr(node.children[1])
    emit_code("]")

# ---------------------------------------------------------------
# collection literals
# ---------------------------------------------------------------

fn emit_list_literal(node_idx: Int):
    node := get_node(node_idx)
    if node.children.len() == 0:
        emit_code("forge_list_empty()")
        return
    elem_tid := c_get_expr_type(node.children[0])
    elem_c := get_c_type_string(elem_tid)
    count := node.children.len()
    emit_code("forge_list_create(")
    emit_code(count.to_string())
    emit_code(", sizeof(")
    emit_code(elem_c)
    emit_code("), (")
    emit_code(elem_c)
    emit_code("[])" + LB)
    mut first := true
    for child in node.children:
        if first == false:
            emit_code(", ")
        first = false
        emit_expr(child)
    emit_code(RB + ")")

fn emit_map_literal(node_idx: Int):
    node := get_node(node_idx)
    if node.children.len() == 0:
        emit_code("forge_map_empty()")
        return
    # each child is a map_entry with [key, value]
    first_entry := get_node(node.children[0])
    key_tid := c_get_expr_type(first_entry.children[0])
    val_tid := c_get_expr_type(first_entry.children[1])
    key_c := get_c_type_string(key_tid)
    val_c := get_c_type_string(val_tid)
    count := node.children.len()
    emit_code("forge_map_create(")
    emit_code(count.to_string())
    emit_code(", sizeof(")
    emit_code(key_c)
    emit_code("), sizeof(")
    emit_code(val_c)
    emit_code("), (")
    emit_code(key_c)
    emit_code("[])" + LB)
    mut kfirst := true
    for child in node.children:
        entry := get_node(child)
        if kfirst == false:
            emit_code(", ")
        kfirst = false
        emit_expr(entry.children[0])
    emit_code(RB + ", (")
    emit_code(val_c)
    emit_code("[])" + LB)
    mut vfirst := true
    for child in node.children:
        entry := get_node(child)
        if vfirst == false:
            emit_code(", ")
        vfirst = false
        emit_expr(entry.children[1])
    emit_code(RB + ")")

fn emit_set_literal(node_idx: Int):
    node := get_node(node_idx)
    if node.children.len() == 0:
        emit_code("forge_list_empty()")
        return
    elem_tid := c_get_expr_type(node.children[0])
    elem_c := get_c_type_string(elem_tid)
    count := node.children.len()
    emit_code("forge_set_create(")
    emit_code(count.to_string())
    emit_code(", sizeof(")
    emit_code(elem_c)
    emit_code("), (")
    emit_code(elem_c)
    emit_code("[])" + LB)
    mut first := true
    for child in node.children:
        if first == false:
            emit_code(", ")
        first = false
        emit_expr(child)
    emit_code(RB + ")")

fn emit_tuple_expr(node_idx: Int):
    node := get_node(node_idx)
    tuple_tid := c_get_expr_type(node_idx)
    tuple_c := get_c_type_string(tuple_tid)
    emit_code("(" + tuple_c + ")" + LB + " ")
    mut ei := 0
    for child in node.children:
        if ei > 0:
            emit_code(", ")
        emit_code("._")
        emit_code(ei.to_string())
        emit_code(" = ")
        emit_expr(child)
        ei = ei + 1
    emit_code(" " + RB)

# ---------------------------------------------------------------
# if expression (ternary)
# ---------------------------------------------------------------

fn emit_if_expr(node_idx: Int):
    node := get_node(node_idx)
    # children: [cond, then_expr, (elif pairs...,) else_expr]
    emit_code("(")
    emit_expr(node.children[0])
    emit_code(" ? ")
    emit_expr(node.children[1])
    emit_code(" : ")
    if node.children.len() > 3:
        # has elif — nest ternaries
        emit_elif_ternary(node_idx, 2)
    else:
        emit_expr(node.children[2])
    emit_code(")")

fn emit_elif_ternary(node_idx: Int, start: Int):
    node := get_node(node_idx)
    cn := get_node(node.children[start])
    if cn.kind == "elif":
        emit_code("(")
        emit_expr(cn.children[0])
        emit_code(" ? ")
        emit_expr(cn.children[1])
        emit_code(" : ")
        if start + 1 < node.children.len():
            next := get_node(node.children[start + 1])
            if next.kind == "elif":
                emit_elif_ternary(node_idx, start + 1)
            else:
                emit_expr(node.children[start + 1])
        emit_code(")")
    else:
        emit_expr(node.children[start])

# ---------------------------------------------------------------
# string interpolation
# ---------------------------------------------------------------

fn emit_string_interp(node_idx: Int):
    node := get_node(node_idx)
    parts := node.children
    if parts.len() == 0:
        emit_code("forge_string_empty")
        return
    if parts.len() == 1:
        emit_string_part(parts[0])
        return
    # nested forge_string_concat for n parts
    mut i := 0
    while i < parts.len() - 1:
        emit_code("forge_string_concat(")
        i = i + 1
    emit_string_part(parts[0])
    mut j := 1
    while j < parts.len():
        emit_code(", ")
        emit_string_part(parts[j])
        emit_code(")")
        j = j + 1

fn emit_string_part(node_idx: Int):
    node := get_node(node_idx)
    if node.kind == "string_lit":
        emit_string_lit(node.value)
        return
    if node.kind == "lit":
        # string interpolation literal part — may have leading/trailing quotes
        val := node.value
        mut s := val
        if s.len() > 0:
            if s[0] == "\"":
                s = s.substring(1, s.len())
        if s.len() > 0:
            if s[s.len() - 1] == "\"":
                s = s.substring(0, s.len() - 1)
        emit_code("FORGE_STRING_LIT(\"")
        write_escaped_string(s)
        emit_code("\")")
        return
    # expression — convert to string
    emit_expr_as_string(node_idx)

fn emit_expr_as_string(node_idx: Int):
    tid := c_get_expr_type(node_idx)
    if tid == TID_STRING:
        emit_expr(node_idx)
        return
    if tid == TID_INT:
        emit_code("forge_int_to_string(")
        emit_expr(node_idx)
        emit_code(")")
        return
    if tid == TID_FLOAT:
        emit_code("forge_float_to_string(")
        emit_expr(node_idx)
        emit_code(")")
        return
    if tid == TID_BOOL:
        emit_code("forge_bool_to_string(")
        emit_expr(node_idx)
        emit_code(")")
        return
    # fallback — try int conversion
    node := get_node(node_idx)
    if node.kind == "int_lit":
        emit_code("forge_int_to_string(")
        emit_expr(node_idx)
        emit_code(")")
        return
    if node.kind == "float_lit":
        emit_code("forge_float_to_string(")
        emit_expr(node_idx)
        emit_code(")")
        return
    if node.kind == "bool_lit":
        emit_code("forge_bool_to_string(")
        emit_expr(node_idx)
        emit_code(")")
        return
    emit_expr(node_idx)

# ---------------------------------------------------------------
# match
# ---------------------------------------------------------------

fn emit_match_stmt(node_idx: Int):
    needs_return := current_function_return_type != TID_VOID
    emit_match_as_if_chain(node_idx, true, needs_return)

fn emit_match_as_if_chain(node_idx: Int, is_stmt: Bool, needs_return: Bool):
    node := get_node(node_idx)
    # children: [subject, arm0, arm1, ...]
    subject_idx := node.children[0]
    if is_stmt:
        emit_match_stmt_chain(node_idx, needs_return)
    else:
        emit_match_expr_chain(node_idx)

fn emit_match_stmt_chain(node_idx: Int, needs_return: Bool):
    node := get_node(node_idx)
    subject_idx := node.children[0]
    # wrap in block scope
    write_indent()
    emit_code(LB + "\n")
    current_indent_level = current_indent_level + 1
    mut first := true
    mut has_if_else := false
    mut ai := 1
    while ai < node.children.len():
        arm := get_node(node.children[ai])
        # arm has children: [pattern, body]
        pattern_idx := arm.children[0]
        body_idx := arm.children[1]
        pattern := get_node(pattern_idx)
        if pattern.kind == "pat_wildcard":
            if has_if_else:
                write_indent()
                emit_code(RB + " else " + LB + "\n")
            elif first:
                write_indent()
                emit_code(LB + "\n")
            current_indent_level = current_indent_level + 1
            emit_match_body(body_idx, needs_return)
            current_indent_level = current_indent_level - 1
            has_if_else = true
        elif pattern.kind == "pat_binding":
            # binding pattern — emit directly in the match block scope
            # declare the binding variable with the subject's type
            sub_tid := c_get_expr_type(subject_idx)
            write_indent()
            emit_c_type(sub_tid)
            emit_code(" ")
            emit_code(pattern.value)
            emit_code(" = ")
            emit_expr(subject_idx)
            emit_code(";\n")
            local_variable_types.insert(pattern.value, sub_tid)
            emit_match_body(body_idx, needs_return)
        else:
            if first:
                write_indent()
                emit_code("if (")
            else:
                write_indent()
                emit_code(RB + " else if (")
            emit_pattern_condition(subject_idx, pattern_idx)
            emit_code(") " + LB + "\n")
            current_indent_level = current_indent_level + 1
            # check for variant binding patterns
            emit_variant_bindings(subject_idx, pattern_idx, body_idx)
            emit_match_body(body_idx, needs_return)
            current_indent_level = current_indent_level - 1
            has_if_else = true
        first = false
        ai = ai + 1
    if has_if_else:
        write_indent()
        emit_code(RB + "\n")
    # close block scope
    current_indent_level = current_indent_level - 1
    write_indent()
    emit_code(RB + "\n")

fn emit_match_body(body_idx: Int, needs_return: Bool):
    body := get_node(body_idx)
    # unwrap "body" wrapper node
    mut actual_idx := body_idx
    if body.kind == "body":
        if body.children.len() > 0:
            actual_idx = body.children[0]
    actual := get_node(actual_idx)
    if actual.kind == "block":
        emit_block(actual_idx)
    else:
        write_indent()
        if needs_return:
            if is_result_type(current_function_return_type):
                ret_c := get_c_type_string(current_function_return_type)
                emit_code("return (")
                emit_code(ret_c)
                emit_code(")" + LB + " .is_ok = true, .ok = ")
                emit_expr(actual_idx)
                emit_code(" " + RB + ";\n")
                return
            emit_code("return ")
        emit_expr(actual_idx)
        emit_code(";\n")

fn emit_match_expr_chain(node_idx: Int):
    node := get_node(node_idx)
    subject_idx := node.children[0]
    emit_code("(")
    mut ai := 1
    while ai < node.children.len():
        arm := get_node(node.children[ai])
        pattern_idx := arm.children[0]
        mut body_idx := arm.children[1]
        # unwrap "body" wrapper node
        body_node := get_node(body_idx)
        if body_node.kind == "body":
            if body_node.children.len() > 0:
                body_idx = body_node.children[0]
        pattern := get_node(pattern_idx)
        if pattern.kind == "pat_wildcard":
            emit_expr(body_idx)
        elif pattern.kind == "pat_binding":
            emit_expr(body_idx)
        else:
            emit_pattern_condition(subject_idx, pattern_idx)
            emit_code(" ? ")
            emit_expr(body_idx)
            emit_code(" : ")
        ai = ai + 1
    emit_code(")")

fn emit_pattern_condition(subject_idx: Int, pattern_idx: Int):
    pattern := get_node(pattern_idx)
    if pattern.kind == "pat_wildcard":
        emit_code("1")
        return
    if pattern.kind == "pat_binding":
        emit_code("1")
        return
    if pattern.kind == "pat_int":
        emit_expr(subject_idx)
        emit_code(" == ")
        emit_code(pattern.value)
        return
    if pattern.kind == "pat_float":
        emit_expr(subject_idx)
        emit_code(" == ")
        emit_code(pattern.value)
        return
    if pattern.kind == "pat_string":
        emit_code("forge_string_eq(")
        emit_expr(subject_idx)
        emit_code(", ")
        emit_string_lit(pattern.value)
        emit_code(")")
        return
    if pattern.kind == "pat_bool":
        emit_expr(subject_idx)
        emit_code(" == ")
        emit_code(pattern.value)
        return
    if pattern.kind == "pat_none":
        emit_code("0 /* None pattern */")
        return
    if pattern.kind == "pat_variant":
        # EnumName.Variant → check tag
        name := pattern.value
        mut dot_pos := -1
        mut di := 0
        while di < name.len():
            if name[di] == ".":
                dot_pos = di
            di = di + 1
        if dot_pos >= 0:
            enum_name := name.substring(0, dot_pos)
            variant := name.substring(dot_pos + 1, name.len())
            emit_expr(subject_idx)
            emit_code(".tag == ")
            emit_code(enum_name)
            emit_code("_TAG_")
            emit_code(variant)
        else:
            emit_code("1")
        return
    if pattern.kind == "pat_tuple":
        emit_code("1 /* tuple pattern */")
        return
    emit_code("1")

fn ast_contains_identifier(node_idx: Int, name: String) -> Bool:
    node := get_node(node_idx)
    if node.kind == "ident":
        if node.value == name:
            return true
    for child in node.children:
        if ast_contains_identifier(child, name):
            return true
    return false

fn emit_variant_bindings(subject_idx: Int, pattern_idx: Int, body_idx: Int):
    pattern := get_node(pattern_idx)
    if pattern.kind != "pat_variant":
        return
    if pattern.children.len() == 0:
        return
    # extract enum name and variant name
    name := pattern.value
    mut dot_pos := -1
    mut di := 0
    while di < name.len():
        if name[di] == ".":
            dot_pos = di
        di = di + 1
    if dot_pos < 0:
        return
    enum_name := name.substring(0, dot_pos)
    variant := name.substring(dot_pos + 1, name.len())
    # each child is a binding name for a variant field
    mut fi := 0
    for child in pattern.children:
        cn := get_node(child)
        binding_name := cn.value
        if binding_name == "_":
            fi = fi + 1
            continue
        # only emit if actually referenced in the body
        if not ast_contains_identifier(body_idx, binding_name):
            fi = fi + 1
            continue
        ftid := resolve_enum_field_type(enum_name, variant, fi)
        write_indent()
        emit_c_type(ftid)
        emit_code(" ")
        emit_code(binding_name)
        emit_code(" = ")
        emit_expr(subject_idx)
        emit_code(".data.")
        emit_code(variant)
        emit_code("._")
        emit_code(fi.to_string())
        emit_code(";\n")
        local_variable_types.insert(binding_name, ftid)
        fi = fi + 1

# ---------------------------------------------------------------
# capture detection
# ---------------------------------------------------------------

# detect variables captured from the enclosing scope by a lambda.
# pushes results into lambda_capture_names/lambda_capture_type_ids and
# returns the count of captures found.
fn detect_lambda_captures(node_idx: Int) -> Int:
    node := get_node(node_idx)
    # build set of param names
    mut param_names: Map[String, Bool] := {}
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "param":
            mut pname := cn.value
            # strip "mut " prefix if present
            if pname.starts_with("mut "):
                pname = pname.substring(4, pname.len())
            param_names.insert(pname, true)
    # collect identifiers from the body using the global map
    captured_identifiers = {}
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "body":
            if cn.children.len() > 0:
                body_child := get_node(cn.children[0])
                if body_child.kind == "block":
                    collect_block_identifiers(cn.children[0])
                else:
                    collect_expression_identifiers(cn.children[0])
    # filter: keep idents in local_variable_types but not in params or module scope
    mut count := 0
    for name in captured_identifiers.keys():
        if param_names.contains_key(name):
            continue
        # skip module-scope names (functions, types, globals)
        if lookup_binding(0, name) >= 0:
            continue
        if local_variable_types.contains_key(name):
            tid := local_variable_types[name]
            if tid != TID_ERR:
                lambda_capture_names.push(name)
                lambda_capture_type_ids.push(tid)
                count = count + 1
    return count

# recursively collect all identifier names from an expression tree.
# uses the global captured_identifiers map (can't pass mutable maps to functions).
fn collect_expression_identifiers(node_idx: Int):
    node := get_node(node_idx)
    if node.kind == "ident":
        captured_identifiers.insert(node.value, true)
        return
    # don't descend into nested lambdas — they have their own scope
    if node.kind == "lambda":
        return
    for child in node.children:
        collect_expression_identifiers(child)

# collect identifiers from a block (list of statements).
fn collect_block_identifiers(node_idx: Int):
    node := get_node(node_idx)
    for child in node.children:
        collect_statement_identifiers(child)

# collect identifiers from a single statement.
fn collect_statement_identifiers(node_idx: Int):
    node := get_node(node_idx)
    # don't descend into nested lambdas
    if node.kind == "lambda":
        return
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "lambda":
            continue
        collect_expression_identifiers(child)

# ---------------------------------------------------------------
# lambda
# ---------------------------------------------------------------

fn emit_lambda(node_idx: Int):
    node := get_node(node_idx)
    idx := lambda_counter
    lambda_counter = lambda_counter + 1
    # find the function type for this lambda
    fn_tid := find_lambda_function_type(node_idx)
    # detect captures from enclosing scope
    cap_offset := lambda_capture_names.len()
    cap_count := detect_lambda_captures(node_idx)
    # record for hoisting
    lambda_node_indices.push(idx)
    lambda_ast_nodes.push(node_idx)
    lambda_function_types.push(fn_tid)
    lambda_capture_counts.push(cap_count)
    lambda_capture_offsets.push(cap_offset)
    if cap_count > 0:
        # capturing lambda: heap-allocate env struct, build closure
        emit_code("(__extension__(" + LB + " __closure_env_")
        emit_code(idx.to_string())
        emit_code(" *__env_")
        emit_code(idx.to_string())
        emit_code(" = (__closure_env_")
        emit_code(idx.to_string())
        emit_code(" *)malloc(sizeof(__closure_env_")
        emit_code(idx.to_string())
        emit_code(")); ")
        # fill in captured variable values
        mut ci := 0
        while ci < cap_count:
            cap_name := lambda_capture_names[cap_offset + ci]
            cap_tid := lambda_capture_type_ids[cap_offset + ci]
            emit_code("__env_")
            emit_code(idx.to_string())
            emit_code("->")
            emit_code(cap_name)
            emit_code(" = ")
            emit_code(cap_name)
            emit_code("; ")
            # ARC: retain captured string variables
            if cap_tid == TID_STRING:
                emit_code("forge_string_retain(")
                emit_code(cap_name)
                emit_code("); ")
            ci = ci + 1
        emit_code("(forge_closure_t)" + LB + " (void*)__lambda_")
        emit_code(idx.to_string())
        emit_code(", (void*)__env_")
        emit_code(idx.to_string())
        emit_code(" " + RB + "; " + RB + "))")
    else:
        # non-capturing: closure with NULL env
        emit_code("(forge_closure_t)" + LB + " (void*)__lambda_")
        emit_code(idx.to_string())
        emit_code(", NULL " + RB)

fn find_lambda_function_type(node_idx: Int) -> Int:
    node := get_node(node_idx)
    # resolve param types
    mut param_tids: List[Int] := []
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "param":
            if cn.children.len() > 0:
                ptid := c_resolve_type(cn.children[0])
                param_tids.push(ptid)
                local_variable_types.insert(cn.value, ptid)
            else:
                return TID_ERR
        elif cn.kind == "body":
            # infer return type from body
            if cn.children.len() > 0:
                body_child := get_node(cn.children[0])
                if body_child.kind == "block":
                    # multi-line — return void
                    return scan_for_function_type(param_tids, TID_VOID)
                else:
                    ret_tid := c_get_expr_type(cn.children[0])
                    return scan_for_function_type(param_tids, ret_tid)
    return TID_ERR

fn scan_for_function_type(param_tids: List[Int], ret_tid: Int) -> Int:
    mut tid := 0
    while tid < tt_count():
        info := tt_get(tid)
        if info.kind == "function":
            if info.return_type == ret_tid:
                if info.param_types.len() == param_tids.len():
                    mut matched := true
                    mut pi := 0
                    for pt in info.param_types:
                        if pi < param_tids.len():
                            if pt != param_tids[pi]:
                                matched = false
                        pi = pi + 1
                    if matched:
                        return tid
        tid = tid + 1
    return TID_ERR

# ---------------------------------------------------------------
# try propagation
# ---------------------------------------------------------------

fn emit_try_binding(node_idx: Int, name: String, ok_tid: Int, value_idx: Int):
    inner_node := get_node(value_idx)
    # the try expr wraps an inner expression
    inner_idx := inner_node.children[0]
    result_tid := c_get_expr_type(inner_idx)
    result_c := get_c_type_string(result_tid)
    ok_c := get_c_type_string(ok_tid)
    try_name := "__try_" + try_block_counter.to_string()
    try_block_counter = try_block_counter + 1
    # emit: result_type __try_N = inner_expr;
    write_indent()
    emit_code(result_c)
    emit_code(" ")
    emit_code(try_name)
    emit_code(" = ")
    emit_expr(inner_idx)
    emit_code(";\n")
    # emit: if (!__try_N.is_ok) return (enclosing_result){ ... };
    write_indent()
    emit_code("if (!")
    emit_code(try_name)
    emit_code(".is_ok) return (")
    emit_code(get_c_type_string(current_function_return_type))
    emit_code(")" + LB + " .is_ok = false, .err = ")
    emit_code(try_name)
    emit_code(".err " + RB + ";\n")
    # emit: T x = __try_N.ok;
    write_indent()
    emit_code(ok_c)
    emit_code(" ")
    emit_code(name)
    emit_code(" = ")
    emit_code(try_name)
    emit_code(".ok;\n")

fn emit_try_expr_stmt(node_idx: Int):
    node := get_node(node_idx)
    inner_idx := node.children[0]
    result_tid := c_get_expr_type(inner_idx)
    result_c := get_c_type_string(result_tid)
    try_name := "__try_" + try_block_counter.to_string()
    try_block_counter = try_block_counter + 1
    write_indent()
    emit_code(result_c)
    emit_code(" ")
    emit_code(try_name)
    emit_code(" = ")
    emit_expr(inner_idx)
    emit_code(";\n")
    write_indent()
    emit_code("if (!")
    emit_code(try_name)
    emit_code(".is_ok) return (")
    emit_code(get_c_type_string(current_function_return_type))
    emit_code(")" + LB + " .is_ok = false, .err = ")
    emit_code(try_name)
    emit_code(".err " + RB + ";\n")

# ---------------------------------------------------------------
# global bindings
# ---------------------------------------------------------------

fn emit_global_bindings(root_idx: Int):
    root := get_node(root_idx)
    mut has_any := false
    # first pass: emit global variable declarations
    for child in root.children:
        mut node := get_node(child)
        if node.kind == "pub":
            node = get_node(node.children[0])
        if node.kind == "binding":
            has_any = true
            name := extract_binding_name(node.value)
            tid := get_binding_type(node)
            emit_c_type(tid)
            emit_code(" ")
            emit_code(name)
            emit_code(";\n")
            local_variable_types.insert(name, tid)
    if has_any == false:
        return
    has_global_variables = true
    emit_code("\n")
    # second pass: emit init function
    emit_code("void __forge_init_globals(void) " + LB + "\n")
    current_indent_level = current_indent_level + 1
    for child in root.children:
        mut node := get_node(child)
        if node.kind == "pub":
            node = get_node(node.children[0])
        if node.kind == "binding":
            name := extract_binding_name(node.value)
            value_idx := get_binding_value_node(node)
            if value_idx >= 0:
                write_indent()
                emit_code(name)
                emit_code(" = ")
                emit_expr(value_idx)
                emit_code(";\n")
    current_indent_level = current_indent_level - 1
    emit_code(RB + "\n\n")

# emit only global variable declarations (no init function)
fn emit_global_decls(root_idx: Int) -> Bool:
    root := get_node(root_idx)
    mut has_any := false
    for child in root.children:
        mut node := get_node(child)
        if node.kind == "pub":
            node = get_node(node.children[0])
        if node.kind == "binding":
            has_any = true
            name := extract_binding_name(node.value)
            tid := get_binding_type(node)
            emit_c_type(tid)
            emit_code(" ")
            emit_code(name)
            emit_code(";\n")
            local_variable_types.insert(name, tid)
    return has_any

# emit init body for one module's globals (inside __forge_init_globals)
fn emit_global_init_body(root_idx: Int):
    root := get_node(root_idx)
    for child in root.children:
        mut node := get_node(child)
        if node.kind == "pub":
            node = get_node(node.children[0])
        if node.kind == "binding":
            name := extract_binding_name(node.value)
            value_idx := get_binding_value_node(node)
            if value_idx >= 0:
                write_indent()
                emit_code(name)
                emit_code(" = ")
                emit_expr(value_idx)
                emit_code(";\n")

fn get_binding_type(node: Node) -> Int:
    # check for type annotation, otherwise infer from value
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "type":
            return c_resolve_type(child)
        if cn.kind == "generic_type":
            return c_resolve_type(child)
        if cn.kind == "optional_type":
            return c_resolve_type(child)
        if cn.kind == "result_type":
            return c_resolve_type(child)
    # infer from value (last child)
    if node.children.len() > 0:
        value_idx := node.children[node.children.len() - 1]
        return c_get_expr_type(value_idx)
    return TID_ERR

fn get_binding_value_node(node: Node) -> Int:
    # value is the last child that isn't a type annotation
    if node.children.len() > 0:
        last := node.children[node.children.len() - 1]
        cn := get_node(last)
        if cn.kind != "type":
            if cn.kind != "generic_type":
                if cn.kind != "optional_type":
                    if cn.kind != "result_type":
                        return last
    return -1

# ---------------------------------------------------------------
# function definitions
# ---------------------------------------------------------------

fn emit_fn_def(node_idx: Int, skip_main: Bool):
    node := get_node(node_idx)
    name := node.value
    if is_generic_type(name):
        return
    if test_mode:
        if name == "main":
            return
    if skip_main:
        if name == "main":
            return
    local_variable_types = {}
    # track return type
    current_function_return_type = resolve_function_return_type(node_idx)
    # register params as locals
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "param":
            if cn.children.len() > 0:
                ptid := c_resolve_type(cn.children[0])
                local_variable_types.insert(cn.value, ptid)
    if name == "main":
        emit_code("int main(int __argc, char **__argv) " + LB + "\n")
        current_indent_level = current_indent_level + 1
        write_indent()
        emit_code("forge_set_args(__argc, __argv);\n")
        if has_global_variables:
            write_indent()
            emit_code("__forge_init_globals();\n")
        current_indent_level = current_indent_level - 1
    else:
        emit_return_type(node_idx)
        emit_code(" fg_")
        emit_code(name)
        emit_param_list(node_idx)
        emit_code(" " + LB + "\n")
    current_indent_level = current_indent_level + 1
    # emit body
    emit_fn_body(node_idx)
    # ARC: cleanup function-level locals before return (for functions without explicit return)
    emit_scope_cleanup_at_level(0)
    if name == "main":
        write_indent()
        emit_code("return 0;\n")
    current_indent_level = current_indent_level - 1
    emit_code(RB + "\n\n")

fn emit_fn_body(node_idx: Int):
    node := get_node(node_idx)
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "body":
            if cn.children.len() > 0:
                emit_block(cn.children[0])
            return

fn resolve_function_return_type(node_idx: Int) -> Int:
    node := get_node(node_idx)
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "returns":
            if cn.children.len() > 0:
                return c_resolve_type(cn.children[0])
    return TID_VOID

# ---------------------------------------------------------------
# method definitions
# ---------------------------------------------------------------

fn emit_impl_method_defs(node_idx: Int):
    type_name := get_implementation_type_name(node_idx)
    if type_name == "":
        return
    node := get_node(node_idx)
    method_start := get_implementation_method_start(node_idx)
    mut skip := method_start
    for child in node.children:
        if skip > 0:
            skip = skip - 1
            continue
        mut cn := get_node(child)
        mut method_idx := child
        if cn.kind == "pub":
            method_idx = cn.children[0]
            cn = get_node(method_idx)
        if cn.kind == "fn_decl":
            emit_method_def(type_name, method_idx)

fn emit_method_def(type_name: String, node_idx: Int):
    node := get_node(node_idx)
    if is_generic_type(node.value):
        return
    local_variable_types = {}
    current_function_return_type = resolve_function_return_type(node_idx)
    # register self as local
    self_tid := tt_lookup(type_name)
    if self_tid >= 0:
        local_variable_types.insert("self", self_tid)
    # register params
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "param":
            if cn.children.len() > 0:
                ptid := c_resolve_type(cn.children[0])
                local_variable_types.insert(cn.value, ptid)
    # emit signature
    emit_return_type(node_idx)
    emit_code(" ")
    emit_code(type_name)
    emit_code("_")
    emit_code(node.value)
    emit_code("(")
    emit_code(type_name)
    emit_code(" self")
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "param":
            emit_code(", ")
            if cn.children.len() > 0:
                type_node := get_node(cn.children[0])
                if type_node.kind == "fn_type":
                    emit_fn_ptr_param(cn.children[0], cn.value)
                else:
                    emit_type_expr(cn.children[0])
                    emit_code(" ")
                    emit_code(cn.value)
            else:
                emit_code("/* unknown */ ")
                emit_code(cn.value)
    emit_code(") " + LB + "\n")
    current_indent_level = current_indent_level + 1
    emit_fn_body(node_idx)
    current_indent_level = current_indent_level - 1
    emit_code(RB + "\n\n")

# ---------------------------------------------------------------
# instantiated generic function definitions
# ---------------------------------------------------------------

fn emit_instantiated_fns_from_root(root_idx: Int):
    # emit definitions for all collected generic function instances
    mut i := 0
    while i < generic_function_instances.len():
        inst_name := generic_function_instances[i]
        fn_node_idx := generic_function_ast_nodes[i]
        fn_node := get_node(fn_node_idx)
        subst := build_substitution_map(fn_node.value, inst_name)
        mangled := mangle_identifier(inst_name)
        # resolve return type
        ret_tid := resolve_function_return_with_substitution(fn_node_idx, subst)
        # set up local types for body emission
        local_variable_types = {}
        current_function_return_type = ret_tid
        for child in fn_node.children:
            cn := get_node(child)
            if cn.kind == "param":
                if cn.children.len() > 0:
                    ptid := resolve_type_with_substitution(cn.children[0], subst)
                    local_variable_types.insert(cn.value, ptid)
        # emit signature
        emit_code(get_c_type_string(ret_tid))
        emit_code(" fg_")
        emit_code(mangled)
        emit_code("(")
        mut first := true
        for child in fn_node.children:
            cn := get_node(child)
            if cn.kind == "param":
                if first == false:
                    emit_code(", ")
                first = false
                if cn.children.len() > 0:
                    ptid := resolve_type_with_substitution(cn.children[0], subst)
                    emit_code(get_c_type_string(ptid))
                emit_code(" ")
                emit_code(cn.value)
        emit_code(") " + LB + "\n")
        current_indent_level = current_indent_level + 1
        emit_fn_body(fn_node_idx)
        current_indent_level = current_indent_level - 1
        emit_code(RB + "\n\n")
        i = i + 1

# ---------------------------------------------------------------
# test definitions
# ---------------------------------------------------------------

fn emit_test_def(node_idx: Int):
    node := get_node(node_idx)
    index := test_function_names.len()
    test_function_names.push(node.value)
    local_variable_types = {}
    current_function_return_type = TID_VOID
    emit_code("static void __test_")
    emit_code(index.to_string())
    emit_code("(void) " + LB + "\n")
    current_indent_level = current_indent_level + 1
    # emit body
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "block":
            emit_block(child)
    current_indent_level = current_indent_level - 1
    emit_code(RB + "\n\n")

fn emit_test_runner_main():
    emit_code("int main(int __argc, char **__argv) " + LB + "\n")
    current_indent_level = current_indent_level + 1
    write_indent()
    emit_code("forge_set_args(__argc, __argv);\n")
    write_indent()
    emit_code("int __passed = 0, __failed = 0;\n")
    mut i := 0
    while i < test_function_names.len():
        name := test_function_names[i]
        display := strip_quotes(name)
        emit_code("\n")
        write_indent()
        emit_code("__current_test_failed = 0;\n")
        write_indent()
        emit_code("fprintf(stderr, \"test \\\"")
        emit_code(display)
        emit_code("\\\"... \");\n")
        write_indent()
        emit_code("__test_")
        emit_code(i.to_string())
        emit_code("();\n")
        write_indent()
        emit_code("if (__current_test_failed) " + LB + " __failed++; fprintf(stderr, \"FAILED\\n\"); " + RB + "\n")
        write_indent()
        emit_code("else " + LB + " __passed++; fprintf(stderr, \"ok\\n\"); " + RB + "\n")
        i = i + 1
    emit_code("\n")
    write_indent()
    emit_code("fprintf(stderr, \"\\n%d passed, %d failed\\n\", __passed, __failed);\n")
    write_indent()
    emit_code("return __failed > 0 ? 1 : 0;\n")
    current_indent_level = current_indent_level - 1
    emit_code(RB + "\n")

# ---------------------------------------------------------------
# hoisted lambdas
# ---------------------------------------------------------------

fn emit_hoisted_lambdas():
    mut li := 0
    while li < lambda_node_indices.len():
        idx := lambda_node_indices[li]
        lam_node_idx := lambda_ast_nodes[li]
        fn_tid := lambda_function_types[li]
        cap_count := lambda_capture_counts[li]
        cap_offset := lambda_capture_offsets[li]
        if fn_tid < 0:
            li = li + 1
            continue
        if fn_tid >= tt_count():
            li = li + 1
            continue
        info := tt_get(fn_tid)
        if info.kind != "function":
            li = li + 1
            continue
        lam_node := get_node(lam_node_idx)
        # emit: static return_type __lambda_N(void *__env, params...) { body }
        emit_code("static ")
        emit_code(get_c_type_string(info.return_type))
        emit_code(" __lambda_")
        emit_code(idx.to_string())
        emit_code("(void *__env")
        # collect params from lambda node
        mut pi := 0
        for child in lam_node.children:
            cn := get_node(child)
            if cn.kind == "param":
                emit_code(", ")
                if pi < info.param_types.len():
                    emit_code(get_c_type_string(info.param_types[pi]))
                emit_code(" ")
                emit_code(cn.value)
                pi = pi + 1
        emit_code(") " + LB + "\n")
        current_indent_level = current_indent_level + 1
        # for capturing lambdas, unpack the env struct
        if cap_count > 0:
            write_indent()
            emit_code("__closure_env_")
            emit_code(idx.to_string())
            emit_code(" *__captures = (__closure_env_")
            emit_code(idx.to_string())
            emit_code(" *)__env;\n")
            # create local aliases for captured variables
            mut ci := 0
            while ci < cap_count:
                cap_name := lambda_capture_names[cap_offset + ci]
                cap_tid := lambda_capture_type_ids[cap_offset + ci]
                write_indent()
                emit_code(get_c_type_string(cap_tid))
                emit_code(" ")
                emit_code(cap_name)
                emit_code(" = __captures->")
                emit_code(cap_name)
                emit_code(";\n")
                ci = ci + 1
        # emit body
        emit_lambda_body(lam_node_idx, info.return_type)
        # ARC: release captured string variables before returning
        if cap_count > 0:
            mut ci := 0
            while ci < cap_count:
                cap_name := lambda_capture_names[cap_offset + ci]
                cap_tid := lambda_capture_type_ids[cap_offset + ci]
                if cap_tid == TID_STRING:
                    write_indent()
                    emit_code("forge_string_release(")
                    emit_code(cap_name)
                    emit_code(");\n")
                ci = ci + 1
        current_indent_level = current_indent_level - 1
        emit_code(RB + "\n\n")
        li = li + 1

fn emit_lambda_body(node_idx: Int, ret_type: Int):
    node := get_node(node_idx)
    for child in node.children:
        cn := get_node(child)
        if cn.kind == "body":
            if cn.children.len() > 0:
                body := get_node(cn.children[0])
                if body.kind == "block":
                    emit_block(cn.children[0])
                else:
                    write_indent()
                    emit_code("return ")
                    emit_expr(cn.children[0])
                    emit_code(";\n")
            return

fn build_lambda_forward_declarations():
    mut li := 0
    while li < lambda_node_indices.len():
        idx := lambda_node_indices[li]
        fn_tid := lambda_function_types[li]
        lam_node_idx := lambda_ast_nodes[li]
        cap_count := lambda_capture_counts[li]
        cap_offset := lambda_capture_offsets[li]
        if fn_tid < 0:
            li = li + 1
            continue
        if fn_tid >= tt_count():
            li = li + 1
            continue
        info := tt_get(fn_tid)
        if info.kind != "function":
            li = li + 1
            continue
        lam_node := get_node(lam_node_idx)
        # emit env struct typedef for capturing lambdas
        if cap_count > 0:
            mut env_decl := "typedef struct " + LB + " "
            mut ci := 0
            while ci < cap_count:
                cap_name := lambda_capture_names[cap_offset + ci]
                cap_tid := lambda_capture_type_ids[cap_offset + ci]
                env_decl = env_decl + get_c_type_string(cap_tid) + " " + cap_name + "; "
                ci = ci + 1
            env_decl = env_decl + RB + " __closure_env_" + idx.to_string() + ";\n"
            lambda_forward_buffer.push(env_decl)
        # all lambdas take void* __env as first param (uniform closure ABI)
        mut fwd := "static "
        fwd = fwd + get_c_type_string(info.return_type)
        fwd = fwd + " __lambda_"
        fwd = fwd + idx.to_string()
        fwd = fwd + "(void *__env"
        mut pi := 0
        for child in lam_node.children:
            cn := get_node(child)
            if cn.kind == "param":
                fwd = fwd + ", "
                if pi < info.param_types.len():
                    fwd = fwd + get_c_type_string(info.param_types[pi])
                fwd = fwd + " "
                fwd = fwd + cn.value
                pi = pi + 1
        fwd = fwd + ");\n"
        lambda_forward_buffer.push(fwd)
        li = li + 1

# ---------------------------------------------------------------
# module emission — top-level orchestrator
# ---------------------------------------------------------------

pub fn emit_module(root_idx: Int):
    root_node_index = root_idx
    # pre-scan: collect generic function instantiations before emission
    collect_generic_function_instances(root_idx)
    emit_preamble()
    root := get_node(root_idx)

    # pre-bucket children by kind in a single pass (avoids 6 repeated scans)
    mut struct_decls: List[Int] := []
    mut enum_decls: List[Int] := []
    mut type_alias_decls: List[Int] := []
    mut fn_decls: List[Int] := []
    mut impl_decls: List[Int] := []
    mut test_decls: List[Int] := []
    for child in root.children:
        mut node := get_node(child)
        mut decl_idx := child
        if node.kind == "pub":
            decl_idx = node.children[0]
            node = get_node(decl_idx)
        if node.kind == "struct_decl":
            struct_decls.push(decl_idx)
        elif node.kind == "enum_decl":
            enum_decls.push(decl_idx)
        elif node.kind == "type_alias":
            type_alias_decls.push(decl_idx)
        elif node.kind == "fn_decl":
            fn_decls.push(decl_idx)
        elif node.kind == "impl_decl":
            impl_decls.push(decl_idx)
        elif node.kind == "test_decl":
            test_decls.push(child)

    # pass 1: struct definitions
    for decl_idx in struct_decls:
        emit_struct_def(decl_idx)

    # pass 1b: instantiated generic structs
    emit_instantiated_structs(root_idx)

    # pass 2: enum definitions
    for decl_idx in enum_decls:
        emit_enum_def(decl_idx)

    # pass 2b: result/optional/tuple typedefs
    emit_wrapper_typedefs("result", "forge_result_", emitted_result_types)
    emit_wrapper_typedefs("optional", "forge_optional_", emitted_optional_types)
    emit_tuple_typedefs()

    # pass 2c: builtin helpers
    emit_builtin_helpers()

    # pass 2d: type alias typedefs
    for decl_idx in type_alias_decls:
        emit_type_alias(decl_idx)

    # pass 3: function forward declarations
    for decl_idx in fn_decls:
        emit_fn_forward_decl(decl_idx, false)

    # pass 3b: method forward declarations
    for decl_idx in impl_decls:
        emit_impl_forward_decls(decl_idx)

    # pass 3c: instantiated generic function forward declarations
    emit_instantiated_fn_forward_decls()
    emit_code("\n")

    # pass 3d: global bindings
    emit_global_bindings(root_idx)

    # mark position for lambda forward declarations
    lambda_forward_position = codegen_buffer.len()

    # pass 4: function definitions
    for decl_idx in fn_decls:
        emit_fn_def(decl_idx, false)

    # pass 5: method definitions
    for decl_idx in impl_decls:
        emit_impl_method_defs(decl_idx)

    # pass 6: instantiated generic function definitions
    emit_instantiated_fns_from_root(root_idx)

    # pass 6b: test definitions
    if test_mode:
        emit_code("int __current_test_failed = 0;\n\n")
        for decl_idx in test_decls:
            emit_test_def(decl_idx)

    # pass 7: hoisted lambda functions
    if lambda_node_indices.len() > 0:
        build_lambda_forward_declarations()
        emit_hoisted_lambdas()
        # insert forward declarations at the marked position
        insert_lambda_forward_declarations()

    # pass 7b: hoisted spawn wrappers
    if spawn_node_indices.len() > 0:
        build_spawn_forward_declarations()
        emit_hoisted_spawns()
        insert_lambda_forward_declarations()

    # pass 8: test runner main
    if test_mode:
        emit_test_runner_main()

# emit C for multiple module roots (multi-module compilation).
# roots should be in dependency order — imported modules first, main last.
pub fn emit_modules(roots: List[Int]):
    main_root := roots[roots.len() - 1]
    root_node_index = main_root

    # pre-scan all modules for generic function instantiations
    for root in roots:
        collect_generic_function_instances(root)

    emit_preamble()

    # pass 1: struct definitions from all modules
    for root in roots:
        r := get_node(root)
        for child in r.children:
            mut node := get_node(child)
            mut decl_idx := child
            if node.kind == "pub":
                decl_idx = node.children[0]
                node = get_node(decl_idx)
            if node.kind == "struct_decl":
                emit_struct_def(decl_idx)

    # pass 1b: instantiated generic structs from all modules
    for root in roots:
        emit_instantiated_structs(root)

    # pass 2: enum definitions from all modules
    for root in roots:
        r := get_node(root)
        for child in r.children:
            mut node := get_node(child)
            mut decl_idx := child
            if node.kind == "pub":
                decl_idx = node.children[0]
                node = get_node(decl_idx)
            if node.kind == "enum_decl":
                emit_enum_def(decl_idx)

    # pass 2b: result/optional/tuple typedefs (once, covers all modules)
    emit_wrapper_typedefs("result", "forge_result_", emitted_result_types)
    emit_wrapper_typedefs("optional", "forge_optional_", emitted_optional_types)
    emit_tuple_typedefs()

    # pass 2c: builtin helpers (once)
    emit_builtin_helpers()

    # pass 2d: type alias typedefs from all modules
    for root in roots:
        r := get_node(root)
        for child in r.children:
            mut node := get_node(child)
            mut decl_idx := child
            if node.kind == "pub":
                decl_idx = node.children[0]
                node = get_node(decl_idx)
            if node.kind == "type_alias":
                emit_type_alias(decl_idx)

    # pass 3: function forward declarations from all modules
    for root in roots:
        is_import := root != main_root
        r := get_node(root)
        for child in r.children:
            mut node := get_node(child)
            mut decl_idx := child
            if node.kind == "pub":
                decl_idx = node.children[0]
                node = get_node(decl_idx)
            if node.kind == "fn_decl":
                emit_fn_forward_decl(decl_idx, is_import)

    # pass 3b: method forward declarations from all modules
    for root in roots:
        r := get_node(root)
        for child in r.children:
            mut node := get_node(child)
            mut decl_idx := child
            if node.kind == "pub":
                decl_idx = node.children[0]
                node = get_node(decl_idx)
            if node.kind == "impl_decl":
                emit_impl_forward_decls(decl_idx)

    # pass 3c: instantiated generic function forward declarations
    emit_instantiated_fn_forward_decls()
    emit_code("\n")

    # pass 3d: global declarations from all modules
    mut has_globals := false
    for root in roots:
        if emit_global_decls(root):
            has_globals = true
    # combined __forge_init_globals for all modules
    if has_globals:
        has_global_variables = true
        emit_code("\n")
        emit_code("void __forge_init_globals(void) " + LB + "\n")
        current_indent_level = current_indent_level + 1
        for root in roots:
            emit_global_init_body(root)
        current_indent_level = current_indent_level - 1
        emit_code(RB + "\n\n")

    # mark position for lambda forward declarations
    lambda_forward_position = codegen_buffer.len()

    # pass 4: function definitions from all modules
    for root in roots:
        is_import := root != main_root
        r := get_node(root)
        for child in r.children:
            mut node := get_node(child)
            mut decl_idx := child
            if node.kind == "pub":
                decl_idx = node.children[0]
                node = get_node(decl_idx)
            if node.kind == "fn_decl":
                emit_fn_def(decl_idx, is_import)

    # pass 5: method definitions from all modules
    for root in roots:
        r := get_node(root)
        for child in r.children:
            mut node := get_node(child)
            mut decl_idx := child
            if node.kind == "pub":
                decl_idx = node.children[0]
                node = get_node(decl_idx)
            if node.kind == "impl_decl":
                emit_impl_method_defs(decl_idx)

    # pass 6: instantiated generic function definitions
    for root in roots:
        emit_instantiated_fns_from_root(root)

    # pass 6b: test definitions (main module only)
    if test_mode:
        emit_code("int __current_test_failed = 0;\n\n")
        r := get_node(main_root)
        for child in r.children:
            mut node := get_node(child)
            if node.kind == "test_decl":
                emit_test_def(child)

    # pass 7: hoisted lambda functions
    if lambda_node_indices.len() > 0:
        build_lambda_forward_declarations()
        emit_hoisted_lambdas()
        insert_lambda_forward_declarations()

    # pass 7b: hoisted spawn wrappers
    if spawn_node_indices.len() > 0:
        build_spawn_forward_declarations()
        emit_hoisted_spawns()
        insert_lambda_forward_declarations()

    # pass 8: test runner main
    if test_mode:
        emit_test_runner_main()

fn insert_lambda_forward_declarations():
    if lambda_forward_buffer.len() == 0:
        return
    # reconstruct the buffer with fwd decls inserted at lambda_forward_position
    fwd_str := lambda_forward_buffer.join("")
    mut new_buf: List[String] := []
    mut i := 0
    while i < lambda_forward_position:
        new_buf.push(codegen_buffer[i])
        i = i + 1
    new_buf.push(fwd_str)
    while i < codegen_buffer.len():
        new_buf.push(codegen_buffer[i])
        i = i + 1
    codegen_buffer = new_buf

# ---------------------------------------------------------------
# spawn wrapper hoisting
# ---------------------------------------------------------------

fn build_spawn_forward_declarations():
    # build per-spawn struct typedefs and wrapper forward declarations
    # these get inserted at the same lambda fwd position
    mut si := 0
    while si < spawn_node_indices.len():
        idx := spawn_node_indices[si]
        ret_type := spawn_return_types[si]
        arg_count := spawn_argument_counts[si]
        arg_offset := spawn_argument_offsets[si]
        ret_c := get_c_type_string(ret_type)
        # struct typedef: typedef struct { forge_task_header_t __header; [ret_type __value;] arg_types... } __spawn_data_N;
        mut s := "typedef struct " + LB + " forge_task_header_t __header; "
        if ret_type != TID_VOID:
            s = s + ret_c + " __value; "
        mut ai := 0
        while ai < arg_count:
            s = s + get_c_type_string(spawn_argument_type_ids[arg_offset + ai]) + " __arg_" + ai.to_string() + "; "
            ai = ai + 1
        s = s + RB + " __spawn_data_" + idx.to_string() + ";\n"
        lambda_forward_buffer.push(s)
        # wrapper forward declaration
        lambda_forward_buffer.push("static void *__spawn_wrapper_" + idx.to_string() + "(void *__arg);\n")
        si = si + 1

fn emit_hoisted_spawns():
    # emit spawn wrapper function bodies
    mut si := 0
    while si < spawn_node_indices.len():
        idx := spawn_node_indices[si]
        fn_name := spawn_function_names[si]
        ret_type := spawn_return_types[si]
        arg_count := spawn_argument_counts[si]
        # static void *__spawn_wrapper_N(void *__arg) {
        #     __spawn_data_N *__data = (__spawn_data_N *)__arg;
        #     __data->__value = fg_funcname(__data->__arg_0, ...);  // or just call if void
        #     return NULL;
        # }
        emit_code("static void *__spawn_wrapper_")
        emit_code(idx.to_string())
        emit_code("(void *__arg) " + LB + "\n")
        emit_code("    __spawn_data_")
        emit_code(idx.to_string())
        emit_code(" *__data = (__spawn_data_")
        emit_code(idx.to_string())
        emit_code(" *)__arg;\n")
        if ret_type == TID_VOID:
            emit_code("    fg_")
        else:
            emit_code("    __data->__value = fg_")
        emit_code(fn_name)
        emit_code("(")
        mut ai := 0
        while ai < arg_count:
            if ai > 0:
                emit_code(", ")
            emit_code("__data->__arg_")
            emit_code(ai.to_string())
            ai = ai + 1
        emit_code(");\n    return NULL;\n" + RB + "\n\n")
        si = si + 1
