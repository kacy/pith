# environment and argument access

fn main():
    # PATH should always exist
    path := env("PATH")
    print("has PATH: " + (path.len() > 0).to_string())

    # nonexistent var returns empty
    missing := env("PITH_NONEXISTENT_VAR_12345")
    print("missing is empty: " + (missing.len() == 0).to_string())

    # args returns a list
    a := args()
    print("has args: " + (a.len() >= 0).to_string())

    print("env ops work")
