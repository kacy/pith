import std.bytes as bytes
import std.io as io
import std.net.http as http

fn main() -> String!:
    crlf := chr(13) + chr(10)
    raw := "HTTP/1.1 200 OK" + crlf + "Content-Type: text/plain" + crlf + "Content-Length: 4" + crlf + "Connection: keep-alive" + crlf + crlf + "/one" + "HTTP/1.1 200 OK" + crlf + "Content-Type: text/plain" + crlf + "Content-Length: 4" + crlf + "Connection: close" + crlf + crlf + "/two"
    reader := io.bytes_reader(bytes.from_string_utf8(raw)).buffered_chunked(4)
    first := http.read_response_buffered_bytes(reader)!
    second := http.read_response_buffered_bytes(reader)!

    print("first:" + first.body_text()!)
    print("first-connection:" + first.header_value("Connection"))
    print("second:" + second.body_text()!)
    print("second-connection:" + second.header_value("Connection"))
    return ""
