    define_builtin_function("byte_buffer_write_string_utf8", create_function_type([TID_INT, TID_STRING], int_result))
    define_builtin_function("byte_buffer_write_byte", create_function_type([TID_INT, TID_INT], int_result))
    define_builtin_function("byte_buffer_bytes", create_function_type([TID_INT], tid_bytes))
    define_builtin_function("byte_buffer_len", create_function_type([TID_INT], TID_INT))
    define_builtin_function("byte_buffer_get", create_function_type([TID_INT, TID_INT], TID_INT))
    define_builtin_function("byte_buffer_set", create_function_type([TID_INT, TID_INT, TID_INT], TID_BOOL))
    define_builtin_function("byte_buffer_clear", create_function_type([TID_INT], TID_VOID))
    # (Int, Int) -> String!
