# test_example — demonstrates the forge test framework
#
# run with: forge test examples/test_example.fg

fn add(a: Int, b: Int) -> Int:
    return a + b

fn double(x: Int) -> Int:
    return x * 2

fn greet(name: String) -> String:
    return "hello, " + name

test "addition":
    assert_eq(add(1, 2), 3)
    assert_eq(add(0, 0), 0)
    assert_eq(add(-1, 1), 0)

test "doubling":
    assert_eq(double(5), 10)
    assert_ne(double(3), 5)

test "string equality":
    assert_eq(greet("world"), "hello, world")
    assert_ne(greet("forge"), "hello, world")

test "basic assertions":
    assert(true)
    assert(1 == 1)
    assert(2 + 2 == 4)
