# file operations — stream and path-based fs helpers

import std.fs as fs
import std.io as io

fn main() -> String!:
    path := "/tmp/forge_test_file_ops.txt"

    # write through the shared file stream path
    writer := fs.create(path)!
    io.write_text(writer, "hello from forge")!
    writer.close()
    print("write: ok")

    # read back through the same stream surface
    reader := fs.open(path)!
    content := io.read_text(reader)!
    reader.close()
    if content.contains("hello"):
        print("read: ok")

    # exists
    if fs.exists(path):
        print("exists: ok")

    # read by size
    size := content.len()
    print("size: " + size.to_string())

    # clean up
    fs.remove(path)
    if not fs.exists(path):
        print("remove: ok")

    # stream a known file too
    hello_reader := fs.open("examples/hello.fg")!
    hello := io.read_text(hello_reader)!
    hello_reader.close()
    if hello.contains("greet"):
        print("read hello.fg: ok")

    print("file ops work")
    return ""
