                    _kids40 := fcn.children
                    while _fi40 < _kids40.len():
                        rc := _kids40[_fi40]
                        rn := get_node(rc)
                        if rn.kind == "type" or rn.kind == "generic_type":
                            ir_func_returns.insert(cn.value, ir_resolve_type_node(rc))

                        _fi40 = _fi40 + 1
                _fi35 = _fi35 + 1
        _fi24 = _fi24 + 1
    # emit global variables (unwrap pub)
    mut _fi25 := 0
    _kids25 := root.children
    while _fi25 < _kids25.len():
        child := _kids25[_fi25]
        mut cn := get_node(child)
        if cn.kind == "pub" and cn.children.len() > 0:
            cn = get_node(cn.children[0])
        if cn.kind == "bind" or cn.kind == "binding":
            mut gname := cn.value
            if gname.contains(" mut"):
                gname = gname.substring(0, gname.len() - 4)
            elif gname.contains(" "):
                gname = gname.split(" ")[0]
            # find initial value
            mut init_val := "0"
            mut global_type := ""
            print("[g] bind " + gname)
            mut _fi36 := 0
            _kids36 := cn.children
            while _fi36 < _kids36.len():
                gc := _kids36[_fi36]
                gcn := get_node(gc)
                print("[g] child " + gcn.kind + " " + gcn.value)
                if gcn.kind == "type" or gcn.kind == "generic_type":
                    global_type = ir_resolve_type_node(gc)
                elif gcn.kind == "int_lit":
                    init_val = gcn.value
                    if global_type.len() == 0:
                        global_type = "int"
                elif gcn.kind == "string_lit":
                    si := ir_str(gcn.value)
                    init_val = "str:" + si
                    if global_type.len() == 0:
                        global_type = "string"
                elif gcn.kind == "list":
                    init_val = "list"
                    if global_type.len() == 0:
                        global_type = "list"
                elif gcn.kind == "map":
                    init_val = "map"
                    if global_type.len() == 0:
                        global_type = "map"
                elif gcn.kind == "set":
                    init_val = "set"
                    if global_type.len() == 0:
                        global_type = "set"
                elif gcn.kind == "bool_lit":
                    if gcn.value == "true":
                        init_val = "1"
                    else:
                        init_val = "0"
                    if global_type.len() == 0:
                        global_type = "bool"
                _fi36 = _fi36 + 1
            print("[g] final " + gname + " init=" + init_val + " type=" + global_type)
            if global_type.len() > 0:
                if global_type == "int":
                    ir_global_int_names.push(gname)
                elif global_type == "string":
                    ir_global_string_names.push(gname)
                elif global_type == "list_string":
                    ir_global_list_string_names.push(gname)
                elif global_type == "list":
                    ir_global_list_names.push(gname)
                elif global_type == "map_int":
                    ir_global_map_int_names.push(gname)
                elif global_type == "map":
                    ir_global_map_names.push(gname)
                elif global_type == "set":
                    ir_global_set_names.push(gname)
                elif global_type == "bool":
                    ir_global_bool_names.push(gname)
            ir_emit("global " + gname + " " + init_val)

        _fi25 = _fi25 + 1
    # emit __init_globals to initialize list/map/set globals
    mut has_collection_globals := false
    mut _fi26 := 0
    _kids26 := root.children
    while _fi26 < _kids26.len():
        child := _kids26[_fi26]
        mut cn := get_node(child)
