# method calls via impl blocks

struct Point:
    pub x: Int
    pub y: Int

impl Point:
    fn magnitude(a: Int) -> Int:
        return a

interface Display:
    fn show(x: String) -> String

impl Display for Point:
    fn show(x: String) -> String:
        return x

fn main():
    p := Point(1, 2)
    m := p.magnitude(5)
    s := p.show("hello")
    print(s)
