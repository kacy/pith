from lambda_capture_helper import imported_add_one

fn apply(x: Int, f: fn(Int) -> Int) -> Int:
    return f(x)

fn make_adder(v: Int) -> fn(Int) -> Int:
    return fn(x: Int) => x + v

fn make_nested(v: Int) -> fn(Int) -> fn() -> Int:
    return fn(x: Int) => fn() => x + v

fn make_imported_reader(v: Int) -> fn() -> Int:
    return fn() => imported_add_one(v)

fn main():
    add2 := make_adder(2)
    add5 := make_adder(5)
    print("multi-1:{add2(10)}")
    print("multi-2:{add5(10)}")

    outer := make_nested(3)
    inner := outer(4)
    print("nested:{inner()}")

    imported_reader := make_imported_reader(9)
    print("imported:{imported_reader()}")

    y := 10
    print("inline:{apply(5, fn(x: Int) => x + y)}")
