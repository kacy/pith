# collection literals and type annotations

fn main():
    # list literals
    numbers := [1, 2, 3]
    names := ["alice", "bob", "charlie"]

    # map literals
    ages := {"alice": 30, "bob": 25}

    # set literals
    tags := {"rust", "zig", "forge"}

    # nested collections
    matrix := [[1, 2], [3, 4]]

    print("ok")
