# std.testing — lightweight testing helpers
#
#   from std.testing import assert_eq, assert_ne, check_true, check_not, done
#
#   fn main():
#       assert_eq(1 + 1, 2)
#       assert_eq("hello", "hello")
#       assert_ne(2 + 2, 5)
#       check_true(10 > 5, "comparison")
#       done()

import std.fs as fs

mut pass_count: Int := 0
mut fail_count: Int := 0
mut silent: Bool := false

fn reset_counts():
    pass_count = 0
    fail_count = 0
    silent = false

fn silence_output():
    silent = true

fn record_pass(name: String):
    pass_count = pass_count + 1
    if silent:
        return
    print("  ok   " + name)

fn record_fail(name: String, detail: String):
    fail_count = fail_count + 1
    if silent:
        return
    print("  FAIL " + name + " -- " + detail)

# assert that two values are equal.
pub fn assert_eq[T](got: T, want: T):
    if got == want:
        record_pass("assert_eq")
    else:
        record_fail("assert_eq", "got {got}, want {want}")

# assert that two values are different.
pub fn assert_ne[T](left: T, right: T):
    if left != right:
        record_pass("assert_ne")
    else:
        record_fail("assert_ne", "values should differ: {left}")

# two integers are equal
pub fn check(got: Int, want: Int, name: String):
    if got != want:
        detail := "got " + got.to_string() + ", want " + want.to_string()
        record_fail(name, detail)
        return
    record_pass(name)

# two strings are equal
pub fn check_str(got: String, want: String, name: String):
    if got != want:
        detail := "got " + chr(34) + got + chr(34) + ", want " + chr(34) + want + chr(34)
        record_fail(name, detail)
        return
    record_pass(name)

# two integers differ
pub fn check_ne(a: Int, b: Int, name: String):
    if a == b:
        record_fail(name, "values should differ")
        return
    record_pass(name)

# condition is true
pub fn check_true(cond: Bool, name: String):
    if not cond:
        record_fail(name, "expected true")
        return
    record_pass(name)

# condition is false
pub fn check_not(cond: Bool, name: String):
    if cond:
        record_fail(name, "expected false")
        return
    record_pass(name)

# assert that a condition is true.
pub fn assert_true(cond: Bool):
    if cond:
        record_pass("assert_true")
    else:
        record_fail("assert_true", "expected true")

# assert that a condition is false.
pub fn assert_false(cond: Bool):
    if not cond:
        record_pass("assert_false")
    else:
        record_fail("assert_false", "expected false")

# assert that a string contains the expected substring.
pub fn assert_contains(text: String, part: String):
    if text.contains(part):
        record_pass("assert_contains")
    else:
        record_fail("assert_contains", "missing substring: " + chr(34) + part + chr(34))

# assert that two strings are equal and print a compact diff hint.
pub fn assert_eq_text(got: String, want: String):
    if got == want:
        record_pass("assert_eq_text")
    else:
        record_fail("assert_eq_text", "got " + got.len().to_string() + " chars, want " + want.len().to_string() + " chars")

# assert that a file exists.
pub fn assert_file_exists(path: String):
    if fs.exists(path) and fs.is_file(path):
        record_pass("assert_file_exists")
    else:
        record_fail("assert_file_exists", "missing file: " + path)

# assert that a directory exists.
pub fn assert_dir_exists(path: String):
    if fs.exists(path) and fs.is_dir(path):
        record_pass("assert_dir_exists")
    else:
        record_fail("assert_dir_exists", "missing dir: " + path)

# run a callback with a temporary directory and remove it afterwards.
pub fn with_temp_dir(prefix: String, run: fn(String) -> Bool) -> Bool:
    dir := fs.make_temp_dir(prefix)
    if dir.is_err:
        record_fail("with_temp_dir", "could not create temp dir")
        return false
    ok := run(dir.ok)
    fs.remove_tree(dir.ok)
    if ok:
        record_pass("with_temp_dir")
    else:
        record_fail("with_temp_dir", "callback returned false")
    return ok

# print summary
pub fn done():
    total := pass_count + fail_count
    print("")
    if fail_count == 0:
        print(total.to_string() + " passed")
    else:
        print(pass_count.to_string() + " passed, " + fail_count.to_string() + " failed")

test "testing helpers count passing checks":
    reset_counts()
    silence_output()

    assert_eq(1, 1)
    assert_ne(1, 2)
    check(3, 3, "ints")
    check_str("pith", "pith", "strings")
    check_ne(1, 2, "different ints")
    check_true(true, "truth")
    check_not(false, "falsehood")
    assert_true(true)
    assert_false(false)
    assert_contains("hello pith", "pith")
    assert_eq_text("same", "same")

    assert(pass_count == 11)
    assert(fail_count == 0)

test "testing helpers count failing checks":
    reset_counts()
    silence_output()

    assert_eq(1, 2)
    assert_ne(1, 1)
    check(1, 2, "bad ints")
    check_str("left", "right", "bad strings")
    check_ne(1, 1, "same ints")
    check_true(false, "not true")
    check_not(true, "not false")
    assert_true(false)
    assert_false(true)
    assert_contains("hello", "pith")
    assert_eq_text("left", "right")

    assert(pass_count == 0)
    assert(fail_count == 11)

test "testing helpers inspect files and temp dirs":
    reset_counts()
    silence_output()

    ok := with_temp_dir("pith-std-testing-", fn(dir: String) => fs.is_dir(dir))

    assert(ok)
    assert(pass_count == 1)
    assert(fail_count == 0)
