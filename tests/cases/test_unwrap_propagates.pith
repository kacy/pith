fn maybe(n: Int) -> Int?:
    if n > 0:
        return n
    return none

fn try_unwrap(input: Int) -> Int!:
    val := maybe(input)?
    return val * 10

fn main() -> Int!:
    print("good:{(try_unwrap(5) catch -1).to_string()}")
    print("bad:{(try_unwrap(0) catch -1).to_string()}")
    return 0
