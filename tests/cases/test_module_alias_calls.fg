import std.io
import std.collections as collections
import std.json as json
import std.math as math_lib

fn main() -> Int!:
    reader := io.string_reader("alias io")
    print(reader.read_all()!)

    lb := chr(123)
    rb := chr(125)
    quote := chr(34)
    input := lb + quote + "name" + quote + ":" + quote + "forge" + quote + rb
    parsed := json.parse(input)
    print(json.type_of(parsed))
    name_value := json.object_get(parsed, "name")
    print(json.get_string(name_value))

    print(math_lib.abs(-7).to_string())
    print(collections.count_where([1, 2, 3, 4], fn(n: Int) => n > 2).to_string())
    return 0
