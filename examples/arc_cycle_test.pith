# ARC Cycle Detection Test
# This test creates scenarios where reference cycles might occur
# With proper cycle detection, these should be collected and not leak

# Note: In pith, direct reference cycles are not easily created
# since we don't have mutable references or pointers between heap objects.
# However, this test verifies the cycle collection infrastructure is in place.

fn main():
    print("ARC Cycle Detection Test")
    print("Testing cycle collection infrastructure...")

    # Create many short-lived objects to trigger periodic cycle collection
    print("Test 1: High volume object churn (1000 iterations)")
    mut i := 0
    while i < 1000:
        # Create and immediately discard objects
        s := "iteration " + i.to_string()
        list := [1, 2, 3]
        map := {"a": 1, "b": 2}
        i = i + 1
    print("Test 1 complete")

    # Test 2: Nested collections that might form cycles
    print("Test 2: Nested collections (500 iterations)")
    i = 0
    while i < 500:
        inner := ["a", "b"]
        outer := [inner]
        # inner and outer have a reference relationship
        # With proper cycle detection, both should be freed
        i = i + 1
    print("Test 2 complete")

    # Test 3: Multiple levels of nesting
    print("Test 3: Deep nesting (200 iterations)")
    i = 0
    while i < 200:
        level1 := {"name": "level1"}
        level2 := {"parent": level1}
        level3 := {"parent": level2}
        # This creates a chain: level3 -> level2 -> level1
        # All should be freed when they go out of scope
        i = i + 1
    print("Test 3 complete")

    # Test 4: Lists with string elements (triggers many RC operations)
    print("Test 4: Collection with string elements (500 iterations)")
    i = 0
    while i < 500:
        items := ["item_" + i.to_string()]
        items.push("second_" + i.to_string())
        # This creates collections that need to manage string references
        i = i + 1
    print("Test 4 complete")

    print("Cycle detection tests complete")
    print("Cycle collection runs periodically in the background")
    print("All objects should be properly freed via ARC + cycle detection")