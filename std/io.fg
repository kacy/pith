interface Reader:
    fn read(max_bytes: Int) -> String!

interface Writer:
    fn write(data: String) -> Int!

interface BytesReader:
    fn read_bytes(max_bytes: Int) -> Bytes!

interface BytesWriter:
    fn write_bytes(data: Bytes) -> Int!

interface Closer:
    fn close()

interface Flusher:
    fn flush() -> Int!

