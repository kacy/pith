from checker import initialize_checker
from types import add_type_info, get_type_info, ti_list

fn main():
    initialize_checker("post_checker_list_type_probe")
    tid := add_type_info(ti_list(4))
    print(tid.to_string())
    info := get_type_info(tid)
    print(info.kind)
    print(info.inner.to_string())
