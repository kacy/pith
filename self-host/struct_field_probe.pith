struct Sample:
    kind: String
    name: String
    fields: List[String]
    field_types: List[Int]
    field_pub: List[Bool]
    field_mut: List[Bool]
    param_types: List[Int]
    return_type: Int

fn main():
    s := Sample("", "", [], [], [], [], [4], 6)
    print(s.param_types.len().to_string())
    print(s.return_type.to_string())
