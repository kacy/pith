import std.io as io

fn main() -> Int!:
    stdout_proc := io.spawn_process("printf 'hello from child'")!
    print(stdout_proc.stdout().read_all_chunked(3)!)
    print(stdout_proc.wait().to_string())
    stdout_proc.close()

    stderr_proc := io.spawn_process("printf 'problem' >&2")!
    print(stderr_proc.stderr().read_all_chunked(2)!)
    print(stderr_proc.wait().to_string())
    stderr_proc.close()

    io_proc := io.spawn_process("head -c 5")!
    print(io_proc.stdin().write_all("hello world")!.to_string())
    print(io_proc.stdout().read_all_chunked(2)!)
    print(io_proc.wait().to_string())
    io_proc.close()
    return 0
