import std.bytes as bytes
import std.fs as fs
import std.io as io

fn main() -> String!:
    reader := io.bytes_reader(bytes.from_string_utf8("abcdef")).buffered_chunked(2)
    print(reader.read_bytes(3)!.to_string_utf8()!)
    print(reader.read_bytes(2)!.to_string_utf8()!)
    print("[" + reader.read_bytes(2)!.to_string_utf8()! + "]")

    sink := bytes.buffer()
    writer := sink.buffered_chunked(3)
    print(writer.write_bytes(bytes.from_string_utf8("ab"))!.to_string())
    print(writer.write_bytes(bytes.from_string_utf8("cdef"))!.to_string())
    print(writer.flush()!.to_string())
    print(sink.bytes().to_string_utf8()!)

    path := "/tmp/pith_io_bytes_buffered.txt"
    file_writer := fs.create(path)!
    buffered_file_writer := file_writer.buffered_bytes_writer_chunked(4)
    print(buffered_file_writer.write_bytes(bytes.from_string_utf8("hello"))!.to_string())
    print(buffered_file_writer.flush()!.to_string())
    file_writer.close()

    file_reader := fs.open(path)!
    buffered_file_reader := file_reader.buffered_bytes_reader_chunked(3)
    print(buffered_file_reader.read_bytes(4)!.to_string_utf8()!)
    print("[" + buffered_file_reader.read_all_bytes()!.to_string_utf8()! + "]")
    file_reader.close()
    fs.remove(path)

    proc := io.spawn_process("printf 'xyz123'")!
    stdout_reader := proc.stdout().buffered_bytes_chunked(2)
    print(stdout_reader.read_bytes(3)!.to_string_utf8()!)
    print(stdout_reader.read_all_bytes()!.to_string_utf8()!)
    print(proc.wait().to_string())
    proc.close()
    return ""
