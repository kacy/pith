import std.bytes as bytes
import std.io as io
import std.net.websocket as websocket
from std.io import BufferedBytesReader
fn choose_port(start: Int) -> Int!:
    mut port := start
    while port < start + 200:
        probe := tcp_listen("127.0.0.1", port)
        if probe.is_ok:
            tcp_close(probe.ok)
            return port
        port = port + 1
    fail "no free tcp port"
fn find_head_end(raw: Bytes) -> Int:
    mut i := 0
    while i < raw.len() - 3:
        if raw[i] == 13 and raw[i + 1] == 10 and raw[i + 2] == 13 and raw[i + 3] == 10:
            return i + 4
        i = i + 1
    return - 1
fn read_http_head(reader: BufferedBytesReader) -> Bytes!:
    buf := bytes.buffer()
    mut end := -1
    while end < 0:
        chunk := reader.read_bytes(1)!
        if chunk.is_empty():
            fail "truncated response"
        buf.write(chunk)!
        end = find_head_end(buf.bytes())
    return buf.bytes().slice(0, end)
fn run_server(port: Int) -> Int!:
    server_fd := tcp_listen("127.0.0.1", port)!
    ws := websocket.accept(tcp_accept(server_fd)!)!
    text := ws.recv_text()!
    ws.send_text("echo:" + text)!
    ws.close(1000, "done")!
    tcp_close(server_fd)
    return 0
fn main() -> Int!:
    port := choose_port(18845)!
    server_task := spawn run_server(port)
    sleep(200)
    conn := io.connect("127.0.0.1", port)!
    mut headers: Map[String, String] := {}
    conn.write_all_bytes(websocket.client_request("127.0.0.1:" + port.to_string(), "/ws", headers)!)!
    reader := conn.buffered_bytes_reader_chunked(1)
    head := read_http_head(reader)!
    print(head.to_string_utf8()!.contains("101 Switching Protocols").to_string())
    ping := websocket.masked_frame_bytes(9, bytes.from_string_utf8("ok"), bytes.from_string_utf8("abcd"))!
    text := websocket.client_text_frame_bytes("pith", bytes.from_string_utf8("wxyz"))!
    conn.write_all_bytes(ping.concat(text))!
    pong := websocket.read_frame_buffered(reader)!
    echoed := websocket.read_frame_buffered(reader)!
    print(pong.is_pong().to_string())
    print(pong.payload_text()!)
    print(echoed.payload_text()!)
    await server_task
    return 0
