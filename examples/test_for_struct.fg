struct Token:
    kind: String
    value: String

fn make_tokens() -> List[Token]:
    mut result: List[Token] := []
    result.push(Token("ident", "hello"))
    result.push(Token("lit", "world"))
    return result

fn main():
    tokens := make_tokens()
    print(tokens.len())
    for tok in tokens:
        print(tok.kind + " " + tok.value)
