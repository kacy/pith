import std.bytes as bytes
import std.io as io
import std.net.http as http
import std.net.websocket as websocket
from std.io import BufferedBytesReader, BufferedBytesWriter
from std.net.http import HttpRequestBytes

fn write_response(writer: BufferedBytesWriter, response: String) -> Int!:
    writer.write_bytes(bytes.from_string_utf8(response))!
    flushed := writer.flush()
    if flushed.is_err:
        fail "http response flush failed"
    return response.len()

fn handle_app(req: HttpRequestBytes, reader: BufferedBytesReader, writer: BufferedBytesWriter) -> String!:
    if websocket.route_echo_buffered(req, reader, writer, "/ws", "", "echo:", "")!:
        return "ws:ok"
    write_response(writer, http.not_found())!
    return "http:404"
fn main() -> Int!:
    mut headers: Map[String, String] := {}
    req_bytes := websocket.client_request("example.com", "/ws", headers)!
    req := http.read_request_buffered_bytes(io.bytes_reader(req_bytes).buffered_chunked(5))!
    inbound := websocket.client_text_frame_bytes("pith", bytes.from_string_utf8("abcd"))!
    outbound := bytes.buffer()
    print(handle_app(req, io.bytes_reader(inbound).buffered_chunked(3), outbound.buffered_chunked(4))!)
    response := websocket.upgrade_response(req)!
    print(outbound.bytes().slice(0, response.len()).to_string_utf8()!.contains("101 Switching Protocols").to_string())
    frame := websocket.parse_frame(outbound.bytes().slice(response.len(), outbound.bytes().len()))!
    print(frame.is_text().to_string())
    print(frame.payload_text()!)
    return 0
