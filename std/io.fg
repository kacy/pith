## std.io — input/output utilities
##
## Functions:
##   prompt() -> String       Read a line from stdin
##   prompt_with(msg: String) -> String  Print prompt, then read stdin

## Read a line from standard input
pub fn prompt() -> String:
    return input()

## Print a message then read a line from standard input
pub fn prompt_with(msg: String) -> String:
    print(msg)
    return input()
