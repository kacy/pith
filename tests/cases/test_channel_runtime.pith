fn producer(ch: Channel[Int], count: Int):
    mut i := 0
    while i < count:
        ch.send(i)
        i = i + 1

fn main():
    ch := Channel[Int]()
    task := spawn producer(ch, 5)

    mut total := 0
    mut i := 0
    while i < 5:
        total = total + ch.recv()?
        i = i + 1

    await task
    print("unbuffered-total:{total}")
    print("unbuffered-len:{ch.len()}")

    buffered := Channel[Int](2)
    print("buffered-cap:{buffered.cap()}")
    print("send1:{buffered.send(7)}")
    print("send2:{buffered.send(9)}")
    print("buffered-len:{buffered.len()}")
    print("recv1:{buffered.recv()?}")
    print("recv2:{buffered.recv()?}")
    print("buffered-len2:{buffered.len()}")
    print("close1:{buffered.close()}")
    print("close2:{buffered.close()}")
