import std.bytes as bytes
import std.fs as fs
import std.io as io

fn test_copy_and_write_text() -> String!:
    copied := io.string_buffer()
    print(io.copy_n(io.string_reader("abcdef"), copied, 4)!.to_string())
    print(copied.string())
    print(io.copy_n(io.string_reader("ab"), io.string_buffer(), 3).is_err.to_string())

    sink := io.string_buffer()
    print(io.write_n(sink, "hello", 3)!.to_string())
    print(sink.string())
    return ""

fn test_buffered_text_reads() -> String!:
    text_reader := io.string_reader("alpha--beta--gamma").buffered_chunked(3)
    print(text_reader.read_until("--")!)
    print(text_reader.read_until("--")!)
    print("[" + text_reader.read_until("--")! + "]")

    empty_sep := io.string_reader("x").buffered()
    print(empty_sep.read_until("").is_err.to_string())
    return ""

fn test_buffered_text_reads_including() -> String!:
    including_reader := io.string_reader("alpha--beta").buffered_chunked(3)
    print(including_reader.read_until_including("--")!)
    print("[" + including_reader.read_until_including("--")! + "]")
    return ""

fn test_exact_and_buffered_bytes() -> String!:
    exact_reader := io.bytes_reader(bytes.from_string_utf8("abcdef"))
    print(io.read_exact_bytes(exact_reader, 4)!.to_string_utf8()!)
    print(io.read_exact_bytes(io.bytes_reader(bytes.from_string_utf8("ab")), 3).is_err.to_string())

    bytes_reader := io.bytes_reader(bytes.from_string_utf8("alpha::beta::gamma")).buffered_chunked(2)
    first_bytes := bytes_reader.read_until_bytes(bytes.from_string_utf8("::"))!
    print(first_bytes.to_string_utf8()!)
    second_bytes := bytes_reader.read_until_bytes(bytes.from_string_utf8("::"))!
    print(second_bytes.to_string_utf8()!)
    third_bytes := bytes_reader.read_until_bytes(bytes.from_string_utf8("::"))!
    print("[" + third_bytes.to_string_utf8()! + "]")

    print(bytes_empty_sep_result()!)
    return ""

fn test_exact_and_buffered_bytes_including() -> String!:
    including_bytes_reader := io.bytes_reader(bytes.from_string_utf8("alpha::beta")).buffered_chunked(2)
    including_first := including_bytes_reader.read_until_bytes_including(bytes.from_string_utf8("::"))!
    print(including_first.to_string_utf8()!)
    including_second := including_bytes_reader.read_until_bytes_including(bytes.from_string_utf8("::"))!
    print("[" + including_second.to_string_utf8()! + "]")
    return ""

fn bytes_empty_sep_result() -> String!:
    empty_bytes_reader := io.bytes_reader(bytes.from_string_utf8("x")).buffered()
    return empty_bytes_reader.read_until_bytes(bytes.empty()).is_err.to_string()

fn test_byte_writes_and_copy() -> String!:
    byte_sink := bytes.buffer()
    print(io.write_n_bytes(byte_sink, bytes.from_string_utf8("hello"), 3)!.to_string())
    print(byte_sink.bytes().to_string_utf8()!)

    copied_bytes := bytes.buffer()
    print(io.copy_n_bytes(io.bytes_reader(bytes.from_string_utf8("abcdef")), copied_bytes, 4)!.to_string())
    print(copied_bytes.bytes().to_string_utf8()!)
    return ""

fn test_file_helpers() -> String!:
    path := "/tmp/pith_io_composition_helpers.txt"
    fs.write(path, "alpha--beta")!
    file_reader := fs.open(path)!
    print(file_reader.read_exact_bytes(5)!.to_string_utf8()!)
    file_reader.close()

    file_buffered_stream := fs.open(path)!
    file_buffered := file_buffered_stream.buffered_reader_chunked(3)
    print(file_buffered.read_until("--")!)
    print("[" + file_buffered.read_until("--")! + "]")
    file_buffered_stream.close()

    fs.remove(path)
    return ""

fn test_file_helpers_including() -> String!:
    path := "/tmp/pith_io_composition_helpers.txt"
    fs.write(path, "alpha--beta")!
    file_including_stream := fs.open(path)!
    file_including := file_including_stream.buffered_reader_chunked(3)
    print(file_including.read_until_including("--")!)
    print("[" + file_including.read_until_including("--")! + "]")
    file_including_stream.close()
    fs.remove(path)
    return ""

fn main() -> String!:
    test_copy_and_write_text()!
    test_buffered_text_reads()!
    test_buffered_text_reads_including()!
    test_exact_and_buffered_bytes()!
    test_exact_and_buffered_bytes_including()!
    test_byte_writes_and_copy()!
    test_file_helpers()!
    test_file_helpers_including()!
    return ""
