    define_builtin_function("fs_file_size", str_to_int)
    define_builtin_function("list_dir", create_function_type([TID_STRING], list_string))
    define_builtin_function("os_getcwd", create_function_type([], tid_string))
    define_builtin_function("os_temp_dir", create_function_type([], tid_string))
    define_builtin_function("os_home_dir", create_function_type([], tid_string))
    define_builtin_function("os_cert_roots_pem", create_function_type([], tid_string))
    define_builtin_function("os_chdir", str_to_bool)
    define_builtin_function("os_unset_env", str_to_bool)

    define_builtin_function("parse_int", create_function_type([TID_STRING], int_result))
    define_builtin_function("parse_float", create_function_type([TID_STRING], float_result))
    define_builtin_function("bytes_from_string_utf8", create_function_type([TID_STRING], tid_bytes))

    str_to_str_result := create_function_type([TID_STRING], str_result)
    define_builtin_function("read_file", str_to_str_result)
    define_builtin_function("exec_output", str_to_str_result)
    define_builtin_function("dns_resolve", str_to_str_result)
    define_builtin_function("read_file_bytes", create_function_type([TID_STRING], bytes_result))
    define_builtin_function("b64_decode", create_function_type([TID_STRING], bytes_result))
    define_builtin_function("from_hex", create_function_type([TID_STRING], bytes_result))
    define_builtin_function("file_open_read", create_function_type([TID_STRING], int_result))
    define_builtin_function("file_open_write", create_function_type([TID_STRING], int_result))
    define_builtin_function("file_open_append", create_function_type([TID_STRING], int_result))

    define_builtin_function("rename_file", create_function_type([TID_STRING, TID_STRING], TID_BOOL))
    define_builtin_function("os_set_env", create_function_type([TID_STRING, TID_STRING], TID_BOOL))

    two_str_to_bool_result := create_function_type([TID_STRING, TID_STRING], bool_result)
    define_builtin_function("write_file", two_str_to_bool_result)
    define_builtin_function("append_file", two_str_to_bool_result)
    define_builtin_function("write_file_bytes", create_function_type([TID_STRING, tid_bytes], bool_result))
    define_builtin_function("append_file_bytes", create_function_type([TID_STRING, tid_bytes], bool_result))
    define_builtin_function("bytes_eq", create_function_type([tid_bytes, tid_bytes], TID_BOOL))
    define_builtin_function("bytes_concat", create_function_type([tid_bytes, tid_bytes], tid_bytes))
    define_builtin_function("bytes_len", create_function_type([tid_bytes], TID_INT))
    define_builtin_function("bytes_is_empty", create_function_type([tid_bytes], TID_BOOL))
    define_builtin_function("bytes_get", create_function_type([tid_bytes, TID_INT], TID_INT))
    define_builtin_function("bytes_slice", create_function_type([tid_bytes, TID_INT, TID_INT], tid_bytes))
    define_builtin_function("bytes_to_string_utf8", create_function_type([tid_bytes], str_result))
    define_builtin_function("crypto_constant_time_eq", create_function_type([tid_bytes, tid_bytes], TID_BOOL))
    define_builtin_function("secure_random_bytes", create_function_type([TID_INT], tid_bytes))
    define_builtin_function("crypto_x25519_keygen", create_function_type([], int_result))
    define_builtin_function("crypto_x25519_public_key", create_function_type([TID_INT], bytes_result))
    define_builtin_function("crypto_x25519_shared_secret", create_function_type([TID_INT, tid_bytes], bytes_result))
    define_builtin_function("crypto_x25519_close", create_function_type([TID_INT], TID_VOID))
    define_builtin_function("crypto_aes_128_gcm_seal", create_function_type([tid_bytes, tid_bytes, tid_bytes, tid_bytes], bytes_result))
    define_builtin_function("crypto_aes_128_gcm_open", create_function_type([tid_bytes, tid_bytes, tid_bytes, tid_bytes], bytes_result))
    define_builtin_function("crypto_chacha20_poly1305_seal", create_function_type([tid_bytes, tid_bytes, tid_bytes, tid_bytes], bytes_result))
    define_builtin_function("crypto_chacha20_poly1305_open", create_function_type([tid_bytes, tid_bytes, tid_bytes, tid_bytes], bytes_result))
