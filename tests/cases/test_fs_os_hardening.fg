import std.bytes as bytes
import std.fs as fs
import std.os as os
import std.os.path as path

fn main() -> Int!:
    print(path.clean("../alpha"))
    print(path.clean("alpha/../../gamma"))
    print(path.clean("../.."))
    print(path.clean("/../alpha"))

    print((os.which("sh") != "").to_string())
    print((os.which("definitely_missing_forge_cmd_xyz") == "").to_string())

    root := fs.make_temp_dir("forge_fs_hardening_")!
    other := fs.make_temp_dir("forge_fs_hardening_")!
    print((root != other).to_string())

    temp_file := fs.make_temp_file("forge_tmp_", ".txt")!
    print(fs.exists(temp_file).to_string())
    print(fs.size(temp_file)!.to_string())

    src := path.join(root, "src")
    nested := path.join(src, "nested")
    dst := path.join(root, "dst")
    fs.make_dirs(nested)
    fs.write(path.join(src, "root.txt"), "root")!
    fs.write(path.join(nested, "leaf.txt"), "leaf")!
    fs.copy_tree(src, dst)!
    print(fs.read(path.join(dst, "root.txt"))!)
    print(fs.read(path.join(path.join(dst, "nested"), "leaf.txt"))!)
    print(fs.metadata(path.join(dst, "root.txt"))!.size.to_string())

    entries := fs.read_dir(src)!
    mut has_root_file := false
    mut has_nested_dir := false
    for entry in entries:
        if entry.name == "root.txt" and not entry.is_dir and entry.size == 4:
            has_root_file = true
        if entry.name == "nested" and entry.is_dir:
            has_nested_dir = true
    print(entries.len().to_string())
    print(has_root_file.to_string())
    print(has_nested_dir.to_string())

    walked := fs.walk(src)!
    mut has_walk_root := false
    mut has_walk_leaf := false
    for entry in walked:
        rel := path.rel(src, entry.path)
        if rel == "." and entry.is_dir:
            has_walk_root = true
        if rel == "nested/leaf.txt" and not entry.is_dir and entry.size == 4:
            has_walk_leaf = true
    print(walked.len().to_string())
    print(has_walk_root.to_string())
    print(has_walk_leaf.to_string())

    atomic_text := path.join(root, "atomic.txt")
    fs.write_atomic(atomic_text, "old")!
    fs.write_atomic(atomic_text, "new")!
    print(fs.read(atomic_text)!)

    atomic_bytes := path.join(root, "atomic.bin")
    fs.write_bytes_atomic(atomic_bytes, bytes.from_string_utf8("abc"))!
    print(fs.read_bytes(atomic_bytes)!.to_string_utf8()!)

    temp_dir_in := fs.make_temp_dir_in(root, "inner_")!
    temp_file_in := fs.make_temp_file_in(root, "inner_", ".tmp")!
    print((path.dir(temp_dir_in) == root).to_string())
    print((path.dir(temp_file_in) == root).to_string())
    print((path.dir(fs.temp_path_in(root, "probe_", ".txt")) == root).to_string())
    print(fs.remove_all(temp_dir_in).to_string())
    print(fs.remove(temp_file_in).to_string())

    print(fs.info(path.join(root, "missing.txt")).is_err.to_string())

    nonempty := path.join(root, "nonempty")
    fs.make_dir(nonempty)
    fs.write(path.join(nonempty, "child.txt"), "x")!
    print(fs.remove_empty_dir(nonempty).to_string())

    print(fs.remove_tree(path.join(root, "missing_tree")).to_string())
    print(fs.remove_tree(root).to_string())
    print(fs.exists(root).to_string())
    print(fs.remove(temp_file).to_string())
    print(fs.remove_tree(other).to_string())
    return 0
