fn main():
    a := "hello"
    b := "hello"
    c := "world"
    
    if a == b:
        print("a == b: true")
    else:
        print("a == b: false")
    
    if a == c:
        print("a == c: true")
    else:
        print("a == c: false")
    
    # Test with command argument
    args_list := args()
    if args_list.len() >= 2:
        cmd := args_list[1]
        if cmd == "test":
            print("command is test")
        else:
            print("command is not test")