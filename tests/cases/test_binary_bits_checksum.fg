import std.binary as binary
import std.bits as bits
import std.bytes as bytes
import std.checksum as checksum

fn main() -> Int:
    out := bytes.buffer()
    binary.write_u8(out, 31)
    binary.write_u16_le(out, 4660)
    binary.write_u16_be(out, 4660)
    binary.write_u32_le(out, 305419896)
    binary.write_u32_be(out, 305419896)
    data := out.bytes()

    print("len:" + data.len().to_string())
    print("at-u16-le:" + binary.read_u16_le_at(data, 1).ok.to_string())
    print("at-u16-be:" + binary.read_u16_be_at(data, 3).ok.to_string())
    print("at-u32-le:" + binary.read_u32_le_at(data, 5).ok.to_string())
    print("at-u32-be:" + binary.read_u32_be_at(data, 9).ok.to_string())

    wide := bytes.buffer()
    binary.write_u64_le(wide, 81985529216486895)
    binary.write_u64_be(wide, 81985529216486895)
    wide_data := wide.bytes()
    print("u64le:" + binary.read_u64_le_at(wide_data, 0).ok.to_string())
    print("u64be:" + binary.read_u64_be_at(wide_data, 8).ok.to_string())

    bin_reader := binary.reader(data)
    print("pos0:" + binary.position(bin_reader).to_string())
    print("u8:" + binary.read_u8(bin_reader).ok.to_string())
    print("u16le:" + binary.read_u16_le(bin_reader).ok.to_string())
    print("u16be:" + binary.read_u16_be(bin_reader).ok.to_string())
    skipped := binary.skip(bin_reader, 4)
    print("skip:" + skipped.ok.to_string())
    print("u32be:" + binary.read_u32_be(bin_reader).ok.to_string())
    print("remaining:" + binary.remaining(bin_reader).to_string())
    print("eof:" + binary.read_u8(bin_reader).is_err.to_string())

    zero_data := bytes.buffer()
    zero_data.write_string_utf8("abc")
    zero_data.write_byte(0)
    zero_data.write_string_utf8("tail")
    zero_reader := binary.reader(zero_data.bytes())
    zero_text := binary.read_until_zero(zero_reader).ok.to_string_utf8()
    print("zero:" + zero_text.ok)
    print("zero-pos:" + binary.position(zero_reader).to_string())

    print("mask8:" + bits.mask8(511).to_string())
    print("rotl32:" + bits.rotl32(1, 8).to_string())
    print("rotr32:" + bits.rotr32(256, 8).to_string())
    print("crc32:" + checksum.crc32(bytes.from_string_utf8("hello")).to_string())
    print("write-bad:" + binary.write_u8(bytes.buffer(), 256).is_err.to_string())
    print("write-u64-bad:" + binary.write_u64_be(bytes.buffer(), -1).is_err.to_string())
    return 0
