import std.json as json
import std.fs as fs

fn main() -> String!:
    json_path := "/tmp/forge_io_json.json"
    lb := chr(123)
    rb := chr(125)

    doc := lb + "\"name\":\"forge\",\"enabled\":true,\"items\":[1,2,3]" + rb
    root := json.parse(doc)
    print(json.save_chunked(json_path, root, 4).to_string())

    loaded := json.parse_file_chunked(json_path, 3)
    print(json.type_of(loaded))
    print(json.get_string(json.object_get(loaded, "name")))
    print(json.get_bool(json.object_get(loaded, "enabled")).to_string())
    print(json.array_len(json.object_get(loaded, "items")).to_string())
    print(fs.exists(json_path).to_string())

    fs.remove(json_path)
    return ""
