    buffered_string_reader_cache.insert(handle, chunk)
    return chunk.len()

fn buffered_string_writer_write_internal(writer: BufferedStringWriter, data: String) -> Int!:
    if not buffered_string_writer_targets.contains_key(writer.handle):
        return 0

    cached := buffered_string_writer_cache_get(writer.handle)
    buffered_string_writer_cache.insert(writer.handle, cached + data)
    if buffered_string_writer_should_flush(writer.handle):
        buffered_string_writer_flush_internal(writer)!
    return data.len()

