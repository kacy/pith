fn remaining_after_write(data: String, wrote: Int) -> String:
    if wrote >= data.len():
        return ""
    return data.substring(wrote, data.len())

fn cache_after_consume(cached: String, consumed: Int) -> String:
    if consumed >= cached.len():
        return ""
    return cached.substring(consumed, cached.len())

fn trim_trailing_cr(line: String) -> String:
    if line.len() == 0:
        return ""
    end := line.len()
    if line.substring(end - 1, end) == chr(13):
        return line.substring(0, end - 1)
    return line

fn find_newline(data: String) -> Int:
    mut i := 0
    while i < data.len():
        if data.substring(i, i + 1) == chr(10):
            return i
        i = i + 1
    return -1

fn read_all_string(reader: StringReader) -> String!:
    return read_all_string_chunked(reader, DEFAULT_CHUNK_SIZE)

fn read_all_string_chunked(reader: StringReader, chunk_size: Int) -> String!:
    size := normalized_chunk_size(chunk_size)
    mut result := ""
    mut chunk := reader.read(size)!
    while chunk.len() > 0:
        result = result + chunk
        chunk = reader.read(size)!
    return result

fn write_all_string(writer: StringBuffer, data: String) -> Int!:
    mut total := 0
    mut remaining := data
    while remaining.len() > 0:
        wrote := writer.write(remaining)!
        if wrote <= 0:
            fail "write returned 0"
        total = total + wrote
        remaining = remaining_after_write(remaining, wrote)
    return total

fn write_all_tcp_stream(writer: TcpStream, data: String) -> Int!:
    mut total := 0
    mut remaining := data
    while remaining.len() > 0:
        wrote := writer.write(remaining)!
        if wrote <= 0:
            fail "write returned 0"
        total = total + wrote
        remaining = remaining_after_write(remaining, wrote)
    return total

fn write_all_file_stream(writer: FileStream, data: String) -> Int!:
    mut total := 0
    mut remaining := data
    while remaining.len() > 0:
        wrote := writer.write(remaining)!
        if wrote <= 0:
            fail "write returned 0"
        total = total + wrote
        remaining = remaining_after_write(remaining, wrote)
    return total

fn copy_string(reader: StringReader, writer: StringBuffer) -> Int!:
    return copy_string_chunked(reader, writer, DEFAULT_CHUNK_SIZE)

fn copy_string_chunked(reader: StringReader, writer: StringBuffer, chunk_size: Int) -> Int!:
    size := normalized_chunk_size(chunk_size)
    mut total := 0
    mut chunk := reader.read(size)!
    while chunk.len() > 0:
        total = total + write_all_string(writer, chunk)!
        chunk = reader.read(size)!
    return total

fn read_all_tcp_stream(stream: TcpStream) -> String!:
    return read_all_tcp_stream_chunked(stream, DEFAULT_CHUNK_SIZE)

fn read_all_tcp_stream_chunked(stream: TcpStream, chunk_size: Int) -> String!:
