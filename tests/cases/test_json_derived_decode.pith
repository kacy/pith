import std.json as json
import std.bytes as bytes
import std.fs as fs
import std.os.path as os_path

struct JsonDerivedFixture:
    pub name: String
    pub score: Int
    pub active: Bool

struct JsonDerivedWideFixture:
    pub name: String
    pub region: String
    pub active: Bool
    pub score: Int
    pub limit: Int
    pub multiplier: Int

struct JsonDerivedNestedFixture:
    pub host: String
    pub port: Int

struct JsonDerivedOptionalFixture:
    pub name: String
    pub region: String?
    pub active: Bool

struct JsonDerivedDefaultFixture:
    pub name: String
    pub region: String = "local"
    pub active: Bool = false

struct JsonDerivedNestedDefaultServer:
    pub host: String
    pub port: Int = 8080
    pub tls: Bool = false

struct JsonDerivedNestedDefaultApp:
    pub name: String
    pub server: JsonDerivedNestedDefaultServer = JsonDerivedNestedDefaultServer("localhost")

fn main() -> Int!:
    dq := chr(34)
    mut doc := chr(123) + dq + "name" + dq + ":" + dq + "pith" + dq
    doc = doc + "," + dq + "score" + dq + ":42"
    doc = doc + "," + dq + "active" + dq + ":true" + chr(125)

    from_bytes := json.decode[JsonDerivedFixture](bytes.from_string_utf8(doc))
    if from_bytes.is_ok:
        print(from_bytes.ok.name + ":" + from_bytes.ok.score.to_string() + ":" + from_bytes.ok.active.to_string())

    from_text := json.decode_text[JsonDerivedFixture](doc)
    if from_text.is_ok:
        print(from_text.ok.name + "@" + from_text.ok.score.to_string())

    missing := json.decode_text[JsonDerivedFixture](chr(123) + dq + "name" + dq + ":" + dq + "pith" + dq + chr(125))
    print(missing.is_err.to_string())
    if missing.is_err:
        print(missing.err.message.contains("score").to_string())

    mut wide_doc := chr(123) + dq + "name" + dq + ":" + dq + "pith" + dq
    wide_doc = wide_doc + "," + dq + "region" + dq + ":" + dq + "west" + dq
    wide_doc = wide_doc + "," + dq + "active" + dq + ":true"
    wide_doc = wide_doc + "," + dq + "score" + dq + ":42"
    wide_doc = wide_doc + "," + dq + "limit" + dq + ":5"
    wide_doc = wide_doc + "," + dq + "multiplier" + dq + ":3" + chr(125)
    wide := json.decode_text[JsonDerivedWideFixture](wide_doc)
    if wide.is_ok:
        print(wide.ok.name + ":" + wide.ok.region + ":" + wide.ok.score.to_string() + ":" + wide.ok.limit.to_string() + ":" + wide.ok.multiplier.to_string())
    wide_missing := json.decode_text[JsonDerivedWideFixture](chr(123) + dq + "name" + dq + ":" + dq + "pith" + dq + chr(125))
    print(wide_missing.is_err.to_string())

    optional_doc := chr(123) + dq + "name" + dq + ":" + dq + "pith" + dq + "," + dq + "region" + dq + ":" + dq + "west" + dq + "," + dq + "active" + dq + ":true" + chr(125)
    optional_missing_doc := chr(123) + dq + "name" + dq + ":" + dq + "pith" + dq + "," + dq + "active" + dq + ":false" + chr(125)
    optional_present := json.decode_text[JsonDerivedOptionalFixture](optional_doc)
    optional_missing := json.decode_text[JsonDerivedOptionalFixture](optional_missing_doc)
    if optional_present.is_ok:
        print(optional_present.ok.name + ":" + optional_present.ok.region? + ":" + optional_present.ok.active.to_string())
    if optional_missing.is_ok:
        print(optional_missing.ok.name + ":" + (optional_missing.ok.region == none).to_string() + ":" + optional_missing.ok.active.to_string())

    default_doc := chr(123) + dq + "name" + dq + ":" + dq + "pith" + dq + chr(125)
    defaulted := json.decode_text[JsonDerivedDefaultFixture](default_doc)
    if defaulted.is_ok:
        print(defaulted.ok.name + ":" + defaulted.ok.region + ":" + defaulted.ok.active.to_string())

    nested_default_missing_doc := chr(123) + dq + "name" + dq + ":" + dq + "pith" + dq + chr(125)
    nested_default_partial_doc := chr(123) + dq + "name" + dq + ":" + dq + "pith" + dq + "," + dq + "server" + dq + ":" + chr(123) + dq + "host" + dq + ":" + dq + "edge" + dq + chr(125) + chr(125)
    nested_default_missing := json.decode_text[JsonDerivedNestedDefaultApp](nested_default_missing_doc)
    nested_default_partial := json.decode_text[JsonDerivedNestedDefaultApp](nested_default_partial_doc)
    if nested_default_missing.is_ok:
        print(nested_default_missing.ok.name + ":" + nested_default_missing.ok.server.host + ":" + nested_default_missing.ok.server.port.to_string() + ":" + nested_default_missing.ok.server.tls.to_string())
    if nested_default_partial.is_ok:
        print(nested_default_partial.ok.name + ":" + nested_default_partial.ok.server.host + ":" + nested_default_partial.ok.server.port.to_string() + ":" + nested_default_partial.ok.server.tls.to_string())

    nested_doc := chr(123) + dq + "server" + dq + ":" + chr(123) + dq + "host" + dq + ":" + dq + "localhost" + dq + "," + dq + "port" + dq + ":8080" + chr(125) + chr(125)
    nested_root := json.parse(nested_doc)
    nested := json.decode_path[JsonDerivedNestedFixture](nested_root, "server")
    nested_text := json.decode_text_path[JsonDerivedNestedFixture](nested_doc, "server")
    nested_missing := json.decode_text_path[JsonDerivedNestedFixture](nested_doc, "database")
    root := fs.make_temp_dir("pith-json-derived-")!
    file_path := os_path.join(root, "app.json")
    assert(fs.write(file_path, nested_doc)!)
    nested_file := json.decode_file_path[JsonDerivedNestedFixture](file_path, "server")
    if nested.is_ok:
        print(nested.ok.host + "#" + nested.ok.port.to_string())
    if nested_text.is_ok:
        print(nested_text.ok.host + "$" + nested_text.ok.port.to_string())
    if nested_file.is_ok:
        print(nested_file.ok.host + "%" + nested_file.ok.port.to_string())
    print(nested_missing.is_err.to_string())
    assert(fs.remove_tree(root))
    return 0
