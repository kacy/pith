import std.bytes as bytes
import std.fs as fs
import std.os.path as path

fn main() -> Int!:
    root := "/tmp/forge_fs_path_ops"
    nested := path.join_all([root, "alpha", "beta"])
    text_path := path.join(nested, "data.txt")
    bytes_path := path.join(nested, "data.bin")
    moved_path := path.join(nested, "moved.bin")

    print(path.clean("/tmp//forge_fs_path_ops/./alpha/beta/"))
    print(path.clean("alpha/./beta/gamma"))
    print(path.is_abs(root).to_string())
    print(path.is_rel("alpha/beta").to_string())
    print(path.base("/tmp/demo/file.txt/"))
    print(path.dir("/tmp/demo/file.txt/"))
    print(path.ext("/tmp/demo/file.txt"))
    print(path.stem("/tmp/demo/file.txt"))
    print(path.parts("/tmp/demo/file.txt").join(","))
    print(path.has_ext("/tmp/demo/file.txt").to_string())
    print(path.without_ext("/tmp/demo/file.txt"))
    print(path.with_ext("/tmp/demo/file.txt", "json"))
    print(path.rel("/tmp/demo", "/tmp/demo/file.txt"))
    print(path.rel("/tmp/demo/alpha", "/tmp/demo/beta/file.txt"))
    print(fs.make_dirs(nested).to_string())
    fs.write(text_path, "hello path")!
    print(fs.read(text_path)!)

    payload := bytes.from_string_utf8("xyz")
    fs.write_bytes(bytes_path, payload)!
    print(fs.read_bytes(bytes_path)!.to_string_utf8()!)

    fs.copy(bytes_path, moved_path)!
    print(fs.read_bytes(moved_path)!.to_string_utf8()!)

    fs.append(text_path, "!")!
    print(fs.read(text_path)!)

    final_path := path.join(nested, "renamed.bin")
    print(fs.move(moved_path, final_path).to_string())
    print(fs.exists(final_path).to_string())
    return 0
