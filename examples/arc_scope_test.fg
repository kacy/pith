# ARC scope cleanup test
# Tests that variables are properly released when going out of scope

fn inner_function():
    # These strings should be cleaned up when function returns
    local1 := "local string 1"
    local2 := "local string 2"
    print("inner_function: " + local1 + ", " + local2)

fn test_early_return(cond: Bool) -> String:
    temp := "temporary string"
    if cond:
        # temp should be released before early return
        return "early result"
    # temp should be released before normal return
    return "normal result"

fn main():
    print("ARC Scope Test")
    
    # Test 1: Function scope cleanup
    print("Test 1: Function scope cleanup")
    inner_function()
    print("Test 1 complete")
    
    # Test 2: Early return cleanup
    print("Test 2: Early return cleanup")
    result1 := test_early_return(true)
    print("Result: " + result1)
    result2 := test_early_return(false)
    print("Result: " + result2)
    print("Test 2 complete")
    
    # Test 3: Block scope cleanup
    print("Test 3: Block scope cleanup")
    if true:
        block_var := "block local"
        print("In block: " + block_var)
    # block_var should be released here
    print("Test 3 complete")
    
    print("All scope tests passed!")
