struct Node:
    kind: String
    value: String
    children: List[Int]

mut nodes: List[Node] := []

fn add_node(kind: String, value: String, children: List[Int]) -> Int:
    idx := nodes.len()
    nodes.push(Node(kind, value, children))
    return idx

fn get_node(idx: Int) -> Node:
    return nodes[idx]

fn main():
    mut kids: List[Int] := []
    kids.push(1)
    kids.push(2)
    kids.push(3)
    parent := add_node("parent", "test", kids)

    node := get_node(parent)
    print("kind: " + node.kind)
    print("children count: " + to_string(node.children.len()))
    for child in node.children:
        print("child: " + to_string(child))
