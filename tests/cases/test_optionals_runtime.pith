fn maybe_even(n: Int) -> Int?:
    if n % 2 == 0:
        return n
    return none

fn main():
    hit := maybe_even(8)
    miss := maybe_even(3)
    print("hit-set:{hit != none}")
    print("miss-none:{miss == none}")
    print("hit:{hit?}")

    mut boxed: Int? := 11
    print("boxed:{boxed?}")
    boxed = none
    print("boxed-none:{boxed == none}")
