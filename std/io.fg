    return ""

fn buffered_string_writer_should_flush(handle: Int) -> Bool:
    cached := buffered_string_writer_cache_get(handle)
    mut chunk_size := DEFAULT_CHUNK_SIZE
    if buffered_string_writer_chunk_sizes.contains_key(handle):
        chunk_size = buffered_string_writer_chunk_sizes[handle]
    return cached.len() >= chunk_size

