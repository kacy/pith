from lexer import lex_all
from parser import parse
from ast import reset_arena

fn main() -> String!:
    src := read_file("self-host/import_main_interp_src.fg")!
    print("read")
    token_list := lex_all(src)
    print("lexed")
    reset_arena()
    parsed_root := parse(token_list)
    print("parsed")
    if parsed_root >= 0:
        print("done")
    return ""
