from std.testing import assert_eq, assert_ne, assert_true, assert_false
from std.testing import assert_contains, done

fn main():
    assert_eq(1 + 1, 2)
    assert_eq("pith".to_upper(), "PITH")
    assert_ne(7, 8)
    assert_true("pith".starts_with("pit"))
    assert_false("pith".contains("zig"))
    assert_contains("hello pith", "pith")
    assert_eq(false, true)
    assert_ne("same", "same")
    done()
